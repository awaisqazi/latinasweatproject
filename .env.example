# Supabase browser client configuration for the marketing dashboard.
# These are public client values, not service role or secret keys.
#
# Supabase Auth URL Configuration should keep the production Site URL as:
# https://latinasweatproject.com
#
# Add both live and local reset URLs to Redirect URLs so password resets and
# marketing invites work in both environments:
# https://latinasweatproject.com/admin/marketing/reset-password
# http://localhost:4321/admin/marketing/reset-password
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
