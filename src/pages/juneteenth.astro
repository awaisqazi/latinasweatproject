---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";

const base = import.meta.env.BASE_URL;
const withBase = (path) => `${base}${path.replace(/^\//, "")}`;

// Event listings sourced from Block Club Chicago's weekend roundup.
const sourceUrl =
  "https://blockclubchicago.org/2026/06/18/28-things-to-do-in-chicago-this-weekend-pride-fest-juneteenth-and-obama-center-open-house/";

// Day-based accent: Friday in Pan-African red, Saturday in Pan-African green.
const dayAccent = {
  Friday: { hex: "#e4392b", soft: "rgba(228,57,43,0.14)", line: "rgba(228,57,43,0.4)" },
  Saturday: { hex: "#1e9e5a", soft: "rgba(30,158,90,0.14)", line: "rgba(30,158,90,0.4)" },
};

const events = [
  {
    day: "Friday",
    time: "6-9 p.m.",
    tag: "Art & Exhibition",
    title: 'Mike Weary Solo Exhibition: "The Will to Escape"',
    venue: "Gallery Guichard",
    address: "436 E. 47th St.",
    neighborhood: "Bronzeville",
    description:
      "Artist Mike Weary brings powerful work to Bronzeville: paintings that witness grief, inherited trauma, and the resilience of Black bodies in the American South. Bring your heart and an open mind.",
    note: "Free · Reserve a spot",
    cta: "Reserve a spot",
    url: "https://www.eventbrite.com/e/the-solo-exhibition-of-mike-weary-the-will-to-escape-tickets-1990631220567",
  },
  {
    day: "Friday",
    time: "7:30 p.m.",
    tag: "Live Music",
    title: "Juneteenth Celebration with the Freddie Dixon Blues Band",
    venue: "Old Town School of Folk Music",
    address: "4544 N. Lincoln Ave.",
    neighborhood: "Lincoln Square",
    description:
      "Let Chicago blues move through you. The Freddie Dixon Blues Band and violinist Judy Lei host a celebration that honors our collective joy and our collective struggle.",
    note: "Free · Suggested donation",
    cta: "Reserve tickets",
    url: "https://www.oldtownschool.org/events/event.php?event_id=9674",
  },
  {
    day: "Saturday",
    time: "10-11:30 a.m.",
    tag: "Community Action",
    title: "Hyde Park Community Cleanup",
    venue: "Elm Park",
    address: "5215 S. Woodlawn Ave.",
    neighborhood: "Hyde Park",
    description:
      "Bring your neighbors and your energy. Trash People is out caring for our neighborhoods, one hour of collective action, side by side.",
    note: "Free · Registration required",
    cta: "Learn more and register",
    url: "https://www.eventbrite.com/e/trash-people-of-hyde-park-community-clean-up-tickets-1989835077281",
  },
  {
    day: "Saturday",
    time: "10 a.m.-3 p.m.",
    tag: "Festival",
    title: "6th Annual Bronzeville Juneteenth Celebration",
    venue: "Absolutely Anything Essential",
    address: "3521 S. King Drive",
    neighborhood: "Bronzeville",
    description:
      "The sixth year of this essential gathering. Live performances, local vendors, family, food, and special recognition of the fathers and father figures holding us down. Come celebrate culture, resilience, and the radical act of living fully.",
    note: "Free · All welcome",
    cta: "Learn more",
    url: "https://www.eventbrite.com/e/bronzevilles-6th-annual-juneteenth-celebration-the-largest-in-bronzeville-tickets-1984692966088",
  },
];
---

<Layout
  title="Honoring Juneteenth | The Latina Sweat Project"
  description="Honoring Juneteenth and the long struggle for Black liberation. Beautiful ways to show up for Chicago this weekend, from The Latina Sweat Project."
>
  <Header />
  <main class="bg-off-black text-white">
    {/* START: Hero */}
    <section class="relative overflow-hidden py-20 sm:py-28">
      {/* Pan-African accent rule */}
      <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-[#e4392b] via-accent-gold to-[#1e9e5a]"></div>
      {/* Star-field texture */}
      <div
        class="absolute inset-0 opacity-[0.07]"
        style="background-image: radial-gradient(circle at 20% 30%, #fff 0, transparent 1.3px), radial-gradient(circle at 72% 58%, #fff 0, transparent 1.1px), radial-gradient(circle at 45% 84%, #fff 0, transparent 1.2px), radial-gradient(circle at 88% 22%, #fff 0, transparent 1px); background-size: 110px 110px, 140px 140px, 90px 90px, 160px 160px;"
      >
      </div>
      {/* Ambient glows in the freedom palette */}
      <div class="absolute -left-24 -top-10 h-72 w-1/2 rounded-full bg-[#e4392b]/15 blur-[120px]"></div>
      <div class="absolute -right-24 bottom-0 h-72 w-1/2 rounded-full bg-[#1e9e5a]/15 blur-[120px]"></div>
      <div class="absolute left-1/2 top-1/3 h-64 w-64 -translate-x-1/2 rounded-full bg-accent-gold/10 blur-[110px]"></div>

      <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2.5 rounded-full border border-white/15 bg-white/[0.05] px-4 py-1.5 backdrop-blur-sm">
          <span class="text-base leading-none">✊🏿</span>
          <span class="text-xs font-extrabold uppercase tracking-[0.25em] text-accent-gold">
            June 19 · Freedom Day
          </span>
        </div>

        <h1 class="mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tight sm:text-6xl lg:text-7xl">
          Honoring
          <span class="block text-transparent bg-clip-text bg-gradient-to-r from-[#ff6a3d] via-accent-gold to-[#3ec06f]">
            Juneteenth
          </span>
        </h1>

        <p class="mx-auto mt-7 max-w-2xl font-body text-lg leading-relaxed text-white/75 sm:text-xl">
          Today is Juneteenth. We honor the freedom fighters who paved the way:
          the long, powerful struggle for Black liberation that grounds every
          movement for justice we're part of. That includes us, and our work.
        </p>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a
            href="#ways-to-show-up"
            class="btn inline-flex items-center gap-2 rounded-full bg-accent-gold px-6 py-3 text-sm font-bold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-105 hover:shadow-xl"
          >
            Ways to show up
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </a>
          <a
            href={sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border-2 border-white/20 bg-white/5 px-6 py-3 text-sm font-bold text-white transition-all duration-300 hover:border-accent-gold/60 hover:bg-white/10"
          >
            Read on Block Club Chicago
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
    </section>
    {/* END: Hero */}

    {/* START: Honoring statement */}
    <section class="relative py-16 sm:py-20">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="reveal relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.04] p-8 shadow-2xl shadow-black/30 sm:p-10">
          {/* Left freedom-flag rule */}
          <div class="absolute inset-y-0 left-0 w-1.5 bg-gradient-to-b from-[#e4392b] via-accent-gold to-[#1e9e5a]"></div>
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] text-accent-gold">
            In the true spirit of Juneteenth
          </p>
          <p class="mt-5 font-body text-xl leading-relaxed text-white/85 sm:text-2xl">
            Let's celebrate this weekend in the true spirit of Juneteenth:
            together, in our bodies, in our communities, with intention and joy.
          </p>
          <p class="mt-5 font-body text-base leading-relaxed text-white/60 sm:text-lg">
            Here are some beautiful ways to show up for Chicago, courtesy of Block
            Club Chicago.
          </p>
        </div>
      </div>
    </section>
    {/* END: Honoring statement */}

    {/* START: Ways to show up */}
    <section id="ways-to-show-up" class="relative scroll-mt-28 py-12 sm:py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 text-center sm:mb-12">
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] text-accent-gold">
            This weekend in Chicago
          </p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            Beautiful ways to show up
          </h2>
          <p class="mx-auto mt-4 max-w-2xl font-body text-base text-white/60 sm:text-lg">
            Four gatherings across the city, celebrating culture, resilience, and
            the radical act of living fully. Each one is free.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {
            events.map((event) => {
              const a = dayAccent[event.day];
              return (
                <article
                  class="reveal group relative flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.035] p-6 shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-1 hover:border-white/20 sm:p-7"
                >
                  {/* Top freedom rule */}
                  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-[#e4392b] via-accent-gold to-[#1e9e5a]"></div>

                  {/* Day + time + tag */}
                  <div class="flex flex-wrap items-center gap-2.5">
                    <span
                      class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[11px] font-extrabold uppercase tracking-widest text-white"
                      style={`background:${a.hex}`}
                    >
                      {event.day}
                    </span>
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/75">
                      {event.time}
                    </span>
                    <span class="ml-auto text-[11px] font-bold uppercase tracking-[0.2em] text-accent-gold/90">
                      {event.tag}
                    </span>
                  </div>

                  <h3 class="mt-5 font-sans text-xl font-extrabold leading-snug tracking-tight text-white sm:text-2xl">
                    {event.title}
                  </h3>

                  {/* Venue line */}
                  <div class="mt-3 flex items-start gap-2 text-sm text-white/65">
                    <svg class="mt-0.5 h-4 w-4 flex-shrink-0" style={`color:${a.hex}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>
                      <span class="font-bold text-white/85">{event.venue}</span>
                      <span class="text-white/55"> · {event.address} · {event.neighborhood}</span>
                    </span>
                  </div>

                  <p class="mt-4 font-body text-[15px] leading-relaxed text-white/70">
                    {event.description}
                  </p>

                  <div class="mt-6 flex flex-wrap items-center justify-between gap-3 pt-1">
                    <span
                      class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/80"
                      style={`background:${a.soft}; border:1px solid ${a.line}`}
                    >
                      {event.note}
                    </span>
                    <a
                      href={event.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group/cta inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-bold text-white shadow-lg transition-all duration-300 hover:scale-[1.03]"
                      style={`background:${a.hex}; box-shadow:0 10px 24px -10px ${a.hex}`}
                    >
                      {event.cta}
                      <svg class="h-4 w-4 transition-transform group-hover/cta:translate-x-0.5 group-hover/cta:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </a>
                  </div>
                </article>
              );
            })
          }
        </div>

        {/* Source credit */}
        <p class="mt-8 text-center text-xs text-white/40">
          Event listings courtesy of{" "}
          <a
            href={sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold text-white/60 underline decoration-white/20 underline-offset-2 transition-colors hover:text-accent-gold"
          >
            Block Club Chicago
          </a>. Details and times are subject to change; confirm with each event
          before you go.
        </p>
      </div>
    </section>
    {/* END: Ways to show up */}

    {/* START: Move with us closing */}
    <section class="relative overflow-hidden py-16 sm:py-20">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
      <div class="absolute -bottom-16 left-1/2 h-64 w-3/4 -translate-x-1/2 rounded-full bg-accent-gold/10 blur-[120px]"></div>

      <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
        <p class="text-xs font-extrabold uppercase tracking-[0.25em] text-accent-gold">
          Together, in our bodies
        </p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
          Celebrate this weekend with us
        </h2>
        <p class="mx-auto mt-5 font-body text-base leading-relaxed text-white/65 sm:text-lg">
          The work of liberation lives in how we move, rest, and gather. Come
          breathe, sweat, and celebrate in community on the mat this weekend, with
          intention and joy.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href={withBase("schedule")}
            class="btn inline-flex items-center gap-2 rounded-full bg-accent-gold px-7 py-3 text-sm font-bold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-105 hover:shadow-xl"
            data-conversion-event="class_booking_start"
            data-conversion-context="juneteenth_move_with_us"
            data-conversion-booking-path="schedule_page"
          >
            See our class schedule
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href={withBase("about")}
            class="inline-flex items-center gap-2 rounded-full border-2 border-white/20 bg-white/5 px-7 py-3 text-sm font-bold text-white transition-all duration-300 hover:border-accent-gold/60 hover:bg-white/10"
          >
            About LSP
          </a>
        </div>
      </div>
      <div class="absolute inset-x-0 bottom-0 h-1.5 bg-gradient-to-r from-[#e4392b] via-accent-gold to-[#1e9e5a]"></div>
    </section>
    {/* END: Move with us closing */}
  </main>
</Layout>
