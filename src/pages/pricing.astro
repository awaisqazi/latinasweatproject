---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';

const pricingOptions = [
  {
    name: "Drop-in class",
    price: "$20",
    detail: "Best for a single yoga, pilates, dance fitness, or community fitness class.",
  },
  {
    name: "5-class pack",
    price: "$90",
    detail: "A flexible bundle for occasional studio visits. Class packs expire after 3 months.",
  },
  {
    name: "10-class pack",
    price: "$160",
    detail: "A lower per-class rate for students building a steady movement practice.",
  },
  {
    name: "Monthly membership",
    price: "$125/mo",
    detail: "Unlimited class access for students who attend regularly throughout the month.",
  },
  {
    name: "6-month membership",
    price: "$600",
    detail: "A longer-term unlimited option for committed community members.",
  },
  {
    name: "New member intro",
    price: "Free week",
    detail: "Try unlimited classes for a week before choosing the option that fits.",
  },
];
---

<Layout
  title="Pricing | The Latina Sweat Project"
  description="Memberships, class packs, drop-ins, and accessible community wellness pricing for The Latina Sweat Project in Pilsen, Chicago."
>
  <Header />
  <main>
    <section class="bg-off-black px-4 py-14 text-white sm:py-16">
      <div class="mx-auto max-w-6xl">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent-gold">
          Studio pricing
        </p>
        <div class="mt-4 grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
          <div>
            <h1 class="max-w-3xl font-sans text-4xl font-extrabold leading-tight sm:text-5xl">
              Class packs and memberships for movement in Pilsen.
            </h1>
            <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-200">
              The Latina Sweat Project offers yoga, pilates, dance fitness, and
              community wellness classes with options for drop-ins, class packs,
              unlimited memberships, and new students trying the studio for the
              first time.
            </p>
          </div>
          <div class="rounded-lg border border-white/15 bg-white/[0.06] p-5">
            <p class="text-sm font-bold uppercase tracking-[0.14em] text-slate-300">
              Need support?
            </p>
            <p class="mt-3 text-base leading-7 text-slate-100">
              If cost is a barrier, email
              <a
                href="mailto:membership@latinasweatproject.com"
                class="font-bold text-accent-gold underline underline-offset-4 hover:text-white"
                >membership@latinasweatproject.com</a
              >. The studio is committed to keeping movement and wellness
              accessible to the community.
            </p>
          </div>
        </div>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="https://latinasweatproject.marianatools.com/?_mt=/buy/48717"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-vibrant-pink px-6 text-sm font-bold text-white shadow-lg transition hover:bg-accent-gold hover:text-off-black"
            data-conversion-event="membership_purchase_start"
            data-conversion-context="pricing_hero"
            data-conversion-provider="mariana_tek"
            data-conversion-booking-path="external_buy"
            data-conversion-location-id="48717"
            >Buy passes or memberships</a
          >
          <a
            href="/schedule"
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/25 px-6 text-sm font-bold text-white transition hover:border-accent-gold hover:text-accent-gold"
            data-conversion-event="class_booking_start"
            data-conversion-context="pricing_hero_schedule"
            data-conversion-booking-path="schedule_page"
            >View class schedule</a
          >
        </div>
      </div>
    </section>

    <section class="px-4 py-12">
      <div class="mx-auto max-w-6xl">
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {
            pricingOptions.map((option) => (
              <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
                <h2 class="font-sans text-xl font-extrabold text-off-black">
                  {option.name}
                </h2>
                <p class="mt-3 text-3xl font-extrabold text-vibrant-pink">
                  {option.price}
                </p>
                <p class="mt-3 text-sm leading-6 text-medium-gray">
                  {option.detail}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-y border-gray-100 bg-slate-50 px-4 py-10">
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3">
        <div>
          <h2 class="font-sans text-2xl font-extrabold text-off-black">
            What your membership supports
          </h2>
        </div>
        <div class="md:col-span-2">
          <p class="text-base leading-8 text-medium-gray">
            Memberships and class purchases help sustain a nonprofit wellness
            space rooted in Latina culture, Pilsen community, and accessible
            movement. They support instructors, studio operations, community
            classes, and wellness programming for students across Chicago's
            Southwest Side.
          </p>
          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <div class="rounded-lg border border-gray-200 bg-white p-4">
              <p class="text-sm font-bold uppercase tracking-[0.12em] text-vibrant-pink">
                Classes
              </p>
              <p class="mt-2 text-sm leading-6 text-medium-gray">
                Yoga, pilates, dance fitness, and movement for all levels.
              </p>
            </div>
            <div class="rounded-lg border border-gray-200 bg-white p-4">
              <p class="text-sm font-bold uppercase tracking-[0.12em] text-vibrant-pink">
                Community
              </p>
              <p class="mt-2 text-sm leading-6 text-medium-gray">
                Free and accessible wellness experiences whenever support is
                available.
              </p>
            </div>
            <div class="rounded-lg border border-gray-200 bg-white p-4">
              <p class="text-sm font-bold uppercase tracking-[0.12em] text-vibrant-pink">
                Pilsen
              </p>
              <p class="mt-2 text-sm leading-6 text-medium-gray">
                A neighborhood studio experience near 949 W 16th St.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 py-10">
      <div class="mx-auto max-w-4xl rounded-lg border border-accent-gold/50 bg-amber-50 p-5 text-center">
        <p class="font-semibold text-amber-900">
          Membership cancellation policy
        </p>
        <p class="mt-2 text-sm leading-6 text-amber-800">
          To cancel your membership, please email
          <a
            href="mailto:membership@latinasweatproject.com"
            class="font-bold underline hover:text-vibrant-pink transition-colors"
            >membership@latinasweatproject.com</a
          >. Cancellations take effect at the end of your current billing cycle
          (30 days from your request).
        </p>
      </div>
    </section>

    <section class="px-4 pb-4 text-center">
      <p class="text-vibrant-pink">
        Trouble viewing pricing options or making a purchase below?
        <a
          href="https://latinasweatproject.marianatools.com/?_mt=/buy/48717"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold underline transition hover:text-accent-gold"
          data-conversion-event="membership_purchase_start"
          data-conversion-context="pricing_trouble_link"
          data-conversion-provider="mariana_tek"
          data-conversion-booking-path="external_buy"
          data-conversion-location-id="48717">Open in a new window.</a
        >
      </p>
    </section>
    <div
      data-mariana-integrations="/buy/48717"
    ></div>
  </main>
</Layout>
