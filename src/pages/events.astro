---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import EventsList from "@/components/EventsList.svelte";
import GalaCountdown from "@/components/GalaCountdown.astro";
import GalaPhotoFrame from "@/components/GalaPhotoFrame.astro";
import SweatFestArtwork from "@/components/SweatFestArtwork.astro";
import HausDiscoBall from "@/components/HausDiscoBall.astro";
import { galaPhotos, galaTeaser, galaTickets } from "@/data/galaTeaser";
import {
  sweatFest,
  sweatFestDay,
  sweatFestTickets,
  sweatFestPicadoUri,
} from "@/data/sweatFest";
import {
  hausOfLsp,
  summerRenaissance,
  summerRenaissanceActs,
  hausColors,
  hausLightTileUri,
} from "@/data/hausOfLsp";
const base = import.meta.env.BASE_URL;
const withBase = (path) => `${base}${path.replace(/^\//, "")}`;
const galaPageUrl = withBase(galaTeaser.pagePath);
// Lowest live ticket price, for the early-bird note near the gala CTAs.
const galaFromPrice = Math.min(
  ...galaTickets.tiers.map((tier) => tier.earlyBird),
);
// Deepened day-arc accents legible on the light mini-cards.
const sweatFestDeepAccents = {
  sunrise: "#b56400",
  ember: "#d63d22",
  dusk: "#c81e63",
};
const sweatFestFromPrice = Math.min(
  ...sweatFestTickets.tiers.map((tier) => tier.price),
);
// Haus of LSP CTA gating: points at the ticketing form once entry details
// go live (flip in src/data/hausOfLsp.js), at the event page until then.
const hausHasTickets =
  summerRenaissance.ticketsOnSale && summerRenaissance.ticketsUrl;
const hausPrimaryUrl = hausHasTickets
  ? summerRenaissance.ticketsUrl
  : withBase("hausoflsp");
const hausPrimaryLabel = hausHasTickets
  ? summerRenaissance.ticketsLabel
  : summerRenaissance.exploreLabel;
// Events already featured in the hand-designed sections below; the
// Supabase-driven list skips these so they don't appear twice.
const featuredSlugs = [
  "noche-inolvidable-gala",
  "sweat-fest",
  "monday-miles",
  "summer-renaissance",
  "haus-of-lsp-summer-renaissance",
];
---

<Layout title="Events | The Latina Sweat Project">
  <Header />
  <main>
    {/* START: Page Header Section */}
    <section class="bg-light-gray py-16 md:py-24">
      <div class="mx-auto max-w-7xl px-4 text-center">
        <h1
          class="font-sans text-4xl font-extrabold tracking-tight text-off-black sm:text-5xl md:text-6xl"
        >
          Our Events
        </h1>
        <p class="mx-auto mt-4 max-w-2xl font-body text-lg text-medium-gray">
          Join our vibrant community. Sweat, dance, and connect at our upcoming
          events.
        </p>
      </div>
    </section>
    {/* END: Page Header Section */}

    {/* START: Haus of LSP — Summer Renaissance Featured Section (dark
        nightlife-collage theme, Option G. Leads because Aug 1 is the
        soonest event; the dark room between the light page header and the
        light Sweat Fest section also removes the old L-L adjacency there) */}
    <section
      id="summer-renaissance"
      class="relative overflow-hidden py-16 text-white md:py-20 scroll-mt-28"
      style={`background:
        radial-gradient(46rem 26rem at 10% -4rem, rgba(160, 107, 216, 0.42), transparent 62%),
        radial-gradient(38rem 22rem at 100% 100%, rgba(255, 111, 181, 0.28), transparent 60%),
        radial-gradient(40rem 18rem at 50% 112%, rgba(255, 111, 181, 0.2), transparent 70%),
        linear-gradient(to bottom, ${hausColors.maroon}, ${hausColors.plum});`}
    >
      <div class="haus-halftone absolute bottom-0 left-0 h-48 w-64 opacity-15 [mask-image:radial-gradient(closest-side,black,transparent)]" aria-hidden="true"></div>
      {/* Slow-breathing party glows (gala-ambient pulse: ~8s scale/opacity
          drift, nothing close to a flash) */}
      <div class="gala-ambient pointer-events-none absolute -right-24 top-4 h-72 w-72 rounded-full blur-[110px]" style="background: rgba(255, 111, 181, 0.3);" aria-hidden="true"></div>
      <div class="gala-ambient pointer-events-none absolute -left-16 bottom-0 h-80 w-80 rounded-full blur-[120px]" style="background: rgba(160, 107, 216, 0.34); animation-delay: 2.5s;" aria-hidden="true"></div>
      {/* The mirror ball's throw, drifting across the whole section
          (motion-safety notes on .haus-lights in global.css) */}
      <div
        class="haus-lights haus-lights--section"
        style={`--haus-light-tile: ${hausLightTileUri};`}
        aria-hidden="true"
      >
      </div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-5 lg:gap-12">
          {/* Media (left, matching the page's media column rhythm): a
              collage — the real 3D mirror ball hanging on its cord over the
              taped-up note, with the printed flyer tucked behind it */}
          <div class="reveal relative mx-auto w-full max-w-md pt-16 lg:col-span-2 lg:max-w-none">
            <div class="pointer-events-none absolute -top-10 -right-2 z-[3] sm:-right-4" aria-hidden="true">
              <HausDiscoBall size="h-36 w-36 sm:h-44 sm:w-44" />
            </div>
            <img
              src={`${base}images/hausoflsp1.jpg`}
              width="1000"
              height="1250"
              alt=""
              class="haus-sticker absolute -left-5 top-4 hidden w-40 rotate-[-8deg] rounded-sm sm:block lg:-left-10 lg:w-44"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <div class="relative rotate-[-1.1deg]">
              <span class="haus-tape -top-3 left-6 rotate-[-8deg]" aria-hidden="true"></span>
              <span class="haus-tape -top-3 right-6 rotate-[7deg]" aria-hidden="true"></span>
              <div class="haus-note px-7 py-9 sm:px-9">
                <p class="text-center font-marker text-3xl" style="color: #24201a;">
                  qué va a pasar?
                </p>
                <div class="mt-5 space-y-5">
                  {summerRenaissanceActs.map((act) => (
                    <div>
                      <p
                        class="inline-block -rotate-1 rounded px-2 py-0.5 font-marker text-base text-off-black"
                        style={`background: ${act.accent === "pink" ? `${hausColors.pink}55` : hausColors.mint};`}
                      >
                        {act.time}
                      </p>
                      <ul class="mt-2 space-y-1.5 pl-1">
                        {act.items.map((item) => (
                          <li class="flex items-baseline gap-2.5">
                            <span class="font-marker text-lg leading-none" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                            <span class="font-marker text-lg uppercase tracking-wide text-off-black">{item.title}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
                <p class="mt-6 text-center font-marker text-base text-off-black/70">
                  all proceeds &rarr; {hausOfLsp.fundName} &hearts;
                </p>
              </div>
            </div>
          </div>

          {/* Copy (right) */}
          <div class="reveal lg:col-span-3 text-center lg:text-left" style="transition-delay: 120ms;">
            <p class="font-marker text-xl text-white/85 sm:text-2xl">
              <span class="haus-glow">Haus of LSP</span>
              <span class="ml-2 inline-block -rotate-6 text-base text-white/55 sm:text-lg">presents</span>
            </p>
            <h2 class="mt-3 font-marker leading-[0.95]">
              <span class="haus-glow block text-5xl sm:text-6xl" style={`color: ${hausColors.pink};`}>Summer</span>
              <span class="haus-chrome block text-5xl sm:text-6xl">Renaissance</span>
            </h2>
            <p class="mt-4 text-lg font-bold text-white">
              {summerRenaissance.dateLabel} · {summerRenaissance.timeLabel}
            </p>
            <p class="mt-1 text-base font-semibold text-white/60">
              {summerRenaissance.venueLine}
            </p>

            <p class="mt-5 max-w-2xl text-base leading-relaxed text-white/70 mx-auto lg:mx-0">
              {summerRenaissance.pageDescription}
            </p>

            {/* The night in two acts */}
            <div class="mt-7 grid grid-cols-1 gap-3 sm:grid-cols-2 max-w-2xl mx-auto lg:mx-0">
              {summerRenaissanceActs.map((act, i) => (
                <div
                  class="haus-sticker rounded-xl bg-off-black/50 px-4 py-3 text-left backdrop-blur-sm"
                  style={`transform: rotate(${[-0.8, 0.6][i % 2]}deg);`}
                >
                  <p class="text-[10px] font-bold uppercase tracking-widest" style={`color: ${act.accent === "pink" ? hausColors.pink : hausColors.mint};`}>
                    {act.time}
                  </p>
                  <p class="mt-1 text-sm font-extrabold uppercase tracking-wide text-white">
                    {act.title}
                  </p>
                  <p class="mt-1 text-xs font-semibold text-white/55">
                    {act.items.map((item) => item.title).join(" · ")}
                  </p>
                </div>
              ))}
            </div>

            <p
              class="mt-6 inline-block -rotate-1 border-2 border-dashed px-4 py-2 text-xs font-extrabold uppercase tracking-[0.18em]"
              style={`color: ${hausColors.mint}; border-color: ${hausColors.mint}66;`}
            >
              {summerRenaissance.cause}
            </p>

            <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:flex-wrap justify-center lg:justify-start">
              <a
                href={hausPrimaryUrl}
                target={hausHasTickets ? "_blank" : undefined}
                rel={hausHasTickets ? "noopener noreferrer" : undefined}
                class="haus-btn group inline-flex items-center gap-3 px-8 py-4 text-base font-extrabold text-off-black"
                style={`background-color: ${hausColors.pink};`}
                data-conversion-event={hausHasTickets ? "haus_ticket_click" : "haus_explore_click"}
                data-conversion-context="events_haus_feature"
              >
                {hausPrimaryLabel}
                <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
              {
                hausHasTickets && (
                  <a
                    href={withBase("hausoflsp")}
                    class="haus-btn group inline-flex items-center gap-3 bg-white/10 px-8 py-4 text-base font-extrabold text-white backdrop-blur-sm"
                    data-conversion-event="haus_explore_click"
                    data-conversion-context="events_haus_feature"
                  >
                    {summerRenaissance.exploreLabel}
                    <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                  </a>
                )
              }
              <a
                href={withBase(summerRenaissance.calendarPath)}
                class="haus-btn inline-flex items-center gap-3 bg-white/10 px-8 py-4 text-base font-extrabold text-white backdrop-blur-sm"
                download
              >
                Add to calendar
              </a>
            </div>
            <p class="mt-5 text-xs font-extrabold uppercase tracking-[0.2em] text-white/45">
              {summerRenaissance.statusLabel}
            </p>
          </div>
        </div>
      </div>
    </section>
    {/* END: Haus of LSP — Summer Renaissance Featured Section */}

    {/* START: Sweat Fest Featured Section (bright daylight festival theme;
        light, follows the dark Summer Renaissance section above) */}
    <section
      id="sweat-fest"
      class="relative overflow-hidden py-16 md:py-20 scroll-mt-28"
      style="background: linear-gradient(to bottom, #fff8ef, #fffaf1 45%, #ffefe2);"
    >
      {/* Papel picado strung along the top */}
      <div
        class="sf-picado absolute inset-x-0 top-0 h-[52px]"
        style={`background-image: ${sweatFestPicadoUri};`}
        aria-hidden="true"
      >
      </div>

      <div class="relative mx-auto max-w-7xl px-4 pt-8">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-5 lg:gap-12">
          {/* Media (left): the campaign poster taped to the wall, with the
              exact logo and event copy layered as HTML. */}
          <div class="reveal relative mx-auto w-full max-w-md lg:col-span-2 lg:max-w-none">
            <div class="sf-taped -rotate-[1.3deg]">
              <span class="sf-tape -left-4 -top-3 rotate-[-38deg]" aria-hidden="true"></span>
              <span class="sf-tape -right-4 -top-3 rotate-[34deg]" aria-hidden="true"></span>
              <SweatFestArtwork variant="portrait" className="rounded-[3px]" />
              <p class="mt-3 text-center font-slab text-sm uppercase tracking-[0.2em] text-off-black/70">
                {sweatFest.tagline}
              </p>
            </div>
          </div>

          <div class="reveal lg:col-span-3 text-center lg:text-left" style="transition-delay: 120ms;">
            <span class="sf-stamp px-3 py-1.5 text-[11px]" style="color: #b03a20;">
              First-ever · All-day movement festival
            </span>
            <h2 class="mt-5 font-slab text-4xl uppercase tracking-tight sm:text-5xl lg:text-6xl leading-[0.98]">
              <span class="sf-print" style="--sf-print: #e94f8a;">Sweat Fest</span>
            </h2>
            <p class="mt-4 text-lg font-bold text-off-black">
              {sweatFest.dateLabel} · {sweatFest.timeLabel}
            </p>
            <p class="mt-1 text-base font-semibold text-medium-gray">
              {sweatFest.venueLine}
            </p>
            <p class="mt-3 text-sm font-extrabold uppercase tracking-[0.22em] text-off-black/80">
              {sweatFest.tagline}
            </p>

            <p class="mt-5 max-w-2xl text-base leading-relaxed text-off-black/70 mx-auto lg:mx-0">
              {sweatFest.pageDescription}
            </p>

            {/* The arc of the day: Run / Sweat / Pachanga (mercado tags) */}
            <div class="mt-7 grid grid-cols-1 gap-3 sm:grid-cols-3 max-w-2xl mx-auto lg:mx-0">
              {sweatFestDay.map((phase, i) => (
                <div
                  class="sf-tag px-4 py-3 text-left"
                  style={`transform: rotate(${[-0.9, 0.6, -0.5][i % 3]}deg);`}
                >
                  <p class="text-[10px] font-bold uppercase tracking-widest" style={`color: ${sweatFestDeepAccents[phase.accent]};`}>
                    {phase.time}
                  </p>
                  <p class="mt-1 text-sm font-extrabold uppercase tracking-wide text-off-black">
                    {phase.title}
                  </p>
                </div>
              ))}
            </div>

            {/* Ticket tiers, priced like the stub wall on /sweatfest */}
            <div class="mt-7 flex flex-wrap justify-center gap-3 lg:justify-start">
              {sweatFestTickets.tiers.map((tier, i) => (
                <span
                  class="sf-tag inline-flex items-baseline gap-1.5 px-3.5 py-1.5 text-xs font-extrabold uppercase tracking-[0.06em] text-off-black/80"
                  style={`transform: rotate(${[-0.8, 0.5, -0.4, 0.7][i % 4]}deg);`}
                >
                  {tier.name} · <span class="font-slab text-sm normal-case" style="color: #9b2c18;">${tier.price}</span>
                </span>
              ))}
            </div>

            <div class="mt-9 flex flex-col items-center gap-4 sm:flex-row sm:flex-wrap justify-center lg:justify-start">
              {
                sweatFestTickets.onSale && sweatFestTickets.url && (
                  <a
                    href={sweatFestTickets.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="sf-btn group inline-flex items-center gap-3 bg-accent-gold px-8 py-4 text-base font-extrabold text-off-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-off-black focus-visible:ring-offset-4"
                    data-conversion-event="sweatfest_ticket_click"
                    data-conversion-context="events_sweatfest_feature"
                  >
                    {sweatFest.ticketsLabel}
                    <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                  </a>
                )
              }
              <a
                href={withBase("sweatfest")}
                class:list={[
                  "sf-btn group inline-flex items-center gap-3 px-8 py-4 text-base font-extrabold text-off-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-off-black focus-visible:ring-offset-4",
                  sweatFestTickets.onSale ? "bg-white" : "bg-accent-gold",
                ]}
                data-conversion-event="sweatfest_explore_click"
                data-conversion-context="events_sweatfest_feature"
              >
                Explore Sweat Fest
                <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
              <a
                href={`${withBase("sweatfest")}#sponsors`}
                class="inline-flex items-center gap-3 border-2 border-off-black/20 bg-white px-8 py-4 text-base font-bold text-off-black transition-colors duration-300 hover:border-[#ff6b52] hover:bg-[#ff6b52]/5"
                style="border-radius: 8px;"
              >
                Become a sponsor
              </a>
            </div>
            <p class="mt-6 flex flex-wrap items-center justify-center gap-3 text-sm font-semibold text-off-black/70 lg:justify-start">
              <span class="sf-stamp px-3 py-1.5 text-[11px]" style="color: #b03a20;">
                {sweatFestTickets.statusLabel}
              </span>
              Tickets from ${sweatFestFromPrice}
            </p>
          </div>
        </div>
      </div>
    </section>
    {/* END: Sweat Fest Featured Section */}

    {/* START: Annual Gala Featured Section */}
    <section
      id="noche-inolvidable-gala"
      class="relative overflow-hidden bg-off-black py-16 text-white md:py-20 scroll-mt-28"
    >
      <div class="gala-lattice absolute inset-0 opacity-[0.06]"></div>
      <div class="absolute inset-x-0 top-0 h-px gala-foil-rule"></div>
      <div class="gala-ambient absolute -left-20 top-0 h-72 w-1/2 rounded-full bg-gradient-to-r from-accent-gold/20 to-transparent blur-3xl"></div>
      <div class="gala-ambient absolute -right-20 bottom-0 h-72 w-1/2 rounded-full bg-gradient-to-l from-vibrant-pink/20 to-transparent blur-3xl" style="animation-delay: 2.5s;"></div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12">
          <div class="reveal group relative lg:col-span-2">
            <div class="gala-ambient absolute -inset-3 rounded-3xl bg-gradient-to-br from-accent-gold/30 via-vibrant-pink/20 to-transparent blur-xl"></div>
            <GalaPhotoFrame slot={galaPhotos.atrium} variant="event" corners />
          </div>

          <div class="reveal lg:col-span-3 text-center lg:text-left" style="transition-delay: 120ms;">
            <p class="flex items-center justify-center gap-3 text-xs font-extrabold uppercase tracking-[0.3em] text-accent-gold lg:justify-start">
              <span class="h-px w-8 bg-accent-gold/70"></span>
              Featured · Annual Gala
            </p>
            <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl leading-[1.05]">
              <span class="gala-foil">{galaTeaser.shortTitle}</span>
              <span class="text-white/90"> Gala</span>
            </h2>
            <p class="mt-4 text-lg font-semibold text-accent-gold">
              {galaTeaser.dateLabel} · {galaTeaser.timeLabel}
            </p>
            <p class="mt-2 text-base font-semibold text-white/80">
              {galaTeaser.venueLine}
            </p>

            <p class="mt-5 max-w-2xl text-base leading-relaxed text-white/65 mx-auto lg:mx-0">
              {galaTeaser.homepageDescription} {galaTeaser.statusLabel}.
            </p>
            <p class="mt-3 max-w-2xl text-sm font-semibold leading-relaxed text-white/75 mx-auto lg:mx-0">
              Our signature fundraising evening: every seat expands free and
              discounted access across Chicago.
            </p>

            <div class="mt-7 max-w-2xl mx-auto lg:mx-0">
              <GalaCountdown variant="card" />
            </div>

            <div class="mt-7 flex flex-wrap justify-center gap-2 lg:justify-start">
              {[galaTeaser.attire, "Downtown Chicago", "MCA Chicago"].map((item) => (
                <span class="rounded-full border border-accent-gold/25 bg-accent-gold/10 px-3.5 py-1.5 text-xs font-bold uppercase tracking-wider text-accent-gold">
                  {item}
                </span>
              ))}
            </div>

            <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:flex-wrap justify-center lg:justify-start">
              <a
                href={galaTeaser.ticketsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="gala-btn gala-btn--gold gala-sheen group inline-flex items-center gap-3 px-8 py-4 text-base font-extrabold"
                data-conversion-event="gala_ticket_click"
                data-conversion-context="events_featured_gala"
              >
                <span class="relative z-[1]">{galaTeaser.ticketsLabel}</span>
                <svg class="relative z-[1] h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
              <a
                href={galaPageUrl}
                class="gala-btn gala-btn--ghost inline-flex items-center gap-3 px-8 py-4 text-base font-extrabold"
              >
                Explore the Gala
              </a>
            </div>
            <p class="mt-4 flex flex-wrap items-center justify-center gap-2 text-sm font-semibold text-accent-gold/90 lg:justify-start">
              <span class="inline-flex items-center gap-1.5 rounded-full border border-accent-gold/30 bg-accent-gold/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-accent-gold">
                <span class="h-1.5 w-1.5 rounded-full bg-accent-gold"></span>
                On sale now
              </span>
              {galaTickets.earlyBirdLabel} · from ${galaFromPrice}
            </p>
          </div>
        </div>
      </div>
    </section>
    {/* END: Annual Gala Featured Section */}

    {/* START: Dashboard-managed events (Supabase). Placed here (between
        the dark gala and dark Monday Miles sections) so the light-themed
        island keeps the alternation rhythm intact now that Pride's two
        light slots are retired. */}
    <EventsList client:load excludeSlugs={featuredSlugs} />
    {/* END: Dashboard-managed events */}

    {/* START: Monday Miles Featured Section (light sand; restyled from dark so
        the page cadence never depends on the Supabase island above rendering) */}
    <section class="relative overflow-hidden bg-gradient-to-br from-[#f7efe3] via-white to-[#fff7e8] py-16 md:py-20">
      {/* Subtle track lines background */}
      <div class="absolute inset-0 opacity-[0.05]">
        <div
          class="absolute inset-0"
