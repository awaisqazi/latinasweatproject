---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import EventCard from "@/components/EventCard.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Events | The Latina Sweat Project">
  <Header />
  <main>
    {/* START: Page Header Section */}
    <section class="bg-light-gray py-16 md:py-24">
      <div class="mx-auto max-w-7xl px-4 text-center">
        <h1
          class="font-sans text-4xl font-extrabold tracking-tight text-off-black sm:text-5xl md:text-6xl"
        >
          Our Events
        </h1>
        <p class="mx-auto mt-4 max-w-2xl font-body text-lg text-medium-gray">
          Join our vibrant community. Sweat, dance, and connect at our upcoming
          events.
        </p>
      </div>
    </section>
    {/* END: Page Header Section */}

    {/* START: Yoga For Wishes — Make-A-Wish Section (Dark) */}
    <section class="relative overflow-hidden bg-gradient-to-r from-[#0a1628] via-[#0f2847] to-[#0a1628] py-16 md:py-20">
      {/* Subtle star decorations */}
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-16 right-1/4 w-[350px] h-[350px] bg-sky-500/10 rounded-full blur-[100px]"></div>
        <div class="absolute -bottom-20 left-1/4 w-[300px] h-[300px] bg-blue-400/8 rounded-full blur-[80px]"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12">
          {/* Left: Flyer Image (2 cols) */}
          <div class="relative lg:col-span-2">
            <div class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-sky-400/20 via-blue-300/10 to-transparent blur-xl"></div>
            <div class="relative overflow-hidden rounded-2xl border border-white/10 shadow-lg">
              <img
                src={`${base}images/yoga-for-wishes.png`}
                alt="Yoga For Wishes · Make-A-Wish Illinois × Latina Sweat Project, April 18"
                class="w-full object-cover"
              />
            </div>
          </div>

          {/* Right: Content (3 cols) */}
          <div class="lg:col-span-3 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 rounded-full bg-sky-500/15 px-4 py-2 mb-5">
              <span class="relative flex h-2.5 w-2.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-sky-400 opacity-75"></span>
                <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-sky-400"></span>
              </span>
              <span class="text-xs font-bold uppercase tracking-widest text-sky-400">April 18 · Community Event</span>
            </div>

            <h2 class="font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
              Yoga For <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-blue-300">Wishes</span>
            </h2>
            <p class="mt-2 text-xl font-semibold text-sky-400">
              Make‑A‑Wish Illinois × Latina Sweat Project
            </p>

            <p class="mt-5 text-lg text-white/70 leading-relaxed max-w-xl mx-auto lg:mx-0">
              Latina Sweat Project is proud to support Make‑A‑Wish Illinois and its mission to grant wishes to children with critical illnesses. Join our <span class="font-bold text-sky-400">3:30 PM donation‑based class</span>, or stop by anytime throughout the day to write a birthday card for a wish child and learn more about other ways to get involved.
            </p>

            <p class="mt-3 text-base text-white/50 italic max-w-xl mx-auto lg:mx-0">
              Move. Breathe. Give back.
            </p>

            {/* Details grid */}
            <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-xl mx-auto lg:mx-0">
              <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3">
                <svg class="h-5 w-5 text-sky-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">When</p>
                  <p class="text-sm font-bold text-white">April 18</p>
                </div>
              </div>
              <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3">
                <svg class="h-5 w-5 text-sky-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">Class</p>
                  <p class="text-sm font-bold text-white">3:30 PM</p>
                </div>
              </div>
              <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3">
                <svg class="h-5 w-5 text-sky-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">Where</p>
                  <p class="text-sm font-bold text-white">949 W 16th St</p>
                </div>
              </div>
            </div>

            {/* Tags */}
            <div class="mt-6 flex flex-wrap justify-center lg:justify-start gap-2">
              <span class="rounded-full bg-sky-500/20 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-sky-400">Donation‑Based</span>
              <span class="rounded-full bg-blue-500/20 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-blue-400">All‑Day Open House</span>
              <span class="rounded-full bg-indigo-500/20 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-indigo-300">Birthday Cards</span>
            </div>

            {/* CTA */}
            <div class="mt-8">
              <a
                href="https://www.zeffy.com/en-US/ticketing/makeawish-together-we-grant-wishes-for-children-with-critical-illnesses"
                target="_blank"
                rel="noopener noreferrer"
                class="btn group inline-flex items-center gap-3 rounded-full bg-sky-600 px-8 py-4 text-base font-bold text-white shadow-lg shadow-sky-600/25 transition-all duration-300 hover:scale-105 hover:bg-sky-500 hover:shadow-xl hover:shadow-sky-500/40"
              >
                Get Tickets · $15
                <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: Yoga For Wishes — Make-A-Wish Section */}

    {/* START: Spring Clean Up Section (Light) */}
    <section class="relative overflow-hidden bg-gradient-to-br from-emerald-50 via-green-50 to-slate-50 py-16 md:py-20">
      {/* Subtle decorations */}
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-16 right-1/4 w-[350px] h-[350px] bg-emerald-200/30 rounded-full blur-[100px]"></div>
        <div class="absolute -bottom-20 left-1/4 w-[300px] h-[300px] bg-green-200/20 rounded-full blur-[80px]"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div
          class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12"
        >
          {/* Left: Flyer Image (2 cols) */}
          <div class="relative lg:col-span-2">
            <div
              class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-emerald-300/20 via-green-200/10 to-transparent blur-xl"
            >
            </div>
            <div
              class="relative overflow-hidden rounded-2xl border-2 border-emerald-200/60 shadow-lg"
            >
              <img
                src={`${base}images/spring-cleanup.png`}
                alt="Spring Clean Up Saturdays · April 25th at Latina Sweat Project, 949 W. 16th Street, 10 AM – 12 PM"
                class="w-full object-cover"
              />
            </div>
          </div>

          {/* Right: Content (3 cols) */}
          <div class="lg:col-span-3 text-center lg:text-left">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-emerald-100 border border-emerald-200 px-4 py-2 mb-5"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500"
                ></span>
              </span>
              <span
                class="text-xs font-bold uppercase tracking-widest text-emerald-700"
                >April 25 · Community Event</span
              >
            </div>

            <h2
              class="font-sans text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl"
            >
              Spring <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-green-500">Clean Up</span>
            </h2>
            <p class="mt-2 text-xl font-semibold text-emerald-700">
              Latina Sweat Project × Alderman Byron Sigcho-Lopez
            </p>

            <p
              class="mt-5 text-lg text-slate-600 leading-relaxed max-w-xl mx-auto lg:mx-0"
            >
              Please join us to help pick up trash and clean up our neighborhood as we get ready to enjoy the upcoming warmer weather. This is a team effort so we'd appreciate all hands on deck! Your participation will help us create safer and cleaner areas for us to enjoy outdoor movement, wellness, and connection.
            </p>

            <p class="mt-3 text-base text-slate-500 italic max-w-xl mx-auto lg:mx-0">
              Any donations made towards this event will be used for supplies. Light refreshments will be provided.
            </p>

            {/* Details grid */}
            <div
              class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-xl mx-auto lg:mx-0"
            >
              <div class="flex items-center gap-3 rounded-xl bg-white border border-emerald-100 shadow-sm px-4 py-3">
                <svg class="h-5 w-5 text-emerald-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <div>
                  <p class="text-xs text-slate-400 uppercase tracking-wider">When</p>
                  <p class="text-sm font-bold text-slate-800">April 25</p>
                </div>
              </div>
              <div class="flex items-center gap-3 rounded-xl bg-white border border-emerald-100 shadow-sm px-4 py-3">
                <svg class="h-5 w-5 text-emerald-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-slate-400 uppercase tracking-wider">Time</p>
                  <p class="text-sm font-bold text-slate-800">10 AM – 12 PM</p>
                </div>
              </div>
              <div class="flex items-center gap-3 rounded-xl bg-white border border-emerald-100 shadow-sm px-4 py-3">
                <svg class="h-5 w-5 text-emerald-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-slate-400 uppercase tracking-wider">Where</p>
                  <p class="text-sm font-bold text-slate-800">949 W 16th St</p>
                </div>
              </div>
            </div>

            {/* Tags */}
            <div class="mt-6 flex flex-wrap justify-center lg:justify-start gap-2">
              <span class="rounded-full bg-emerald-100 border border-emerald-200 px-3 py-1 text-xs font-bold uppercase tracking-wider text-emerald-700">Community</span>
              <span class="rounded-full bg-green-100 border border-green-200 px-3 py-1 text-xs font-bold uppercase tracking-wider text-green-700">Volunteer</span>
              <span class="rounded-full bg-slate-100 border border-slate-200 px-3 py-1 text-xs font-bold uppercase tracking-wider text-slate-600">All Ages</span>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: Spring Clean Up Section */}

    {/* START: ALPFA Mental Health & Business Panel Section (Dark) */}
    <section class="relative overflow-hidden bg-gradient-to-r from-[#0a0f28] via-[#141b3d] to-[#0a0f28] py-16 md:py-20">
      {/* Subtle decorations */}
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-16 right-1/4 w-[350px] h-[350px] bg-indigo-500/10 rounded-full blur-[100px]"></div>
        <div class="absolute -bottom-20 left-1/4 w-[300px] h-[300px] bg-violet-400/8 rounded-full blur-[80px]"></div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12">
          {/* Left: Flyer Image (2 cols) */}
          <div class="relative lg:col-span-2">
            <div class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-indigo-400/20 via-violet-300/10 to-transparent blur-xl"></div>
            <div class="relative overflow-hidden rounded-2xl border border-white/10 shadow-lg">
              <img
                src={`${base}images/alpfa-mental-health-panel.png`}
                alt="ALPFA × Latina Sweat Project · Mental Health & Business Panel, Saturday May 2, 3:30 PM – 6:00 PM"
                class="w-full object-cover"
              />
            </div>
          </div>

          {/* Right: Content (3 cols) */}
          <div class="lg:col-span-3 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 rounded-full bg-indigo-500/15 px-4 py-2 mb-5">
              <span class="relative flex h-2.5 w-2.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-75"></span>
                <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-indigo-400"></span>
              </span>
              <span class="text-xs font-bold uppercase tracking-widest text-indigo-400">May 2 · Panel Event</span>
            </div>

            <h2 class="font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
              Mental Health & <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-violet-300">Business Panel</span>
            </h2>
            <p class="mt-2 text-xl font-semibold text-indigo-400">
              ALPFA × Latina Sweat Project
            </p>

            <p class="mt-5 text-lg text-white/70 leading-relaxed max-w-xl mx-auto lg:mx-0">
              Join ALPFA & LSP for a powerful panel on the intersection of mental health and business. In today's busy and driven world, we often lose sight of our mental well-being while advancing professionally. We'll discuss how to <span class="font-bold text-indigo-400">navigate work-life balance</span> and prioritize both your mental health and career simultaneously.
            </p>

            <p class="mt-3 text-base text-white/50 italic max-w-xl mx-auto lg:mx-0">
              Doors open at 3:30 PM · Panel runs 4:00 – 5:00 PM · Stick around until 6 PM to network. Hawa Hospitality café open for the event.
            </p>

            {/* Panelists */}
            <div class="mt-6 rounded-xl bg-white/5 border border-white/10 px-5 py-4 max-w-xl mx-auto lg:mx-0">
              <p class="text-xs text-indigo-300 uppercase tracking-wider font-bold mb-2">Panelists</p>
              <p class="text-sm text-white/80 leading-relaxed">
                Mona Asra · Nelly Montoya · Odette Rivera · Rosemary Magana
              </p>
              <p class="mt-2 text-xs text-white/50">
                <span class="font-semibold text-indigo-300/80">Moderator:</span> Dinorah Zubieta
              </p>
            </div>

            {/* Details grid */}
            <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-xl mx-auto lg:mx-0">
              <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3">
                <svg class="h-5 w-5 text-indigo-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">When</p>
                  <p class="text-sm font-bold text-white">Sat, May 2</p>
                </div>
              </div>
              <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3">
                <svg class="h-5 w-5 text-indigo-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">Time</p>
                  <p class="text-sm font-bold text-white">3:30 – 6 PM</p>
                </div>
              </div>
              <div class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3">
                <svg class="h-5 w-5 text-indigo-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">Where</p>
                  <p class="text-sm font-bold text-white">949 W 16th St</p>
                </div>
              </div>
            </div>

            {/* Tags */}
            <div class="mt-6 flex flex-wrap justify-center lg:justify-start gap-2">
              <span class="rounded-full bg-indigo-500/20 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-indigo-400">Panel Discussion</span>
              <span class="rounded-full bg-violet-500/20 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-violet-400">Networking</span>
              <span class="rounded-full bg-sky-500/20 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-sky-300">Wellness</span>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: ALPFA Mental Health & Business Panel Section */}

    {/* START: Monday Miles Featured Section (Dark) */}
    <section class="relative overflow-hidden bg-off-black py-16 md:py-20">
      {/* Subtle track lines background */}
      <div class="absolute inset-0 opacity-[0.04]">
        <div
          class="absolute inset-0"
          style="background-image: repeating-linear-gradient(0deg, transparent, transparent 60px, white 60px, white 61px);"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div
          class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12"
        >
          {/* Left: Image (2 cols) */}
          <div class="relative lg:col-span-2">
            <div
              class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-accent-gold/20 via-vibrant-pink/10 to-transparent blur-xl"
            >
            </div>
            <div
              class="relative overflow-hidden rounded-2xl border border-white/10"
            >
              <img
                src={`${base}images/monday-miles-runner.png`}
                alt="Monday Miles · community running group in Pilsen, Chicago"
                class="h-80 w-full object-cover sm:h-96 lg:h-[28rem]"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-off-black via-off-black/50 to-off-black/10"
              >
              </div>
              <div
                class="absolute bottom-4 left-4 right-4 flex flex-wrap gap-2"
              >
                <span
                  class="rounded-full bg-accent-gold px-3 py-1 text-xs font-bold uppercase tracking-wider text-off-black"
                  >Free</span
                >
                <span
                  class="rounded-full bg-vibrant-pink/80 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-white drop-shadow-sm"
                  >All Levels</span
                >
                <span
                  class="rounded-full bg-white/20 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-white drop-shadow-sm"
                  >Weekly</span
                >
              </div>
            </div>
          </div>

          {/* Right: Content (3 cols) */}
          <div class="lg:col-span-3 text-center lg:text-left">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-accent-gold/15 px-4 py-2 mb-5"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"
                ></span>
              </span>
              <span
                class="text-xs font-bold uppercase tracking-widest text-accent-gold"
                >Weekly Community Series</span
              >
            </div>

            <h2
              class="font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl"
            >
              Monday Miles
            </h2>
            <p class="mt-2 text-xl font-semibold text-accent-gold">
              Weekly Walk & Run Group
            </p>

            <p
              class="mt-5 text-lg text-white/70 leading-relaxed max-w-xl mx-auto lg:mx-0"
            >
              Mondays just got better. Meet in the cafe, warm up together, and
              head out. Walk 1 mile or jog/run 2. You set the pace. Because
              movement is medicine, and it's better in community.
            </p>

            {/* Details grid */}
            <div
              class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-xl mx-auto lg:mx-0"
            >
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3"
              >
                <svg
                  class="h-5 w-5 text-accent-gold flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
