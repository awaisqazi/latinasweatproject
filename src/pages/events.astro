---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import EventsList from "@/components/EventsList.svelte";
import GalaCountdown from "@/components/GalaCountdown.astro";
import GalaPhotoFrame from "@/components/GalaPhotoFrame.astro";
import { galaPhotos, galaTeaser, galaTickets } from "@/data/galaTeaser";
const base = import.meta.env.BASE_URL;
const withBase = (path) => `${base}${path.replace(/^\//, "")}`;
const galaPageUrl = withBase(galaTeaser.pagePath);
// Lowest live ticket price, for the early-bird note near the gala CTAs.
const galaFromPrice = Math.min(
  ...galaTickets.tiers.map((tier) => tier.earlyBird),
);
// Events already featured in the hand-designed sections below; the
// Supabase-driven list skips these so they don't appear twice.
const featuredSlugs = [
  "noche-inolvidable-gala",
  "monday-miles",
];
---

<Layout title="Events | The Latina Sweat Project">
  <Header />
  <main>
    {/* START: Page Header Section */}
    <section class="bg-light-gray py-16 md:py-24">
      <div class="mx-auto max-w-7xl px-4 text-center">
        <h1
          class="font-sans text-4xl font-extrabold tracking-tight text-off-black sm:text-5xl md:text-6xl"
        >
          Our Events
        </h1>
        <p class="mx-auto mt-4 max-w-2xl font-body text-lg text-medium-gray">
          Join our vibrant community. Sweat, dance, and connect at our upcoming
          events.
        </p>
      </div>
    </section>
    {/* END: Page Header Section */}

    {/* START: Annual Gala Featured Section */}
    <section
      id="noche-inolvidable-gala"
      class="relative overflow-hidden bg-off-black py-16 text-white md:py-20 scroll-mt-28"
    >
      <div class="absolute inset-0 opacity-[0.08]" style="background-image: linear-gradient(rgba(255,189,89,0.4) 1px, transparent 1px), linear-gradient(90deg, rgba(255,189,89,0.3) 1px, transparent 1px); background-size: 56px 56px;"></div>
      <div class="absolute inset-x-0 top-0 h-px gala-foil-rule"></div>
      <div class="gala-ambient absolute -left-20 top-0 h-72 w-1/2 rounded-full bg-gradient-to-r from-accent-gold/20 to-transparent blur-3xl"></div>
      <div class="gala-ambient absolute -right-20 bottom-0 h-72 w-1/2 rounded-full bg-gradient-to-l from-vibrant-pink/20 to-transparent blur-3xl" style="animation-delay: 2.5s;"></div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12">
          <div class="reveal group relative lg:col-span-2">
            <div class="gala-ambient absolute -inset-3 rounded-3xl bg-gradient-to-br from-accent-gold/30 via-vibrant-pink/20 to-transparent blur-xl"></div>
            <GalaPhotoFrame slot={galaPhotos.atrium} variant="event" corners />
          </div>

          <div class="reveal lg:col-span-3 text-center lg:text-left" style="transition-delay: 120ms;">
            <p class="flex items-center justify-center gap-3 text-xs font-extrabold uppercase tracking-[0.3em] text-accent-gold lg:justify-start">
              <span class="h-px w-8 bg-accent-gold/70"></span>
              Featured · Annual Gala
            </p>
            <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl leading-[1.05]">
              <span class="gala-foil">{galaTeaser.shortTitle}</span>
              <span class="text-white/90"> Gala</span>
            </h2>
            <p class="mt-4 text-lg font-semibold text-accent-gold">
              {galaTeaser.dateLabel} · {galaTeaser.timeLabel}
            </p>
            <p class="mt-2 text-base font-semibold text-white/80">
              {galaTeaser.venueLine}
            </p>

            <p class="mt-5 max-w-2xl text-base leading-relaxed text-white/65 mx-auto lg:mx-0">
              {galaTeaser.homepageDescription} {galaTeaser.statusLabel}.
            </p>
            <p class="mt-3 max-w-2xl text-sm font-semibold leading-relaxed text-white/75 mx-auto lg:mx-0">
              Our signature fundraising evening: every seat expands free and
              discounted access across Chicago.
            </p>

            <div class="mt-7 max-w-2xl mx-auto lg:mx-0">
              <GalaCountdown variant="card" />
            </div>

            <div class="mt-7 flex flex-wrap justify-center gap-2 lg:justify-start">
              {[galaTeaser.attire, "Downtown Chicago", "MCA Chicago"].map((item) => (
                <span class="rounded-full border border-accent-gold/25 bg-accent-gold/10 px-3.5 py-1.5 text-xs font-bold uppercase tracking-wider text-accent-gold">
                  {item}
                </span>
              ))}
            </div>

            <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:flex-wrap justify-center lg:justify-start">
              <a
                href={galaTeaser.ticketsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn group inline-flex items-center gap-3 rounded-full bg-accent-gold px-8 py-4 text-base font-bold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-105 hover:shadow-xl"
                data-conversion-event="gala_ticket_click"
                data-conversion-context="events_featured_gala"
              >
                {galaTeaser.ticketsLabel}
                <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
              <a
                href={galaPageUrl}
                class="inline-flex items-center gap-3 rounded-full border border-accent-gold/45 bg-white/[0.04] px-8 py-4 text-base font-bold text-white transition-all duration-300 hover:border-accent-gold hover:bg-accent-gold/10"
              >
                Explore the Gala
              </a>
            </div>
            <p class="mt-4 flex flex-wrap items-center justify-center gap-2 text-sm font-semibold text-accent-gold/90 lg:justify-start">
              <span class="inline-flex items-center gap-1.5 rounded-full border border-accent-gold/30 bg-accent-gold/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-accent-gold">
                <span class="h-1.5 w-1.5 rounded-full bg-accent-gold"></span>
                On sale now
              </span>
              {galaTickets.earlyBirdLabel} · from ${galaFromPrice}
            </p>
          </div>
        </div>
      </div>
    </section>
    {/* END: Annual Gala Featured Section */}

    {/* START: Celebrating Pride Featured Section */}
    <section id="pride-at-lsp" class="relative overflow-hidden bg-gradient-to-br from-white via-[#fbf3ef] to-[#f1ecf6] py-16 md:py-20 scroll-mt-28">
      <div
        class="absolute inset-0 opacity-[0.05]"
        style="background-image: linear-gradient(rgba(30,30,30,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(30,30,30,0.5) 1px, transparent 1px); background-size: 58px 58px;"
      >
      </div>
      <div class="absolute -top-28 -left-20 h-72 w-72 rounded-full bg-[#9333ea]/12 blur-[110px]"></div>
      <div class="absolute -bottom-28 -right-20 h-80 w-80 rounded-full bg-[#0ea5e9]/12 blur-[120px]"></div>
      <div class="lsp-pride-bar absolute inset-x-0 top-0 h-1"></div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12">
          {/* Media (left): teacher spotlight covers */}
          <div class="lg:col-span-2">
            <a
              href={`${withBase("pride")}#spotlight`}
              class="group block"
              aria-label="Meet our Pride teacher spotlights, Luz Rodriguez and lizlates"
            >
              <div class="grid grid-cols-2 gap-4">
                <div class="overflow-hidden rounded-2xl bg-white p-1.5 shadow-2xl shadow-[#9333ea]/10 ring-1 ring-off-black/5 transition-transform duration-300 group-hover:-translate-y-1">
                  <img
                    src={`${base}images/pridespotlight/1.jpg`}
                    alt="Teacher Spotlight: Luz Rodriguez, she/her/ella"
                    class="aspect-[4/5] w-full rounded-xl object-cover"
                    loading="lazy"
                  />
                </div>
                <div class="mt-0 sm:mt-6 overflow-hidden rounded-2xl bg-white p-1.5 shadow-2xl shadow-[#0ea5e9]/10 ring-1 ring-off-black/5 transition-transform duration-300 group-hover:-translate-y-1">
                  <img
                    src={`${base}images/pridespotlight/6.jpg`}
                    alt="Teacher Spotlight: lizlates, she/her"
                    class="aspect-[4/5] w-full rounded-xl object-cover"
                    loading="lazy"
                  />
                </div>
              </div>
            </a>
          </div>

          <div class="lg:col-span-3 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 rounded-full bg-off-black px-4 py-2 mb-5 shadow-lg shadow-off-black/10">
              <span class="text-base leading-none">🏳️‍🌈</span>
              <span class="lsp-pride-text-bright text-xs font-extrabold uppercase tracking-widest">
                June · Pride Month
              </span>
            </div>

            <h2 class="font-sans text-4xl font-extrabold tracking-tight text-off-black sm:text-5xl lg:text-6xl leading-tight">
              Celebrating <span class="lsp-pride-text-deep">Pride</span>
            </h2>

            <p class="mt-5 text-base text-off-black/70 leading-relaxed max-w-2xl mx-auto lg:mx-0">
              This month, we honor the LGBTQIA+ community and the generations who
              fought so that everyone could live and love freely. Let's close out
              Pride together, in our communities, with intention and joy.
            </p>

            <div class="mt-7 grid grid-cols-1 gap-3 sm:grid-cols-2 max-w-2xl mx-auto lg:mx-0">
              <div class="rounded-xl bg-white/80 border border-off-black/10 px-4 py-3 text-left">
                <p class="text-[10px] font-bold uppercase tracking-widest text-[#c81e2b]">Sat · Jun 27</p>
                <p class="mt-1 text-sm font-bold text-off-black">Proud to Run 5K & 10K</p>
                <p class="text-xs text-off-black/55">Montrose Harbor</p>
              </div>
              <div class="rounded-xl bg-white/80 border border-off-black/10 px-4 py-3 text-left">
                <p class="text-[10px] font-bold uppercase tracking-widest text-[#d6249f]">Sat · Jun 27</p>
                <p class="mt-1 text-sm font-bold text-off-black">Pride Pilates Party</p>
                <p class="text-xs text-off-black/55">Center on Halsted</p>
              </div>
              <div class="rounded-xl bg-white/80 border border-off-black/10 px-4 py-3 text-left">
                <p class="text-[10px] font-bold uppercase tracking-widest text-[#3b6fe0]">Sun · Jun 28</p>
                <p class="mt-1 text-sm font-bold text-off-black">Chicago Pride Parade</p>
                <p class="text-xs text-off-black/55">Northalsted</p>
              </div>
              <div class="rounded-xl bg-white/80 border border-off-black/10 px-4 py-3 text-left">
                <p class="text-[10px] font-bold uppercase tracking-widest text-[#7c3aed]">Sat & Sun</p>
                <p class="mt-1 text-sm font-bold text-off-black">Back Lot Bash</p>
                <p class="text-xs text-off-black/55">Uptown</p>
              </div>
            </div>

            <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:flex-wrap justify-center lg:justify-start">
              <a
                href={withBase("pride")}
                class="btn group inline-flex items-center gap-3 rounded-full bg-off-black px-8 py-4 text-base font-bold text-white shadow-lg shadow-off-black/25 transition-all duration-300 hover:scale-105 hover:bg-[#7c3aed] hover:shadow-xl"
              >
                Explore Pride at LSP
                <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
              <a
                href={`${withBase("schedule")}`}
                class="inline-flex items-center gap-2 rounded-full border border-off-black/15 bg-white px-6 py-4 text-sm font-bold text-off-black shadow-sm transition-all duration-300 hover:scale-[1.03] hover:border-off-black/30"
                data-conversion-event="class_booking_start"
                data-conversion-context="events_pride"
                data-conversion-booking-path="schedule_page"
              >
                Book a class
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: Celebrating Pride Featured Section */}

    {/* START: Monday Miles Featured Section (Dark) */}
    <section class="relative overflow-hidden bg-off-black py-16 md:py-20">
      {/* Subtle track lines background */}
      <div class="absolute inset-0 opacity-[0.04]">
        <div
          class="absolute inset-0"
          style="background-image: repeating-linear-gradient(0deg, transparent, transparent 60px, white 60px, white 61px);"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div
          class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12"
        >
          {/* Left: Image (2 cols) */}
          <div class="relative lg:col-span-2">
            <div
              class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-accent-gold/20 via-vibrant-pink/10 to-transparent blur-xl"
            >
            </div>
            <div
              class="relative overflow-hidden rounded-2xl border border-white/10"
            >
              <img
                src={`${base}images/monday-miles-runner.png`}
                alt="Monday Miles · community running group in Pilsen, Chicago"
                class="h-80 w-full object-cover sm:h-96 lg:h-[28rem]"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-off-black via-off-black/50 to-off-black/10"
              >
              </div>
              <div
                class="absolute bottom-4 left-4 right-4 flex flex-wrap gap-2"
              >
                <span
                  class="rounded-full bg-accent-gold px-3 py-1 text-xs font-bold uppercase tracking-wider text-off-black"
                  >Free</span
                >
                <span
                  class="rounded-full bg-vibrant-pink/80 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-white drop-shadow-sm"
                  >All Levels</span
                >
                <span
                  class="rounded-full bg-white/20 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-white drop-shadow-sm"
                  >Weekly</span
                >
              </div>
            </div>
          </div>

          {/* Right: Content (3 cols) */}
          <div class="lg:col-span-3 text-center lg:text-left">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-accent-gold/15 px-4 py-2 mb-5"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"
                ></span>
              </span>
              <span
                class="text-xs font-bold uppercase tracking-widest text-accent-gold"
                >Weekly Community Series</span
              >
            </div>

            <h2
              class="font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl"
            >
              Monday Miles
            </h2>
            <p class="mt-2 text-xl font-semibold text-accent-gold">
              Weekly Walk & Run Group
            </p>

            <p
              class="mt-5 text-lg text-white/70 leading-relaxed max-w-xl mx-auto lg:mx-0"
            >
              Mondays just got better. Meet in the cafe, warm up together, and
              head out. Walk 1 mile or jog/run 2. You set the pace. Because
              movement is medicine, and it's better in community.
            </p>

            {/* Details grid */}
            <div
              class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-xl mx-auto lg:mx-0"
            >
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3"
              >
                <svg
                  class="h-5 w-5 text-accent-gold flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">
                    When
                  </p>
                  <p class="text-sm font-bold text-white">Every Monday</p>
                </div>
              </div>
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3"
              >
                <svg
                  class="h-5 w-5 text-accent-gold flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">
                    Time
                  </p>
                  <p class="text-sm font-bold text-white">6:30 PM</p>
                </div>
              </div>
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3"
              >
                <svg
                  class="h-5 w-5 text-accent-gold flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">
                    Where
                  </p>
                  <p class="text-sm font-bold text-white">LSP Cafe</p>
                </div>
              </div>
            </div>

            {/* Route options */}
            <div
              class="mt-6 flex flex-wrap justify-center lg:justify-start gap-6"
            >
              <div class="flex items-center gap-2">
                <span
                  class="flex h-8 w-8 items-center justify-center rounded-full bg-vibrant-pink/20 text-vibrant-pink"
                >
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg
                  >
                </span>
                <span class="text-sm text-white/70"
                  >Walk <span class="font-bold text-vibrant-pink">1 mile</span
                  ></span
                >
              </div>
              <div class="flex items-center gap-2">
                <span
                  class="flex h-8 w-8 items-center justify-center rounded-full bg-accent-gold/20 text-accent-gold"
                >
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
                  >
                </span>
                <span class="text-sm text-white/70"
                  >Jog / Run <span class="font-bold text-accent-gold"
                    >2 miles</span
                  ></span
                >
              </div>
            </div>

            {/* CTA */}
            <div class="mt-8">
              <a
                href={`${base}schedule`}
                class="btn group inline-flex items-center gap-3 rounded-full bg-accent-gold px-8 py-4 text-base font-bold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/40"
              >
                Join for Free
                <svg
                  class="h-5 w-5 transition-transform group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: Monday Miles Featured Section */}

    {/* START: Dashboard-managed events (Supabase) */}
    <EventsList client:load excludeSlugs={featuredSlugs} />
    {/* END: Dashboard-managed events */}

    {/* START: Stay Connected Section */}
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-7xl px-4 text-center">
        <p class="text-lg text-medium-gray">
          More events coming soon! Follow us on
          <a
            href="https://www.instagram.com/latinasweatproject/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-vibrant-pink font-semibold hover:underline"
          >
            Instagram
          </a>
          for the latest updates.
        </p>
      </div>
    </section>
    {/* END: Stay Connected Section */}
  </main>
</Layout>
