---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import EventCard from "@/components/EventCard.astro";
import EventsList from "@/components/EventsList.svelte";
const base = import.meta.env.BASE_URL;
// Events already featured in the hand-designed sections below; the
// Supabase-driven list skips these so they don't appear twice.
const featuredSlugs = [
  "pride-in-the-park",
  "dia-del-nino-kids-day",
  "monday-miles",
];
const kidsDayRegistrationUrl = "https://www.zeffy.com/en-US/ticketing/lsp-dia-del-nino-kids-day";
const prideRegistrationUrl = "https://www.zeffy.com/en-US/ticketing/pride-in-the-park-2";
---

<Layout title="Events | The Latina Sweat Project">
  <Header />
  <main>
    {/* START: Page Header Section */}
    <section class="bg-light-gray py-16 md:py-24">
      <div class="mx-auto max-w-7xl px-4 text-center">
        <h1
          class="font-sans text-4xl font-extrabold tracking-tight text-off-black sm:text-5xl md:text-6xl"
        >
          Our Events
        </h1>
        <p class="mx-auto mt-4 max-w-2xl font-body text-lg text-medium-gray">
          Join our vibrant community. Sweat, dance, and connect at our upcoming
          events.
        </p>
      </div>
    </section>
    {/* END: Page Header Section */}

    {/* START: Pride in the Park Featured Section */}
    <section id="pride-in-the-park" class="relative overflow-hidden bg-[#4a1d6e] py-16 md:py-20 text-white scroll-mt-28">
      <div
        class="absolute inset-0 opacity-[0.16]"
        style="background-image: linear-gradient(90deg, rgba(255,255,255,0.28) 1px, transparent 1px), linear-gradient(rgba(255,255,255,0.18) 1px, transparent 1px); background-size: 72px 72px;"
      >
      </div>
      <div class="absolute -top-28 -left-20 h-72 w-72 rounded-full bg-pink-500/30 blur-[110px]"></div>
      <div class="absolute -bottom-28 -right-20 h-80 w-80 rounded-full bg-sky-500/30 blur-[120px]"></div>
      <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-red-500 via-amber-400 via-green-500 via-blue-500 to-purple-500"></div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12">
          <div class="relative lg:col-span-2">
            <div class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-white/30 via-pink-400/20 to-sky-500/20 blur-xl"></div>
            <div class="relative overflow-hidden rounded-2xl border border-white/20 bg-white p-3 shadow-2xl shadow-black/25">
              <img
                src={`${base}images/pride-in-the-park.png`}
                alt="Pride in the Park event flyer: free Pilates and dance fitness at 12th St Beach on June 14"
                class="w-full rounded-xl object-contain"
                loading="lazy"
              />
            </div>
          </div>

          <div class="lg:col-span-3 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-2 mb-5 shadow-lg shadow-black/10 ring-1 ring-white/20">
              <span class="relative flex h-2.5 w-2.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"></span>
                <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"></span>
              </span>
              <span class="text-xs font-bold uppercase tracking-widest text-accent-gold">
                June 14 · Free Event
              </span>
            </div>

            <p class="text-xs font-bold uppercase tracking-[0.3em] text-white/70 mb-2">
              Movement, joy, and visibility
            </p>

            <h2 class="font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl leading-tight">
              Pride in the Park
            </h2>
            <p class="mt-3 text-lg font-semibold text-accent-gold">
              Celebrate Pride Month with LSP at 12th St Beach
            </p>

            <p class="mt-5 text-base text-white/75 leading-relaxed max-w-2xl mx-auto lg:mx-0">
              Pride In The Park brings our Latina Sweat Cares community
              together for movement, joy, and visibility. Join us outdoors for
              a lizlates Pilates class and a Dance Fitness class, with
              connection and support that centers Latina wellness.
            </p>
            <p class="mt-4 text-base text-white/65 leading-relaxed max-w-2xl mx-auto lg:mx-0">
              Your registration helps us create a safe, welcoming space to
              move, care for mental health, and celebrate together. All are
              welcome. Sign up to save your spot and sweat with pride.
            </p>

            <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-3 max-w-2xl mx-auto lg:mx-0">
              <div class="rounded-xl bg-white/10 border border-white/15 px-4 py-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-accent-gold">When</p>
                <p class="mt-1 text-sm font-bold text-white">Sunday, June 14</p>
                <p class="text-xs text-white/55">1:00 to 3:00 PM</p>
              </div>
              <div class="rounded-xl bg-white/10 border border-white/15 px-4 py-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-accent-gold">Where</p>
                <p class="mt-1 text-sm font-bold text-white">12th St Beach</p>
                <p class="text-xs text-white/55">Near Museum Campus, Chicago</p>
              </div>
              <div class="rounded-xl bg-white/10 border border-white/15 px-4 py-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-accent-gold">Ticket</p>
                <p class="mt-1 text-sm font-bold text-white">Free</p>
                <p class="text-xs text-white/55">RSVP on Zeffy</p>
              </div>
            </div>

            <div class="mt-6 flex flex-wrap justify-center gap-2 lg:justify-start">
              {["lizlates Pilates", "Dance Fitness", "BYOM: bring your own mat", "All levels"].map((item) => (
                <span class="rounded-full bg-white/10 border border-white/15 px-3 py-1 text-xs font-bold text-white/80">
                  {item}
                </span>
              ))}
            </div>

            <div class="mt-8">
              <a
                href={prideRegistrationUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn group inline-flex items-center gap-3 rounded-full bg-accent-gold px-8 py-4 text-base font-bold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-105 hover:bg-white hover:shadow-xl"
                data-conversion-event="event_registration_start"
                data-conversion-context="events_pride_in_the_park"
                data-conversion-provider="zeffy"
                data-conversion-booking-path="pride_in_the_park_ticketing"
              >
                RSVP Free
                <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: Pride in the Park Featured Section */}

    {/* START: Kids Day at LSP Featured Section */}
    <section
      class="relative overflow-hidden bg-gradient-to-br from-[#fbf3ea] via-[#fff8ef] to-[#f4dfcf] py-16 md:py-20"
    >
      <div
        class="absolute inset-0 opacity-[0.22]"
        style="background-image: linear-gradient(rgba(255,255,255,0.75) 2px, transparent 2px), linear-gradient(90deg, rgba(255,255,255,0.75) 2px, transparent 2px); background-size: 58px 58px;"
      >
      </div>
      <div
        class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-[#ff7a59] via-accent-gold to-cyan-400"
      >
      </div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div
          class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12"
        >
          <div class="relative lg:col-span-3">
            <div
              class="relative overflow-hidden rounded-2xl border border-[#c7602d]/20 bg-white/70 shadow-xl shadow-[#c7602d]/10"
            >
              <img
                src={`${base}images/dia-del-nino-kids-day-en.png`}
                alt="Kids Day at LSP flyer with age-group class times and registration QR code"
                class="w-full h-auto object-contain"
                loading="lazy"
              />
            </div>
          </div>

          <div class="lg:col-span-2 text-center lg:text-left">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-[#c7602d] px-4 py-2 mb-5 shadow-lg shadow-[#c7602d]/20"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-white opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2.5 w-2.5 rounded-full bg-white"
                ></span>
              </span>
              <span class="text-xs font-bold uppercase tracking-widest text-white">
                Register · Free Kids Event
              </span>
            </div>

            <p
              class="text-xs font-bold uppercase tracking-[0.3em] text-[#c7602d] mb-2"
            >
              Día del Niño en LSP
            </p>

            <h2
              class="font-sans text-4xl font-extrabold tracking-tight text-off-black sm:text-5xl lg:text-6xl leading-tight"
            >
              Kids Day at LSP
            </h2>
            <p class="mt-3 text-base font-semibold text-off-black/70">
              Movement, play, and wellness for kids and teens
            </p>

            <p
              class="mt-5 text-base text-off-black/70 leading-relaxed max-w-xl mx-auto lg:mx-0"
            >
              Celebrate Kids Day with four free yoga classes grouped by age.
              Every registered child gets a movement-centered class experience
              and a goody bag.
            </p>

            <div
              class="mt-7 grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-xl mx-auto lg:mx-0"
            >
              <div
                class="flex items-center gap-3 rounded-xl bg-white/80 border border-[#c7602d]/20 px-4 py-3"
              >
                <svg
                  class="h-5 w-5 text-[#c7602d] flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <p
                    class="text-[10px] text-off-black/50 uppercase tracking-wider font-bold"
                  >
                    When
                  </p>
                  <p class="text-sm font-bold text-off-black">Sun, June 14</p>
                </div>
              </div>
              <div
                class="flex items-center gap-3 rounded-xl bg-white/80 border border-[#c7602d]/20 px-4 py-3"
              >
                <svg
                  class="h-5 w-5 text-[#c7602d] flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p
                    class="text-[10px] text-off-black/50 uppercase tracking-wider font-bold"
                  >
                    Time
                  </p>
                  <p class="text-sm font-bold text-off-black">1:00 to 4:15 PM</p>
                </div>
              </div>
              <div
                class="flex items-center gap-3 rounded-xl bg-white/80 border border-[#c7602d]/20 px-4 py-3 sm:col-span-2"
              >
                <svg
                  class="h-5 w-5 text-[#c7602d] flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p
                    class="text-[10px] text-off-black/50 uppercase tracking-wider font-bold"
                  >
                    Where
                  </p>
                  <p class="text-sm font-bold text-off-black">
                    LSP Studio · 949 W. 16th St, Chicago
                  </p>
                </div>
              </div>
            </div>

            <div class="mt-7 rounded-2xl bg-white/80 border border-[#c7602d]/20 p-5 text-left">
              <p
                class="text-[11px] font-bold uppercase tracking-[0.25em] text-[#c7602d] mb-3"
              >
                Age Group Schedule
              </p>
              <div class="space-y-2.5 text-sm text-off-black/75">
                <div class="flex items-center justify-between gap-4">
                  <span class="font-bold text-off-black">3-5 years old</span>
                  <span class="font-semibold tabular-nums">1:00-1:30 PM</span>
                </div>
                <div class="h-px bg-[#c7602d]/10"></div>
                <div class="flex items-center justify-between gap-4">
                  <span class="font-bold text-off-black">6-9 years old</span>
                  <span class="font-semibold tabular-nums">1:50-2:20 PM</span>
                </div>
                <div class="h-px bg-[#c7602d]/10"></div>
                <div class="flex items-center justify-between gap-4">
                  <span class="font-bold text-off-black">10-13 years old</span>
                  <span class="font-semibold tabular-nums">2:40-3:10 PM</span>
                </div>
                <div class="h-px bg-[#c7602d]/10"></div>
                <div class="flex items-center justify-between gap-4">
                  <span class="font-bold text-off-black">14-18 years old</span>
                  <span class="font-semibold tabular-nums">3:30-4:15 PM</span>
                </div>
              </div>
            </div>

            <div class="mt-8">
              <a
                href={kidsDayRegistrationUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn group inline-flex items-center gap-3 rounded-full bg-[#c7602d] px-8 py-4 text-base font-bold text-white shadow-lg shadow-[#c7602d]/25 transition-all duration-300 hover:scale-105 hover:bg-accent-gold hover:text-off-black hover:shadow-xl hover:shadow-accent-gold/30"
              >
                Register on Zeffy
                <svg
                  class="h-5 w-5 transition-transform group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: Kids Day at LSP Featured Section */}

    {/* START: Monday Miles Featured Section (Dark) */}
    <section class="relative overflow-hidden bg-off-black py-16 md:py-20">
      {/* Subtle track lines background */}
      <div class="absolute inset-0 opacity-[0.04]">
        <div
          class="absolute inset-0"
          style="background-image: repeating-linear-gradient(0deg, transparent, transparent 60px, white 60px, white 61px);"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4">
        <div
          class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-12"
        >
          {/* Left: Image (2 cols) */}
          <div class="relative lg:col-span-2">
            <div
              class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-accent-gold/20 via-vibrant-pink/10 to-transparent blur-xl"
            >
            </div>
            <div
              class="relative overflow-hidden rounded-2xl border border-white/10"
            >
              <img
                src={`${base}images/monday-miles-runner.png`}
                alt="Monday Miles · community running group in Pilsen, Chicago"
                class="h-80 w-full object-cover sm:h-96 lg:h-[28rem]"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-off-black via-off-black/50 to-off-black/10"
              >
              </div>
              <div
                class="absolute bottom-4 left-4 right-4 flex flex-wrap gap-2"
              >
                <span
                  class="rounded-full bg-accent-gold px-3 py-1 text-xs font-bold uppercase tracking-wider text-off-black"
                  >Free</span
                >
                <span
                  class="rounded-full bg-vibrant-pink/80 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-white drop-shadow-sm"
                  >All Levels</span
                >
                <span
                  class="rounded-full bg-white/20 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-white drop-shadow-sm"
                  >Weekly</span
                >
              </div>
            </div>
          </div>

          {/* Right: Content (3 cols) */}
          <div class="lg:col-span-3 text-center lg:text-left">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-accent-gold/15 px-4 py-2 mb-5"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"
                ></span>
              </span>
              <span
                class="text-xs font-bold uppercase tracking-widest text-accent-gold"
                >Weekly Community Series</span
              >
            </div>

            <h2
              class="font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl"
            >
              Monday Miles
            </h2>
            <p class="mt-2 text-xl font-semibold text-accent-gold">
              Weekly Walk & Run Group
            </p>

            <p
              class="mt-5 text-lg text-white/70 leading-relaxed max-w-xl mx-auto lg:mx-0"
            >
              Mondays just got better. Meet in the cafe, warm up together, and
              head out. Walk 1 mile or jog/run 2. You set the pace. Because
              movement is medicine, and it's better in community.
            </p>

            {/* Details grid */}
            <div
              class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-xl mx-auto lg:mx-0"
            >
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3"
              >
                <svg
                  class="h-5 w-5 text-accent-gold flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">
                    When
                  </p>
                  <p class="text-sm font-bold text-white">Every Monday</p>
                </div>
              </div>
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3"
              >
                <svg
                  class="h-5 w-5 text-accent-gold flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">
                    Time
                  </p>
                  <p class="text-sm font-bold text-white">6:30 PM</p>
                </div>
              </div>
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-4 py-3"
              >
                <svg
                  class="h-5 w-5 text-accent-gold flex-shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider">
                    Where
                  </p>
                  <p class="text-sm font-bold text-white">LSP Cafe</p>
                </div>
              </div>
            </div>

            {/* Route options */}
            <div
              class="mt-6 flex flex-wrap justify-center lg:justify-start gap-6"
            >
              <div class="flex items-center gap-2">
                <span
                  class="flex h-8 w-8 items-center justify-center rounded-full bg-vibrant-pink/20 text-vibrant-pink"
                >
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg
                  >
                </span>
                <span class="text-sm text-white/70"
                  >Walk <span class="font-bold text-vibrant-pink">1 mile</span
                  ></span
                >
              </div>
              <div class="flex items-center gap-2">
                <span
                  class="flex h-8 w-8 items-center justify-center rounded-full bg-accent-gold/20 text-accent-gold"
                >
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
                  >
                </span>
                <span class="text-sm text-white/70"
                  >Jog / Run <span class="font-bold text-accent-gold"
                    >2 miles</span
                  ></span
                >
              </div>
            </div>

            {/* CTA */}
            <div class="mt-8">
              <a
                href={`${base}schedule`}
                class="btn group inline-flex items-center gap-3 rounded-full bg-accent-gold px-8 py-4 text-base font-bold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/40"
              >
                Join for Free
                <svg
                  class="h-5 w-5 transition-transform group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
