        transition: all 0.3s ease;
      }
      .free-card:hover {
        background: rgba(255, 189, 89, 0.15);
        border-color: rgba(255, 189, 89, 0.6);
        transform: scale(1.05);
      }
      .free-card--emerald {
        border-color: rgba(52, 211, 153, 0.3);
      }
      .free-card--emerald:hover {
        background: rgba(16, 185, 129, 0.15);
        border-color: rgba(52, 211, 153, 0.6);
      }
      .free-card--sm {
        padding: 0.875rem 0.625rem;
      }
      .free-card--lg {
        padding: 0.875rem 0.75rem;
      }
      .free-card--lg .free-card__day {
        font-size: 10px;
      }
      .free-card--lg .free-card__date {
        font-size: 2rem;
      }
      .free-card--lg .free-card__month {
        font-size: 10px;
      }
      .free-card--holiday {
        background: rgba(255, 189, 89, 0.15);
        border-color: rgba(255, 189, 89, 0.6);
      }
      .free-card__day {
        font-size: 9px;
        font-weight: 700;
        line-height: 1;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(255, 189, 89, 0.85);
      }
      .free-card--emerald .free-card__day {
        color: rgba(110, 231, 183, 0.85);
      }
      .free-card__date {
        font-size: 1.5rem;
        line-height: 1.1;
        font-weight: 800;
        color: #fff;
        margin-top: 2px;
      }
      .free-card--sm .free-card__date {
        font-size: 1.5rem;
      }
      .free-card__month {
        font-size: 9px;
        line-height: 1;
        color: rgba(255, 255, 255, 0.5);
      }
      .free-card__badge {
        position: absolute;
        top: -6px;
        left: 50%;
        transform: translateX(-50%);
        background: #b5a18d;
        color: #fff;
        font-size: 7px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 2px 6px;
        border-radius: 9999px;
        white-space: nowrap;
      }

      /* Next-up highlight */
      .free-card[data-free-next="true"] {
        background: linear-gradient(135deg, rgba(255, 189, 89, 0.35), rgba(255, 189, 89, 0.18));
        border-color: #ffbd59;
        transform: none;
        box-shadow: 0 8px 24px -6px rgba(255, 189, 89, 0.5);
        animation: free-card-pulse-gold 2.2s ease-in-out infinite;
      }
      .free-card--emerald[data-free-next="true"] {
        background: linear-gradient(135deg, rgba(52, 211, 153, 0.35), rgba(52, 211, 153, 0.18));
        border-color: #34d399;
        box-shadow: 0 8px 24px -6px rgba(52, 211, 153, 0.5);
        animation: free-card-pulse-emerald 2.2s ease-in-out infinite;
      }
      .free-card[data-free-next="true"]::before {
        content: '↓ NEXT FREE DAY';
        position: absolute;
        top: -10px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 8px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 3px 8px;
        border-radius: 9999px;
        background: #ffbd59;
        color: #1e1e1e;
        white-space: nowrap;
        box-shadow: 0 4px 10px rgba(255, 189, 89, 0.4);
        z-index: 2;
      }
      .free-card--emerald[data-free-next="true"]::before {
        background: #34d399;
        color: #064e3b;
        box-shadow: 0 4px 10px rgba(52, 211, 153, 0.4);
      }
      .free-card--holiday[data-free-next="true"] .free-card__badge {
        display: none;
      }
      @keyframes free-card-pulse-gold {
        0%, 100% { box-shadow: 0 8px 24px -6px rgba(255, 189, 89, 0.5), 0 0 0 0 rgba(255, 189, 89, 0.5); }
        50% { box-shadow: 0 8px 24px -6px rgba(255, 189, 89, 0.5), 0 0 0 10px rgba(255, 189, 89, 0); }
      }
      @keyframes free-card-pulse-emerald {
        0%, 100% { box-shadow: 0 8px 24px -6px rgba(52, 211, 153, 0.5), 0 0 0 0 rgba(52, 211, 153, 0.5); }
        50% { box-shadow: 0 8px 24px -6px rgba(52, 211, 153, 0.5), 0 0 0 10px rgba(52, 211, 153, 0); }
      }
    </style>

    <script>
      (function () {
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const todayStr =
          today.getFullYear() +
          '-' +
          String(today.getMonth() + 1).padStart(2, '0') +
          '-' +
          String(today.getDate()).padStart(2, '0');

        const groups = new Map<string, HTMLElement[]>();
        document.querySelectorAll<HTMLElement>('[data-free-date][data-free-loc]').forEach((el) => {
          const loc = el.dataset.freeLoc || 'default';
          if (!groups.has(loc)) groups.set(loc, []);
          groups.get(loc)!.push(el);
        });

        groups.forEach((pills) => {
          pills.sort((a, b) => (a.dataset.freeDate || '').localeCompare(b.dataset.freeDate || ''));
          const next = pills.find((p) => (p.dataset.freeDate || '') >= todayStr);
          if (next) next.dataset.freeNext = 'true';
        });
      })();
    </script>
  </main></Layout
>
