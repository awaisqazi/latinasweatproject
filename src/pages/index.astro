                class="absolute -top-6 left-0 lg:-top-24 lg:left-8 w-16 h-16 lg:w-32 lg:h-32 text-purple-200/25 rotate-12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                stroke-linecap="round"
                stroke-linejoin="round"
