---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import TestimonialCard from "@/components/TestimonialCard.astro";
import { pressArticles } from "@/data/press";
const base = import.meta.env.BASE_URL;
---

<Layout title="The Latina Sweat Project | Home">
  <Header />
  <main>
    {/* START: Hero Section */}
    <section class="relative h-[60vh] min-h-[480px] w-full sm:h-screen">
      <div class="absolute inset-0 bg-black/50"></div>

      <video
        autoplay
        loop
        muted
        playsinline
        class="hidden h-full w-full object-cover sm:block"
      >
        <source src={`${base}videos/heroclip.mp4`} type="video/mp4" />
      </video>

      <div
        class="sm:hidden h-full w-full bg-cover bg-center"
        style='background-image: url("https://images.pexels.com/photos/4753997/pexels-photo-4753997.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2");'
      >
      </div>

      <div
        class="absolute inset-0 flex flex-col items-center justify-center p-4 text-center text-white"
      >
        <h1
          class="font-sans text-4xl font-extrabold tracking-tighter sm:text-5xl md:text-6xl lg:text-7xl"
        >
          Empowering Through Movement
        </h1>
        <p class="mt-4 max-w-2xl font-body text-lg sm:text-xl">
          Join our vibrant community in Chicago and experience fitness that
          celebrates our culture.
        </p>
        <a
          href={`${base}schedule`}
          class="btn mt-8 rounded-full bg-vibrant-pink px-8 py-3 text-base font-bold text-white shadow-lg transition hover:scale-105 hover:bg-accent-gold focus:outline-none focus:ring-2 focus:ring-vibrant-pink focus:ring-offset-2 focus:ring-offset-slate-900"
        >
          Join a Class
        </a>
      </div>
    </section>
    {/* END: Hero Section */}

    {/* START: Free Day Promo */}
    <section class="relative overflow-hidden bg-gradient-to-br from-off-black via-[#1a1a2e] to-off-black py-12 sm:py-16">
      {/* Decorative ambient glows */}
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-20 left-[10%] w-[420px] h-[420px] bg-accent-gold/20 rounded-full blur-[120px]"></div>
        <div class="absolute -bottom-24 right-[10%] w-[380px] h-[380px] bg-emerald-500/15 rounded-full blur-[110px]"></div>
        <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[300px] h-[300px] bg-vibrant-pink/10 rounded-full blur-[100px]"></div>
      </div>
      {/* Subtle grid texture */}
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"></div>

      <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          {/* Pulsing badge */}
          <div class="inline-flex items-center gap-2 rounded-full bg-accent-gold/15 border border-accent-gold/40 px-4 py-2 mb-4 backdrop-blur-sm">
            <span class="relative flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"></span>
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"></span>
            </span>
            <span class="text-sm font-bold uppercase tracking-widest text-accent-gold">Free · May & June 2026</span>
          </div>

          <h2 class="font-sans text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-white">
            Free Classes, <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-gold via-amber-300 to-emerald-400">Two Locations</span>&nbsp;🎉
          </h2>
          <p class="mt-3 text-light-gray/70 text-base sm:text-lg font-medium">Clases gratis · No membership needed · Two locations, two ways to register</p>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {/* PILSEN CARD */}
          <div class="group relative rounded-3xl bg-white/[0.04] backdrop-blur-xl border border-accent-gold/30 shadow-2xl shadow-accent-gold/5 p-6 sm:p-7 transition-all duration-300 hover:bg-white/[0.07] hover:border-accent-gold/60 hover:shadow-accent-gold/20 flex flex-col">
            {/* Gradient accent edge */}
            <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-gold/60 to-transparent"></div>

            <div class="flex items-center gap-3 mb-4">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent-gold text-off-black font-extrabold text-2xl shadow-lg shadow-accent-gold/30">X</span>
              <div>
                <p class="text-[11px] font-bold uppercase tracking-widest text-accent-gold">Location 1</p>
                <h3 class="font-sans text-2xl font-extrabold tracking-tight text-white leading-tight">Pilsen</h3>
              </div>
              <div class="ml-auto text-right">
                <p class="text-3xl font-extrabold text-accent-gold leading-none">8</p>
                <p class="text-[10px] font-bold uppercase tracking-wider text-light-gray/60 leading-none mt-1">Free Days</p>
              </div>
            </div>
            <p class="text-sm text-light-gray/70 font-medium">
              LSP Studio &middot; <span class="font-semibold text-white">949 W 16th St</span>, Chicago, IL 60608
            </p>

            {/* Day rotation insight */}
            <div class="mt-4 rounded-xl bg-accent-gold/10 border border-accent-gold/20 px-3 py-2.5">
              <p class="text-[11px] font-bold uppercase tracking-widest text-accent-gold mb-1.5">Rotates Through Every Day</p>
              <div class="flex items-center justify-between gap-1">
                <span class="flex-1 rounded-md bg-accent-gold/20 text-center text-[10px] font-bold text-accent-gold py-1">FRI</span>
                <span class="flex-1 rounded-md bg-accent-gold/20 text-center text-[10px] font-bold text-accent-gold py-1">SAT</span>
                <span class="flex-1 rounded-md bg-accent-gold/20 text-center text-[10px] font-bold text-accent-gold py-1">SUN</span>
                <span class="flex-1 rounded-md bg-accent-gold/20 text-center text-[10px] font-bold text-accent-gold py-1">MON</span>
                <span class="flex-1 rounded-md bg-accent-gold/20 text-center text-[10px] font-bold text-accent-gold py-1">TUE</span>
                <span class="flex-1 rounded-md bg-accent-gold/20 text-center text-[10px] font-bold text-accent-gold py-1">WED</span>
                <span class="flex-1 rounded-md bg-accent-gold/20 text-center text-[10px] font-bold text-accent-gold py-1">THU</span>
              </div>
            </div>

            {/* May dates - large grid */}
            <div class="mt-5">
              <p class="text-[11px] font-bold uppercase tracking-wider text-light-gray/60 mb-2.5">May 2026</p>
              <div class="grid grid-cols-2 gap-3.5">
                <div class="free-card free-card--gold free-card--lg" data-free-date="2026-05-01" data-free-loc="pilsen">
                  <p class="free-card__day">Fri</p>
                  <p class="free-card__date">1</p>
                  <p class="free-card__month">May</p>
                </div>
                <div class="free-card free-card--gold free-card--lg" data-free-date="2026-05-09" data-free-loc="pilsen">
                  <p class="free-card__day">Sat</p>
                  <p class="free-card__date">9</p>
                  <p class="free-card__month">May</p>
                </div>
                <div class="free-card free-card--gold free-card--lg" data-free-date="2026-05-17" data-free-loc="pilsen">
                  <p class="free-card__day">Sun</p>
                  <p class="free-card__date">17</p>
                  <p class="free-card__month">May</p>
                </div>
                <div class="free-card free-card--gold free-card--lg free-card--holiday" data-free-date="2026-05-25" data-free-loc="pilsen">
                  <span class="free-card__badge">Holiday</span>
                  <p class="free-card__day">Mon</p>
                  <p class="free-card__date">25</p>
                  <p class="free-card__month">May</p>
                </div>
              </div>
            </div>

            {/* June dates */}
            <div class="mt-4">
              <p class="text-[11px] font-bold uppercase tracking-wider text-light-gray/60 mb-2.5">June 2026</p>
              <div class="grid grid-cols-2 gap-3.5">
                <div class="free-card free-card--gold free-card--lg" data-free-date="2026-06-02" data-free-loc="pilsen">
                  <p class="free-card__day">Tue</p>
                  <p class="free-card__date">2</p>
                  <p class="free-card__month">Jun</p>
                </div>
                <div class="free-card free-card--gold free-card--lg" data-free-date="2026-06-10" data-free-loc="pilsen">
                  <p class="free-card__day">Wed</p>
                  <p class="free-card__date">10</p>
                  <p class="free-card__month">Jun</p>
                </div>
                <div class="free-card free-card--gold free-card--lg" data-free-date="2026-06-18" data-free-loc="pilsen">
                  <p class="free-card__day">Thu</p>
                  <p class="free-card__date">18</p>
                  <p class="free-card__month">Jun</p>
                </div>
                <div class="free-card free-card--gold free-card--lg" data-free-date="2026-06-26" data-free-loc="pilsen">
                  <p class="free-card__day">Fri</p>
                  <p class="free-card__date">26</p>
                  <p class="free-card__month">Jun</p>
                </div>
              </div>
            </div>

            {/* Pilsen registration */}
            <div class="mt-auto pt-5 border-t border-accent-gold/15">
              <p class="text-[10px] font-bold uppercase tracking-widest text-accent-gold mb-2.5">Reserve your spot</p>
              <div class="flex flex-col sm:flex-row gap-2">
                <a
                  href={`${base}schedule`}
                  class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-xl bg-accent-gold px-4 py-2.5 text-xs font-bold text-off-black shadow-md shadow-accent-gold/20 transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:shadow-accent-gold/40"
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  Schedule
                </a>
                <a
                  href="https://apps.apple.com/us/app/lsp-studio/id6755971141"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-xl bg-white/[0.06] border border-white/15 px-4 py-2.5 text-xs font-bold text-white transition-all duration-300 hover:bg-white/[0.12] hover:border-white/30"
                >
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path></svg>
                  iOS
                </a>
                <a
                  href="https://play.google.com/store/apps/details?id=com.marianatek.latinasweatproject&hl=en_US"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-xl bg-white/[0.06] border border-white/15 px-4 py-2.5 text-xs font-bold text-white transition-all duration-300 hover:bg-white/[0.12] hover:border-white/30"
                >
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"></path></svg>
                  Android
                </a>
              </div>
              <p class="mt-2.5 text-[10px] text-light-gray/55 font-medium text-center">Book up to <span class="text-accent-gold font-bold">7 days ahead</span> in the LSP Studio app or schedule page</p>
            </div>
          </div>

          {/* BACK OF THE YARDS CARD */}
          <div class="group relative rounded-3xl bg-white/[0.04] backdrop-blur-xl border border-emerald-400/30 shadow-2xl shadow-emerald-500/5 p-6 sm:p-7 transition-all duration-300 hover:bg-white/[0.07] hover:border-emerald-400/60 hover:shadow-emerald-500/20 flex flex-col">
            {/* Gradient accent edge */}
            <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-400/60 to-transparent"></div>

            <div class="flex items-center gap-3 mb-4">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500 text-white font-extrabold text-2xl shadow-lg shadow-emerald-500/30">X</span>
              <div>
                <p class="text-[11px] font-bold uppercase tracking-widest text-emerald-300">Location 2</p>
                <h3 class="font-sans text-2xl font-extrabold tracking-tight text-white leading-tight">Back of the Yards</h3>
              </div>
              <div class="ml-auto text-right">
                <p class="text-3xl font-extrabold text-emerald-400 leading-none">16</p>
                <p class="text-[10px] font-bold uppercase tracking-wider text-light-gray/60 leading-none mt-1">Free Days</p>
              </div>
            </div>
            <p class="text-sm text-light-gray/70 font-medium">
              Southside Social &middot; <span class="font-semibold text-white">4432 S Ashland Ave</span>, Chicago, IL 60609
            </p>

            <div class="mt-4 rounded-xl bg-emerald-500/10 border border-emerald-400/20 px-3 py-2.5 text-center">
              <p class="text-[11px] font-bold uppercase tracking-widest text-emerald-300">Every Saturday &amp; Sunday</p>
              <p class="text-sm font-semibold text-white/80 mt-0.5">All May &amp; June 2026</p>
            </div>

            {/* Weekly lineup */}
            <div class="mt-4 rounded-xl bg-emerald-500/[0.07] border border-emerald-400/20 p-3.5">
              <p class="text-[11px] font-bold uppercase tracking-widest text-emerald-300 mb-2.5">Weekly Lineup</p>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <p class="text-[10px] font-extrabold uppercase tracking-wider text-emerald-300/80 mb-1.5">Saturday</p>
                  <div class="space-y-1.5">
                    <div>
                      <p class="text-xs font-bold text-white tabular-nums leading-tight">8:00 AM</p>
                      <p class="text-[11px] text-white/65 font-medium leading-tight">Andrea Fuentes</p>
                    </div>
                    <div>
                      <p class="text-xs font-bold text-white tabular-nums leading-tight">9:15 AM</p>
                      <p class="text-[11px] text-white/65 font-medium leading-tight">Melissa Salinas</p>
                    </div>
                  </div>
                </div>
                <div>
                  <p class="text-[10px] font-extrabold uppercase tracking-wider text-emerald-300/80 mb-1.5">Sunday</p>
                  <div class="space-y-1.5">
                    <div>
                      <p class="text-xs font-bold text-white tabular-nums leading-tight">9:15 AM</p>
                      <p class="text-[11px] text-white/65 font-medium leading-tight">Lizsandra Heredia</p>
                    </div>
                    <div>
                      <p class="text-xs font-bold text-white tabular-nums leading-tight">10:30 AM</p>
                      <p class="text-[11px] text-white/65 font-medium leading-tight">Arturo Zurita</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-5">
              <p class="text-[11px] font-bold uppercase tracking-wider text-light-gray/60 mb-2.5 text-center">May 2026</p>
              <div class="grid grid-cols-4 gap-2.5">
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-05-09" data-free-loc="boty">
                  <p class="free-card__day">Sat</p>
                  <p class="free-card__date">9</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-05-10" data-free-loc="boty">
                  <p class="free-card__day">Sun</p>
                  <p class="free-card__date">10</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-05-16" data-free-loc="boty">
                  <p class="free-card__day">Sat</p>
                  <p class="free-card__date">16</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-05-17" data-free-loc="boty">
                  <p class="free-card__day">Sun</p>
                  <p class="free-card__date">17</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-05-23" data-free-loc="boty">
                  <p class="free-card__day">Sat</p>
                  <p class="free-card__date">23</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-05-24" data-free-loc="boty">
                  <p class="free-card__day">Sun</p>
                  <p class="free-card__date">24</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-05-30" data-free-loc="boty">
                  <p class="free-card__day">Sat</p>
                  <p class="free-card__date">30</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-05-31" data-free-loc="boty">
                  <p class="free-card__day">Sun</p>
                  <p class="free-card__date">31</p>
                </div>
              </div>
            </div>

            <div class="mt-4">
              <p class="text-[11px] font-bold uppercase tracking-wider text-light-gray/60 mb-2.5 text-center">June 2026</p>
              <div class="grid grid-cols-4 gap-2.5">
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-06-06" data-free-loc="boty">
                  <p class="free-card__day">Sat</p>
                  <p class="free-card__date">6</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-06-07" data-free-loc="boty">
                  <p class="free-card__day">Sun</p>
                  <p class="free-card__date">7</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-06-13" data-free-loc="boty">
                  <p class="free-card__day">Sat</p>
                  <p class="free-card__date">13</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-06-14" data-free-loc="boty">
                  <p class="free-card__day">Sun</p>
                  <p class="free-card__date">14</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-06-20" data-free-loc="boty">
                  <p class="free-card__day">Sat</p>
                  <p class="free-card__date">20</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-06-21" data-free-loc="boty">
                  <p class="free-card__day">Sun</p>
                  <p class="free-card__date">21</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-06-27" data-free-loc="boty">
                  <p class="free-card__day">Sat</p>
                  <p class="free-card__date">27</p>
                </div>
                <div class="free-card free-card--emerald free-card--sm" data-free-date="2026-06-28" data-free-loc="boty">
                  <p class="free-card__day">Sun</p>
                  <p class="free-card__date">28</p>
                </div>
              </div>
            </div>

            {/* Southside Social registration */}
            <div class="mt-auto pt-5 border-t border-emerald-400/15">
              <p class="text-[10px] font-bold uppercase tracking-widest text-emerald-300 mb-2.5">Reserve your spot</p>
              <a
                href="https://www.zeffy.com/en-US/ticketing/latina-sweat-project-southside-social-free-classes"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center justify-center gap-2 rounded-xl bg-emerald-500 hover:bg-emerald-400 px-5 py-3.5 text-sm font-bold text-white shadow-lg shadow-emerald-500/30 transition-all duration-300 hover:scale-[1.02] hover:shadow-xl hover:shadow-emerald-500/50"
              >
                Register on Zeffy
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              </a>
              <p class="mt-2.5 text-[10px] text-light-gray/55 font-medium text-center">Southside Social classes are <span class="text-emerald-300 font-bold">not in the LSP app or schedule page</span></p>
            </div>
          </div>
        </div>

        {/* Side-by-side path summary */}
        <div class="mt-8 rounded-2xl bg-white/[0.04] backdrop-blur-xl border border-white/10 px-5 py-4 sm:px-6 sm:py-5 text-center shadow-2xl">
          <p class="text-[11px] font-bold uppercase tracking-widest text-light-gray/55 mb-2">Two locations, two ways to register</p>
          <p class="text-sm text-white/85 font-medium leading-relaxed">
            <span class="text-accent-gold font-bold">Pilsen</span> → LSP Studio app or schedule page &nbsp;·&nbsp; <span class="text-emerald-300 font-bold">Southside Social</span> → Zeffy
          </p>
          <p class="mt-2 text-[12px] text-light-gray/55 font-medium">All ages 12+ welcome. No membership required at either location.</p>
        </div>
      </div>
    </section>
    {/* END: Free Day Promo */}

