    <script>
      // Wiggle + swipe hint + pagination dots for events carousel
      (function initEventsCarousel() {
        const carousel = document.getElementById('events-carousel');
        const hint = document.getElementById('events-swipe-hint');
        const dotsContainer = document.getElementById('events-dots');
        if (!carousel) return;

        const cards = Array.from(carousel.children);
        const isScrollable = () => carousel.scrollWidth > carousel.clientWidth + 4;

        const DOT_INACTIVE = 'events-dot h-2 w-2 rounded-full bg-off-black/20 transition-all duration-300 hover:bg-vibrant-pink/60 focus:outline-none focus:ring-2 focus:ring-vibrant-pink/40 focus:ring-offset-2 focus:ring-offset-light-gray';
        const DOT_ACTIVE = 'events-dot h-2 w-8 rounded-full bg-vibrant-pink transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-vibrant-pink/40 focus:ring-offset-2 focus:ring-offset-light-gray';

        const dots = [];

        const cardOffset = (card) =>
          card.getBoundingClientRect().left -
          carousel.getBoundingClientRect().left +
          carousel.scrollLeft;

        const updateActiveDot = () => {
          if (!dots.length) return;
          const scrollLeft = carousel.scrollLeft;
          let closestIndex = 0;
          let closestDist = Infinity;
          cards.forEach((card, i) => {
            const dist = Math.abs(scrollLeft - cardOffset(card));
            if (dist < closestDist) {
              closestDist = dist;
              closestIndex = i;
            }
          });
          dots.forEach((dot, i) => {
            dot.className = i === closestIndex ? DOT_ACTIVE : DOT_INACTIVE;
            dot.setAttribute('aria-selected', i === closestIndex ? 'true' : 'false');
          });
        };

        // Build dots
        if (dotsContainer && cards.length > 1) {
          cards.forEach((card, i) => {
            const dot = document.createElement('button');
            dot.type = 'button';
            dot.className = DOT_INACTIVE;
            dot.setAttribute('role', 'tab');
            dot.setAttribute('aria-label', `Go to event ${i + 1}`);
            dot.addEventListener('click', () => {
              carousel.scrollTo({ left: cardOffset(card), behavior: 'smooth' });
            });
            dotsContainer.appendChild(dot);
            dots.push(dot);
          });
          updateActiveDot();
        }

        // Wiggle hint on first view
        if (isScrollable()) {
          let hinted = false;
          const triggerHint = () => {
            if (hinted) return;
            hinted = true;
            if (hint) {
              hint.style.opacity = '1';
              hint.style.transition = 'opacity 0.4s ease';
            }
            setTimeout(() => {
              carousel.scrollTo({ left: 90, behavior: 'smooth' });
              setTimeout(() => {
                carousel.scrollTo({ left: 0, behavior: 'smooth' });
              }, 700);
            }, 350);
            setTimeout(() => {
              if (hint) hint.style.opacity = '0';
            }, 4500);
          };

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  triggerHint();
                  observer.disconnect();
                }
              });
            },
            { threshold: 0.25 }
          );
          observer.observe(carousel);
        }

        carousel.addEventListener(
          'scroll',
          () => {
            if (carousel.scrollLeft > 30 && hint) {
              hint.style.opacity = '0';
            }
            updateActiveDot();
          },
          { passive: true }
        );

        window.addEventListener('resize', updateActiveDot, { passive: true });
      })();
    </script>

