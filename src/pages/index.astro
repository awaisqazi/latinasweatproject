---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import TestimonialCard from "@/components/TestimonialCard.astro";
import { pressArticles } from "@/data/press";
const base = import.meta.env.BASE_URL;
const kidsDayRegistrationUrl = "https://www.zeffy.com/en-US/ticketing/lsp-dia-del-nino-kids-day";
const prideRegistrationUrl = "https://www.zeffy.com/en-US/ticketing/pride-in-the-park-2";
---

<Layout title="The Latina Sweat Project | Home">
  <Header />
  <main>
    {/* START: Hero Section */}
    <section class="relative h-[60vh] min-h-[480px] w-full sm:h-screen">
      <div class="absolute inset-0 bg-black/50"></div>

      <video
        autoplay
        loop
        muted
        playsinline
        class="hidden h-full w-full object-cover sm:block"
      >
        <source src={`${base}videos/heroclip.mp4`} type="video/mp4" />
      </video>

      <div
        class="sm:hidden h-full w-full bg-cover bg-center"
        style='background-image: url("https://images.pexels.com/photos/4753997/pexels-photo-4753997.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2");'
      >
      </div>

      <div
        class="absolute inset-0 flex flex-col items-center justify-center p-4 text-center text-white"
      >
        <h1
          class="font-sans text-4xl font-extrabold tracking-tighter sm:text-5xl md:text-6xl lg:text-7xl"
        >
          Empowering Through Movement
        </h1>
        <p class="mt-4 max-w-2xl font-body text-lg sm:text-xl">
          Join our vibrant community in Chicago and experience fitness that
          celebrates our culture.
        </p>
        <a
          href={`${base}schedule`}
          class="btn mt-8 rounded-full bg-vibrant-pink px-8 py-3 text-base font-bold text-white shadow-lg transition hover:scale-105 hover:bg-accent-gold focus:outline-none focus:ring-2 focus:ring-vibrant-pink focus:ring-offset-2 focus:ring-offset-slate-900"
          data-conversion-event="class_booking_start"
          data-conversion-context="home_hero"
          data-conversion-booking-path="schedule_page"
        >
          Join a Class
        </a>
      </div>
    </section>
    {/* END: Hero Section */}

    {/* START: Pride in the Park Featured Event */}
    <section class="relative overflow-hidden bg-gradient-to-br from-[#fdf2f8] via-white to-[#eff6ff] py-16 sm:py-20 lg:py-24">
      <div
        class="absolute inset-0 opacity-[0.12]"
        style="background-image: linear-gradient(90deg, rgba(147,51,234,0.18) 1px, transparent 1px), linear-gradient(rgba(147,51,234,0.13) 1px, transparent 1px); background-size: 68px 68px;"
      >
      </div>
      <div class="absolute -top-28 -right-24 h-72 w-72 rounded-full bg-pink-500/20 blur-[110px]"></div>
      <div class="absolute -bottom-28 -left-24 h-80 w-80 rounded-full bg-sky-500/15 blur-[120px]"></div>
      <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-red-500 via-amber-400 via-green-500 via-blue-500 to-purple-500"></div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-14">
          <div class="relative lg:col-span-2">
            <div class="absolute -inset-3 rounded-[2rem] bg-gradient-to-br from-pink-500/25 via-amber-400/20 to-purple-500/20 blur-2xl"></div>
            <div class="relative overflow-hidden rounded-3xl border border-purple-700/15 bg-white p-3 shadow-2xl shadow-purple-700/15">
              <div class="absolute top-4 left-4 z-10 flex flex-col items-center justify-center rounded-2xl bg-purple-700 px-3 py-2 shadow-lg">
                <span class="text-[9px] font-extrabold uppercase tracking-wider text-white/80 leading-none">Sun</span>
                <span class="text-2xl font-extrabold leading-none text-white mt-0.5">14</span>
                <span class="text-[9px] font-extrabold uppercase tracking-wider text-white/80 leading-none mt-0.5">Jun</span>
              </div>
              <img
                src={`${base}images/pride-in-the-park.png`}
                alt="Pride in the Park event flyer: free Pilates and dance fitness at 12th St Beach on June 14"
                class="w-full rounded-2xl object-contain"
                loading="lazy"
              />
            </div>
          </div>

          <div class="lg:col-span-3 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 rounded-full bg-purple-700 px-4 py-2 mb-6 shadow-lg shadow-purple-700/15">
              <span class="relative flex h-2.5 w-2.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"></span>
                <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"></span>
              </span>
              <span class="text-xs font-bold uppercase tracking-widest text-accent-gold">
                June 14 · Free Event
              </span>
            </div>

            <p class="text-xs font-bold uppercase tracking-[0.3em] text-purple-700 mb-2">
              Movement, joy, and visibility
            </p>

            <h2 class="font-sans text-4xl font-extrabold tracking-tight text-off-black sm:text-5xl lg:text-6xl leading-[1.05]">
              Pride in<br class="hidden sm:block" /> the Park
            </h2>
            <p class="mt-3 text-base font-semibold text-purple-700 sm:text-lg">
              A lizlates Pilates class and a Dance Fitness class, outdoors by the lake.
            </p>

            <p class="mt-5 text-base text-medium-gray leading-relaxed max-w-2xl mx-auto lg:mx-0">
              Pride In The Park brings our Latina Sweat Cares community
              together for movement, joy, and visibility. Join us outdoors for
              fitness, connection, and support that centers Latina wellness.
            </p>
            <p class="mt-4 text-base text-medium-gray leading-relaxed max-w-2xl mx-auto lg:mx-0">
              Your registration helps us create a safe, welcoming space to
              move, care for mental health, and celebrate together. All are
              welcome. Sign up to save your spot and sweat with pride.
            </p>

            <div class="mt-6 flex flex-wrap gap-2.5 justify-center lg:justify-start">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-purple-700/10 border border-purple-700/15 px-3.5 py-1.5 text-xs font-bold text-purple-700">
                Sunday, June 14 · 1 to 3 PM
              </span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-sky-600/10 border border-sky-600/15 px-3.5 py-1.5 text-xs font-bold text-sky-800">
                12th St Beach · Near Museum Campus
              </span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-pink-600/10 border border-pink-600/15 px-3.5 py-1.5 text-xs font-bold text-pink-700">
                Free · BYOM: Bring Your Own Mat
              </span>
            </div>

            <div class="mt-6 flex flex-wrap justify-center gap-2 lg:justify-start">
              {["lizlates Pilates", "Dance Fitness", "Free", "Outdoors"].map((item) => (
                <span class="rounded-full bg-white/70 border border-purple-700/15 px-3 py-1 text-xs font-bold text-purple-800">
                  {item}
                </span>
              ))}
            </div>

            <div class="mt-8 flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-3">
              <a
                href={prideRegistrationUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn group inline-flex items-center justify-center gap-3 rounded-full bg-purple-700 px-8 py-4 text-base font-bold text-white shadow-lg shadow-purple-700/25 transition-all duration-300 hover:scale-105 hover:bg-off-black hover:shadow-xl"
                data-conversion-event="event_registration_start"
                data-conversion-context="home_pride_in_the_park"
                data-conversion-provider="zeffy"
                data-conversion-booking-path="pride_in_the_park_ticketing"
              >
                RSVP Free
                <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              </a>
              <span class="text-xs text-medium-gray font-medium">
                Supports Latina Sweat Cares
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: Pride in the Park Featured Event */}

    {/* START: WGN9 Spotlight Section */}
    <section class="relative overflow-hidden bg-off-black py-14 sm:py-20">
      {/* Background pattern */}
      <div
        class="absolute inset-0 opacity-[0.05]"
        style="background-image: url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cpath d=%22M30 0L60 30L30 60L0 30z%22 fill=%22none%22 stroke=%22%23fff%22 stroke-width=%221%22/%3E%3C/svg%3E'); background-size: 60px 60px;"
      >
      </div>

      {/* Top accent line */}
      <div
        class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-vibrant-pink to-transparent opacity-80"
      >
      </div>

      {/* Decorative glows */}
      <div
        class="absolute -top-32 -left-20 w-[400px] h-[400px] bg-vibrant-pink/15 rounded-full blur-[120px] pointer-events-none"
      >
      </div>
      <div
        class="absolute -bottom-32 -right-20 w-[400px] h-[400px] bg-accent-gold/15 rounded-full blur-[120px] pointer-events-none"
      >
      </div>

      <div
        class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8"
      >
        <div class="grid gap-10 lg:grid-cols-12 lg:gap-12 items-center">
          {/* Left: Copy + CTAs */}
          <div class="lg:col-span-5 text-center lg:text-left">
            <div
              class="inline-flex items-center gap-2 rounded-full border border-vibrant-pink/40 bg-vibrant-pink/10 px-4 py-1.5"
            >
              <span class="relative flex h-2 w-2">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-vibrant-pink opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2 w-2 rounded-full bg-vibrant-pink"
                ></span>
              </span>
              <p
                class="text-vibrant-pink text-xs font-bold uppercase tracking-[0.25em]"
              >
                As Seen On WGN9 Chicago
              </p>
            </div>

            <h2
              class="mt-5 font-sans text-4xl sm:text-5xl lg:text-5xl font-extrabold tracking-tight text-white leading-[1.05]"
            >
              Around Town<br />checks out{" "}
              <span
                class="text-transparent bg-clip-text bg-gradient-to-r from-vibrant-pink to-accent-gold"
                >The Latina<br class="hidden sm:block" /> Sweat Project</span
              >
            </h2>
            <p
              class="mt-5 font-body text-base sm:text-lg text-slate-300 max-w-xl mx-auto lg:mx-0"
            >
              WGN9's Ana Belaval spent the morning with us in Pilsen. Four
              segments: a Spanish yoga flow, our community art gallery, the
              workout, and a conversation with our founder Margarita.
            </p>

            <div
              class="mt-7 flex flex-wrap items-center justify-center lg:justify-start gap-3"
            >
              <a
                href={`${base}wgn9-around-town`}
                class="btn group inline-flex items-center gap-2 rounded-full bg-vibrant-pink px-6 py-3 text-sm font-bold text-white shadow-lg shadow-vibrant-pink/25 transition-all duration-300 hover:scale-[1.03] hover:shadow-xl"
              >
                <svg
                  class="w-4 h-4"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M8 5v14l11-7z" />
                </svg>
                Watch all 4 segments
              </a>
              <a
                href="https://wgntv.com/morning-news/around-town/around-town-checks-out-the-latina-sweat-project/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border-2 border-white/20 bg-white/5 px-6 py-3 text-sm font-bold text-white transition-all duration-300 hover:border-accent-gold/60 hover:bg-white/10"
              >
                Read on WGN9
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="2.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  ></path></svg
                >
              </a>
            </div>

            {/* Segment chips */}
            <div
              class="mt-6 flex flex-wrap justify-center lg:justify-start gap-2"
            >
              <span
                class="inline-flex items-center gap-1.5 rounded-full bg-white/5 border border-white/10 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/70"
              >
                <span class="text-accent-gold">01</span> The Workout
              </span>
              <span
                class="inline-flex items-center gap-1.5 rounded-full bg-white/5 border border-white/10 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/70"
              >
                <span class="text-accent-gold">02</span> Meet the Founder
              </span>
              <span
                class="inline-flex items-center gap-1.5 rounded-full bg-white/5 border border-white/10 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/70"
              >
                <span class="text-accent-gold">03</span> Spanish Yoga Flow
              </span>
              <span
                class="inline-flex items-center gap-1.5 rounded-full bg-white/5 border border-white/10 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/70"
              >
                <span class="text-accent-gold">04</span> Community & Art
              </span>
            </div>
          </div>

          {/* Right: Featured video */}
          <div class="lg:col-span-7">
            <div
              class="relative rounded-2xl overflow-hidden shadow-2xl ring-1 ring-white/10 bg-black"
            >
              {/* Gradient halo */}
              <div
                class="absolute -inset-px rounded-2xl bg-gradient-to-br from-vibrant-pink/40 via-transparent to-accent-gold/40 opacity-60 pointer-events-none"
                aria-hidden="true"
              >
              </div>

              <div class="relative aspect-video w-full">
                <iframe
                  id="nxs-video-iframe-home"
                  frameborder="0"
                  allowfullscreen
                  loading="lazy"
                  title="WGN9 Around Town: Ana tries the workout at The Latina Sweat Project"
                  src="https://redir1.wgntv.com/nxs-video/vid-anvato-11802590/embed/?injected_via=embed&post_id=3976584"
                  rel="nofollow"
                  class="absolute inset-0 w-full h-full"
                ></iframe>
              </div>
            </div>

            <p
              class="mt-3 text-center lg:text-right text-xs font-medium text-white/40 italic"
            >
              Featured segment: Ana tries the workout · 3 more on the feature
              page
            </p>
          </div>
        </div>
      </div>

      {/* Bottom accent line */}
      <div
        class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-accent-gold to-transparent opacity-40"
      >
      </div>
    </section>
    {/* END: WGN9 Spotlight Section */}

    {/* START: Merch Drop — Monday Miles Tee Section */}
    <section
      class="relative overflow-hidden bg-gradient-to-br from-amber-50 via-orange-50/40 to-amber-50 py-16 sm:py-20 lg:py-24"
    >
      {/* Decorative background elements */}
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div
          class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-accent-gold/20 rounded-full blur-[120px]"
        >
        </div>
        <div
          class="absolute bottom-0 left-1/4 w-[400px] h-[400px] bg-orange-200/30 rounded-full blur-[100px]"
        >
        </div>
        {/* Subtle running stripes pattern */}
        <div
          class="absolute inset-0 opacity-[0.04]"
          style="background-image: repeating-linear-gradient(90deg, transparent, transparent 60px, #1E1E1E 60px, #1E1E1E 61px); background-size: 100% 100%;"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        {/* Header area */}
        <div class="text-center mb-12">
          {/* Pulsing badge */}
          <div
            class="inline-flex items-center gap-2 rounded-full bg-off-black px-4 py-2 mb-6 shadow-lg shadow-off-black/10"
          >
            <span class="relative flex h-2.5 w-2.5">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"
              ></span>
              <span
                class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"
              ></span>
            </span>
            <span
              class="text-sm font-bold uppercase tracking-widest text-accent-gold"
              >New Drop · In Studio Only</span
            >
          </div>

          <p
            class="text-xs font-bold uppercase tracking-[0.3em] text-accent-gold/90 mb-3"
          >
            The Monday Miles Tee
          </p>

          <h2
            class="font-sans text-5xl font-extrabold tracking-tight text-off-black sm:text-6xl lg:text-7xl italic"
          >
            <span class="monday-tee-gradient">Ponte</span> las pilas.
          </h2>

          <p
            class="mt-5 text-lg text-off-black/70 sm:text-xl max-w-2xl mx-auto leading-relaxed"
          >
            Our runners' tank, built for the pavement. Wear it on Mondays. Wear
            it on race day. Wear it whenever you need a reminder.
          </p>

          {/* Feature pills */}
          <div class="mt-7 flex flex-wrap gap-3 justify-center">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-white border border-off-black/10 px-4 py-2 text-sm font-bold text-off-black shadow-sm"
            >
              <svg
                class="w-4 h-4 text-accent-gold"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 2L9.91 8.26 3 9.27l5 4.87L6.82 21 12 17.77 17.18 21 16 14.14l5-4.87-6.91-1.01L12 2z"
                ></path>
              </svg>
              Limited Run
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-white border border-off-black/10 px-4 py-2 text-sm font-bold text-off-black shadow-sm"
            >
              <svg
                class="w-4 h-4 text-accent-gold"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Race-Ready Cut
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-white border border-off-black/10 px-4 py-2 text-sm font-bold text-off-black shadow-sm"
            >
              <svg
                class="w-4 h-4 text-accent-gold"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Studio Pickup
            </span>
          </div>
        </div>

        {/* Main showcase: Hero image + Details */}
        <div
          class="grid grid-cols-1 items-center gap-10 lg:grid-cols-5 lg:gap-14"
        >
          {/* Hero tee image — takes 3 of 5 cols */}
          <div class="lg:col-span-3 relative">
            {/* Decorative glow behind image */}
            <div
              class="absolute -inset-6 rounded-[2rem] bg-gradient-to-br from-accent-gold/40 via-orange-300/20 to-transparent blur-2xl opacity-70"
            >
            </div>

            <div
              class="relative overflow-hidden rounded-3xl bg-off-black shadow-2xl shadow-off-black/30 ring-1 ring-off-black/10"
            >
              {/* Tag in corner */}
              <div
                class="absolute top-4 left-4 z-10 flex items-center gap-2 rounded-full bg-accent-gold px-3.5 py-1.5 shadow-lg"
              >
                <span class="text-xs font-extrabold uppercase tracking-wider text-off-black"
                  >Front · Back</span
                >
              </div>

              <img
                src={`${base}images/monday-miles-tee.png`}
                alt="The Latina Sweat Project Monday Miles running tee. Front shows arched logo with X and yellow sun. Back reads Ponte las pilas."
                class="w-full h-auto object-contain"
                loading="lazy"
              />
            </div>

            {/* Tagline under image */}
            <p
              class="mt-5 text-center text-sm font-medium text-off-black/60 italic"
            >
              Photographed in studio. Designed for the pavement.
            </p>
          </div>

          {/* Details panel — takes 2 of 5 cols */}
          <div class="lg:col-span-2 flex flex-col gap-6">
            {/* Price + availability card */}
            <div
              class="relative overflow-hidden rounded-3xl bg-off-black p-7 sm:p-8 shadow-2xl shadow-off-black/20"
            >
              {/* Subtle glow inside card */}
              <div
                class="absolute -top-20 -right-20 w-48 h-48 bg-accent-gold/20 rounded-full blur-3xl"
              >
              </div>

              <div class="relative">
                <p
                  class="text-xs font-bold uppercase tracking-[0.25em] text-accent-gold mb-2"
                >
                  How to Get One
                </p>
                <h3 class="text-2xl font-extrabold text-white leading-tight">
                  Drop by the studio.
                </h3>
                <p class="mt-3 text-base text-white/70 leading-relaxed">
                  No online shop, no waitlist. Tees live on the rack at LSP
                  Studio until they're gone.
                </p>

                <div class="my-6 h-px bg-white/10"></div>

                {/* Details grid */}
                <div class="space-y-3.5">
                  <div class="flex items-center justify-between">
                    <span
                      class="text-xs font-bold uppercase tracking-wider text-white/50"
                      >Style</span
                    >
                    <span class="text-sm font-bold text-white"
                      >Runners' tank</span
                    >
                  </div>
                  <div class="h-px bg-white/10"></div>
                  <div class="flex items-center justify-between">
                    <span
                      class="text-xs font-bold uppercase tracking-wider text-white/50"
                      >Sizes</span
                    >
                    <span class="text-sm font-bold text-white">XS · S · M · L</span>
                  </div>
                  <div class="h-px bg-white/10"></div>
                  <div class="flex items-center justify-between">
                    <span
                      class="text-xs font-bold uppercase tracking-wider text-white/50"
                      >Where</span
                    >
                    <span class="text-sm font-bold text-accent-gold"
                      >LSP Studio</span
                    >
                  </div>
                </div>
              </div>
            </div>

            {/* Connection to Monday Miles */}
            <div
              class="rounded-2xl bg-white border border-accent-gold/30 p-5 shadow-sm"
            >
              <div class="flex items-start gap-3">
                <div
