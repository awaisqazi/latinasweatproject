        animation: swipe-pulse 1.6s ease-in-out infinite;
      }

      /* Smooth scroll behavior on the events carousel */
      #events-carousel {
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
      }

      /* Monday Miles tee gradient text */
      .monday-tee-gradient {
        background: linear-gradient(
          135deg,
          #ffbd59 0%,
          #f97316 35%,
          #ffbd59 70%,
          #f59e0b 100%
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmer-text 3s ease-in-out infinite;
      }

      /* Monday Miles gradient text */
      .monday-miles-gradient {
        background: linear-gradient(
          135deg,
          #ffbd59 0%,
          #b5a18d 50%,
          #ffbd59 100%
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmer-text 3s ease-in-out infinite;
      }

      @keyframes shimmer-text {
        0%,
        100% {
          background-position: 0% center;
        }
        50% {
          background-position: 200% center;
        }
      }

      /* Hide scrollbar on carousel */
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }

      /* Free-class date cards */
      .free-card {
        position: relative;
        border-radius: 0.75rem;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 189, 89, 0.3);
        padding: 0.75rem 0.5rem;
