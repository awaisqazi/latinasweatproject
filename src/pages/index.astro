---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import TestimonialCard from "@/components/TestimonialCard.astro";
import { pressArticles } from "@/data/press";
const base = import.meta.env.BASE_URL;
---

<Layout title="The Latina Sweat Project | Home">
  <Header />
  <main>
    {/* START: Hero Section */}
    <section class="relative h-[60vh] min-h-[480px] w-full sm:h-screen">
      <div class="absolute inset-0 bg-black/50"></div>

      <video
        autoplay
        loop
        muted
        playsinline
        class="hidden h-full w-full object-cover sm:block"
      >
        <source src={`${base}videos/heroclip.mp4`} type="video/mp4" />
      </video>

      <div
        class="sm:hidden h-full w-full bg-cover bg-center"
        style='background-image: url("https://images.pexels.com/photos/4753997/pexels-photo-4753997.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2");'
      >
      </div>

      <div
        class="absolute inset-0 flex flex-col items-center justify-center p-4 text-center text-white"
      >
        <h1
          class="font-sans text-4xl font-extrabold tracking-tighter sm:text-5xl md:text-6xl lg:text-7xl"
        >
          Empowering Through Movement
        </h1>
        <p class="mt-4 max-w-2xl font-body text-lg sm:text-xl">
          Join our vibrant community in Chicago and experience fitness that
          celebrates our culture.
        </p>
        <a
          href={`${base}schedule`}
          class="btn mt-8 rounded-full bg-vibrant-pink px-8 py-3 text-base font-bold text-white shadow-lg transition hover:scale-105 hover:bg-accent-gold focus:outline-none focus:ring-2 focus:ring-vibrant-pink focus:ring-offset-2 focus:ring-offset-slate-900"
        >
          Join a Class
        </a>
      </div>
    </section>
    {/* END: Hero Section */}

    {/* START: Free Day Promo */}
    <section class="relative overflow-hidden bg-gradient-to-br from-amber-50 via-yellow-50 to-orange-50 py-10 sm:py-14">
      {/* Decorative warm glows */}
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-16 left-1/4 w-[350px] h-[350px] bg-accent-gold/20 rounded-full blur-[100px]"></div>
        <div class="absolute -bottom-20 right-1/4 w-[300px] h-[300px] bg-vibrant-pink/15 rounded-full blur-[80px]"></div>
      </div>

      <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
        {/* Pulsing badge */}
        <div class="inline-flex items-center gap-2 rounded-full bg-accent-gold/20 border border-accent-gold/40 px-4 py-2 mb-4">
          <span class="relative flex h-2.5 w-2.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"></span>
          </span>
          <span class="text-sm font-bold uppercase tracking-widest text-amber-800">New at LSP</span>
        </div>

        <h2 class="font-sans text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-off-black">
          One Free Day <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-gold to-vibrant-pink">Every Week</span>&nbsp;🎉
        </h2>
        <p class="mt-2 text-amber-900/60 text-base sm:text-lg font-medium">Un dia gratis cada semana · All classes, all day, no membership needed</p>

        <div class="mt-8 flex flex-wrap justify-center gap-3 sm:gap-4">
          <div class="rounded-2xl bg-white border-2 border-accent-gold/40 shadow-lg shadow-accent-gold/10 px-5 py-3 text-center min-w-[130px] transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/20 hover:border-accent-gold">
            <p class="text-[11px] font-bold uppercase tracking-wider text-accent-gold">Mar 30</p>
            <p class="text-lg font-extrabold text-off-black leading-tight">Monday</p>
            <p class="text-[10px] font-bold uppercase tracking-wider text-vibrant-pink mt-0.5">FREE</p>
          </div>
          <div class="rounded-2xl bg-white border-2 border-accent-gold/40 shadow-lg shadow-accent-gold/10 px-5 py-3 text-center min-w-[130px] transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/20 hover:border-accent-gold">
            <p class="text-[11px] font-bold uppercase tracking-wider text-accent-gold">Apr 7</p>
            <p class="text-lg font-extrabold text-off-black leading-tight">Tuesday</p>
            <p class="text-[10px] font-bold uppercase tracking-wider text-vibrant-pink mt-0.5">FREE</p>
          </div>
          <div class="rounded-2xl bg-white border-2 border-accent-gold/40 shadow-lg shadow-accent-gold/10 px-5 py-3 text-center min-w-[130px] transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/20 hover:border-accent-gold">
            <p class="text-[11px] font-bold uppercase tracking-wider text-accent-gold">Apr 15</p>
            <p class="text-lg font-extrabold text-off-black leading-tight">Wednesday</p>
            <p class="text-[10px] font-bold uppercase tracking-wider text-vibrant-pink mt-0.5">FREE</p>
          </div>
          <div class="rounded-2xl bg-white border-2 border-accent-gold/40 shadow-lg shadow-accent-gold/10 px-5 py-3 text-center min-w-[130px] transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/20 hover:border-accent-gold">
            <p class="text-[11px] font-bold uppercase tracking-wider text-accent-gold">Apr 23</p>
            <p class="text-lg font-extrabold text-off-black leading-tight">Thursday</p>
            <p class="text-[10px] font-bold uppercase tracking-wider text-vibrant-pink mt-0.5">FREE</p>
          </div>
          <div class="rounded-2xl bg-white border-2 border-accent-gold/40 shadow-lg shadow-accent-gold/10 px-5 py-3 text-center min-w-[130px] transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/20 hover:border-accent-gold">
            <p class="text-[11px] font-bold uppercase tracking-wider text-accent-gold">May 1</p>
            <p class="text-lg font-extrabold text-off-black leading-tight">Friday</p>
            <p class="text-[10px] font-bold uppercase tracking-wider text-vibrant-pink mt-0.5">FREE</p>
          </div>
        </div>

        <a
          href={`${base}schedule`}
          class="mt-8 inline-flex items-center gap-2 rounded-full bg-accent-gold px-8 py-4 text-base font-bold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/40"
        >
          View Schedule & Sign Up
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
        </a>
      </div>
    </section>
    {/* END: Free Day Promo */}

    {/* START: Yoga For Wishes — Make-A-Wish Banner (Dark Section) */}
    <section class="relative overflow-hidden bg-gradient-to-r from-[#0a1628] via-[#0f2847] to-[#0a1628] py-10 sm:py-12">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/3 w-[300px] h-[300px] bg-sky-500/10 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 right-1/4 w-[250px] h-[250px] bg-blue-400/8 rounded-full blur-[80px]"></div>
      </div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-sky-400/40 to-transparent"></div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-8">
          <div class="flex items-center gap-4 text-center md:text-left">
            <div class="hidden sm:flex items-center justify-center w-16 h-16 rounded-full bg-sky-400/20 backdrop-blur-sm flex-shrink-0">
              <svg class="w-8 h-8 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sky-300/90 text-sm font-semibold uppercase tracking-wider">
                April 18th · Make‑A‑Wish Illinois
              </p>
              <h3 class="text-white text-xl sm:text-2xl font-bold mt-1">
                Yoga For Wishes ⭐
              </h3>
              <p class="text-sky-200/70 text-sm sm:text-base mt-1 max-w-xl">
                Donation‑based class at 3:30 PM + write birthday cards for wish kids all day. Move. Breathe. Give back.
              </p>
            </div>
          </div>
          <a
            href="https://www.zeffy.com/en-US/ticketing/makeawish-together-we-grant-wishes-for-children-with-critical-illnesses"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex-shrink-0 inline-flex items-center gap-3 rounded-full bg-sky-600 px-6 sm:px-8 py-3 sm:py-4 font-bold text-white shadow-xl transition-all duration-300 hover:scale-105 hover:bg-sky-500 hover:shadow-2xl focus:outline-none focus:ring-4 focus:ring-sky-400/50"
          >
            <span class="text-base sm:text-lg">Get Tickets · $15</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-sky-400/40 to-transparent"></div>
    </section>
    {/* END: Yoga For Wishes — Make-A-Wish Banner */}

    {/* START: 40 Under 40 Spotlight */}
    <section
      class="relative overflow-hidden bg-gradient-to-br from-amber-50 via-yellow-50 to-orange-50 py-10 sm:py-14"
    >
      <div class="absolute inset-0 opacity-[0.04]">
        <div
          class="absolute inset-0"
          style="background-image: radial-gradient(circle at 30% 50%, #b8860b 0%, transparent 50%), radial-gradient(circle at 70% 50%, #daa520 0%, transparent 50%);"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
          {/* Photo */}
          <div class="flex-shrink-0 mx-auto md:mx-0">
            <div class="relative">
              <div
                class="absolute -inset-2 rounded-2xl bg-gradient-to-br from-amber-400/30 via-yellow-300/20 to-orange-400/30 blur-lg"
              >
              </div>
              <img
                src={`${base}images/40under40.png`}
                alt="Margarita Quiñones Peña · Negocios Now 40 Under 40 Chicago 2025"
                class="relative w-48 sm:w-56 rounded-2xl object-contain border-2 border-amber-200/60 shadow-lg"
              />
            </div>
          </div>

          {/* Content */}
          <div class="text-center md:text-left flex-1">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-amber-100 border border-amber-300/60 px-4 py-2 mb-4"
            >
              <svg
                class="h-4 w-4 text-amber-700"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                ></path>
              </svg>
              <span
                class="text-sm font-bold uppercase tracking-widest text-amber-800"
                >40 Under 40 &middot; Chicago 2025</span
              >
            </div>

            <h2
              class="font-sans text-2xl font-extrabold tracking-tight text-amber-950 sm:text-3xl lg:text-4xl"
            >
              Our Founder, Recognized
            </h2>
            <p
              class="mt-3 text-base text-amber-900/70 sm:text-lg leading-relaxed max-w-2xl mx-auto md:mx-0"
            >
              Margarita Qui&ntilde;ones Pe&ntilde;a has been named to the
              <strong class="text-amber-900">Negocios Now 40 Under 40</strong>
              list, honoring emerging leaders making an impact in Chicago. From building
              a grassroots wellness movement in Pilsen to certifying over 50 yoga
              instructors from underrepresented communities, her work continues to
              transform lives.
            </p>

            <div
              class="mt-6 flex flex-col items-center gap-4 sm:flex-row sm:justify-center md:justify-start"
            >
              <a
                href="https://negociosnow.com/margarita-quinones-pena-advocate-for-holistic-community-empowerment/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn group inline-flex items-center gap-3 rounded-full bg-amber-800 px-7 py-3 text-base font-bold text-white shadow-lg shadow-amber-800/25 transition-all duration-300 hover:scale-105 hover:bg-amber-700 hover:shadow-xl"
              >
                Read the Feature
                <svg
                  class="h-4 w-4 transition-transform group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: 40 Under 40 Spotlight */}

    {/* START: Monday Miles — Community Runs Section */}
    <section
      class="relative overflow-hidden bg-off-black py-16 sm:py-20 lg:py-24"
    >
      {/* Animated background pattern */}
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute inset-0"
          style="background-image: repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(255,189,89,0.3) 40px, rgba(255,189,89,0.3) 41px); background-size: 100% 100%;"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div
          class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16"
        >
          {/* Left: Content */}
          <div class="text-center lg:text-left">
            {/* Badge */}
            <div
              class="inline-flex items-center gap-2 rounded-full bg-accent-gold/15 px-4 py-2 mb-6"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"
                ></span>
              </span>
              <span
                class="text-sm font-bold uppercase tracking-widest text-accent-gold"
                >New Weekly Series</span
              >
            </div>

            <h2
              class="font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl"
            >
              Monday<br />
              <span class="monday-miles-gradient">Miles</span>
            </h2>

            <p class="mt-4 text-lg text-white/70 sm:text-xl">
              Our new weekly walk & run group. Every Monday at
              <span class="font-bold text-accent-gold">6:30 PM</span>.
            </p>

            {/* Route options */}
            <div
              class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center lg:justify-start"
            >
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-5 py-4 backdrop-blur-sm"
              >
                <div
                  class="flex h-12 w-12 items-center justify-center rounded-full bg-vibrant-pink/20"
                >
                  <svg
                    class="h-6 w-6 text-vibrant-pink"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-white">Walk</p>
                  <p class="text-2xl font-extrabold text-vibrant-pink">
                    1 Mile
                  </p>
                </div>
              </div>
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-5 py-4 backdrop-blur-sm"
              >
                <div
                  class="flex h-12 w-12 items-center justify-center rounded-full bg-accent-gold/20"
                >
                  <svg
                    class="h-6 w-6 text-accent-gold"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-white">Jog / Run</p>
                  <p class="text-2xl font-extrabold text-accent-gold">
                    2 Miles
                  </p>
                </div>
              </div>
            </div>

            <p class="mt-6 text-base text-white/50 italic">
              You set the pace. All levels welcome.
            </p>

            {/* CTA */}
            <div
              class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center lg:justify-start"
            >
              <a
                href={`${base}schedule`}
                class="btn group inline-flex items-center gap-3 rounded-full bg-accent-gold px-8 py-4 text-lg font-bold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/40"
              >
                <svg
                  class="h-5 w-5 transition-transform group-hover:translate-x-0.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 4v16m8-8H4"></path>
                </svg>
                Join for Free
              </a>
              <span class="text-sm text-white/40"
                >Meet in the cafe. Warm up together.</span
              >
            </div>
          </div>

          {/* Right: Visual card */}
          <div class="relative mx-auto w-full max-w-md lg:max-w-none">
            {/* Decorative glow */}
            <div
              class="absolute -inset-4 rounded-3xl bg-gradient-to-br from-accent-gold/20 via-vibrant-pink/10 to-transparent blur-2xl"
            >
            </div>

            <div
              class="relative overflow-hidden rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm"
            >
              <img
                src={`${base}images/monday-miles-runner.png`}
                alt="Community members running together at Monday Miles"
                class="h-72 w-full object-cover sm:h-80"
              />
              {/* Stronger gradient for readability over busy photos */}
              <div
                class="absolute inset-0 bg-gradient-to-t from-off-black via-off-black/60 to-off-black/10"
              >
              </div>

              {/* Overlay info */}
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <div class="flex items-center gap-3">
                  <div
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-accent-gold"
                  >
                    <svg
                      class="h-5 w-5 text-off-black"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-white drop-shadow-md">
                      Every Monday
                    </p>
                    <p class="text-xl font-extrabold text-white drop-shadow-md">
                      6:30 PM
                    </p>
                  </div>
                </div>
                <div class="mt-4 flex flex-wrap gap-2">
                  <span
                    class="rounded-full bg-accent-gold/30 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-accent-gold drop-shadow-sm"
                    >Free</span
                  >
                  <span
                    class="rounded-full bg-vibrant-pink/30 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-vibrant-pink drop-shadow-sm"
                    >All Levels</span
                  >
                  <span
                    class="rounded-full bg-white/15 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-white drop-shadow-sm"
                    >Weekly</span
                  >
                </div>
                <p class="mt-3 text-sm text-white/80 drop-shadow-md">
                  Movement is medicine, and it's better in community.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: Monday Miles — Community Runs Section */}

    {/* START: Merch Drop Teaser Section */}
    <section
      class="relative overflow-hidden bg-light-gray py-16 sm:py-20 lg:py-24"
    >
      {/* Decorative background blobs */}
      <div class="absolute inset-0 overflow-hidden">
        <div
          class="absolute -top-20 -right-20 w-[400px] h-[400px] bg-purple-200/30 rounded-full blur-[100px]"
        >
        </div>
        <div
          class="absolute bottom-0 left-1/4 w-[300px] h-[300px] bg-purple-100/40 rounded-full blur-[80px]"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        {/* Header area */}
        <div class="text-center mb-12">
          {/* Pulsing badge */}
          <div
            class="inline-flex items-center gap-2 rounded-full bg-purple-100 px-4 py-2 mb-6 border border-purple-200"
          >
            <span class="relative flex h-2.5 w-2.5">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-purple-500 opacity-75"
              ></span>
              <span
                class="relative inline-flex h-2.5 w-2.5 rounded-full bg-purple-500"
              ></span>
            </span>
            <span
              class="text-sm font-bold uppercase tracking-widest text-purple-700"
              >Available Now · In Studio Only</span
            >
          </div>

          <h2
            class="font-sans text-4xl font-extrabold tracking-tight text-off-black sm:text-5xl lg:text-6xl"
          >
            Women <span class="merch-drop-gradient">Made.</span>
          </h2>

          <p
            class="mt-4 text-lg text-medium-gray sm:text-xl max-w-2xl mx-auto leading-relaxed italic"
          >
            Made by the hands that held us. Made by the voices that guided us.
          </p>

          <p
            class="mt-4 text-base text-medium-gray max-w-xl mx-auto leading-relaxed"
          >
            Our limited edition merch collection celebrating <span
              class="font-semibold text-purple-700"
