---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import TestimonialCard from "@/components/TestimonialCard.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="The Latina Sweat Project | Home">
  <Header />
  <main>
    {/* START: Hero Section */}
    <section class="relative h-[60vh] min-h-[480px] w-full sm:h-screen">
      <div class="absolute inset-0 bg-black/50"></div>

      <video
        autoplay
        loop
        muted
        playsinline
        class="hidden h-full w-full object-cover sm:block"
      >
        <source src={`${base}videos/heroclip.mp4`} type="video/mp4" />
      </video>

      <div
        class="sm:hidden h-full w-full bg-cover bg-center"
        style='background-image: url("https://images.pexels.com/photos/4753997/pexels-photo-4753997.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2");'
      >
      </div>

      <div
        class="absolute inset-0 flex flex-col items-center justify-center p-4 text-center text-white"
      >
        <h1
          class="font-sans text-4xl font-extrabold tracking-tighter sm:text-5xl md:text-6xl lg:text-7xl"
        >
          Empowering Through Movement
        </h1>
        <p class="mt-4 max-w-2xl font-body text-lg sm:text-xl">
          Join our vibrant community in Chicago and experience fitness that
          celebrates our culture.
        </p>
        <a
          href={`${base}schedule`}
          class="btn mt-8 rounded-full bg-vibrant-pink px-8 py-3 text-base font-bold text-white shadow-lg transition hover:scale-105 hover:bg-accent-gold focus:outline-none focus:ring-2 focus:ring-vibrant-pink focus:ring-offset-2 focus:ring-offset-slate-900"
        >
          Join a Class
        </a>
      </div>
    </section>
    {/* END: Hero Section */}

    {/* START: Documentary CTA Section */}
    <section
      class="bg-gradient-to-r from-vibrant-pink via-accent-gold to-vibrant-pink py-10 sm:py-12"
    >
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div
          class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-8"
        >
          {/* Left: Text Content */}
          <div class="flex items-center gap-4 text-center md:text-left">
            <div
              class="hidden sm:flex items-center justify-center w-16 h-16 rounded-full bg-white/20 backdrop-blur-sm flex-shrink-0"
            >
              <svg
                class="w-8 h-8 text-white"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M8 5v14l11-7z"></path>
              </svg>
            </div>
            <div>
              <p
                class="text-white/90 text-sm font-semibold uppercase tracking-wider"
              >
                🎬 New Mini-Documentary
              </p>
              <h3 class="text-white text-xl sm:text-2xl font-bold mt-1">
                Watch Our Story: Reclaiming Wellness in Pilsen
              </h3>
              <p class="text-white/80 text-sm sm:text-base mt-1 max-w-xl">
                Experience the heart of our movement — community, healing, and
                resistance through yoga.
              </p>
            </div>
          </div>

          {/* Right: CTA Button */}
          <a
            href={`${base}about`}
            class="group flex-shrink-0 inline-flex items-center gap-3 rounded-full bg-white px-6 sm:px-8 py-3 sm:py-4 font-bold text-vibrant-pink shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl focus:outline-none focus:ring-4 focus:ring-white/50"
          >
            <svg
              class="w-6 h-6 group-hover:scale-110 transition-transform"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M8 5v14l11-7z"></path>
            </svg>
            <span class="text-base sm:text-lg">Watch Now</span>
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>
    {/* END: Documentary CTA Section */}

    {/* START: Monday Miles — Community Runs Section */}
    <section
      class="relative overflow-hidden bg-off-black py-16 sm:py-20 lg:py-24"
    >
      {/* Animated background pattern */}
      <div class="absolute inset-0 opacity-10">
        <div
          class="absolute inset-0"
          style="background-image: repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(255,189,89,0.3) 40px, rgba(255,189,89,0.3) 41px); background-size: 100% 100%;"
        >
        </div>
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div
          class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16"
        >
          {/* Left: Content */}
          <div class="text-center lg:text-left">
            {/* Badge */}
            <div
              class="inline-flex items-center gap-2 rounded-full bg-accent-gold/15 px-4 py-2 mb-6"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span
                  class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"
                ></span>
                <span
                  class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent-gold"
                ></span>
              </span>
              <span
                class="text-sm font-bold uppercase tracking-widest text-accent-gold"
                >New Weekly Series</span
              >
            </div>

            <h2
              class="font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl"
            >
              Monday<br />
              <span class="monday-miles-gradient">Miles</span>
            </h2>

            <p class="mt-4 text-lg text-white/70 sm:text-xl">
              Our new weekly walk & run group. Every Monday at
              <span class="font-bold text-accent-gold">6:30 PM</span>.
            </p>

            {/* Route options */}
            <div
              class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center lg:justify-start"
            >
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-5 py-4 backdrop-blur-sm"
              >
                <div
                  class="flex h-12 w-12 items-center justify-center rounded-full bg-vibrant-pink/20"
                >
                  <svg
                    class="h-6 w-6 text-vibrant-pink"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-white">Walk</p>
                  <p class="text-2xl font-extrabold text-vibrant-pink">
                    1 Mile
                  </p>
                </div>
              </div>
              <div
                class="flex items-center gap-3 rounded-xl bg-white/5 border border-white/10 px-5 py-4 backdrop-blur-sm"
              >
                <div
                  class="flex h-12 w-12 items-center justify-center rounded-full bg-accent-gold/20"
                >
                  <svg
                    class="h-6 w-6 text-accent-gold"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-bold text-white">Jog / Run</p>
                  <p class="text-2xl font-extrabold text-accent-gold">
                    2 Miles
                  </p>
                </div>
              </div>
            </div>

            <p class="mt-6 text-base text-white/50 italic">
              You set the pace. All levels welcome.
            </p>

            {/* CTA */}
            <div
              class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center lg:justify-start"
            >
              <a
                href={`${base}schedule`}
                class="btn group inline-flex items-center gap-3 rounded-full bg-accent-gold px-8 py-4 text-lg font-bold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-accent-gold/40"
              >
                <svg
                  class="h-5 w-5 transition-transform group-hover:translate-x-0.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 4v16m8-8H4"></path>
                </svg>
                Join for Free
              </a>
              <span class="text-sm text-white/40"
                >Meet in the cafe. Warm up together.</span
              >
            </div>
          </div>

          {/* Right: Visual card */}
          <div class="relative mx-auto w-full max-w-md lg:max-w-none">
            {/* Decorative glow */}
            <div
              class="absolute -inset-4 rounded-3xl bg-gradient-to-br from-accent-gold/20 via-vibrant-pink/10 to-transparent blur-2xl"
            >
            </div>

            <div
              class="relative overflow-hidden rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm"
            >
              <img
                src={`${base}images/monday-miles-runner.png`}
                alt="Community members running together at Monday Miles"
                class="h-72 w-full object-cover sm:h-80"
              />
              {/* Stronger gradient for readability over busy photos */}
              <div
                class="absolute inset-0 bg-gradient-to-t from-off-black via-off-black/60 to-off-black/10"
              >
              </div>

              {/* Overlay info */}
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <div class="flex items-center gap-3">
                  <div
                    class="flex h-10 w-10 items-center justify-center rounded-full bg-accent-gold"
                  >
                    <svg
                      class="h-5 w-5 text-off-black"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-white drop-shadow-md">
                      Every Monday
                    </p>
                    <p class="text-xl font-extrabold text-white drop-shadow-md">6:30 PM</p>
                  </div>
                </div>
                <div class="mt-4 flex flex-wrap gap-2">
                  <span
                    class="rounded-full bg-accent-gold/30 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-accent-gold drop-shadow-sm"
                    >Free</span
                  >
                  <span
                    class="rounded-full bg-vibrant-pink/30 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-vibrant-pink drop-shadow-sm"
                    >All Levels</span
                  >
                  <span
                    class="rounded-full bg-white/15 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-white drop-shadow-sm"
                    >Weekly</span
                  >
                </div>
                <p class="mt-3 text-sm text-white/80 drop-shadow-md">
                  Movement is medicine, and it's better in community.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* END: Monday Miles — Community Runs Section */}

    {/* START: Merch Section */}
    <section class="bg-light-gray py-12 sm:py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <h2
            class="font-sans text-3xl font-bold tracking-tight text-off-black sm:text-4xl"
          >
            Shop Our 'Immigrant Made' Merch Drop
          </h2>
          <p class="mt-4 font-body text-lg text-medium-gray">
            Support our mission and wear your pride! Our exclusive 'Immigrant
            Made' collection is now available. Every purchase helps us continue
            to empower our community through movement.
          </p>
          <div class="mt-8">
            <a
              href="https://www.zeffy.com/en-US/ticketing/lsp-immigrant-made-merch-drop"
              target="_blank"
              rel="noopener noreferrer"
              class="btn rounded-full bg-vibrant-pink px-8 py-3 text-base font-bold text-white shadow-lg transition hover:scale-105 hover:bg-accent-gold focus:outline-none focus:ring-2 focus:ring-vibrant-pink focus:ring-offset-2 focus:ring-offset-slate-900"
            >
              Open Shop in New Window
            </a>
          </div>
        </div>
        <div class="mt-10 mx-auto max-w-4xl w-full">
          <img
            src={`${base}merch.PNG`}
            alt="Latina Sweat Project 'Immigrant Made' merchandise"
            class="h-full w-full object-cover"
          />
        </div>
        <div
          class="mt-10 mx-auto max-w-4xl rounded-lg shadow-xl overflow-hidden"
        >
          <div
            style="position: relative; overflow: hidden; width: 100%; height: 700px;"
          >
            <iframe
              title="LSP Immigrant Made Merch Drop"
              style="position: absolute; border: 0; top: 0; left: 0; bottom: 0; right: 0; width: 100%; height: 100%;"
              src="https://www.zeffy.com/embed/ticketing/lsp-immigrant-made-merch-drop"
              allowpaymentrequest
              allowTransparency="true"
            >
            </iframe>
          </div>
        </div>
      </div>
    </section>
    {/* END: Merch Section */}

    {
      /*
    START: Testimonials Section
    <section class="py-12 sm:py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="font-sans text-3xl font-bold tracking-tight text-center text-off-black sm:text-4xl">
          What Our Community Says
        </h2>
        <div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 lg:gap-12">
          <TestimonialCard imageSrc="https://images.pexels.com/photos/3775131/pexels-photo-3775131.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2" quote="This community has transformed my fitness journey. I feel stronger and more connected than ever." author="Ana S." />
          <TestimonialCard imageSrc="https://images.pexels.com/photos/5327585/pexels-photo-5327585.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2" quote="The classes are challenging yet fun, and the instructors are incredibly supportive." author="Maria G." />
          <TestimonialCard imageSrc="https://images.pexels.com/photos/415829/pexels-photo-415829.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2" quote="I love the energy and the sense of belonging. It's more than just a workout; it's a family." author="Sofia R." />
        </div>
      </div>
    </section>
    END: Testimonials Section
    */
    }

    {/* START: Grand Opening Section */}
    <section class="py-12 sm:py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div
          class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-24"
        >
          <div>
            <p
              class="font-sans text-base font-semibold uppercase tracking-wider text-vibrant-pink"
            >
              We&apos;re Open!
            </p>
            <h2
              class="mt-2 font-sans text-3xl font-bold tracking-tight text-off-black sm:text-4xl"
            >
              Our New Studio Is Here
            </h2>
            <div class="mt-6 space-y-4 font-body text-lg text-medium-gray">
              <p>The wait is over! Our brand new studio is officially open.</p>
              <p>
                Experience the energy, meet our incredible teaching team, and
                see firsthand what makes LSP more than just a place to move. We
                are a community, a safe space, and a celebration of wellness in
                our neighborhoods.
              </p>
              <p>
                Come join a class and be part of our vibrant community. We can't
                wait to welcome you!
              </p>
            </div>
            <div class="mt-8 text-center">
              <a
                href={`${base}schedule`}
                class="btn rounded-full bg-vibrant-pink px-8 py-3 text-base font-bold text-white shadow-lg transition hover:scale-105 hover:bg-accent-gold focus:outline-none focus:ring-2 focus:ring-vibrant-pink focus:ring-offset-2 focus:ring-offset-slate-900"
              >
                View Class Schedule
              </a>
            </div>
          </div>
          <div class="order-last w-full overflow-hidden rounded-lg shadow-xl">
            <img
              src={`${base}images/studio.png`}
              alt="The brand new Latina Sweat Project yoga studio"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>
    {/* END: Grand Opening Section */}

    {/* START: Events Section */}
    <section class="bg-light-gray py-12 sm:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p
              class="text-sm font-bold uppercase tracking-widest text-vibrant-pink"
            >
              What's Happening
            </p>
            <h2
              class="mt-1 font-sans text-3xl font-bold tracking-tight text-off-black sm:text-4xl"
            >
              Upcoming Events
            </h2>
          </div>
          <a
            href={`${base}events`}
            class="inline-flex items-center gap-1 font-sans font-bold text-vibrant-pink transition-colors hover:text-accent-gold"
          >
            View All
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>

        {/* Monday Miles event card */}
        <div class="mx-auto max-w-md">
          <a href={`${base}schedule`} class="group block">
            <div
              class="relative overflow-hidden rounded-2xl bg-off-black text-white shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-accent-gold/20"
            >
              <div class="relative h-52 overflow-hidden">
                <img
                  src={`${base}images/monday-miles-runner.png`}
                  alt="Monday Miles community run"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                />
                <div
                  class="absolute inset-0 bg-gradient-to-t from-off-black via-off-black/40 to-off-black/10"
                >
                </div>
                <div class="absolute top-3 left-3 flex gap-2">
                  <span
                    class="rounded-full bg-accent-gold px-3 py-1 text-xs font-bold uppercase tracking-wider text-off-black"
                    >New</span
                  >
                  <span
                    class="rounded-full bg-off-black/50 backdrop-blur-sm px-3 py-1 text-xs font-bold uppercase tracking-wider text-white drop-shadow-sm"
                    >Free</span
                  >
                </div>
              </div>
              <div class="p-5">
                <div
                  class="flex items-center gap-2 text-sm text-accent-gold font-semibold"
                >
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                    ></path>
                  </svg>
                  Every Monday at 6:30 PM
                </div>
                <h3
                  class="mt-2 text-xl font-bold transition-colors group-hover:text-accent-gold"
                >
                  Monday Miles
                </h3>
                <p class="mt-2 text-sm text-white/60 leading-relaxed">
                  Walk 1 mile or jog/run 2. You set the pace. All levels
                  welcome. Meet in the cafe and warm up together.
                </p>
                <div
                  class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-accent-gold transition-all group-hover:gap-2"
                >
                  Join the Run Club
                  <svg
                    class="h-4 w-4 transition-transform group-hover:translate-x-1"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>
    {/* END: Events Section */}

    {/* START: Instagram Section */}
    <section class="py-12 sm:py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2
            class="font-sans text-3xl font-bold tracking-tight text-off-black sm:text-4xl"
          >
            Join Our Community Online
          </h2>
          <p class="mt-4 font-body text-lg text-medium-gray">
            See our community in action! Follow us on Instagram for daily
            inspiration, class updates, and behind-the-scenes moments that
            celebrate our culture and movement.
          </p>
          <div class="mt-8">
            <a
              href="https://www.instagram.com/latinasweatproject/"
              class="btn inline-flex items-center gap-2 rounded-full bg-vibrant-pink px-8 py-3 text-base font-bold text-white shadow-lg transition hover:scale-105 hover:bg-accent-gold focus:outline-none focus:ring-2 focus:ring-vibrant-pink focus:ring-offset-2 focus:ring-offset-slate-900"
            >
              <svg
                class="h-5 w-5"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
                ><path
                  fill-rule="evenodd"
                  d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 012.792 2.792c.247.636.416 1.363.465 2.427.048 1.024.06 1.378.06 3.808s-.012 2.784-.06 3.808c-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-2.792 2.792c-.636.247-1.363.416-2.427.465-1.024.048-1.378.06-3.808.06s-2.784-.012-3.808-.06c-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-2.792-2.792c-.247-.636-.416-1.363-.465-2.427-.048-1.024-.06-1.378-.06-3.808s.012-2.784.06-3.808c.049-1.064.218-1.791.465-2.427a4.902 4.902 0 012.792-2.792c.636.247 1.363.416 2.427.465C9.53 2.013 9.884 2 12.315 2zM12 7a5 5 0 100 10 5 5 0 000-10zm0 8a3 3 0 110-6 3 3 0 010 6zm6.406-11.845a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5z"
                  clip-rule="evenodd"></path></svg
              >
              Follow @LatinaSweatProject
            </a>
          </div>
        </div>
      </div>
    </section>
    {/* END: Instagram Section */}

    <style>
      @keyframes pulse-slow {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.85;
        }
      }
      .animate-pulse-slow {
