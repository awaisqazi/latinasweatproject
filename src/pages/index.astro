                    >
                      <div
                        style="background-color: #F4F4F4; border-radius: 50%; flex-grow: 0; height: 40px; margin-right: 14px; width: 40px;"
                      >
                      </div>
                      <div
                        style="display: flex; flex-direction: column; flex-grow: 1; justify-content: center;"
