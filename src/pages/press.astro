---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import { pressArticles } from "@/data/press.js";
const base = import.meta.env.BASE_URL;
---

<Layout title="In the Press | Latina Sweat Project">
  <Header />
  <main>
    {/* START: Hero Section */}
    <section
      class="relative overflow-hidden bg-off-black py-20 sm:py-28 lg:py-32"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-vibrant-pink/20 via-transparent to-accent-gold/10"
      >
      </div>
      <div
        class="absolute top-10 left-10 h-64 w-64 rounded-full bg-accent-gold/5 blur-3xl"
      >
      </div>
      <div
        class="absolute bottom-10 right-10 h-80 w-80 rounded-full bg-vibrant-pink/5 blur-3xl"
      >
      </div>

      <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-accent-gold/30 bg-accent-gold/10 px-4 py-1.5"
        >
          <svg
            class="h-4 w-4 text-accent-gold"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
            ></path>
          </svg>
          <span class="text-sm font-semibold text-accent-gold"
            >Press & Media</span
          >
        </div>

        <h1
          class="font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl"
        >
          Latina Sweat Project
          <span class="block text-accent-gold">in the Press</span>
        </h1>

        <p
          class="mx-auto mt-6 max-w-2xl font-body text-lg leading-relaxed text-white/70 sm:text-xl"
        >
          See what the community is saying about our mission to make yoga and
          wellness accessible to all.
        </p>
      </div>
    </section>
    {/* END: Hero Section */}

    {/* START: Press Articles */}
    <section class="bg-light-gray py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 md:grid-cols-2">
          {
            pressArticles.map((article, index) => (
              <article class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-black/5 transition-all duration-300 hover:shadow-xl hover:ring-vibrant-pink/20 hover:-translate-y-1">
                {/* Accent bar */}
                <div class="h-1.5 w-full bg-gradient-to-r from-vibrant-pink to-accent-gold" />

                <div class="flex flex-1 flex-col p-6 sm:p-8">
                  {/* Outlet badge */}
                  <div class="mb-4 flex items-center gap-3">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-off-black/5">
                      <svg
                        class="h-5 w-5 text-vibrant-pink"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.5"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6V7.5z"
                        />
                      </svg>
                    </div>
                    <span class="text-sm font-bold uppercase tracking-wider text-vibrant-pink">
                      {article.outlet}
                    </span>
                  </div>

                  {/* Title */}
                  <h2 class="text-xl font-bold leading-snug text-off-black sm:text-2xl">
                    {article.title}
                  </h2>

                  {/* Description */}
                  <p class="mt-3 flex-1 text-base leading-relaxed text-medium-gray">
                    {article.description}
                  </p>

                  {/* CTA */}
                  <div class="mt-6 pt-4 border-t border-gray-100">
                    <a
                      href={article.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn inline-flex items-center gap-2 rounded-full bg-off-black px-6 py-2.5 text-sm font-bold text-white shadow-md transition-all hover:scale-105 hover:shadow-lg"
                    >
                      Read Full Article
                      <svg
                        class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2.5"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                        />
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>
    {/* END: Press Articles */}

    {/* START: Media Inquiries CTA */}
    <section class="bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
        <h2
          class="font-sans text-3xl font-bold tracking-tight text-off-black sm:text-4xl"
        >
          Media Inquiries
        </h2>
        <p class="mt-4 font-body text-lg text-medium-gray">
          For press inquiries, interviews, or media collaborations, we'd love to
          hear from you. Reach out and let's share the story of wellness,
          community, and empowerment together.
        </p>
        <div class="mt-8">
          <a
            href={`${base}contact`}
            class="btn inline-flex items-center gap-2 rounded-full bg-vibrant-pink px-8 py-3 text-base font-bold text-white shadow-lg transition hover:scale-105 focus:outline-none focus:ring-2 focus:ring-vibrant-pink focus:ring-offset-2"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              ></path>
            </svg>
            Get in Touch
          </a>
        </div>
      </div>
    </section>
    {/* END: Media Inquiries CTA */}
  </main>
</Layout>
