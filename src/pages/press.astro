---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import { pressArticles } from "@/data/press";
const base = import.meta.env.BASE_URL;
---

<Layout title="In the Press | Latina Sweat Project">
  <Header />
  <main>
    {/* Hero Header */}
    <section class="relative bg-off-black py-20 sm:py-28">
      <div class="absolute inset-0 bg-gradient-to-br from-vibrant-pink/10 via-transparent to-accent-gold/10"></div>
      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-sm font-bold uppercase tracking-widest text-vibrant-pink">
          Media Coverage
        </p>
        <h1 class="mt-3 font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Latina Sweat Project<br />in the Press
        </h1>
        <p class="mt-6 mx-auto max-w-2xl font-body text-lg text-slate-300 sm:text-xl">
          See what the community is saying about our mission to make yoga and wellness accessible to all.
        </p>
      </div>
    </section>

    {/* Press Cards */}
    <section class="py-12 sm:py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          {pressArticles.map((article) => (
            <div class="group rounded-2xl bg-white p-8 shadow-sm border border-gray-100 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-vibrant-pink/20">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-vibrant-pink/10">
                  <svg class="h-5 w-5 text-vibrant-pink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                  </svg>
                </span>
                <p class="text-sm font-bold uppercase tracking-wider text-vibrant-pink">
                  {article.outlet}
                </p>
              </div>
              <h2 class="font-sans text-xl font-bold text-off-black leading-snug sm:text-2xl">
                {article.title}
              </h2>
              <p class="mt-3 font-body text-base text-medium-gray leading-relaxed">
                {article.snippet}
              </p>
              <a
                href={article.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex items-center gap-2 rounded-full bg-off-black px-6 py-2.5 text-sm font-bold text-white transition-all duration-300 hover:bg-vibrant-pink hover:scale-105 hover:shadow-lg"
              >
                {article.isVideo ? "Watch Full Spotlight" : "Read Full Article"}
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          ))}
        </div>

        {/* Back to Home CTA */}
        <div class="mt-16 text-center">
          <p class="font-body text-lg text-medium-gray mb-6">
            Want to learn more about our mission?
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a
              href={`${base}about`}
              class="btn inline-flex items-center gap-2 rounded-full bg-vibrant-pink px-8 py-3 text-base font-bold text-white shadow-lg transition-all hover:scale-105 hover:shadow-xl"
            >
              About Us
            </a>
            <a
              href="mailto:press@latinasweatproject.com"
              class="btn inline-flex items-center gap-2 rounded-full border-2 border-off-black px-8 py-3 text-base font-bold text-off-black transition-all hover:bg-off-black hover:text-white"
            >
              Get in Touch
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
