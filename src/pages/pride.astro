---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";

const base = import.meta.env.BASE_URL;
const withBase = (path) => `${base}${path.replace(/^\//, "")}`;

// Chicago Pride weekend events. Details confirmed against each organizer's
// page (linked); times and venues are subject to change, so the page carries a
// confirm-before-you-go note. Each card carries a single Pride accent so the
// set spans the flag without any one card going multi-color.
const events = [
  {
    day: "Sat",
    date: "Jun 27",
    time: "8:00 AM",
    tag: "Run / Walk",
    emoji: "👟",
    title: "Proud to Run 5K & 10K",
    venue: "Montrose Harbor",
    address: "400 W Montrose Harbor Dr · Uptown",
    description:
      "Run or walk a 5K or 10K along the lakefront. Proud to Run gives 100% of its net proceeds to LGBTQ nonprofits across Chicago, and it is staffed entirely by volunteers.",
    note: "Registration required",
    cta: "Register to run",
    url: "https://www.proudtorunchicago.org/",
    accent: "#c81e2b",
  },
  {
    day: "Sat",
    date: "Jun 27",
    time: "11:00 AM to 1:00 PM",
    tag: "Pilates · 21+",
    emoji: "🧘🏽‍♀️",
    title: "Pride Pilates Party",
    venue: "Center on Halsted",
    address: "3656 N Halsted St · Northalsted",
    description:
      "A Pilates class led by our own lizlates, then a rooftop party to dance and socialize. Our kind of Pride morning: move first, celebrate after.",
    note: "Tickets · 21+",
    cta: "Get tickets",
    url: "https://northalsted.com/events/pride-pilates-party/",
    accent: "#d6249f",
  },
  {
    day: "Sun",
    date: "Jun 28",
    time: "11:00 AM",
    tag: "Parade",
    emoji: "🏳️‍🌈",
    title: "Chicago Pride Parade",
    venue: "Northalsted",
    address: "Starts at Sheridan & Broadway · viewing from Grace & Broadway",
    description:
      "The city's iconic Pride Parade returns to Northalsted under the theme “Free to Be Proud.” Come celebrate love, unity, and how far we have come, together.",
    note: "Free admission",
    cta: "Parade details",
    url: "https://pridechicago.org/",
    accent: "#3b6fe0",
  },
  {
    day: "Sat & Sun",
    date: "Jun 27 & 28",
    time: "4:00 to 10:30 PM",
    tag: "Music Festival",
    emoji: "🎶",
    title: "Back Lot Bash",
    venue: "Cheetah Gym",
    address: "5248 N Clark St · Uptown",
    description:
      "A block-party music festival centering women and non-binary artists, 20+ years strong. Live music and DJ sets all weekend long.",
    note: "Tickets",
    cta: "Get tickets",
    url: "https://pridechicago.org/event/back-lot-bash-chicago/2026-06-28/",
    accent: "#15803d",
  },
];

// Teacher spotlights. The card images are the marketing team's designed Pride
// cards (Instagram carousel), shown in a swipeable deck per teacher with full
// alt text so the Q&A is available to assistive tech and search.
const spotlights = [
  {
    id: "luz",
    name: "Luz Rodriguez",
    pronouns: "she/her/ella",
    accent: "#9333ea",
    practice: "Yoga · Movement · Cycle healing",
    schedule: "Flow with Luz · Thursdays at 7:00 AM",
    bio: "A healer and leader in our community. Through yoga, movement, and cycle healing, Luz holds space for women and queer folks to reconnect with their inner wisdom, honor their cycles, and find liberation within their own bodies.",
    quote: "Womb work is liberation work.",
    mediaSide: "right",
    cards: [
      {
        src: "images/pridespotlight/1.jpg",
        alt: "Teacher Spotlight: Luz Rodriguez, she/her/ella.",
      },
      {
        src: "images/pridespotlight/2.jpg",
        alt: "Luz on what Pride means to her: celebrating the progress our queer ancestors fought for with their lives, and demanding better for all of us, especially our trans friends.",
      },
      {
        src: "images/pridespotlight/3.jpg",
        alt: "Luz on keeping LGBTQ+ folks safe in her practice: she uses inclusive language like “friends” and offers modifications throughout class so students feel safe to try new things in their bodies.",
      },
      {
        src: "images/pridespotlight/4.jpg",
        alt: "Luz on showing up for community: she creates spaces for women and queer folks to connect with themselves, each other, and the cycles of nature through her business, Grounded Goddess.",
      },
      {
        src: "images/pridespotlight/5.jpg",
        alt: "Luz on how movement serves the queer community: yoga is liberation from systems that try to place us in one box, helping queer people regulate their nervous systems and fully express themselves through movement and breath.",
      },
    ],
  },
  {
    id: "lizlates",
    name: "lizlates",
    pronouns: "she/her",
    accent: "#0ea5e9",
    practice: "Pilates · Community",
    schedule: "Flow with Liz · Mondays & Wednesdays at 12:00 PM",
    bio: "A community builder whose energy makes every room feel like a safe space. From her cues to her language, Liz makes it known that whoever you are and however you identify, you belong here, on the mat at LSP and at her inclusive classes across the city.",
    quote:
      "Pilates is so much more than pulses and breathing. The mindfulness and connection to your body lets everyone, especially queer folks, be in a safe space just for themselves.",
    mediaSide: "left",
    cards: [
      {
        src: "images/pridespotlight/6.jpg",
        alt: "Teacher Spotlight: lizlates, she/her.",
      },
      {
        src: "images/pridespotlight/7.jpg",
        alt: "Liz on what Pride means to her: being your most authentic self everywhere you go.",
      },
      {
        src: "images/pridespotlight/8.jpg",
        alt: "Liz on keeping LGBTQ+ folks safe and seen: as an out queer instructor she sets the tone that her classes are a safe space, and uses gender-inclusive language so everyone knows they belong.",
      },
      {
        src: "images/pridespotlight/9.jpg",
        alt: "Liz on showing up for community: she hosts inclusive, accessible Pilates classes and events across Chicago, and pours 100% into every student.",
      },
      {
        src: "images/pridespotlight/10.jpg",
        alt: "Liz on how Pilates serves the queer community: mindfulness and connection to your body, a safe space just for yourself, dedicating time to care for the most important person there is, you.",
      },
    ],
  },
];

// Pride history timeline. `node` is the saturated flag color for the dot on the
// rainbow spine; `accent` is a brightened version used for legible text on the
// dark page.
const prideHistory = [
  {
    era: "Before Pride",
    node: "#e40303",
    accent: "#ff6b6b",
    date: "The 1950s & '60s",
    headline: "Raids, then resistance",
    body: [
      "Police raids on bars and the safe havens of queer life were common across the United States.",
      "Through the 1950s and '60s, early LGBTQ+ activists began to unite and advocate for the simple right to exist, laying the foundation for everything that followed.",
    ],
  },
  {
    era: "Queer Liberation",
    node: "#1f9e3a",
    accent: "#4ade80",
    date: "June 28, 1969",
    headline: "The Stonewall Uprising",
    body: [
      "Demonstrations had begun as early as the 1950s, when activists gathered at Independence Hall to remind the country that queer citizens were denied basic civil rights.",
      "Then, on June 28, 1969, queer folks resisted a police raid at the Stonewall Inn in New York City. The uprising sparked days of protest and became one of the most documented turning points in the movement.",
      "On its first anniversary, activists organized the Christopher Street Liberation Day March in New York, with sister marches in Los Angeles, Chicago, and San Francisco.",
    ],
  },
  {
    era: "Chicago Pride History",
    node: "#732982",
    accent: "#c4a5f5",
    date: "June 27, 1970",
    headline: "Chicago marches",
    body: [
      "Chicago held its first Pride march, one of the first U.S. cities to commemorate the anniversary of Stonewall.",
      "It began at Washington Square Park and traveled to the Water Tower, the start of a tradition our city still carries today.",
    ],
  },
];

// Movement elders honored in the tribute. Bios drawn from the cited sources;
// both were trans women of color central to Stonewall and co-founders of STAR.
const activists = [
  {
    initials: "MJ",
    name: "Marsha P. Johnson",
    years: "1945 to 1992",
    role: "Stonewall vanguard · Co-founder of STAR",
    quote: "Pay it no mind.",
    quoteNote: "her answer when asked what the “P” stood for",
    bio: "A Black trans woman, performer, and self-described drag queen, Marsha was a central figure in the 1969 Stonewall Uprising and, with Sylvia Rivera, co-founded STAR (Street Transvestite Action Revolutionaries) to shelter homeless queer and trans youth. Known as the “Saint of Christopher Street,” she later poured herself into AIDS activism, helping lay the foundation for the modern trans and queer liberation movements.",
  },
  {
    initials: "SR",
    name: "Sylvia Rivera",
    years: "1951 to 2002",
    role: "Gay Liberation Front · Co-founder of STAR",
    quote:
      "If it wasn't for the drag queen, there would be no gay liberation movement. We're the front-liners.",
    quoteNote: "Christopher Street Liberation Day rally, 1973",
    bio: "Of Puerto Rican and Venezuelan heritage, Sylvia was a Latina trans activist and a key figure at Stonewall who co-founded both the Gay Liberation Front and STAR. She fought fiercely so that trans people and queer people of color would never be left out of the movement. The Sylvia Rivera Law Project carries her name, and she became the first trans activist honored in the National Portrait Gallery.",
  },
];
---

<Layout
  title="Celebrating Pride | The Latina Sweat Project"
  description="June is Pride Month. The Latina Sweat Project honors the LGBTQIA+ community with ways to celebrate Pride in Chicago this weekend and a spotlight on our queer teachers, Luz Rodriguez and lizlates."
>
  <Header />
  <main class="bg-off-black text-white">
    {/* ===================== HERO ===================== */}
    <section class="relative overflow-hidden py-20 sm:py-28">
      <div class="pride-aurora" aria-hidden="true"></div>
      <div class="pride-bar absolute inset-x-0 top-0 h-1.5"></div>

      {/* Sparkle texture (echoes the spotlight cards) */}
      <div
        class="absolute inset-0 opacity-[0.07]"
        style="background-image: radial-gradient(circle at 18% 26%, #fff 0, transparent 1.4px), radial-gradient(circle at 74% 52%, #fff 0, transparent 1.1px), radial-gradient(circle at 42% 82%, #fff 0, transparent 1.3px), radial-gradient(circle at 88% 20%, #fff 0, transparent 1px); background-size: 120px 120px, 150px 150px, 95px 95px, 170px 170px;"
      >
      </div>

      {/* Ambient rainbow glows */}
      <div class="absolute -left-28 -top-12 h-72 w-1/2 rounded-full bg-[#e40303]/15 blur-[120px]"></div>
      <div class="absolute left-1/3 top-0 h-64 w-1/3 rounded-full bg-[#ff8c00]/12 blur-[120px]"></div>
      <div class="absolute -right-28 bottom-0 h-72 w-1/2 rounded-full bg-[#732982]/18 blur-[120px]"></div>
      <div class="absolute right-1/4 bottom-4 h-56 w-1/3 rounded-full bg-[#24408e]/14 blur-[120px]"></div>

      <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2.5 rounded-full border border-white/15 bg-white/[0.05] px-4 py-1.5 backdrop-blur-sm">
          <span class="text-base leading-none" aria-hidden="true">🏳️‍🌈</span>
          <span class="text-xs font-extrabold uppercase tracking-[0.28em] pride-text">
            June · Pride Month
          </span>
        </div>

        <h1 class="mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tight sm:text-6xl lg:text-7xl">
          Celebrating
          <span class="mt-1 block pride-text pride-flow">Pride in Chicago</span>
        </h1>

        <p class="mx-auto mt-7 max-w-2xl font-body text-lg leading-relaxed text-white/75 sm:text-xl">
          This month, we honor the LGBTQIA+ community: their history, their
          resilience, and the generations who fought so that everyone could live
          and love freely. At LSP, we are proud to celebrate and share this space
          with you.
        </p>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a
            href="#celebrate"
            class="btn group inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-bold text-off-black shadow-lg shadow-white/10 transition-all duration-300 hover:scale-105 hover:shadow-xl"
          >
            Celebrate this weekend
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </a>
          <a
            href="#spotlight"
            class="inline-flex items-center gap-2 rounded-full border-2 border-white/20 bg-white/5 px-6 py-3 text-sm font-bold text-white transition-all duration-300 hover:border-white/50 hover:bg-white/10"
          >
            Meet our teachers
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
    </section>

    {/* ===================== ROOTS OF PRIDE (history timeline) ===================== */}
    <section id="roots" class="relative scroll-mt-28 overflow-hidden py-16 sm:py-20">
      <div class="absolute -left-24 top-1/4 h-72 w-1/2 rounded-full bg-[#e40303]/10 blur-[130px]"></div>
      <div class="absolute -right-24 bottom-1/4 h-72 w-1/2 rounded-full bg-[#732982]/12 blur-[130px]"></div>

      <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="reveal text-center">
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] pride-text">Why we march</p>
          <h2 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-5xl">
            Pride is more than a celebration
          </h2>
          <p class="mx-auto mt-5 max-w-2xl font-body text-lg leading-relaxed text-white/75">
            It's a reminder of how far our community came to make sure that we,
            queer people today, have the guidance and strength to keep fighting
            for the right to exist.
          </p>
        </div>

        <ol class="pride-timeline relative mt-12 sm:mt-16">
          {
            prideHistory.map((item) => (
              <li class="reveal pride-timeline-item relative">
                <span class="pride-timeline-node" style={`--node:${item.node}`} aria-hidden="true" />
                <div class="flex flex-wrap items-center gap-2.5">
                  <p class="text-[11px] font-extrabold uppercase tracking-[0.25em]" style={`color:${item.accent}`}>
                    {item.era}
                  </p>
                  <span
                    class="inline-flex items-center rounded-full px-3 py-0.5 text-[11px] font-bold uppercase tracking-wider"
                    style={`color:${item.accent}; background:${item.node}1f; border:1px solid ${item.node}55`}
                  >
                    {item.date}
                  </span>
                </div>
                <h3 class="mt-2 font-display text-2xl font-bold tracking-tight text-white sm:text-3xl">
                  {item.headline}
                </h3>
                <div class="mt-3 space-y-3">
                  {item.body.map((para) => (
                    <p class="font-body text-[15px] leading-relaxed text-white/70">{para}</p>
                  ))}
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    {/* ===================== ACTIVISTS WHO LIT THE WAY ===================== */}
    <section class="relative overflow-hidden py-16 sm:py-20">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
      <div class="absolute left-1/2 top-1/3 h-64 w-2/3 -translate-x-1/2 rounded-full bg-[#5BCEFA]/[0.08] blur-[130px]"></div>

      <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="reveal mb-10 text-center sm:mb-12">
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] pride-text">Honoring our elders</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            The activists who lit the way
          </h2>
          <p class="mx-auto mt-4 max-w-2xl font-body text-base text-white/60 sm:text-lg">
            Again and again, the movement was led by trans women of color. Two of
            them lit the way for everyone who came after.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {
            activists.map((a) => (
              <article class="reveal relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.04] p-7 shadow-xl shadow-black/20 sm:p-8">
                <div class="trans-rule absolute inset-x-0 top-0 h-1" />
                <div class="flex items-center gap-4">
                  <div class="activist-emblem">
                    <span aria-hidden="true">{a.initials}</span>
                  </div>
                  <div>
                    <h3 class="font-display text-2xl font-bold leading-tight tracking-tight text-white sm:text-[1.7rem]">
                      {a.name}
                    </h3>
                    <p class="mt-1 text-[11px] font-bold uppercase tracking-[0.18em] text-white/45">{a.years}</p>
                    <p class="mt-1 text-[11px] font-bold uppercase tracking-wider text-[#f5a9b8]">{a.role}</p>
                  </div>
                </div>

                <figure class="mt-6 border-l-2 border-[#F5A9B8] pl-4">
                  <blockquote class="font-display text-lg italic leading-snug text-white/90 sm:text-xl">
                    &ldquo;{a.quote}&rdquo;
                  </blockquote>
                  <figcaption class="mt-2 text-[11px] uppercase tracking-wider text-white/40">{a.quoteNote}</figcaption>
                </figure>

                <p class="mt-5 font-body text-[15px] leading-relaxed text-white/70">{a.bio}</p>
              </article>
            ))
          }
        </div>

        <p class="reveal mt-8 text-center text-xs text-white/40">
          Histories drawn from{" "}
          <a href="https://en.wikipedia.org/wiki/Marsha_P._Johnson" target="_blank" rel="noopener noreferrer" class="font-semibold text-white/60 underline decoration-white/20 underline-offset-2 transition-colors hover:text-white">Wikipedia</a>,
          the{" "}
          <a href="https://www.womenshistory.org/education-resources/biographies/sylvia-rivera" target="_blank" rel="noopener noreferrer" class="font-semibold text-white/60 underline decoration-white/20 underline-offset-2 transition-colors hover:text-white">National Women's History Museum</a>, and{" "}
          <a href="https://www.biography.com/activists/marsha-p-johnson" target="_blank" rel="noopener noreferrer" class="font-semibold text-white/60 underline decoration-white/20 underline-offset-2 transition-colors hover:text-white">Biography</a>.
        </p>
      </div>
    </section>

    {/* ===================== HAUS OF LSP (mission) ===================== */}
    <section class="relative overflow-hidden py-16 sm:py-20">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
      <div class="absolute -right-24 top-0 h-72 w-1/2 rounded-full bg-[#732982]/12 blur-[130px]"></div>
      <div class="absolute -left-24 bottom-0 h-72 w-1/2 rounded-full bg-[#e40303]/[0.08] blur-[130px]"></div>

      <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="reveal relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.04] p-8 shadow-2xl shadow-black/30 sm:p-10">
          <div class="pride-bar-v absolute inset-y-0 left-0 w-1.5"></div>
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] pride-text">Latina Sweat's Pride mission</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">Haus of LSP</h2>

          <p class="mt-5 font-body text-base leading-relaxed text-white/75 sm:text-lg">
            At the Latina Sweat Project, we honor the powerful queer leaders who
            came before us and uplift the queer leaders standing with us today. We
            believe it is imperative to acknowledge the social and political moment
            we are in, to question what gets normalized, and to remember that it is
            our right as humans to unite and resist what is harmful and unjust.
          </p>
          <p class="mt-4 font-body text-base leading-relaxed text-white/75 sm:text-lg">
            Haus of LSP has become our symbol of a safe haven for the queer
            community across the Southwest Side of Chicago. Here, we are devoted to
            amplifying queer presence, representation, and liberation.
          </p>

          <blockquote class="mt-7 font-display text-2xl font-bold italic leading-snug sm:text-3xl">
            <span class="pride-text pride-flow">The liberation of our community, our people, ourselves.</span>
          </blockquote>
        </div>
      </div>
    </section>

    {/* ===================== HONORING STATEMENT ===================== */}
    <section class="relative py-14 sm:py-16">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="reveal relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.04] p-8 shadow-2xl shadow-black/30 sm:p-10">
          <div class="pride-bar-v absolute inset-y-0 left-0 w-1.5"></div>
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] pride-text">
            Together, with intention and joy
          </p>
          <p class="mt-5 font-body text-xl leading-relaxed text-white/85 sm:text-2xl">
            Let's close out Pride the right way: together, in our communities,
            with intention and joy.
          </p>
          <p class="mt-5 font-body text-base leading-relaxed text-white/60 sm:text-lg">
            Here are some of the events happening across Chicago this weekend to
            celebrate Pride. <span aria-hidden="true">❤️</span>
          </p>
        </div>
      </div>
    </section>

    {/* ===================== CELEBRATE THIS WEEKEND ===================== */}
    <section id="celebrate" class="relative scroll-mt-28 py-12 sm:py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 text-center sm:mb-12">
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] pride-text">
            Pride in Chicago
          </p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            Amazing ways to show up
          </h2>
          <p class="mx-auto mt-4 max-w-2xl font-body text-base text-white/60 sm:text-lg">
            Four ways to celebrate with Pride this weekend, from the lakefront to
            Northalsted. Move, march, and dance in community.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {
            events.map((event) => (
              <article class="reveal group relative flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.035] shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-1 hover:border-white/20">
                <div class="pride-bar absolute inset-x-0 top-0 z-10 h-1"></div>

                <div class="flex flex-1 flex-col p-6 sm:p-7">
                  <div class="flex flex-wrap items-center gap-2.5">
                    <span
                      class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[11px] font-extrabold uppercase tracking-widest text-white"
                      style={`background:${event.accent}`}
                    >
                      {event.day} · {event.date}
                    </span>
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/75">
                      {event.time}
                    </span>
                    <span class="ml-auto inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-[0.18em] text-white/55">
                      <span class="text-sm not-italic" aria-hidden="true">{event.emoji}</span>
                      {event.tag}
                    </span>
                  </div>

                  <h3 class="mt-5 font-sans text-2xl font-extrabold leading-snug tracking-tight text-white sm:text-[1.7rem]">
                    {event.title}
                  </h3>

                  <div class="mt-3 flex items-start gap-2 text-sm text-white/65">
                    <svg class="mt-0.5 h-4 w-4 flex-shrink-0" style={`color:${event.accent}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
