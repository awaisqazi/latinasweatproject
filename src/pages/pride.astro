---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";

const base = import.meta.env.BASE_URL;
const withBase = (path) => `${base}${path.replace(/^\//, "")}`;

// Chicago Pride weekend events. Details confirmed against each organizer's
// page (linked); times and venues are subject to change, so the page carries a
// confirm-before-you-go note. Each card carries a single Pride accent so the
// set spans the flag without any one card going multi-color.
const events = [
  {
    day: "Sat",
    date: "Jun 27",
    time: "8:00 AM",
    tag: "Run / Walk",
    emoji: "👟",
    title: "Proud to Run 5K & 10K",
    venue: "Montrose Harbor",
    address: "400 W Montrose Harbor Dr · Uptown",
    description:
      "Run or walk a 5K or 10K along the lakefront. Proud to Run gives 100% of its net proceeds to LGBTQ nonprofits across Chicago, and it is staffed entirely by volunteers.",
    note: "Registration required",
    cta: "Register to run",
    url: "https://www.proudtorunchicago.org/",
    accent: "#c81e2b",
  },
  {
    day: "Sat",
    date: "Jun 27",
    time: "11:00 AM to 1:00 PM",
    tag: "Pilates · 21+",
    emoji: "🧘🏽‍♀️",
    title: "Pride Pilates Party",
    venue: "Center on Halsted",
    address: "3656 N Halsted St · Northalsted",
    description:
      "A Pilates class led by our own lizlates, then a rooftop party to dance and socialize. Our kind of Pride morning: move first, celebrate after.",
    note: "Tickets · 21+",
    cta: "Get tickets",
    url: "https://northalsted.com/events/pride-pilates-party/",
    accent: "#d6249f",
  },
  {
    day: "Sun",
    date: "Jun 28",
    time: "11:00 AM",
    tag: "Parade",
    emoji: "🏳️‍🌈",
    title: "Chicago Pride Parade",
    venue: "Northalsted",
    address: "Starts at Sheridan & Broadway · viewing from Grace & Broadway",
    description:
      "The city's iconic Pride Parade returns to Northalsted under the theme “Free to Be Proud.” Come celebrate love, unity, and how far we have come, together.",
    note: "Free admission",
    cta: "Parade details",
    url: "https://pridechicago.org/",
    accent: "#3b6fe0",
  },
  {
    day: "Sat & Sun",
    date: "Jun 27 & 28",
    time: "4:00 to 10:30 PM",
    tag: "Music Festival",
    emoji: "🎶",
    title: "Back Lot Bash",
    venue: "Cheetah Gym",
    address: "5248 N Clark St · Uptown",
    description:
      "A block-party music festival centering women and non-binary artists, 20+ years strong. Live music and DJ sets all weekend long.",
    note: "Tickets",
    cta: "Get tickets",
    url: "https://pridechicago.org/event/back-lot-bash-chicago/2026-06-28/",
    accent: "#15803d",
  },
];

// Teacher spotlights. The card images are the marketing team's designed Pride
// cards (Instagram carousel), shown in a swipeable deck per teacher with full
// alt text so the Q&A is available to assistive tech and search.
const spotlights = [
  {
    id: "luz",
    name: "Luz Rodriguez",
    pronouns: "she/her/ella",
    accent: "#9333ea",
    practice: "Yoga · Movement · Cycle healing",
    schedule: "Flow with Luz · Thursdays at 7:00 AM",
    bio: "A healer and leader in our community. Through yoga, movement, and cycle healing, Luz holds space for women and queer folks to reconnect with their inner wisdom, honor their cycles, and find liberation within their own bodies.",
    quote: "Womb work is liberation work.",
    mediaSide: "right",
    cards: [
      {
        src: "images/pridespotlight/1.jpg",
        alt: "Teacher Spotlight: Luz Rodriguez, she/her/ella.",
      },
      {
        src: "images/pridespotlight/2.jpg",
        alt: "Luz on what Pride means to her: celebrating the progress our queer ancestors fought for with their lives, and demanding better for all of us, especially our trans friends.",
      },
      {
        src: "images/pridespotlight/3.jpg",
        alt: "Luz on keeping LGBTQ+ folks safe in her practice: she uses inclusive language like “friends” and offers modifications throughout class so students feel safe to try new things in their bodies.",
      },
      {
        src: "images/pridespotlight/4.jpg",
        alt: "Luz on showing up for community: she creates spaces for women and queer folks to connect with themselves, each other, and the cycles of nature through her business, Grounded Goddess.",
      },
      {
        src: "images/pridespotlight/5.jpg",
        alt: "Luz on how movement serves the queer community: yoga is liberation from systems that try to place us in one box, helping queer people regulate their nervous systems and fully express themselves through movement and breath.",
      },
    ],
  },
  {
    id: "lizlates",
    name: "lizlates",
    pronouns: "she/her",
    accent: "#0ea5e9",
    practice: "Pilates · Community",
    schedule: "Flow with Liz · Mondays & Wednesdays at 12:00 PM",
    bio: "A community builder whose energy makes every room feel like a safe space. From her cues to her language, Liz makes it known that whoever you are and however you identify, you belong here, on the mat at LSP and at her inclusive classes across the city.",
    quote:
      "Pilates is so much more than pulses and breathing. The mindfulness and connection to your body lets everyone, especially queer folks, be in a safe space just for themselves.",
    mediaSide: "left",
    cards: [
      {
        src: "images/pridespotlight/6.jpg",
        alt: "Teacher Spotlight: lizlates, she/her.",
      },
      {
        src: "images/pridespotlight/7.jpg",
        alt: "Liz on what Pride means to her: being your most authentic self everywhere you go.",
      },
      {
        src: "images/pridespotlight/8.jpg",
        alt: "Liz on keeping LGBTQ+ folks safe and seen: as an out queer instructor she sets the tone that her classes are a safe space, and uses gender-inclusive language so everyone knows they belong.",
      },
      {
        src: "images/pridespotlight/9.jpg",
        alt: "Liz on showing up for community: she hosts inclusive, accessible Pilates classes and events across Chicago, and pours 100% into every student.",
      },
      {
        src: "images/pridespotlight/10.jpg",
        alt: "Liz on how Pilates serves the queer community: mindfulness and connection to your body, a safe space just for yourself, dedicating time to care for the most important person there is, you.",
      },
    ],
  },
];
---

<Layout
  title="Celebrating Pride | The Latina Sweat Project"
  description="June is Pride Month. The Latina Sweat Project honors the LGBTQIA+ community with ways to celebrate Pride in Chicago this weekend and a spotlight on our queer teachers, Luz Rodriguez and lizlates."
>
  <Header />
  <main class="bg-off-black text-white">
    {/* ===================== HERO ===================== */}
    <section class="relative overflow-hidden py-20 sm:py-28">
      <div class="pride-bar absolute inset-x-0 top-0 h-1.5"></div>

      {/* Sparkle texture (echoes the spotlight cards) */}
      <div
        class="absolute inset-0 opacity-[0.07]"
        style="background-image: radial-gradient(circle at 18% 26%, #fff 0, transparent 1.4px), radial-gradient(circle at 74% 52%, #fff 0, transparent 1.1px), radial-gradient(circle at 42% 82%, #fff 0, transparent 1.3px), radial-gradient(circle at 88% 20%, #fff 0, transparent 1px); background-size: 120px 120px, 150px 150px, 95px 95px, 170px 170px;"
      >
      </div>

      {/* Ambient rainbow glows */}
      <div class="absolute -left-28 -top-12 h-72 w-1/2 rounded-full bg-[#e40303]/15 blur-[120px]"></div>
      <div class="absolute left-1/3 top-0 h-64 w-1/3 rounded-full bg-[#ff8c00]/12 blur-[120px]"></div>
      <div class="absolute -right-28 bottom-0 h-72 w-1/2 rounded-full bg-[#732982]/18 blur-[120px]"></div>
      <div class="absolute right-1/4 bottom-4 h-56 w-1/3 rounded-full bg-[#24408e]/14 blur-[120px]"></div>

      <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2.5 rounded-full border border-white/15 bg-white/[0.05] px-4 py-1.5 backdrop-blur-sm">
          <span class="text-base leading-none" aria-hidden="true">🏳️‍🌈</span>
          <span class="text-xs font-extrabold uppercase tracking-[0.28em] pride-text">
            June · Pride Month
          </span>
        </div>

        <h1 class="mt-6 font-display text-5xl font-bold leading-[1.02] tracking-tight sm:text-6xl lg:text-7xl">
          Celebrating
          <span class="mt-1 block pride-text">Pride in Chicago</span>
        </h1>

        <p class="mx-auto mt-7 max-w-2xl font-body text-lg leading-relaxed text-white/75 sm:text-xl">
          This month, we honor the LGBTQIA+ community: their history, their
          resilience, and the generations who fought so that everyone could live
          and love freely. At LSP, we are proud to celebrate and share this space
          with you.
        </p>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a
            href="#celebrate"
            class="btn group inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-bold text-off-black shadow-lg shadow-white/10 transition-all duration-300 hover:scale-105 hover:shadow-xl"
          >
            Celebrate this weekend
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </a>
          <a
            href="#spotlight"
            class="inline-flex items-center gap-2 rounded-full border-2 border-white/20 bg-white/5 px-6 py-3 text-sm font-bold text-white transition-all duration-300 hover:border-white/50 hover:bg-white/10"
          >
            Meet our teachers
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
    </section>

    {/* ===================== HONORING STATEMENT ===================== */}
    <section class="relative py-14 sm:py-16">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="reveal relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.04] p-8 shadow-2xl shadow-black/30 sm:p-10">
          <div class="pride-bar-v absolute inset-y-0 left-0 w-1.5"></div>
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] pride-text">
            Together, with intention and joy
          </p>
          <p class="mt-5 font-body text-xl leading-relaxed text-white/85 sm:text-2xl">
            Let's close out Pride the right way: together, in our communities,
            with intention and joy.
          </p>
          <p class="mt-5 font-body text-base leading-relaxed text-white/60 sm:text-lg">
            Here are some of the events happening across Chicago this weekend to
            celebrate Pride. <span aria-hidden="true">❤️</span>
          </p>
        </div>
      </div>
    </section>

    {/* ===================== CELEBRATE THIS WEEKEND ===================== */}
    <section id="celebrate" class="relative scroll-mt-28 py-12 sm:py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 text-center sm:mb-12">
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] pride-text">
            Pride in Chicago
          </p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            Amazing ways to show up
          </h2>
          <p class="mx-auto mt-4 max-w-2xl font-body text-base text-white/60 sm:text-lg">
            Four ways to celebrate with Pride this weekend, from the lakefront to
            Northalsted. Move, march, and dance in community.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {
            events.map((event) => (
              <article class="reveal group relative flex flex-col overflow-hidden rounded-3xl border border-white/10 bg-white/[0.035] shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-1 hover:border-white/20">
                <div class="pride-bar absolute inset-x-0 top-0 z-10 h-1"></div>

                <div class="flex flex-1 flex-col p-6 sm:p-7">
                  <div class="flex flex-wrap items-center gap-2.5">
                    <span
                      class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[11px] font-extrabold uppercase tracking-widest text-white"
                      style={`background:${event.accent}`}
                    >
                      {event.day} · {event.date}
                    </span>
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/75">
                      {event.time}
                    </span>
                    <span class="ml-auto inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-[0.18em] text-white/55">
                      <span class="text-sm not-italic" aria-hidden="true">{event.emoji}</span>
                      {event.tag}
                    </span>
                  </div>

                  <h3 class="mt-5 font-sans text-2xl font-extrabold leading-snug tracking-tight text-white sm:text-[1.7rem]">
                    {event.title}
                  </h3>

                  <div class="mt-3 flex items-start gap-2 text-sm text-white/65">
                    <svg class="mt-0.5 h-4 w-4 flex-shrink-0" style={`color:${event.accent}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>
                      <span class="font-bold text-white/85">{event.venue}</span>
                      <span class="text-white/55"> · {event.address}</span>
                    </span>
                  </div>

                  <p class="mt-4 font-body text-[15px] leading-relaxed text-white/70">
                    {event.description}
                  </p>

                  <div class="mt-auto flex flex-wrap items-center justify-between gap-3 pt-6">
                    <span
                      class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white/85"
                      style={`background:${event.accent}26; border:1px solid ${event.accent}66`}
                    >
                      {event.note}
                    </span>
                    <a
                      href={event.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group/cta inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-bold text-white shadow-lg transition-all duration-300 hover:scale-[1.03]"
                      style={`background:${event.accent}; box-shadow:0 10px 24px -10px ${event.accent}`}
                    >
                      {event.cta}
                      <svg class="h-4 w-4 transition-transform group-hover/cta:translate-x-0.5 group-hover/cta:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <p class="mt-8 text-center text-xs text-white/40">
          Details are subject to change, so confirm date, time, and tickets with
          each organizer before you go. LSP is not the host of these community
          events; we are simply sharing the love.
        </p>
      </div>
    </section>

    {/* ===================== TEACHER SPOTLIGHT (swipeable decks) ===================== */}
    <section id="spotlight" class="relative scroll-mt-28 overflow-hidden py-16 sm:py-20">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
      <div class="absolute -left-24 top-1/4 h-72 w-1/2 rounded-full bg-[#9333ea]/12 blur-[130px]"></div>
      <div class="absolute -right-24 bottom-1/4 h-72 w-1/2 rounded-full bg-[#0ea5e9]/12 blur-[130px]"></div>

      <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-12 text-center sm:mb-16">
          <p class="text-xs font-extrabold uppercase tracking-[0.25em] pride-text">
            Pride at LSP · Teacher Spotlight
          </p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            The teachers holding space
          </h2>
          <p class="mx-auto mt-4 max-w-2xl font-body text-base text-white/60 sm:text-lg">
            This Pride, meet two of the queer teachers who make LSP a place where
            everyone belongs. Swipe through each spotlight.
          </p>
        </div>

        <div class="space-y-16 sm:space-y-24">
          {
            spotlights.map((t) => (
              <div class="reveal grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
                {/* Info column */}
                <div class={t.mediaSide === "left" ? "lg:order-2" : "lg:order-1"}>
                  <p
                    class="text-xs font-extrabold uppercase tracking-[0.25em]"
                    style={`color:${t.accent}`}
                  >
                    Teacher Spotlight
                  </p>
                  <div class="mt-3 flex flex-wrap items-center gap-3">
                    <h3 class="font-display text-4xl font-bold leading-none tracking-tight sm:text-5xl">
                      {t.name}
                    </h3>
                    <span
                      class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold text-white"
                      style={`background:${t.accent}2e; border:1px solid ${t.accent}99`}
                    >
                      {t.pronouns}
                    </span>
                  </div>
                  <p class="mt-3 text-sm font-bold uppercase tracking-[0.18em] text-white/55">
                    {t.practice}
                  </p>

                  <p class="mt-5 font-body text-[15px] leading-relaxed text-white/75 sm:text-base">
                    {t.bio}
                  </p>

                  <figure
                    class="mt-6 border-l-2 pl-4"
                    style={`border-color:${t.accent}`}
                  >
                    <blockquote class="font-display text-xl italic leading-snug text-white/90 sm:text-2xl">
                      &ldquo;{t.quote}&rdquo;
                    </blockquote>
                    <figcaption class="mt-2 text-xs font-bold uppercase tracking-wider text-white/45">
                      {t.name}
                    </figcaption>
                  </figure>

                  <div class="mt-7 flex flex-wrap items-center gap-3">
                    <span
                      class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-bold text-white"
                      style={`background:${t.accent}1f; border:1px solid ${t.accent}66`}
                    >
                      <svg class="h-4 w-4" style={`color:${t.accent}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3M4 11h16M5 5h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z" />
                      </svg>
                      {t.schedule}
                    </span>
                    <a
                      href={withBase("schedule")}
                      class="btn group inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 text-sm font-bold text-off-black shadow-lg transition-all duration-300 hover:scale-105"
                      data-conversion-event="class_booking_start"
                      data-conversion-context={`pride_spotlight_${t.id}`}
                      data-conversion-booking-path="schedule_page"
                    >
                      Book a class
                      <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                      </svg>
                    </a>
                  </div>
                </div>

                {/* Swipeable card deck */}
                <div class={t.mediaSide === "left" ? "lg:order-1" : "lg:order-2"}>
                  <div
                    class="spotlight-deck group/deck relative mx-auto w-full max-w-[360px]"
                    data-deck
                    style={`--deck-accent:${t.accent}`}
                  >
                    <div
                      class="deck-track"
                      data-deck-track
                      tabindex="0"
                      role="group"
                      aria-roledescription="carousel"
                      aria-label={`${t.name} Pride spotlight, ${t.cards.length} cards`}
                    >
                      {t.cards.map((card, i) => (
                        <figure
                          class="deck-slide"
                          role="group"
                          aria-roledescription="slide"
                          aria-label={`Card ${i + 1} of ${t.cards.length}`}
                        >
                          <img
                            src={withBase(card.src)}
                            alt={card.alt}
                            width="1000"
                            height="1250"
                            loading="lazy"
                            decoding="async"
                          />
                        </figure>
                      ))}
                    </div>

                    <button
                      type="button"
                      class="deck-arrow deck-arrow--prev"
                      data-deck-prev
                      aria-label={`Previous card for ${t.name}`}
                    >
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
                      </svg>
                    </button>
                    <button
                      type="button"
                      class="deck-arrow deck-arrow--next"
                      data-deck-next
                      aria-label={`Next card for ${t.name}`}
                    >
                      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
                      </svg>
                    </button>

                    <div class="deck-dots" data-deck-dots role="tablist" aria-label={`Choose a ${t.name} spotlight card`}></div>
                    <p class="sr-only" aria-live="polite" data-deck-status></p>
                    <p class="deck-hint">Swipe to read the full spotlight</p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* ===================== CLOSING ===================== */}
    <section class="relative overflow-hidden py-16 sm:py-20">
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
      <div class="absolute -bottom-16 left-1/2 h-64 w-3/4 -translate-x-1/2 rounded-full bg-[#9333ea]/12 blur-[120px]"></div>

      <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
        <p class="text-xs font-extrabold uppercase tracking-[0.25em] pride-text">
          Everyone belongs here
        </p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
          Celebrate Pride with us on the mat
        </h2>
        <p class="mx-auto mt-5 font-body text-base leading-relaxed text-white/65 sm:text-lg">
          Pride lives in how we move, rest, and gather. Come breathe, sweat, and
          celebrate in community, in a space made for every body and every
          identity.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href={withBase("schedule")}
            class="btn inline-flex items-center gap-2 rounded-full bg-white px-7 py-3 text-sm font-bold text-off-black shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-xl"
            data-conversion-event="class_booking_start"
            data-conversion-context="pride_closing"
            data-conversion-booking-path="schedule_page"
          >
            See our class schedule
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href={withBase("about")}
            class="inline-flex items-center gap-2 rounded-full border-2 border-white/20 bg-white/5 px-7 py-3 text-sm font-bold text-white transition-all duration-300 hover:border-white/50 hover:bg-white/10"
          >
            About LSP
          </a>
        </div>
      </div>
      <div class="pride-bar absolute inset-x-0 bottom-0 h-1.5"></div>
    </section>
  </main>
</Layout>

<style is:global>
  /* Rainbow accents, scoped to the Pride page */
  .pride-bar {
    background: linear-gradient(
      90deg,
      #e40303,
      #ff8c00,
      #ffd000,
      #008026,
      #24408e,
      #732982
    );
  }
  .pride-bar-v {
    background: linear-gradient(
      180deg,
      #e40303,
      #ff8c00,
      #ffd000,
      #008026,
      #24408e,
      #732982
    );
  }
  .pride-text {
    background: linear-gradient(
      90deg,
      #ff5a5a,
      #ff9e3d,
      #ffe14d,
      #4ade80,
      #38bdf8,
      #a78bfa
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* ---- Swipeable spotlight deck ---- */
  .spotlight-deck {
    --deck-accent: #9333ea;
  }
  .deck-track {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    border-radius: 1.5rem;
    -ms-overflow-style: none;
    scrollbar-width: none;
    outline: none;
  }
  .deck-track::-webkit-scrollbar {
    display: none;
  }
  .deck-track:focus-visible {
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.35);
  }
  .deck-slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
    margin: 0;
  }
  .deck-slide img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 1.5rem;
    background: #fff;
    box-shadow: 0 24px 50px -20px rgba(0, 0, 0, 0.6);
    /* Rainbow hairline frame */
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .deck-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    width: 40px;
    border-radius: 9999px;
    color: #fff;
    /* Dark overlay over the accent keeps the white glyph above the 3:1
       non-text contrast bar on every accent (incl. the lighter sky). */
    background: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)),
      var(--deck-accent);
    box-shadow: 0 8px 22px -8px rgba(0, 0, 0, 0.8);
    opacity: 0.92;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
    z-index: 5;
  }
  .deck-arrow:hover {
    transform: translateY(-50%) scale(1.08);
    opacity: 1;
  }
  .deck-arrow:disabled {
    opacity: 0;
    pointer-events: none;
  }
  /* On phones keep arrows inside the deck box so they never hang off-screen;
     pull them outside the card only once there's room at lg. */
  .deck-arrow--prev {
    left: 6px;
  }
  .deck-arrow--next {
    right: 6px;
  }
  @media (min-width: 1024px) {
    .deck-arrow--prev {
      left: -18px;
    }
    .deck-arrow--next {
      right: -18px;
    }
  }

  .deck-dots {
    display: flex;
    justify-content: center;
    gap: 7px;
    margin-top: 16px;
  }
  .deck-dot {
    height: 7px;
    width: 7px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.28);
    transition:
      width 0.25s ease,
      background 0.25s ease;
  }
  .deck-dot.is-active {
    width: 22px;
    background: var(--deck-accent);
  }
  .deck-hint {
    margin-top: 10px;
    text-align: center;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }
  @media (min-width: 1024px) {
    /* On desktop, fade the hint once they can see the arrows */
    .spotlight-deck:hover .deck-hint {
      opacity: 0.6;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .deck-track {
      scroll-behavior: auto;
    }
  }
</style>

<script>
  // Swipeable spotlight decks: native scroll-snap handles touch/trackpad;
  // this wires arrows, dot pagination, and keyboard arrows on top.
  const setupDeck = (deck: HTMLElement) => {
    const track = deck.querySelector<HTMLElement>("[data-deck-track]");
    const prev = deck.querySelector<HTMLButtonElement>("[data-deck-prev]");
    const next = deck.querySelector<HTMLButtonElement>("[data-deck-next]");
    const dotsWrap = deck.querySelector<HTMLElement>("[data-deck-dots]");
    if (!track || !prev || !next || !dotsWrap) return;

    const slides = Array.from(track.children) as HTMLElement[];
    if (!slides.length) return;

    // Build dot indicators (real tablist controls, exposed to assistive tech)
    const dots = slides.map((_, i) => {
      const dot = document.createElement("button");
      dot.type = "button";
      dot.className = "deck-dot";
      dot.setAttribute("role", "tab");
      dot.setAttribute("aria-label", `Go to card ${i + 1}`);
      dot.addEventListener("click", () => go(i));
      dotsWrap.appendChild(dot);
      return dot;
    });

    const status = deck.querySelector<HTMLElement>("[data-deck-status]");
    const prefersReduced = () =>
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const currentIndex = () =>
      Math.round(track.scrollLeft / track.clientWidth);

    const go = (i: number) => {
      const clamped = Math.max(0, Math.min(slides.length - 1, i));
      track.scrollTo({
        left: clamped * track.clientWidth,
        behavior: prefersReduced() ? "auto" : "smooth",
      });
    };

    const update = () => {
      const c = currentIndex();
      dots.forEach((d, i) => {
        const active = i === c;
        d.classList.toggle("is-active", active);
        d.setAttribute("aria-selected", active ? "true" : "false");
      });
      prev.disabled = c <= 0;
      next.disabled = c >= slides.length - 1;
      if (status) status.textContent = `Card ${c + 1} of ${slides.length}`;
    };

    prev.addEventListener("click", () => go(currentIndex() - 1));
    next.addEventListener("click", () => go(currentIndex() + 1));

    let raf = 0;
    track.addEventListener(
      "scroll",
      () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(update);
      },
      { passive: true },
    );

    track.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") {
        e.preventDefault();
        go(currentIndex() + 1);
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        go(currentIndex() - 1);
      }
    });

    window.addEventListener("resize", () => {
      // Re-center the current card after a width change so dots/arrows stay in sync.
      const c = currentIndex();
      track.scrollTo({ left: c * track.clientWidth, behavior: "auto" });
      requestAnimationFrame(update);
    });
    update();
  };

  document
    .querySelectorAll<HTMLElement>("[data-deck]")
    .forEach((deck) => setupDeck(deck));
</script>
