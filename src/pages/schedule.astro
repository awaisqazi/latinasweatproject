    <style>
      /* Tighten the gap between the trouble-viewing line and the MarianaTek widget.
         The widget renders its own top spacing inside an iframe-like container we
         can't reach, but we can pull the wrapper up to compensate. */
      .schedule-widget-tight {
        margin-top: -0.5rem;
      }
      .schedule-widget-tight > * {
        margin-top: 0 !important;
        padding-top: 0 !important;
      }

      .sched-pill {
        display: inline-flex;
        align-items: center;
        padding: 4px 8px;
        border-radius: 6px;
        background: #fffbeb;
        border: 1px solid rgba(255, 189, 89, 0.4);
        font-size: 11px;
        font-weight: 700;
        color: #1e1e1e;
        line-height: 1.2;
        transition: all 0.25s ease;
      }
      .sched-pill--emerald {
        background: #ecfdf5;
        border-color: rgba(110, 231, 183, 1);
        padding: 12px 20px;
        font-size: 15px;
        border-radius: 10px;
      }
      .pilsen-date {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1px;
        padding: 6px 6px;
        border-radius: 8px;
        background: #fffbeb;
        border: 1.5px solid rgba(255, 189, 89, 0.45);
        transition: all 0.25s ease;
      }
      .pilsen-date:hover {
        background: rgba(255, 189, 89, 0.18);
        border-color: rgba(255, 189, 89, 0.75);
        transform: scale(1.02);
      }
      .pilsen-date__day {
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 0.08em;
        color: #92400e;
        line-height: 1;
      }
      .pilsen-date__num {
        font-size: 1.125rem;
        font-weight: 800;
        line-height: 1;
        color: #1e1e1e;
        margin-top: 1px;
      }
      .pilsen-date__month {
        font-size: 9px;
        font-weight: 600;
        color: rgba(30, 30, 30, 0.55);
        line-height: 1;
      }
      .pilsen-date[data-free-next="true"] {
        background: linear-gradient(135deg, #ffbd59, #ffd28a);
        border-color: #ffbd59;
        transform: scale(1.04);
        box-shadow: 0 8px 20px -4px rgba(255, 189, 89, 0.5);
        animation: sched-pulse-gold 2.2s ease-in-out infinite;
      }
      .pilsen-date[data-free-next="true"]::before {
        content: '↓ NEXT';
        position: absolute;
        top: -10px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 8px;
        font-weight: 800;
        letter-spacing: 0.08em;
        padding: 2px 6px;
        border-radius: 4px;
        background: #b5a18d;
        color: #fff;
        white-space: nowrap;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
      }

      .sched-pill[data-free-next="true"] {
        position: relative;
        background: linear-gradient(135deg, #ffbd59, #ffd28a);
        border-color: #ffbd59;
        color: #1e1e1e;
        transform: none;
        box-shadow: 0 4px 12px -2px rgba(255, 189, 89, 0.5);
        animation: sched-pulse-gold 2.2s ease-in-out infinite;
      }
      .sched-pill--emerald[data-free-next="true"] {
        background: linear-gradient(135deg, #34d399, #6ee7b7);
        border-color: #34d399;
        color: #064e3b;
        box-shadow: 0 4px 12px -2px rgba(52, 211, 153, 0.5);
        animation: sched-pulse-emerald 2.2s ease-in-out infinite;
      }
      .sched-pill[data-free-next="true"]::before {
        content: '↓ NEXT';
        position: absolute;
        top: -11px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 8px;
        font-weight: 800;
        letter-spacing: 0.08em;
        padding: 2px 6px;
        border-radius: 4px;
        background: #b5a18d;
        color: #fff;
        white-space: nowrap;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
      }
      @keyframes sched-pulse-gold {
        0%, 100% { box-shadow: 0 4px 12px -2px rgba(255, 189, 89, 0.5), 0 0 0 0 rgba(255, 189, 89, 0.6); }
        50% { box-shadow: 0 4px 12px -2px rgba(255, 189, 89, 0.5), 0 0 0 8px rgba(255, 189, 89, 0); }
      }
      @keyframes sched-pulse-emerald {
        0%, 100% { box-shadow: 0 4px 12px -2px rgba(52, 211, 153, 0.5), 0 0 0 0 rgba(52, 211, 153, 0.6); }
        50% { box-shadow: 0 4px 12px -2px rgba(52, 211, 153, 0.5), 0 0 0 8px rgba(52, 211, 153, 0); }
      }
    </style>

    <script>
      (function () {
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const todayStr =
          today.getFullYear() +
          '-' +
          String(today.getMonth() + 1).padStart(2, '0') +
          '-' +
          String(today.getDate()).padStart(2, '0');

        const groups = new Map<string, HTMLElement[]>();
        document.querySelectorAll<HTMLElement>('[data-free-date][data-free-loc]').forEach((el) => {
          const loc = el.dataset.freeLoc || 'default';
          if (!groups.has(loc)) groups.set(loc, []);
          groups.get(loc)!.push(el);
        });

        groups.forEach((pills) => {
          pills.sort((a, b) => (a.dataset.freeDate || '').localeCompare(b.dataset.freeDate || ''));
          const next = pills.find((p) => (p.dataset.freeDate || '') >= todayStr);
          if (next) next.dataset.freeNext = 'true';
        });
      })();
    </script>
  </main>
</Layout>
