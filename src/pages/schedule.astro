---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
---

<Layout title="Schedule | The Latina Sweat Project">
  <Header />
  <main>
    {/* International Women's Day Banner */}
    <div class="bg-purple-700 py-3 px-4">
      <a href="/womensday" class="block mx-auto max-w-4xl text-center group">
        <p class="text-white font-bold text-sm sm:text-base">
          Wear purple this month to honor International Women's Day
          <span class="inline-block ml-1 group-hover:translate-x-1 transition-transform">&rarr;</span>
        </p>
        <p class="text-purple-200 text-xs sm:text-sm mt-0.5">
          Viste de morado este mes para conmemorar el Dia Internacional de la Mujer
        </p>
      </a>
    </div>

    <div class="my-8 px-4">
      <div
        class="mx-auto max-w-4xl rounded-lg border border-red-300 bg-red-50 p-4 text-center"
      >
        <p class="font-semibold text-red-800">
          Please note: Participants must be 12 years of age or older to register
          for and attend classes.
        </p>
      </div>

      {/* Membership Cancellation Policy Notice */}
      <div
        class="mx-auto mt-4 max-w-4xl rounded-lg border border-accent-gold/50 bg-gradient-to-r from-amber-50 to-yellow-50 p-4 text-center"
      >
        <p class="font-semibold text-amber-900">
          📋 Membership Cancellation Policy
        </p>
        <p class="mt-1 text-sm text-amber-800">
          To cancel your membership, please email
          <a
            href="mailto:membership@latinasweatproject.com"
            class="font-bold underline hover:text-vibrant-pink transition-colors"
            >membership@latinasweatproject.com</a
          >. Cancellations take effect at the end of your current billing cycle
          (30 days from your request).
        </p>
      </div>

      {/* App Promo Banner – iPhone & Android */}
      <div class="mx-auto mt-4 max-w-4xl rounded-xl bg-gradient-to-r from-off-black via-[#1a1a2e] to-off-black p-4 border border-accent-gold/30">
        <div class="flex items-center gap-3 mb-3">
          <span
            class="flex h-12 w-12 items-center justify-center rounded-lg bg-white p-1.5 shrink-0"
          >
            <img
              src="/images/lsp-studio-logo.png"
              alt="LSP Studio App"
              class="h-full w-full object-contain"
            />
          </span>
          <div>
            <p class="text-accent-gold font-bold text-sm sm:text-base">
              LSP Studio App – Now on iPhone & Android!
            </p>
            <p class="text-light-gray/80 text-xs sm:text-sm">
              Book classes, track workouts & manage your account on the go.
            </p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-2">
          <a
            href="https://apps.apple.com/us/app/lsp-studio/id6755971141"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex-1 flex items-center justify-center gap-2 rounded-lg border border-accent-gold/30 hover:border-accent-gold/60 bg-off-black px-4 py-2.5 transition-all duration-300 hover:shadow-lg hover:shadow-accent-gold/10"
          >
            <svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path>
            </svg>
            <div class="text-left">
              <p class="text-[10px] text-light-gray/70 leading-none">Download on the</p>
              <p class="text-sm font-bold text-white group-hover:text-accent-gold transition-colors leading-tight">App Store</p>
            </div>
          </a>
          <a
            href="https://play.google.com/store/apps/details?id=com.marianatek.latinasweatproject&hl=en_US"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex-1 flex items-center justify-center gap-2 rounded-lg border border-green-500/30 hover:border-green-500/60 bg-off-black px-4 py-2.5 transition-all duration-300 hover:shadow-lg hover:shadow-green-500/10"
          >
            <svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"></path>
            </svg>
            <div class="text-left">
              <p class="text-[10px] text-light-gray/70 leading-none">Get it on</p>
              <p class="text-sm font-bold text-white group-hover:text-green-400 transition-colors leading-tight">Google Play</p>
            </div>
          </a>
        </div>
      </div>
    </div>
    <div class="my-8 px-4 text-center">
      <p class="text-vibrant-pink">
        Trouble viewing the schedule or registering below?
        <a
          href="https://latinasweatproject.marianatools.com/?_mt=/schedule/daily/48541?locations=48717"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold underline transition hover:text-accent-gold"
          >Open in a new window.</a
        >
      </p>
    </div>
    <div data-mariana-integrations="/schedule/daily/48541?locations=48717">
    </div>
  </main>
</Layout>
