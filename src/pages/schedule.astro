---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
---

<Layout title="Schedule | The Latina Sweat Project">
  <Header />
  <main>
    {/* Compact policy strip */}
    <div class="mt-6 mb-4 px-4">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-3 sm:grid-cols-3">
          {/* Age Policy */}
          <div class="rounded-xl border border-red-200 bg-red-50/70 p-3.5 flex items-start gap-3">
            <span
              class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-red-100 text-red-700 text-base font-bold"
              >12+</span
            >
            <div class="min-w-0">
              <p
                class="text-[10px] font-bold uppercase tracking-[0.12em] text-red-700/80"
              >
                Age policy
              </p>
              <p
                class="mt-0.5 text-[13px] font-semibold text-red-900 leading-snug"
              >
                Participants must be 12 years or older to register and attend.
              </p>
            </div>
          </div>

          {/* Lockout Policy */}
          <div
            class="rounded-xl border border-vibrant-pink/30 bg-rose-50/70 p-3.5 flex items-start gap-3"
          >
            <span
              class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-vibrant-pink/15 text-vibrant-pink text-base"
              >🔒</span
            >
            <div class="min-w-0">
              <p
                class="text-[10px] font-bold uppercase tracking-[0.12em] text-vibrant-pink"
              >
                Late policy
              </p>
              <p
                class="mt-0.5 text-[13px] font-semibold text-off-black leading-snug"
              >
                Doors close 5 min after class begins.
                <a
                  href="/latepolicy"
                  class="text-vibrant-pink underline decoration-vibrant-pink/40 underline-offset-2 hover:text-accent-gold transition-colors"
                  >Here's why 🤍</a
                >
              </p>
            </div>
          </div>

          {/* Membership Cancellation */}
          <div
            class="rounded-xl border border-accent-gold/40 bg-amber-50/70 p-3.5 flex items-start gap-3"
          >
            <span
              class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-accent-gold/20 text-amber-800 text-base"
              >📋</span
            >
            <div class="min-w-0">
              <p
                class="text-[10px] font-bold uppercase tracking-[0.12em] text-amber-800"
              >
                Cancel membership
              </p>
              <p
                class="mt-0.5 text-[13px] font-semibold text-off-black leading-snug"
              >
                Email
                <a
                  href="mailto:membership@latinasweatproject.com"
                  class="text-amber-800 underline decoration-amber-800/40 underline-offset-2 hover:text-vibrant-pink transition-colors break-all"
                  >membership@latinasweatproject.com</a
                >. Takes effect after your 30-day cycle.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Trouble viewing link — tight spacing above the widget */}
    <div class="mt-2 px-4 text-center">
      <p class="text-vibrant-pink text-xs sm:text-sm leading-tight">
        Trouble viewing the schedule or registering below?
        <a
          href="https://latinasweatproject.marianatools.com/?_mt=/schedule/daily/48541?locations=48717"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold underline transition hover:text-accent-gold"
          data-conversion-event="class_booking_start"
          data-conversion-context="schedule_trouble_link"
          data-conversion-provider="mariana_tek"
          data-conversion-booking-path="external_schedule"
          data-conversion-location-id="48717"
          >Open in a new window.</a
        >
      </p>
    </div>

    {/* MarianaTek embedded schedule */}
    <div
      id="schedule-widget"
      class="schedule-widget-tight"
      data-mariana-integrations="/schedule/daily/48541?locations=48717"
    >
    </div>

    {/* Free Day Promo Banner — spotlighted below the schedule */}
    <div class="relative overflow-hidden bg-gradient-to-br from-amber-50 via-yellow-50 to-emerald-50 py-8 px-4">
      {/* Decorative warm glows */}
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-12 left-[20%] w-[250px] h-[250px] bg-accent-gold/20 rounded-full blur-[80px]"></div>
        <div class="absolute -bottom-12 right-[20%] w-[200px] h-[200px] bg-emerald-500/15 rounded-full blur-[60px]"></div>
      </div>

      <div class="relative mx-auto max-w-5xl">
        <div class="text-center">
          {/* Pulsing badge */}
          <div class="inline-flex items-center gap-2 rounded-full bg-accent-gold/20 border border-accent-gold/40 px-3 py-1.5 mb-3">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-gold"></span>
            </span>
            <span class="text-xs font-bold uppercase tracking-widest text-amber-800">Free · May & June 2026</span>
          </div>

          <h3 class="font-sans text-xl sm:text-2xl font-extrabold tracking-tight text-off-black">
            🎉 Free Classes, <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-gold to-emerald-500">Two Locations</span>
          </h3>
          <p class="mt-1 text-amber-900/70 text-sm font-medium">Clases gratis · No membership needed · Two locations, two ways to register</p>
        </div>

        <div class="mt-5 grid gap-4 md:grid-cols-2">
          {/* PILSEN */}
          <div class="rounded-2xl bg-white border-2 border-accent-gold/40 shadow-md shadow-accent-gold/10 p-5 flex flex-col">
            <div class="flex items-center gap-2 mb-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-off-black text-accent-gold font-extrabold text-base">X</span>
              <div class="text-left flex-1">
                <p class="text-[10px] font-bold uppercase tracking-widest text-accent-gold leading-none">Location 1</p>
                <p class="text-base font-extrabold text-off-black leading-tight">Pilsen · LSP Studio</p>
              </div>
              <div class="text-right">
                <p class="text-2xl font-extrabold text-accent-gold leading-none">8</p>
                <p class="text-[9px] font-bold uppercase tracking-wider text-off-black/55 leading-none mt-0.5">Free Days</p>
              </div>
            </div>
            <p class="text-[11px] text-off-black/70 font-medium mb-3">949 W 16th St, Chicago, IL 60608</p>

            {/* Day rotation insight */}
            <div class="rounded-lg bg-amber-50 border border-amber-200 px-2.5 py-2 mb-3">
              <p class="text-[10px] font-bold uppercase tracking-widest text-amber-800 mb-1.5">Rotates through every day</p>
              <div class="flex items-center gap-1">
                <span class="flex-1 rounded text-center text-[10px] font-extrabold text-amber-900 bg-amber-200/70 py-1">FRI</span>
                <span class="flex-1 rounded text-center text-[10px] font-extrabold text-amber-900 bg-amber-200/70 py-1">SAT</span>
                <span class="flex-1 rounded text-center text-[10px] font-extrabold text-amber-900 bg-amber-200/70 py-1">SUN</span>
                <span class="flex-1 rounded text-center text-[10px] font-extrabold text-amber-900 bg-amber-200/70 py-1">MON</span>
                <span class="flex-1 rounded text-center text-[10px] font-extrabold text-amber-900 bg-amber-200/70 py-1">TUE</span>
                <span class="flex-1 rounded text-center text-[10px] font-extrabold text-amber-900 bg-amber-200/70 py-1">WED</span>
                <span class="flex-1 rounded text-center text-[10px] font-extrabold text-amber-900 bg-amber-200/70 py-1">THU</span>
              </div>
            </div>

            <p class="text-[10px] font-bold uppercase tracking-wider text-amber-800 mb-1.5">May 2026</p>
            <div class="grid grid-cols-2 gap-2 mb-3">
              <div class="pilsen-date" data-free-date="2026-05-01" data-free-loc="pilsen">
                <span class="pilsen-date__day">FRI</span>
                <span class="pilsen-date__num">1</span>
                <span class="pilsen-date__month">May</span>
              </div>
              <div class="pilsen-date" data-free-date="2026-05-09" data-free-loc="pilsen">
                <span class="pilsen-date__day">SAT</span>
                <span class="pilsen-date__num">9</span>
                <span class="pilsen-date__month">May</span>
              </div>
              <div class="pilsen-date" data-free-date="2026-05-17" data-free-loc="pilsen">
                <span class="pilsen-date__day">SUN</span>
                <span class="pilsen-date__num">17</span>
                <span class="pilsen-date__month">May</span>
              </div>
              <div class="pilsen-date" data-free-date="2026-05-25" data-free-loc="pilsen">
                <span class="pilsen-date__day">MON</span>
                <span class="pilsen-date__num">25</span>
                <span class="pilsen-date__month">May</span>
              </div>
            </div>
            <p class="text-[10px] font-bold uppercase tracking-wider text-amber-800 mb-1.5">June 2026</p>
            <div class="grid grid-cols-2 gap-2">
              <div class="pilsen-date" data-free-date="2026-06-02" data-free-loc="pilsen">
                <span class="pilsen-date__day">TUE</span>
                <span class="pilsen-date__num">2</span>
                <span class="pilsen-date__month">Jun</span>
              </div>
              <div class="pilsen-date" data-free-date="2026-06-10" data-free-loc="pilsen">
                <span class="pilsen-date__day">WED</span>
                <span class="pilsen-date__num">10</span>
                <span class="pilsen-date__month">Jun</span>
              </div>
              <div class="pilsen-date" data-free-date="2026-06-18" data-free-loc="pilsen">
                <span class="pilsen-date__day">THU</span>
                <span class="pilsen-date__num">18</span>
                <span class="pilsen-date__month">Jun</span>
              </div>
              <div class="pilsen-date" data-free-date="2026-06-26" data-free-loc="pilsen">
                <span class="pilsen-date__day">FRI</span>
                <span class="pilsen-date__num">26</span>
                <span class="pilsen-date__month">Jun</span>
              </div>
            </div>

            <div class="mt-auto pt-3.5 border-t border-accent-gold/25">
              <p class="text-[10px] font-bold uppercase tracking-widest text-amber-800 mb-2">Reserve your spot</p>
              <div class="flex gap-1.5 mb-2">
                <a
                  href="https://apps.apple.com/us/app/lsp-studio/id6755971141"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-lg bg-off-black px-3 py-2 text-[11px] font-bold text-white transition-all duration-300 hover:scale-[1.02] hover:bg-amber-900"
                  data-conversion-event="app_download_click"
                  data-conversion-context="schedule_free_classes"
                  data-conversion-platform="ios"
                >
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path></svg>
                  iOS
                </a>
                <a
                  href="https://play.google.com/store/apps/details?id=com.marianatek.latinasweatproject&hl=en_US"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-lg bg-off-black px-3 py-2 text-[11px] font-bold text-white transition-all duration-300 hover:scale-[1.02] hover:bg-amber-900"
                  data-conversion-event="app_download_click"
                  data-conversion-context="schedule_free_classes"
                  data-conversion-platform="android"
                >
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"></path></svg>
                  Android
                </a>
                <a
                  href="#schedule-widget"
                  class="flex-1 inline-flex items-center justify-center gap-1.5 rounded-lg bg-accent-gold px-3 py-2 text-[11px] font-bold text-off-black shadow-sm transition-all duration-300 hover:scale-[1.02] hover:shadow-md"
                  data-conversion-event="class_booking_start"
                  data-conversion-context="schedule_widget_jump"
                  data-conversion-provider="mariana_tek"
                  data-conversion-booking-path="embedded_schedule"
                  data-conversion-location-id="48717"
                >
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
                  Above
                </a>
              </div>
              <p class="text-[10px] text-off-black/60 font-medium text-center">Book up to <span class="font-bold text-amber-800">7 days ahead</span> in the app or right on this page</p>
            </div>
          </div>

          {/* BACK OF THE YARDS */}
          <div class="rounded-2xl bg-white border-2 border-emerald-500/40 shadow-md shadow-emerald-500/10 p-5 flex flex-col">
            <div class="flex items-center gap-2 mb-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-600 text-white font-extrabold text-base">X</span>
              <div class="text-left">
                <p class="text-[10px] font-bold uppercase tracking-widest text-emerald-700 leading-none">Location 2</p>
                <p class="text-base font-extrabold text-off-black leading-tight">Back of the Yards</p>
              </div>
            </div>
            <p class="text-[11px] text-off-black/70 font-medium mb-3">Southside Social · 4432 S Ashland Ave, Chicago, IL 60609</p>

            {/* Weekly lineup */}
            <div class="rounded-lg bg-emerald-50 border border-emerald-200 p-3.5 mb-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-emerald-700 mb-2">Weekly Lineup</p>
              <div class="grid grid-cols-2 gap-3 text-[12px] text-off-black/85">
                <div>
                  <p class="text-[9px] font-extrabold uppercase tracking-wider text-emerald-700/70 mb-1">Saturday</p>
                  <p class="font-bold tabular-nums leading-tight">8:00 AM <span class="font-medium text-off-black/65">· Andrea Fuentes</span></p>
                  <p class="font-bold tabular-nums leading-tight mt-0.5">9:15 AM <span class="font-medium text-off-black/65">· Melissa Salinas</span></p>
                </div>
                <div>
                  <p class="text-[9px] font-extrabold uppercase tracking-wider text-emerald-700/70 mb-1">Sunday</p>
                  <p class="font-bold tabular-nums leading-tight">9:15 AM <span class="font-medium text-off-black/65">· Lizsandra Heredia</span></p>
                  <p class="font-bold tabular-nums leading-tight mt-0.5">10:30 AM <span class="font-medium text-off-black/65">· Arturo Zurita</span></p>
                </div>
              </div>
            </div>

            <p class="text-[10px] font-bold uppercase tracking-wider text-emerald-700 mb-2 text-center">May (Every Sat &amp; Sun)</p>
            <div class="flex flex-wrap gap-2.5 mb-4 justify-center">
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-09" data-free-loc="boty">Sat 9</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-10" data-free-loc="boty">Sun 10</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-16" data-free-loc="boty">Sat 16</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-17" data-free-loc="boty">Sun 17</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-23" data-free-loc="boty">Sat 23</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-24" data-free-loc="boty">Sun 24</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-30" data-free-loc="boty">Sat 30</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-31" data-free-loc="boty">Sun 31</span>
            </div>
            <p class="text-[10px] font-bold uppercase tracking-wider text-emerald-700 mb-2 text-center">June (Every Sat &amp; Sun)</p>
            <div class="flex flex-wrap gap-2.5 justify-center">
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-06" data-free-loc="boty">Sat 6</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-07" data-free-loc="boty">Sun 7</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-13" data-free-loc="boty">Sat 13</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-14" data-free-loc="boty">Sun 14</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-20" data-free-loc="boty">Sat 20</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-21" data-free-loc="boty">Sun 21</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-27" data-free-loc="boty">Sat 27</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-28" data-free-loc="boty">Sun 28</span>
            </div>

            <div class="mt-auto pt-3.5 border-t border-emerald-500/25">
              <a
                href="https://www.zeffy.com/en-US/ticketing/latina-sweat-project-southside-social-free-classes"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center justify-center gap-1.5 rounded-lg bg-emerald-600 hover:bg-emerald-500 px-4 py-2.5 text-sm font-bold text-white shadow-md shadow-emerald-500/30 transition-all duration-300 hover:scale-[1.02]"
                data-conversion-event="class_booking_start"
                data-conversion-context="schedule_southside_card"
                data-conversion-provider="zeffy"
                data-conversion-booking-path="southside_ticketing"
                data-conversion-location="southside_social"
              >
                Register on Zeffy
                <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              </a>
              <p class="mt-1.5 text-[10px] text-off-black/55 font-medium text-center">Not bookable in the LSP app or this page</p>
            </div>
          </div>
        </div>

        <p class="mt-4 text-center text-[12px] sm:text-sm text-off-black/65 font-medium">
          <span class="font-bold text-off-black">Pilsen</span> books up to 7 days ahead in the LSP Studio app or this page (iOS &amp; Android). <span class="font-bold text-off-black">Southside Social</span> reservations open at <a href="https://www.zeffy.com/en-US/ticketing/latina-sweat-project-southside-social-free-classes" target="_blank" rel="noopener noreferrer" class="font-bold text-emerald-700 underline decoration-emerald-300 underline-offset-2 hover:text-emerald-800" data-conversion-event="class_booking_start" data-conversion-context="schedule_southside_text_link" data-conversion-provider="zeffy" data-conversion-booking-path="southside_ticketing" data-conversion-location="southside_social">zeffy.com</a>.
        </p>
      </div>
    </div>

    {/* App Promo Banner — supporting tools at the bottom */}
    <div class="my-8 px-4">
      <div class="mx-auto max-w-5xl">
        <div
          class="rounded-xl bg-gradient-to-r from-off-black via-[#1a1a2e] to-off-black border border-accent-gold/30 p-4 sm:p-5"
        >
          <div class="flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="flex items-center gap-3 flex-1 min-w-0">
              <span
                class="flex h-11 w-11 sm:h-12 sm:w-12 items-center justify-center rounded-lg bg-white p-1.5 shrink-0"
              >
                <img
                  src="/images/lsp-studio-logo.png"
                  alt="LSP Studio App"
                  class="h-full w-full object-contain"
                />
              </span>
              <div class="min-w-0">
                <p class="text-accent-gold font-bold text-sm sm:text-base leading-tight">
                  LSP Studio App
                </p>
                <p class="text-light-gray/75 text-xs sm:text-sm leading-snug">
                  Book classes, track workouts & manage your account on the go.
                </p>
              </div>
            </div>
            <div class="flex gap-2 sm:shrink-0">
              <a
                href="https://apps.apple.com/us/app/lsp-studio/id6755971141"
                target="_blank"
                rel="noopener noreferrer"
                class="group flex-1 sm:flex-initial flex items-center justify-center gap-2 rounded-lg border border-accent-gold/30 hover:border-accent-gold/60 bg-off-black px-4 py-2.5 transition-all duration-300 hover:shadow-lg hover:shadow-accent-gold/10"
                data-conversion-event="app_download_click"
                data-conversion-context="schedule_app_banner"
                data-conversion-platform="ios"
              >
                <svg
                  class="h-5 w-5 text-white"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
