---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
---

<Layout title="Schedule | The Latina Sweat Project">
  <Header />
  <main>
    {/* Free Day Promo Banner */}
    <div class="relative overflow-hidden bg-gradient-to-br from-amber-50 via-yellow-50 to-emerald-50 py-8 px-4">
      {/* Decorative warm glows */}
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-12 left-[20%] w-[250px] h-[250px] bg-accent-gold/20 rounded-full blur-[80px]"></div>
        <div class="absolute -bottom-12 right-[20%] w-[200px] h-[200px] bg-emerald-500/15 rounded-full blur-[60px]"></div>
      </div>

      <div class="relative mx-auto max-w-5xl">
        <div class="text-center">
          {/* Pulsing badge */}
          <div class="inline-flex items-center gap-2 rounded-full bg-accent-gold/20 border border-accent-gold/40 px-3 py-1.5 mb-3">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-gold opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-gold"></span>
            </span>
            <span class="text-xs font-bold uppercase tracking-widest text-amber-800">Free · May & June 2026</span>
          </div>

          <h3 class="font-sans text-xl sm:text-2xl font-extrabold tracking-tight text-off-black">
            🎉 Free Classes, <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-gold to-emerald-500">Two Locations</span>
          </h3>
          <p class="mt-1 text-amber-900/70 text-sm font-medium">Clases gratis · All classes, all day, no membership needed</p>
        </div>

        <div class="mt-5 grid gap-4 md:grid-cols-2">
          {/* PILSEN */}
          <div class="rounded-2xl bg-white border-2 border-accent-gold/40 shadow-md shadow-accent-gold/10 p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-off-black text-accent-gold font-extrabold text-base">X</span>
              <div class="text-left">
                <p class="text-[10px] font-bold uppercase tracking-widest text-accent-gold leading-none">Location 1</p>
                <p class="text-base font-extrabold text-off-black leading-tight">Pilsen · LSP Studio</p>
              </div>
            </div>
            <p class="text-[11px] text-off-black/70 font-medium mb-3">949 W 16th St, Chicago, IL 60608</p>

            <p class="text-[10px] font-bold uppercase tracking-wider text-amber-800 mb-1.5">May</p>
            <div class="flex flex-wrap gap-1.5 mb-3">
              <span class="sched-pill" data-free-date="2026-05-01" data-free-loc="pilsen">Fri, May 1</span>
              <span class="sched-pill" data-free-date="2026-05-09" data-free-loc="pilsen">Sat, May 9</span>
              <span class="sched-pill" data-free-date="2026-05-17" data-free-loc="pilsen">Sun, May 17</span>
              <span class="sched-pill" data-free-date="2026-05-25" data-free-loc="pilsen">Mon, May 25</span>
            </div>
            <p class="text-[10px] font-bold uppercase tracking-wider text-amber-800 mb-1.5">June</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="sched-pill" data-free-date="2026-06-02" data-free-loc="pilsen">Tue, Jun 2</span>
              <span class="sched-pill" data-free-date="2026-06-10" data-free-loc="pilsen">Wed, Jun 10</span>
              <span class="sched-pill" data-free-date="2026-06-18" data-free-loc="pilsen">Thu, Jun 18</span>
              <span class="sched-pill" data-free-date="2026-06-26" data-free-loc="pilsen">Fri, Jun 26</span>
            </div>
          </div>

          {/* BACK OF THE YARDS */}
          <div class="rounded-2xl bg-white border-2 border-emerald-500/40 shadow-md shadow-emerald-500/10 p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-600 text-white font-extrabold text-base">X</span>
              <div class="text-left">
                <p class="text-[10px] font-bold uppercase tracking-widest text-emerald-700 leading-none">Location 2</p>
                <p class="text-base font-extrabold text-off-black leading-tight">Back of the Yards</p>
              </div>
            </div>
            <p class="text-[11px] text-off-black/70 font-medium mb-3">Southside Social · 4432 S Ashland Ave, Chicago, IL 60609</p>

            <p class="text-[10px] font-bold uppercase tracking-wider text-emerald-700 mb-1.5">May (Every Sat &amp; Sun)</p>
            <div class="flex flex-wrap gap-1.5 mb-3">
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-09" data-free-loc="boty">Sat 9</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-10" data-free-loc="boty">Sun 10</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-16" data-free-loc="boty">Sat 16</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-17" data-free-loc="boty">Sun 17</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-23" data-free-loc="boty">Sat 23</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-24" data-free-loc="boty">Sun 24</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-30" data-free-loc="boty">Sat 30</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-05-31" data-free-loc="boty">Sun 31</span>
            </div>
            <p class="text-[10px] font-bold uppercase tracking-wider text-emerald-700 mb-1.5">June (Every Sat &amp; Sun)</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-06" data-free-loc="boty">Sat 6</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-07" data-free-loc="boty">Sun 7</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-13" data-free-loc="boty">Sat 13</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-14" data-free-loc="boty">Sun 14</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-20" data-free-loc="boty">Sat 20</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-21" data-free-loc="boty">Sun 21</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-27" data-free-loc="boty">Sat 27</span>
              <span class="sched-pill sched-pill--emerald" data-free-date="2026-06-28" data-free-loc="boty">Sun 28</span>
            </div>
          </div>
        </div>

        <p class="mt-4 text-center text-[12px] sm:text-sm text-off-black/70 font-medium">
          📅 Book up to <span class="font-bold text-vibrant-pink">7 days in advance</span> on this page or in the LSP Studio app (iOS &amp; Android).
        </p>
      </div>
    </div>

    <style>
      .sched-pill {
        display: inline-flex;
        align-items: center;
        padding: 4px 8px;
        border-radius: 6px;
        background: #fffbeb;
        border: 1px solid rgba(255, 189, 89, 0.4);
        font-size: 11px;
        font-weight: 700;
        color: #1e1e1e;
        line-height: 1.2;
        transition: all 0.25s ease;
      }
      .sched-pill--emerald {
        background: #ecfdf5;
        border-color: rgba(110, 231, 183, 1);
      }

      .sched-pill[data-free-next="true"] {
        position: relative;
        background: linear-gradient(135deg, #ffbd59, #ffd28a);
        border-color: #ffbd59;
        color: #1e1e1e;
        transform: scale(1.06);
        box-shadow: 0 4px 12px -2px rgba(255, 189, 89, 0.5);
        animation: sched-pulse-gold 2.2s ease-in-out infinite;
      }
      .sched-pill--emerald[data-free-next="true"] {
        background: linear-gradient(135deg, #34d399, #6ee7b7);
        border-color: #34d399;
        color: #064e3b;
        box-shadow: 0 4px 12px -2px rgba(52, 211, 153, 0.5);
        animation: sched-pulse-emerald 2.2s ease-in-out infinite;
      }
      .sched-pill[data-free-next="true"]::before {
        content: '↓ NEXT';
        position: absolute;
        top: -11px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 8px;
        font-weight: 800;
        letter-spacing: 0.08em;
        padding: 2px 6px;
        border-radius: 4px;
        background: #b5a18d;
        color: #fff;
        white-space: nowrap;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.18);
      }
      @keyframes sched-pulse-gold {
        0%, 100% { box-shadow: 0 4px 12px -2px rgba(255, 189, 89, 0.5), 0 0 0 0 rgba(255, 189, 89, 0.6); }
        50% { box-shadow: 0 4px 12px -2px rgba(255, 189, 89, 0.5), 0 0 0 8px rgba(255, 189, 89, 0); }
      }
      @keyframes sched-pulse-emerald {
        0%, 100% { box-shadow: 0 4px 12px -2px rgba(52, 211, 153, 0.5), 0 0 0 0 rgba(52, 211, 153, 0.6); }
        50% { box-shadow: 0 4px 12px -2px rgba(52, 211, 153, 0.5), 0 0 0 8px rgba(52, 211, 153, 0); }
      }
    </style>

    <script>
      (function () {
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const todayStr =
          today.getFullYear() +
          '-' +
          String(today.getMonth() + 1).padStart(2, '0') +
          '-' +
          String(today.getDate()).padStart(2, '0');

        const groups = new Map<string, HTMLElement[]>();
        document.querySelectorAll<HTMLElement>('[data-free-date][data-free-loc]').forEach((el) => {
          const loc = el.dataset.freeLoc || 'default';
          if (!groups.has(loc)) groups.set(loc, []);
          groups.get(loc)!.push(el);
        });

        groups.forEach((pills) => {
          pills.sort((a, b) => (a.dataset.freeDate || '').localeCompare(b.dataset.freeDate || ''));
          const next = pills.find((p) => (p.dataset.freeDate || '') >= todayStr);
          if (next) next.dataset.freeNext = 'true';
        });
      })();
    </script>

    <div class="my-8 px-4">
      <div
        class="mx-auto max-w-4xl rounded-lg border border-red-300 bg-red-50 p-4 text-center"
      >
        <p class="font-semibold text-red-800">
          Please note: Participants must be 12 years of age or older to register
          for and attend classes.
        </p>
      </div>

      {/* Membership Cancellation Policy Notice */}
      <div
        class="mx-auto mt-4 max-w-4xl rounded-lg border border-accent-gold/50 bg-gradient-to-r from-amber-50 to-yellow-50 p-4 text-center"
      >
        <p class="font-semibold text-amber-900">
          📋 Membership Cancellation Policy
        </p>
        <p class="mt-1 text-sm text-amber-800">
          To cancel your membership, please email
          <a
            href="mailto:membership@latinasweatproject.com"
            class="font-bold underline hover:text-vibrant-pink transition-colors"
            >membership@latinasweatproject.com</a
          >. Cancellations take effect at the end of your current billing cycle
          (30 days from your request).
        </p>
      </div>

      {/* App Promo Banner – iPhone & Android */}
      <div class="mx-auto mt-4 max-w-4xl rounded-xl bg-gradient-to-r from-off-black via-[#1a1a2e] to-off-black p-4 border border-accent-gold/30">
        <div class="flex items-center gap-3 mb-3">
          <span
            class="flex h-12 w-12 items-center justify-center rounded-lg bg-white p-1.5 shrink-0"
          >
            <img
              src="/images/lsp-studio-logo.png"
              alt="LSP Studio App"
              class="h-full w-full object-contain"
            />
          </span>
          <div>
            <p class="text-accent-gold font-bold text-sm sm:text-base">
              LSP Studio App – Now on iPhone & Android!
            </p>
            <p class="text-light-gray/80 text-xs sm:text-sm">
              Book classes, track workouts & manage your account on the go.
            </p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-2">
          <a
            href="https://apps.apple.com/us/app/lsp-studio/id6755971141"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex-1 flex items-center justify-center gap-2 rounded-lg border border-accent-gold/30 hover:border-accent-gold/60 bg-off-black px-4 py-2.5 transition-all duration-300 hover:shadow-lg hover:shadow-accent-gold/10"
          >
            <svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path>
            </svg>
            <div class="text-left">
              <p class="text-[10px] text-light-gray/70 leading-none">Download on the</p>
              <p class="text-sm font-bold text-white group-hover:text-accent-gold transition-colors leading-tight">App Store</p>
            </div>
          </a>
          <a
            href="https://play.google.com/store/apps/details?id=com.marianatek.latinasweatproject&hl=en_US"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex-1 flex items-center justify-center gap-2 rounded-lg border border-green-500/30 hover:border-green-500/60 bg-off-black px-4 py-2.5 transition-all duration-300 hover:shadow-lg hover:shadow-green-500/10"
          >
            <svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"></path>
            </svg>
            <div class="text-left">
              <p class="text-[10px] text-light-gray/70 leading-none">Get it on</p>
              <p class="text-sm font-bold text-white group-hover:text-green-400 transition-colors leading-tight">Google Play</p>
            </div>
          </a>
        </div>
      </div>
    </div>
    <div class="my-8 px-4 text-center">
      <p class="text-vibrant-pink">
        Trouble viewing the schedule or registering below?
        <a
          href="https://latinasweatproject.marianatools.com/?_mt=/schedule/daily/48541?locations=48717"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold underline transition hover:text-accent-gold"
          >Open in a new window.</a
        >
      </p>
    </div>
    <div data-mariana-integrations="/schedule/daily/48541?locations=48717">
    </div>
  </main>
</Layout>
