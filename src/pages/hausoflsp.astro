<style>
  /* Disco ball sway: a slow pendulum, motion-safe only. */
  @media (prefers-reduced-motion: no-preference) {
    .haus-sway {
      animation: haus-sway 7s ease-in-out infinite;
      transform-origin: 50% -6rem;
    }
    @keyframes haus-sway {
      0%,
      100% {
        transform: rotate(-2.2deg);
      }
      50% {
        transform: rotate(2.2deg);
      }
    }
  }

  /* Room speckle styles live in global.css (.haus-lights) so the homepage
     spotlight shares them. */

  /* Sign-up sheet fields: handwriting blanks on the notebook paper. */
  .haus-label {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: var(--font-marker);
    font-size: 1.05rem;
    color: #24201a;
  }
  .haus-input {
    width: 100%;
    margin-top: 0.35rem;
    padding: 0.45rem 0.15rem;
    background: transparent;
    border: 0;
    border-bottom: 2px dashed rgba(36, 32, 26, 0.35);
    border-radius: 0;
    font-weight: 600;
    color: #24201a;
    color-scheme: light;
  }
  .haus-input:focus {
    outline: none;
    border-bottom-style: solid;
    border-bottom-color: #c81e63;
  }
  .haus-input::placeholder {
    font-weight: 500;
    color: rgba(36, 32, 26, 0.4);
  }
  textarea.haus-input {
    resize: vertical;
  }
</style>

<script>
  // The sign-up sheet hands off to the real Google Form pre-filled: the
  // form's required art-photo upload can only happen on Google (uploads
  // store to Drive and require sign-in), so we carry every typed answer
  // over via viewform?usp=pp_url and the artist finishes there.
  const form = document.getElementById("haus-artist-form");
  if (form instanceof HTMLFormElement) {
    const status = document.getElementById("haus-artist-status");
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      const params = new URLSearchParams({ usp: "pp_url" });
      const dobEntry = form.dataset.dobEntry;
      for (const [key, value] of new FormData(form).entries()) {
        const v = String(value).trim();
        if (!v) continue;
        if (key === "dob" && dobEntry) {
          const [y, m, d] = v.split("-");
          params.append(`${dobEntry}_year`, y);
          params.append(`${dobEntry}_month`, String(Number(m)));
          params.append(`${dobEntry}_day`, String(Number(d)));
        } else {
          params.append(key, v);
        }
      }
      window.open(`${form.dataset.formUrl}?${params}`, "_blank", "noopener");
      if (status) {
        status.textContent =
          "Google Forms just opened with your answers filled in. Attach 2+ photos of your work there and hit submit. That tab not showing? Check your pop-up blocker.";
      }
    });
  }
</script>
