---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import HausDiscoBall from "@/components/HausDiscoBall.astro";
import {
  hausOfLsp,
  summerRenaissance,
  summerRenaissanceActs,
  hausArtistForm,
  hausColors,
  hausDiscoUri,
  hausLightTileUri,
} from "@/data/hausOfLsp";

// Haus of LSP · Summer Renaissance: the "Nightlife Collage" identity. The
// reference is the printed flyer itself: a queer scrapbook zine taped
// together by hand. Marker handwriting, clear packing tape, a torn notebook
// page for the schedule, sticker cutouts, chrome type, halftone dots, and a
// disco ball over a deep plum room. Deliberately the opposite of both the
// gala's black-tie foil and Sweat Fest's daylight print kit: this page is a
// dark room with the lights low and the music on.
// Every fact renders from src/data/hausOfLsp.js so ticketing flips in one
// file when entry details are announced.

const base = import.meta.env.BASE_URL;
const withBase = (path) => `${base}${path.replace(/^\//, "")}`;
const calendarHref = withBase(summerRenaissance.calendarPath);
const calendarDescription = [
  "Haus of LSP presents Summer Renaissance — a night of queer art, open mic + slam poetry, and a DJ set in Pilsen.",
  "",
  "QUE VA A PASAR",
  ...summerRenaissanceActs.flatMap((act) =>
    act.items.map((item) => `${act.time} — ${item.title}: ${item.detail}`),
  ),
  "",
  `${summerRenaissance.cause}.`,
  "Details and updates: https://latinasweatproject.com/hausoflsp",
].join("\n");
const googleCalendarHref = `https://calendar.google.com/calendar/render?${new URLSearchParams(
  {
    action: "TEMPLATE",
    text: "Haus of LSP: Summer Renaissance",
    dates: "20260801T180000/20260801T230000",
    ctz: "America/Chicago",
    location: summerRenaissance.address,
    details: calendarDescription,
  },
).toString()}`;

const hasTickets =
  summerRenaissance.ticketsOnSale && summerRenaissance.ticketsUrl;

// Sticker-chip rotations, hand-placed like the flyer's cutouts.
const chipTilt = [-1.6, 1.1, -0.8, 1.4];
---

<Layout
  title="Summer Renaissance | Haus of LSP | The Latina Sweat Project"
  description={summerRenaissance.pageDescription}
  socialImage="images/hausoflsp1.jpg"
  socialImageAlt="Haus of LSP presents Summer Renaissance: Saturday, August 1, 2026, 6 to 11 PM in Pilsen. All proceeds go toward the LSP Queer Scholarship."
  socialImageWidth={1000}
  socialImageHeight={1250}
  socialImageType="image/jpeg"
>
  <Header />
  <main class="haus-page text-white" style={`background-color: ${hausColors.plum};`}>
    {/* ============ HERO: the dark room ============ */}
    <section
      id="top"
      class="relative overflow-hidden pb-20 pt-28 sm:pb-24 sm:pt-32 lg:pt-36"
      style={`background:
        radial-gradient(52rem 30rem at 82% -6rem, rgba(160, 107, 216, 0.32), transparent 62%),
        radial-gradient(44rem 26rem at -10% 30%, rgba(255, 111, 181, 0.2), transparent 60%),
        linear-gradient(to bottom, ${hausColors.maroon}, ${hausColors.plum} 70%);`}
    >
      {/* Disco ball hanging from the top of the room on its cord: real-time
          3D mirror ball (silver facets, party lights, glints), with the flat
          SVG as fallback. Kept low enough that the in-scene cord runs
          unbroken from the section's top edge down to the ball. */}
      <div
        class="pointer-events-none absolute right-[-2.5rem] top-6 sm:right-[4%] sm:top-8"
        aria-hidden="true"
      >
        <HausDiscoBall size="h-44 w-44 sm:h-72 sm:w-72 lg:h-[21rem] lg:w-[21rem]" />
      </div>

      {/* Halftone corner texture */}
      <div class="haus-halftone absolute bottom-0 left-0 h-56 w-72 opacity-20 [mask-image:radial-gradient(closest-side,black,transparent)]" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="reveal font-marker text-2xl text-white/90 sm:text-3xl">
            <span class="haus-glow">Haus of LSP</span>
            <span class="ml-2 inline-block -rotate-6 text-lg text-white/60 sm:text-xl">presents</span>
          </p>

          <h1 class="reveal mt-4 font-marker leading-[0.95]" style="transition-delay: 90ms;">
            <span class="haus-glow block text-6xl sm:text-7xl lg:text-8xl" style={`color: ${hausColors.pink};`}>Summer</span>
            <span class="haus-chrome block text-6xl sm:text-7xl lg:text-8xl">Renaissance</span>
          </h1>

          <p class="reveal mt-6 max-w-xl text-lg font-semibold leading-relaxed text-white/75" style="transition-delay: 160ms;">
            {summerRenaissance.tagline} One night in {summerRenaissance.neighborhood}:
            art on the walls, poets on the mic, and a floor that wants you on it.
          </p>

          {/* Sticker chips: the facts, hand-placed */}
          <div class="reveal mt-8 flex flex-wrap gap-3" style="transition-delay: 220ms;">
            {[
              summerRenaissance.dateLabel,
              summerRenaissance.timeLabel,
              summerRenaissance.venueLine,
              "All are welcome",
            ].map((chip, i) => (
              <span
                class="haus-sticker inline-block rounded-lg bg-off-black px-3.5 py-2 text-xs font-extrabold uppercase tracking-[0.14em] text-white"
                style={`transform: rotate(${chipTilt[i % 4]}deg);`}
              >
                {chip}
              </span>
            ))}
          </div>

          {/* The cause, stamped on the wall */}
          <p
            class="reveal mt-7 inline-block -rotate-1 border-2 border-dashed px-4 py-2 text-sm font-extrabold uppercase tracking-[0.18em]"
            style={`transition-delay: 280ms; color: ${hausColors.mint}; border-color: ${hausColors.mint}66;`}
          >
            {summerRenaissance.cause}
          </p>

          <div class="reveal mt-9 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center" style="transition-delay: 340ms;">
            {
              hasTickets ? (
                <a
                  href={summerRenaissance.ticketsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="haus-btn group inline-flex items-center gap-3 px-8 py-4 text-base font-extrabold text-off-black"
                  style={`background-color: ${hausColors.pink};`}
                  data-conversion-event="haus_ticket_click"
                  data-conversion-context="haus_page_hero"
                >
                  {summerRenaissance.ticketsLabel}
                  <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </a>
              ) : (
                <a
                  href={hausOfLsp.instagramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="haus-btn group inline-flex items-center gap-3 px-8 py-4 text-base font-extrabold text-off-black"
                  style={`background-color: ${hausColors.pink};`}
                  data-conversion-event="haus_follow_click"
                  data-conversion-context="haus_page_hero"
                >
                  Follow for entry details
                  <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </a>
              )
            }
            <a
              href="#que-va-a-pasar"
              class="haus-btn inline-flex items-center gap-3 bg-white/10 px-8 py-4 text-base font-extrabold text-white backdrop-blur-sm"
            >
              Qué va a pasar?
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
              </svg>
            </a>
          </div>
          <p class="reveal mt-5 text-sm font-bold uppercase tracking-[0.2em] text-white/45" style="transition-delay: 400ms;">
            {summerRenaissance.statusLabel}
          </p>
        </div>
      </div>
    </section>

    {/* ============ QUE VA A PASAR: the torn notebook note ============ */}
    <section id="que-va-a-pasar" class="relative overflow-hidden py-16 scroll-mt-28 sm:py-20">
      <div class="pointer-events-none absolute -left-24 top-10 h-72 w-72 rounded-full blur-[110px]" style={`background: ${hausColors.violet}40;`} aria-hidden="true"></div>

      <div class="relative mx-auto max-w-3xl px-4 sm:px-6">
        <div class="reveal relative rotate-[-0.8deg]">
          <span class="haus-tape -top-3 left-8 rotate-[-8deg]" aria-hidden="true"></span>
          <span class="haus-tape -top-3 right-8 rotate-[7deg]" aria-hidden="true"></span>

          <div class="haus-note px-6 py-10 sm:px-12 sm:py-12">
            <h2 class="text-center font-marker text-4xl sm:text-5xl" style="color: #24201a;">
              qué va a pasar?
            </h2>

            <div class="mt-8 space-y-9">
              {summerRenaissanceActs.map((act) => (
                <div>
                  <p
                    class="inline-block -rotate-1 rounded px-2 py-0.5 font-marker text-lg text-off-black"
                    style={`background: ${act.accent === "pink" ? `${hausColors.pink}55` : `${hausColors.mint}`};`}
                  >
                    {act.time} · {act.title}
                  </p>
                  <ul class="mt-3 space-y-3 pl-1">
                    {act.items.map((item) => (
                      <li class="flex items-baseline gap-3">
                        <span class="font-marker text-xl leading-none" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                        <p class="text-base leading-snug">
                          <span class="font-marker text-xl uppercase tracking-wide">{item.title}</span>
                          <span class="ml-2 font-semibold text-off-black/65">{item.detail}</span>
                        </p>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            <p class="mt-9 text-center font-marker text-lg text-off-black/70">
              all proceeds &rarr; {hausOfLsp.fundName} &hearts;
            </p>
          </div>
        </div>

        <p class="reveal mt-8 text-center text-sm font-semibold text-white/55" style="transition-delay: 120ms;">
          Come at 6 for the art. Stay until 11 for everything else.
        </p>
      </div>
    </section>

    {/* ============ THE CAUSE: why we dance ============ */}
    <section id="queer-scholarship" class="relative overflow-hidden py-16 scroll-mt-28 sm:py-20">
      <div class="pointer-events-none absolute -right-20 bottom-0 h-80 w-80 rounded-full blur-[120px]" style={`background: ${hausColors.pink}33;`} aria-hidden="true"></div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div class="reveal">
            <p class="font-marker text-xl" style={`color: ${hausColors.mint};`}>why we dance</p>
            <h2 class="mt-3 font-marker text-4xl leading-tight sm:text-5xl">
              A party with a<br />
              <span class="haus-glow" style={`color: ${hausColors.pink};`}>purpose you can feel.</span>
            </h2>
            <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/70">
              Every drink poured, every ticket, every dollar from Summer
              Renaissance goes to the {hausOfLsp.fundName}: funding LGBTQ+
              community members' access to classes, training, and leadership at
              The Latina Sweat Project.
            </p>
            <p class="mt-4 max-w-xl text-lg leading-relaxed text-white/70">
              So when the DJ tells you to let loose and be free, take it
              literally. The louder the night, the further the fund goes.
            </p>
          </div>

          <div class="reveal relative mx-auto w-full max-w-md" style="transition-delay: 140ms;">
            <span class="haus-tape -top-3 left-1/2 -translate-x-1/2 rotate-[3deg]" aria-hidden="true"></span>
            <div class="haus-sticker rotate-[1.4deg] rounded-2xl p-8 text-center" style={`background: linear-gradient(160deg, ${hausColors.maroon}, #1c0c15);`}>
              <p class="font-marker text-7xl leading-none" style={`color: ${hausColors.pink};`}>100%</p>
              <p class="mt-3 text-sm font-extrabold uppercase tracking-[0.2em] text-white/80">
                of proceeds fund the
              </p>
              <p class="haus-chrome mt-1 font-marker text-3xl">{hausOfLsp.fundName}</p>
              <div class="mx-auto mt-5 h-px w-24 bg-white/20"></div>
              <p class="mt-5 text-sm font-semibold leading-relaxed text-white/60">
                Show up, show out, and send someone from our comunidad further
                on their wellness journey.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ============ CALL FOR ARTISTS: the sign-up sheet ============ */}
    {/* The interest form, restyled as the Haus sign-up sheet. It mirrors the
        Google Form field-for-field (entry ids in hausArtistForm); submitting
        opens the real form pre-filled so the required art-photo upload can
        be attached there (Google file uploads cannot be posted from outside
        Google and require sign-in). */}
    <section id="artists" class="relative overflow-hidden py-16 scroll-mt-28 sm:py-20">
      <div class="pointer-events-none absolute -right-24 top-16 h-72 w-72 rounded-full blur-[110px]" style={`background: ${hausColors.violet}40;`} aria-hidden="true"></div>
      <div class="haus-halftone absolute bottom-0 right-0 h-48 w-64 opacity-15 [mask-image:radial-gradient(closest-side,black,transparent)]" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-3xl px-4 sm:px-6">
        <div class="reveal text-center">
          <p class="font-marker text-xl" style={`color: ${hausColors.mint};`}>call for artists + poets</p>
          <h2 class="mt-3 font-marker text-4xl sm:text-5xl">
            <span class="haus-glow" style={`color: ${hausColors.pink};`}>Show your art.</span>
            <span class="haus-chrome"> Take the mic.</span>
          </h2>
          <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/70">
            The gallery walls and the open mic are built from our comunidad's
            work. Tell us about you and your art; it takes two minutes.
          </p>
        </div>

        {/* How it works: three sticker steps */}
        <div class="reveal mt-8 flex flex-wrap items-stretch justify-center gap-3" style="transition-delay: 100ms;">
          {[
            "1 · Fill out the sheet",
            "2 · Attach 2+ photos of your work on Google",
            "3 · Submit + we'll be in touch",
          ].map((step, i) => (
            <span
              class="haus-sticker inline-flex items-center rounded-lg bg-off-black/60 px-3.5 py-2 text-[11px] font-extrabold uppercase tracking-[0.12em] text-white/85 backdrop-blur-sm"
              style={`transform: rotate(${[-1, 0.8, -0.6][i % 3]}deg);`}
            >
              {step}
            </span>
          ))}
        </div>

        {/* The sign-up sheet, taped to the wall */}
        <div class="reveal relative mt-12 rotate-[0.6deg]" style="transition-delay: 160ms;">
          <span class="haus-tape -top-3 left-8 rotate-[-7deg]" aria-hidden="true"></span>
          <span class="haus-tape -top-3 right-8 rotate-[6deg]" aria-hidden="true"></span>

          <div class="haus-note px-6 py-10 sm:px-12 sm:py-12">
            <p class="text-center font-marker text-3xl sm:text-4xl" style="color: #24201a;">
              the sign-up sheet
            </p>
            <p class="mt-2 text-center text-sm font-semibold text-off-black/60">
              For the art exhibit and the open mic / slam poetry hours.
            </p>

            <form
              id="haus-artist-form"
              class="mt-8 space-y-7 text-off-black"
              data-form-url={hausArtistForm.viewUrl}
              data-dob-entry={hausArtistForm.entries.dob}
              novalidate={false}
            >
              <div class="grid gap-7 sm:grid-cols-2">
                <div class="sm:col-span-2">
                  <label class="haus-label" for="haus-full-name">
                    <span class="font-marker" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                    Full name <span class="text-off-black/45">(required)</span>
                  </label>
                  <input
                    id="haus-full-name"
                    class="haus-input"
                    type="text"
                    name={hausArtistForm.entries.fullName}
                    autocomplete="name"
                    placeholder="Your name, as you'd like it shown"
                    required
                  />
                </div>
                <div>
                  <label class="haus-label" for="haus-dob">
                    <span class="font-marker" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                    Date of birth <span class="text-off-black/45">(required)</span>
                  </label>
                  <input
                    id="haus-dob"
                    class="haus-input"
                    type="date"
                    name="dob"
                    autocomplete="bday"
                    required
                  />
                </div>
                <div>
                  <label class="haus-label" for="haus-phone">
                    <span class="font-marker" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                    Phone number <span class="text-off-black/45">(required)</span>
                  </label>
                  <input
                    id="haus-phone"
                    class="haus-input"
                    type="tel"
                    name={hausArtistForm.entries.phone}
                    autocomplete="tel"
                    placeholder="So we can reach you"
                    required
                  />
                </div>
              </div>

              <fieldset>
                <legend class="haus-label">
                  <span class="font-marker" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                  What's your interest in the event? <span class="text-off-black/45">(required)</span>
                </legend>
                <div class="mt-3 flex flex-wrap gap-3">
                  {hausArtistForm.interestOptions.map((opt, i) => (
                    <label class="cursor-pointer">
                      <input
                        class="peer sr-only"
                        type="radio"
                        name={hausArtistForm.entries.interest}
                        value={opt}
                        required
                      />
                      <span
                        class="inline-block rounded-md border-2 border-off-black/60 px-4 py-2 text-xs font-extrabold uppercase tracking-[0.08em] text-off-black/75 transition-all peer-checked:border-off-black peer-checked:bg-[#ffb1d6] peer-checked:text-off-black peer-checked:shadow-[2.5px_2.5px_0_#24201a] peer-focus-visible:ring-2 peer-focus-visible:ring-[#c81e63] peer-focus-visible:ring-offset-2"
                        style={`transform: rotate(${i % 2 ? 0.8 : -0.8}deg);`}
                      >
                        {opt === "Open Mic/Slam Poetry" ? "Open Mic + Slam Poetry" : opt}
                      </span>
                    </label>
                  ))}
                </div>
              </fieldset>

              <fieldset>
                <legend class="haus-label">
                  <span class="font-marker" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                  Have you visited The Latina Sweat Project? <span class="text-off-black/45">(required)</span>
                </legend>
                <div class="mt-3 flex flex-wrap gap-3">
                  {hausArtistForm.visitedOptions.map((opt, i) => (
                    <label class="cursor-pointer">
                      <input
                        class="peer sr-only"
                        type="radio"
                        name={hausArtistForm.entries.visited}
                        value={opt}
                        required
                      />
                      <span
                        class="inline-block rounded-md border-2 border-off-black/60 px-4 py-2 text-xs font-extrabold uppercase tracking-[0.08em] text-off-black/75 transition-all peer-checked:border-off-black peer-checked:bg-[#b8ecd2] peer-checked:text-off-black peer-checked:shadow-[2.5px_2.5px_0_#24201a] peer-focus-visible:ring-2 peer-focus-visible:ring-[#c81e63] peer-focus-visible:ring-offset-2"
                        style={`transform: rotate(${i % 2 ? 0.8 : -0.8}deg);`}
                      >
                        {opt}
                      </span>
                    </label>
                  ))}
                </div>
              </fieldset>

              <div>
                <label class="haus-label" for="haus-impact">
                  <span class="font-marker" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                  How do you want your art to impact the queer community?
                </label>
                <textarea
                  id="haus-impact"
                  class="haus-input"
                  name={hausArtistForm.entries.impact}
                  rows="3"
                  placeholder="Dream big; this is what the night is for"
                ></textarea>
              </div>

              <div>
                <label class="haus-label" for="haus-invoke">
                  <span class="font-marker" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                  What do you want to invoke through your art?
                </label>
                <input
                  id="haus-invoke"
                  class="haus-input"
                  type="text"
                  name={hausArtistForm.entries.invoke}
                  placeholder="A feeling, a memory, a movement"
                />
              </div>

              <div>
                <label class="haus-label" for="haus-materials">
                  <span class="font-marker" style={`color: ${hausColors.pink};`} aria-hidden="true">x</span>
                  Do you need additional material for your display? <span class="text-off-black/45">(required)</span>
                </label>
                <input
                  id="haus-materials"
                  class="haus-input"
                  type="text"
                  name={hausArtistForm.entries.materials}
                  placeholder="Easels, frames, a table, nothing at all..."
                  required
                />
              </div>

              <div class="pt-2 text-center">
                <button
                  type="submit"
                  class="haus-btn group inline-flex items-center gap-3 px-9 py-4 text-base font-extrabold text-off-black"
                  style={`background-color: ${hausColors.pink};`}
                  data-conversion-event="haus_artist_form_open"
                  data-conversion-context="haus_page_artists"
                >
                  Save my spot
                  <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </button>
                <p id="haus-artist-status" class="mt-4 text-sm font-semibold text-off-black/60">
                  One last step happens on Google Forms: your answers carry
                  over, you attach {hausArtistForm.uploadNote}, and hit submit.
                </p>
              </div>
            </form>
          </div>
        </div>

        <p class="reveal mt-8 text-center text-sm font-semibold text-white/55" style="transition-delay: 200ms;">
          Prefer to start on Google Forms?
          <a
            href={hausArtistForm.viewUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="font-bold underline decoration-dashed underline-offset-4 transition-colors hover:text-white"
            style={`color: ${hausColors.mint};`}
            data-conversion-event="haus_artist_form_open"
            data-conversion-context="haus_page_artists_direct"
          >
            Open the form directly
          </a>
        </p>
      </div>
    </section>

    {/* ============ THE SERIES: what is Haus of LSP ============ */}
    <section id="the-haus" class="relative overflow-hidden py-16 scroll-mt-28 sm:py-20">
      <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6">
        <div class="reveal">
          <p class="text-xs font-extrabold uppercase tracking-[0.3em] text-white/45">The series</p>
          <h2 class="mt-3 font-marker text-4xl sm:text-5xl">
            <span class="haus-chrome">What is the</span>
            <span class="haus-glow" style={`color: ${hausColors.pink};`}> Haus</span><span class="haus-chrome">?</span>
          </h2>
          <p class="mt-3 text-sm font-extrabold uppercase tracking-[0.18em]" style={`color: ${hausColors.mint};`}>
            {hausOfLsp.seriesLine}
          </p>
          <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/70">
            {hausOfLsp.seriesDescription}
          </p>
        </div>

