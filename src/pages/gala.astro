<style>
  /* Cinematic hero load-in. The LCP heading and siblings rise gently into
     place; suppressed entirely for reduced-motion users. */
  @media (prefers-reduced-motion: no-preference) {
    .hero-rise {
      opacity: 0;
      animation: hero-rise 0.85s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
    }
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* Floating gold particles drifting up. Static (invisible) unless motion is
     allowed. Fine motes get a tight glow; bokeh motes get a larger soft halo. */
  .gala-particle {
    opacity: 0;
    box-shadow: 0 0 6px rgba(255, 189, 89, 0.5);
  }
  .gala-particle--bokeh {
    box-shadow: 0 0 14px 3px rgba(255, 189, 89, 0.35);
  }

  @media (prefers-reduced-motion: no-preference) {
    .gala-particle {
      animation-name: gala-float-up;
      animation-timing-function: linear;
      animation-iteration-count: infinite;
    }
  }

  @keyframes gala-float-up {
    0% {
      transform: translate(0, 0);
      opacity: 0;
    }
    12% {
      opacity: var(--peak, 0.4);
    }
    88% {
      opacity: var(--peak, 0.4);
    }
    100% {
      transform: translate(var(--drift, 0px), -92vh);
      opacity: 0;
    }
  }

  /* Aurora: slow-drifting layered radial glow behind the hero (and a softer
     variant for the impact band). Motion-safe only. */
  .gala-aurora {
    background:
      radial-gradient(40% 50% at 18% 25%, rgba(255, 189, 89, 0.16), transparent 70%),
      radial-gradient(38% 48% at 82% 30%, rgba(181, 161, 141, 0.14), transparent 70%),
      radial-gradient(45% 55% at 50% 80%, rgba(255, 189, 89, 0.1), transparent 72%);
    background-repeat: no-repeat;
  }
  .gala-aurora--soft {
    opacity: 0.55;
  }
  @media (prefers-reduced-motion: no-preference) {
    .gala-aurora {
      animation: gala-aurora-drift 18s ease-in-out infinite;
    }
  }
  @keyframes gala-aurora-drift {
    0%, 100% {
      background-position: 0% 0%, 0% 0%, 0% 0%;
      transform: scale(1);
    }
    50% {
      background-position: 6% 4%, -5% -3%, 3% -4%;
      transform: scale(1.05);
    }
  }

  /* One-time theater light sweep across the hero on load. */
  .gala-theater-sweep::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 243, 216, 0.14) 48%,
      transparent 66%
    );
    transform: translateX(-130%);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .gala-theater-sweep::after {
      animation: gala-sweep-once 1.6s cubic-bezier(0.25, 0.8, 0.25, 1) 0.3s 1
        forwards;
    }
  }
  @keyframes gala-sweep-once {
    0% {
      transform: translateX(-130%);
    }
    100% {
      transform: translateX(130%);
    }
  }

  /* Soft spotlight breathing behind the framed hero photo. */
  .gala-spotlight {
    opacity: 0.7;
  }

  /* Glowing countdown panel: a subtle continuous border glow so it reads as
     the live focal point. Motion-safe only. */
  @media (prefers-reduced-motion: no-preference) {
    .gala-countdown-panel {
      animation: gala-panel-glow 4.5s ease-in-out infinite;
    }
  }
  @keyframes gala-panel-glow {
    0%, 100% {
      box-shadow: 0 0 0 1px rgba(255, 189, 89, 0.08), 0 20px 50px -20px rgba(0, 0, 0, 0.5);
    }
    50% {
      box-shadow: 0 0 0 1px rgba(255, 189, 89, 0.22), 0 20px 60px -18px rgba(255, 189, 89, 0.18);
    }
  }

  /* Venue frame hover-lift wrapper (pairs with GalaPhotoFrame's own zoom). */
  .gala-frame-lift {
    transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    height: 100%;
  }
  .gala-frame-lift:hover {
    transform: translateY(-4px);
  }

  /* Infinite sponsor marquee: grayscale by default, gold/color on hover, pause
     on row hover. Two identical halves make the loop seamless. */
  .gala-marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 8%,
      black 92%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      black 8%,
      black 92%,
      transparent
    );
  }
  .gala-marquee__track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    width: max-content;
  }
  .gala-marquee__track--left {
    animation: gala-marquee-left 40s linear infinite;
  }
  .gala-marquee:hover .gala-marquee__track {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .gala-marquee__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }
  }
  @keyframes gala-marquee-left {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .gala-sponsor-logo {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    height: 3rem;
    filter: grayscale(1) opacity(0.65);
    transition: filter 0.3s ease, transform 0.3s ease;
  }
  .gala-sponsor-logo:hover {
    filter: grayscale(0) opacity(1);
    transform: scale(1.06);
  }

  /* Detail cards: the foil-rule divider draws across on hover, the gold
     brackets + top hairline brighten (handled inline above). */
  .gala-detail-rule {
    transition: width 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .gala-detail-card:hover .gala-detail-rule {
    width: 3.5rem;
  }

  /* Sticky conversion bar: hidden by default, shown via JS adding the
     --visible class. Both states use transform + opacity so they never
     conflict with Tailwind's `translate` utility. */
  .gala-sticky-bar {
    transform: translateY(140%);
    opacity: 0;
    pointer-events: none;
  }
  .gala-sticky-bar.gala-sticky--visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  // Subtle parallax: elements with [data-gala-parallax] lag slightly behind
  // scroll for a sense of depth. Each may carry an optional data-gala-speed
  // (default 0.1). rAF-throttled, desktop-only (>=1024px), motion-safe.
  (() => {
    const els = Array.from(
      document.querySelectorAll<HTMLElement>("[data-gala-parallax]"),
    );
    if (els.length === 0) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const lg = window.matchMedia("(min-width: 1024px)");
    let ticking = false;

    const apply = () => {
      ticking = false;
      if (!lg.matches) {
        for (const el of els) el.style.transform = "";
        return;
      }
      for (const el of els) {
        const speed = parseFloat(el.dataset.galaSpeed || "0.1");
        // Clamp the drift proportionally to the speed so subtle layers barely move.
        const max = Math.min(50, 50 * speed);
        const offset = Math.min(window.scrollY * speed, max);
        el.style.transform = `translate3d(0, ${offset}px, 0)`;
      }
    };
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(apply);
    };

    apply();
    window.addEventListener("scroll", onScroll, { passive: true });
    lg.addEventListener("change", apply);
  })();

  // Sticky interest-list conversion bar: fades in once the hero has scrolled
  // away and hides again once the closing invitation reaches view (so it never
  // doubles the final CTA). Dismissible for the session.
  (() => {
    const bar = document.getElementById("gala-sticky-bar");
    const hero = document.getElementById("save-the-date");
    const closing = document.getElementById("gala-interest");
    if (!bar || !hero) return;

    let dismissed = false;
    const closeBtn = bar.querySelector<HTMLButtonElement>(".gala-sticky-close");
    if (closeBtn) {
      closeBtn.addEventListener("click", () => {
        dismissed = true;
        bar.classList.remove("gala-sticky--visible");
      });
    }

    const evaluate = () => {
      if (dismissed) return;
      // Show only between the hero (scrolled past) and the closing invite
      // (not yet in view). Both checks must pass.
      const heroBottom = hero.getBoundingClientRect().bottom;
      const heroGone = heroBottom < 0;
      const closingInView =
        !!closing &&
        closing.getBoundingClientRect().top < window.innerHeight * 0.85;
      const shouldShow = heroGone && !closingInView;
      bar.classList.toggle("gala-sticky--visible", shouldShow);
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        ticking = false;
        evaluate();
      });
    };

    evaluate();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
  })();
</script>
