---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import GalaCountdown from "@/components/GalaCountdown.astro";
import GalaPhotoFrame from "@/components/GalaPhotoFrame.astro";
import GalaImpactStats from "@/components/GalaImpactStats.astro";
import {
  galaDetails,
  galaImpactIntro,
  galaPhotos,
  galaTeaser,
  mcaPhotoSlots,
} from "@/data/galaTeaser";

const base = import.meta.env.BASE_URL;
const flickrGalleryUrl =
  "https://www.flickr.com/photos/88623248@N07/albums/72177720330894284";

// Floating gold particles drifting up through the hero (desktop only, motion-safe).
// A mix of fine motes and a few larger "bokeh" gold dots for depth variation.
const heroParticles = Array.from({ length: 22 }, (_, i) => ({
  left: (i * 53 + 7) % 100,
  size: i % 5 === 0 ? 6 + (i % 3) : 3 + (i % 4),
  duration: 11 + (i % 6) * 2.5,
  delay: (i % 8) * 1.7,
  drift: (i % 2 === 0 ? 1 : -1) * (12 + (i % 3) * 10),
  opacity: 0.22 + (i % 3) * 0.12,
  bokeh: i % 5 === 0,
}));

// Themed SVG path markup for each galaDetails card (When / Where / Dress /
// Details), in array order so they line up with galaDetails index-for-index.
const detailIcons = [
  // When — calendar
  '<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3M4 11h16M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z" />',
  // Where — map pin
  '<path stroke-linecap="round" stroke-linejoin="round" d="M12 21s7-4.8 7-11a7 7 0 1 0-14 0c0 6.2 7 11 7 11z" /><circle cx="12" cy="10" r="2.5" />',
  // Dress — bow tie
  '<path stroke-linecap="round" stroke-linejoin="round" d="M12 12l-5-3.5a1.5 1.5 0 0 0-2.3 1.26v4.48A1.5 1.5 0 0 0 7 15.5l5-3.5 5 3.5a1.5 1.5 0 0 0 2.3-1.26V9.76A1.5 1.5 0 0 0 17 8.5L12 12z" /><circle cx="12" cy="12" r="1.4" />',
  // Details — star/ticket
  '<path stroke-linecap="round" stroke-linejoin="round" d="M12 3l2.09 4.26L19 8.27l-3.5 3.4.83 4.83L12 14.77l-4.33 2.73.83-4.83L5 8.27l4.91-1.01L12 3z" />',
];

// A lighter particle field carried down the page for energy continuity.
const ambientParticles = Array.from({ length: 10 }, (_, i) => ({
  left: (i * 89 + 13) % 100,
  size: 3 + (i % 3),
  duration: 14 + (i % 5) * 2,
  delay: (i % 7) * 2.1,
  drift: (i % 2 === 0 ? 1 : -1) * (8 + (i % 3) * 8),
  opacity: 0.18 + (i % 3) * 0.1,
}));

// Denser particle field for the closing invitation so the page bookends visually.
const closingParticles = Array.from({ length: 16 }, (_, i) => ({
  left: (i * 67 + 5) % 100,
  size: i % 4 === 0 ? 6 : 3 + (i % 4),
  duration: 12 + (i % 6) * 2,
  delay: (i % 8) * 1.5,
  drift: (i % 2 === 0 ? 1 : -1) * (10 + (i % 3) * 10),
  opacity: 0.2 + (i % 3) * 0.12,
  bokeh: i % 4 === 0,
}));

// 2025 sponsors shown as a gratitude marquee (last year's partners, from
// /public/images/galalogos/). Excludes the recap photo + QR. Duplicated by the
// marquee track for a seamless infinite scroll.
const sponsorLogos2025 = [
  "AON Logo",
  "Chicago Community Loan Fund",
  "antiquetaco",
  "barbi",
  "cruzdefuegomexcal",
  "djvestus",
  "donchurro",
  "fleetfeet",
  "losvalores",
  "ohsnap",
  "omni",
  "ponce",
  "sacredagave",
  "sox",
  "studioe",
  "vestus",
  "vidamia",
  "whiskyprieto",
  "wintrust",
];
---

<Layout
  title={`${galaTeaser.title} | The Latina Sweat Project`}
  description={`${galaTeaser.title} is coming to ${galaTeaser.venueName} on ${galaTeaser.dateTimeLabel}. A black-tie evening for art, movement, and community, and our signature fundraising event.`}
>
  <Header />
  <main class="bg-off-black text-white">
    {/* ============================ HERO ============================ */}
    <section
      id="save-the-date"
      class="relative isolate overflow-hidden border-b border-accent-gold/25 py-16 sm:py-20 lg:py-28"
    >
      {/* Aurora: slow-drifting layered radial glow (gold + mauve). */}
      <div class="gala-aurora pointer-events-none absolute inset-0" aria-hidden="true">
      </div>
      <div
        class="absolute inset-0 opacity-[0.10]"
        style="background-image: linear-gradient(rgba(255,189,89,0.28) 1px, transparent 1px), linear-gradient(90deg, rgba(255,189,89,0.2) 1px, transparent 1px); background-size: 64px 64px;"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(125% 85% at 50% -10%, transparent 38%, rgba(0,0,0,0.6) 100%);"
      >
      </div>
      <div
        class="gala-ambient pointer-events-none absolute -left-10 top-10 h-72 w-1/2 rounded-full bg-gradient-to-r from-accent-gold/20 to-transparent blur-3xl"
      >
      </div>
      <div
        class="gala-ambient pointer-events-none absolute bottom-0 right-0 h-80 w-2/3 rounded-full bg-gradient-to-l from-vibrant-pink/20 to-transparent blur-3xl"
        style="animation-delay: 2.5s;"
      >
      </div>
      <div class="absolute inset-x-0 top-0 h-px gala-foil-rule"></div>

      {/* One-time theater light sweep across the hero on load. */}
      <div class="gala-theater-sweep pointer-events-none absolute inset-0" aria-hidden="true">
      </div>

      <div
        class="pointer-events-none absolute inset-0 hidden overflow-hidden lg:block"
        aria-hidden="true"
      >
        {
          heroParticles.map((p) => (
            <span
              class:list={["gala-particle absolute bottom-0 rounded-full bg-accent-gold", p.bokeh && "gala-particle--bokeh"]}
              style={`left: ${p.left}%; width: ${p.size}px; height: ${p.size}px; --drift: ${p.drift}px; --peak: ${p.opacity}; animation-duration: ${p.duration}s; animation-delay: ${p.delay}s;`}
            />
          ))
        }
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
          <div>
            <p
              class="hero-rise flex items-center gap-3 text-xs font-bold uppercase tracking-[0.3em] text-white/55"
            >
              <span class="h-px w-8 bg-accent-gold/70"></span>
              The Latina Sweat Project presents
            </p>
            <h1
              class="hero-rise mt-5 max-w-4xl font-display text-5xl font-bold leading-[1.03] tracking-tight sm:text-6xl lg:text-7xl"
              style="animation-delay: 0.06s;"
            >
              <span class="gala-foil">{galaTeaser.shortTitle}</span>
              <span class="block text-white/90">Gala</span>
            </h1>
            {/* Gold rule that draws in beneath the title. */}
            <div
              class="gala-rule-draw hero-rise mt-5 flex items-center gap-3"
              style="animation-delay: 0.12s;"
            >
              <span class="h-px w-14 gala-foil-rule"></span>
              <span class="h-1.5 w-1.5 rotate-45 bg-accent-gold"></span>
              <span class="h-px w-full max-w-[14rem] gala-foil-rule"></span>
            </div>
            <p
              class="hero-rise mt-5 text-sm font-bold uppercase tracking-[0.32em] text-accent-gold"
              style="animation-delay: 0.16s;"
            >
              Signature Fundraising Gala
            </p>

            <div
              class="hero-rise mt-7 space-y-4 text-lg font-semibold text-white/90"
              style="animation-delay: 0.22s;"
            >
              <p class="flex items-start gap-3">
                <svg
                  class="mt-1 h-5 w-5 flex-shrink-0 text-accent-gold"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8 7V3m8 4V3M4 11h16M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"
                  />
                </svg>
                <span>{galaTeaser.dateTimeLabel}</span>
              </p>
              <p class="flex items-start gap-3">
                <svg
                  class="mt-1 h-5 w-5 flex-shrink-0 text-accent-gold"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 21s7-4.8 7-11a7 7 0 1 0-14 0c0 6.2 7 11 7 11z"
                  />
                  <circle cx="12" cy="10" r="2.5" />
                </svg>
                <span>{galaTeaser.venueName}</span>
              </p>
            </div>

            <p
              class="hero-rise mt-6 max-w-2xl text-lg leading-relaxed text-white/70 sm:text-xl"
              style="animation-delay: 0.28s;"
            >
              {galaTeaser.homepageDescription}
            </p>
            <p
              class="hero-rise mt-3 text-base font-semibold text-accent-gold"
              style="animation-delay: 0.32s;"
            >
              {galaTeaser.statusLabel}.
            </p>

            <div
              class="hero-rise mt-8 flex flex-col gap-3 sm:flex-row"
              style="animation-delay: 0.38s;"
            >
              <a
                href="#gala-interest"
                class="gala-sheen group inline-flex items-center justify-center gap-3 rounded-full bg-accent-gold px-7 py-4 text-base font-extrabold text-off-black shadow-lg shadow-accent-gold/25 transition-all duration-300 hover:scale-[1.02] hover:shadow-xl"
                data-conversion-event="gala_interest_start"
                data-conversion-context="gala_page_hero"
              >
                <span class="relative z-[1]">Save the Date</span>
                <svg
                  class="relative z-[1] h-4 w-4 transition-transform group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"
                  />
                </svg>
              </a>
              <a
                href="#impact"
                class="group inline-flex items-center justify-center gap-3 rounded-full border border-accent-gold/60 bg-white/[0.03] px-7 py-4 text-base font-extrabold text-white transition-all duration-300 hover:border-accent-gold hover:bg-accent-gold/10"
              >
                See Our Impact
                <svg
                  class="h-4 w-4 text-accent-gold transition-transform group-hover:translate-y-0.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 14l-7 7m0 0l-7-7m7 7V3"
                  />
                </svg>
              </a>
            </div>
          </div>

          <div
            class="hero-rise group relative"
            style="animation-delay: 0.24s;"
          >
            {/* Soft spotlight breathing behind the framed photo. */}
            <div
              class="gala-spotlight pointer-events-none absolute -inset-6 rounded-full bg-[radial-gradient(circle_at_50%_40%,rgba(255,189,89,0.32),transparent_60%)] blur-2xl"
              aria-hidden="true"
            >
            </div>
            <div
              class="gala-ambient absolute -inset-3 rounded-[2rem] bg-gradient-to-br from-accent-gold/30 via-vibrant-pink/20 to-transparent blur-2xl"
            >
            </div>
            <div
              data-gala-parallax
              data-gala-speed="0.1"
              class="relative"
              style="will-change: transform;"
            >
              <GalaPhotoFrame
                slot={galaPhotos.atrium}
                variant="hero"
                loading="eager"
                corners
              />
              <div
                class="absolute right-5 top-5 rounded-full border border-accent-gold/40 bg-off-black/80 px-4 py-2 text-xs font-extrabold uppercase tracking-[0.18em] text-accent-gold shadow-lg backdrop-blur-md"
              >
                Black tie
              </div>
            </div>
          </div>
        </div>

        {/* Glowing glass countdown panel — the live focal point. */}
        <div
          class="gala-countdown-panel reveal mt-12 rounded-3xl border border-accent-gold/40 bg-black/30 p-4 shadow-xl shadow-black/30 backdrop-blur-md sm:p-5 lg:p-6"
        >
          <div class="grid items-center gap-5 lg:grid-cols-[0.9fr_1.6fr_0.9fr]">
            <div class="text-center lg:text-left">
              <p
                class="text-[11px] font-bold uppercase tracking-[0.22em] text-white/55"
              >
                Countdown to
              </p>
              <p class="mt-1 font-display text-xl font-bold text-accent-gold">
                {galaTeaser.shortTitle}
              </p>
            </div>
            <GalaCountdown variant="compact" />
            <p
              class="text-center text-sm font-semibold text-white/70 lg:text-right"
            >
              A night to move our future, together.
            </p>
          </div>
        </div>

        <div class="reveal mt-12 flex justify-center">
          <a
            href="#impact"
            class="group inline-flex flex-col items-center gap-2 text-[10px] font-bold uppercase tracking-[0.3em] text-white/40 transition-colors duration-300 hover:text-accent-gold"
          >
            Scroll to explore
            <svg
              class="h-5 w-5 text-accent-gold/70 motion-safe:animate-bounce"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 14l-7 7m0 0l-7-7"
              />
            </svg>
          </a>
        </div>
      </div>
    </section>

    {/* Gold ribbon divider */}
    <div class="gala-ribbon relative -mt-px h-8 bg-off-black" aria-hidden="true">
      <div class="absolute inset-x-0 top-1/2 flex -translate-y-1/2 items-center justify-center gap-4">
        <span class="h-px w-24 sm:w-40 gala-foil-rule"></span>
        <span class="h-2 w-2 rotate-45 bg-accent-gold"></span>
        <span class="h-px w-24 sm:w-40 gala-foil-rule"></span>
      </div>
    </div>

    {/* ============================ IMPACT ============================ */}
    <section
      id="impact"
      class="relative overflow-hidden border-b border-white/10 py-16 scroll-mt-24 sm:py-20 lg:py-24"
    >
      <div
        class="absolute inset-0 bg-gradient-to-b from-off-black via-[#161616] to-off-black"
      >
      </div>
      {/* Faint aurora drift so the section feels continuous with the hero. */}
      <div class="gala-aurora gala-aurora--soft pointer-events-none absolute inset-0" aria-hidden="true">
      </div>
      <div
        class="gala-ambient pointer-events-none absolute left-1/2 top-10 h-72 w-2/3 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(255,189,89,0.16),transparent_65%)] blur-2xl"
      >
      </div>
      <div
        class="absolute inset-x-0 top-0 mx-auto h-px max-w-3xl gala-foil-rule opacity-60"
      >
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p
            class="reveal text-xs font-extrabold uppercase tracking-[0.3em] text-accent-gold"
          >
            {galaImpactIntro.eyebrow}
          </p>
          <h2
            class="reveal mt-4 font-display text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl"
            style="transition-delay: 90ms;"
          >
            {galaImpactIntro.heading}
          </h2>
          <p
            class="reveal mt-5 text-lg leading-relaxed text-white/70"
            style="transition-delay: 180ms;"
          >
            {galaImpactIntro.body}
          </p>
        </div>

        <div class="reveal mt-14">
          <GalaImpactStats variant="feature" />
        </div>
      </div>
    </section>

    {/* Gold ribbon divider */}
    <div class="gala-ribbon relative h-8 bg-off-black" aria-hidden="true">
      <div class="absolute inset-x-0 top-1/2 flex -translate-y-1/2 items-center justify-center gap-4">
        <span class="h-px w-24 sm:w-40 gala-foil-rule"></span>
        <span class="h-2 w-2 rotate-45 bg-accent-gold"></span>
        <span class="h-px w-24 sm:w-40 gala-foil-rule"></span>
      </div>
    </div>

    {/* ====================== EVENING WITH PURPOSE ====================== */}
    <section
      class="relative overflow-hidden border-b border-white/10 py-16 sm:py-20 lg:py-24"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-off-black via-[#171717] to-off-black"
      >
      </div>
      <div
        class="absolute inset-0 opacity-[0.08]"
        style="background-image: radial-gradient(circle at 20% 20%, #ffbd59 0, transparent 28%), radial-gradient(circle at 80% 70%, #b5a18d 0, transparent 24%);"
      >
      </div>

      {/* Ambient particles carrying the hero's energy down the page. */}
      <div
        class="pointer-events-none absolute inset-0 hidden overflow-hidden lg:block"
        aria-hidden="true"
      >
        {
          ambientParticles.map((p) => (
            <span
              class="gala-particle absolute bottom-0 rounded-full bg-accent-gold"
              style={`left: ${p.left}%; width: ${p.size}px; height: ${p.size}px; --drift: ${p.drift}px; --peak: ${p.opacity}; animation-duration: ${p.duration}s; animation-delay: ${p.delay}s;`}
            />
          ))
        }
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
          <div class="reveal">
            <p
              class="text-xs font-extrabold uppercase tracking-[0.28em] text-accent-gold"
            >
              At the Museum of Contemporary Art Chicago
            </p>
            <h2
              class="mt-4 max-w-2xl font-display text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl"
            >
              An evening with purpose.
            </h2>
            <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/70">
              {galaTeaser.pageDescription}
            </p>
            <p class="mt-4 max-w-2xl text-base leading-relaxed text-white/60">
              MCA's event spaces include the Atrium, Terrace, and Sculpture
              Garden, with downtown access and a striking contemporary backdrop.
              It is the right stage for a bigger, bolder chapter of community
              celebration.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {
              mcaPhotoSlots.slice(1).map((slot, index) => (
                <div
                  class:list={[
                    "reveal group",
                    slot.id === "facade" ? "sm:col-span-2" : "",
                  ]}
                  style={`transition-delay: ${index * 110}ms;`}
                >
                  <div class="gala-frame-lift" data-gala-parallax={slot.id === "facade" ? undefined : ""} data-gala-speed="0.04">
                    <GalaPhotoFrame
                      slot={slot}
                      variant={slot.id === "facade" ? "panorama" : "venue"}
                      corners
                    />
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-4">
          {
            galaDetails.map((detail, index) => {
              const icon = detailIcons[index];
              return (
                <div
                  class="gala-detail-card reveal group relative overflow-hidden rounded-2xl border border-accent-gold/20 bg-white/[0.04] p-5 transition-all duration-300 hover:-translate-y-1 hover:border-accent-gold/45 hover:shadow-lg hover:shadow-accent-gold/10"
                  style={`transition-delay: ${index * 90}ms;`}
                >
                  {/* Top gold hairline that brightens on hover. */}
                  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-gold/50 to-transparent transition-opacity duration-300 group-hover:via-accent-gold" />
                  {/* Gold corner brackets (black-tie trim, matches photo frames). */}
                  <span class="pointer-events-none absolute left-2 top-2 h-4 w-4 rounded-tl border-l-2 border-t-2 border-accent-gold/60 transition-colors duration-300 group-hover:border-accent-gold" />
                  <span class="pointer-events-none absolute right-2 top-2 h-4 w-4 rounded-tr border-r-2 border-t-2 border-accent-gold/60 transition-colors duration-300 group-hover:border-accent-gold" />
                  <span class="pointer-events-none absolute bottom-2 left-2 h-4 w-4 rounded-bl border-b-2 border-l-2 border-accent-gold/60 transition-colors duration-300 group-hover:border-accent-gold" />
                  <span class="pointer-events-none absolute bottom-2 right-2 h-4 w-4 rounded-br border-b-2 border-r-2 border-accent-gold/60 transition-colors duration-300 group-hover:border-accent-gold" />

                  <div class="relative">
                    <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-accent-gold/25 bg-accent-gold/10 text-accent-gold transition-all duration-300 group-hover:bg-accent-gold/20 group-hover:shadow-[0_0_18px_-4px] group-hover:shadow-accent-gold/50">
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.8"
                        set:html={icon}
                      />
                    </span>
                    <p class="mt-4 text-xs font-extrabold uppercase tracking-[0.2em] text-accent-gold">
                      {detail.label}
                    </p>
                    {/* Short foil-rule divider that draws across on hover. */}
                    <div class="gala-detail-rule mt-3 h-px w-10 gala-foil-rule" />
                    <p class="mt-3 text-base font-bold leading-snug text-white/90">
                      {detail.value}
                    </p>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    {/* ======================= LAST YEAR RECAP ======================= */}
    <section class="bg-[#fdf2f2] py-16 text-off-black sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
          <div class="reveal">
            <p
              class="text-xs font-extrabold uppercase tracking-[0.28em] text-vibrant-pink"
            >
              Last year's Gala
            </p>
            <h2
              class="mt-4 font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl"
            >
              Relive Noche Inolvidable while we prepare for what comes next.
            </h2>
            <p class="mt-5 text-lg leading-relaxed text-medium-gray">
              Our 2025 inaugural gala brought together movement, wellness, and
              community care. This gallery stays here as a recap while the next
              gala takes shape.
            </p>
            <a
              href={flickrGalleryUrl}
              target="_blank"
              rel="noopener noreferrer"
