     on a per-element --tl-delay custom property. */
  :global(.js) .gala-timeline .gala-tl-anim {
    opacity: 0;
    transform: translateY(10px);
  }
  :global(.js) .gala-timeline.is-visible .gala-tl-anim {
    opacity: 1;
    transform: none;
    transition:
      opacity 0.7s cubic-bezier(0.25, 0.8, 0.25, 1),
      transform 0.7s cubic-bezier(0.25, 0.8, 0.25, 1);
    transition-delay: var(--tl-delay, 0s);
  }
  :global(.js) .gala-timeline .gala-tl-pop {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(45deg) scale(0);
  }
  :global(.js) .gala-timeline.is-visible .gala-tl-pop {
    opacity: 1;
    transform: translate(-50%, -50%) rotate(45deg) scale(1);
    transition:
      opacity 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: var(--tl-delay, 0s);
  }
  /* Non-JS fallback keeps the diamond's rotation. */
  .gala-timeline .gala-tl-pop {
    transform: translate(-50%, -50%) rotate(45deg);
  }
  :global(.js) .gala-timeline .gala-tl-track {
    transform: scaleX(0);
    transform-origin: left center;
  }
  :global(.js) .gala-timeline.is-visible .gala-tl-track {
    transform: scaleX(1);
    transition: transform 1.1s cubic-bezier(0.25, 0.8, 0.25, 1) 0.1s;
  }
  :global(.js) .gala-timeline .gala-tl-bar {
    transform: scaleX(0);
    transform-origin: left center;
  }
  :global(.js) .gala-timeline.is-visible .gala-tl-bar {
    transform: scaleX(1);
    transition: transform 0.9s cubic-bezier(0.25, 0.8, 0.25, 1);
    transition-delay: var(--tl-delay, 0.9s);
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.js) .gala-timeline .gala-tl-anim,
    :global(.js) .gala-timeline .gala-tl-pop,
    :global(.js) .gala-timeline .gala-tl-track,
    :global(.js) .gala-timeline .gala-tl-bar {
      opacity: 1;
      transform: none;
      transition: none;
    }
    :global(.js) .gala-timeline .gala-tl-pop {
      transform: translate(-50%, -50%) rotate(45deg);
    }
  }

  /* A soft glow that travels the track once the timeline is in view, like a
     spotlight crossing the evening. Motion-safe only. */
  .gala-tl-glow {
    opacity: 0;
    box-shadow: 0 0 14px 5px rgba(255, 189, 89, 0.4);
