    box-shadow: 0 18px 40px -18px rgba(255, 107, 82, 0.45);
  }

  /* The rising sun disc, centered behind the wordmark (positioned via Tailwind
     -translate-x/y-1/2). A bright core, a warm glow halo, and soft rays fanning
     out. All motion is motion-safe only. */
  .sf-sun {
    background: radial-gradient(
      circle at 50% 50%,
      rgba(255, 189, 89, 0.55) 0%,
      rgba(255, 189, 89, 0.3) 24%,
      rgba(255, 107, 82, 0.18) 46%,
      rgba(233, 79, 138, 0.07) 62%,
      transparent 74%
    );
  }
  .sf-sun-core {
    background: radial-gradient(
      circle at 50% 44%,
      rgba(255, 250, 238, 0.98) 0%,
      rgba(255, 212, 130, 0.9) 34%,
      rgba(255, 148, 92, 0.55) 62%,
      rgba(233, 79, 138, 0.18) 84%,
      transparent 100%
    );
    filter: blur(2px);
  }
  /* Soft rays: a faint conic fan clipped to a disc, slowly rotating. */
  .sf-rays {
    background: repeating-conic-gradient(
      from 0deg at 50% 50%,
      rgba(255, 189, 89, 0.16) 0deg 6deg,
      transparent 6deg 18deg
    );
    -webkit-mask-image: radial-gradient(
      circle at 50% 50%,
      transparent 26%,
      black 38%,
      transparent 68%
    );
    mask-image: radial-gradient(
      circle at 50% 50%,
      transparent 26%,
      black 38%,
      transparent 68%
    );
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf-sun {
      animation: sf-sun-breathe 10s ease-in-out infinite;
