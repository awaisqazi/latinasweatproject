            class="group inline-flex items-center justify-center gap-2.5 rounded-full border border-white/25 bg-white/[0.04] px-7 py-3.5 text-sm font-extrabold text-white transition-all duration-300 hover:border-[var(--sf-dusk)] hover:bg-[var(--sf-dusk)]/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-off-black"
            data-conversion-event="sweatfest_follow_click"
            data-conversion-context="sweatfest_page_closing"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={instagramGlyph} />
            Follow along
          </a>
        </div>

        <p
          class="reveal mt-8 text-[11px] font-bold uppercase tracking-[0.22em] text-white/65"
          style="transition-delay: 560ms;"
        >
          {sweatFest.statusLabel}
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ============================================================
     Sweat Fest "Sunrise to Last Set" utilities. Scoped to this page.
     The three arc colors ride on --sf-sunrise / --sf-ember / --sf-dusk,
     set from sweatFestColors on <main> so CSS and data never drift.
     ============================================================ */

  /* Warm gradient signature clipped to text (dark backgrounds only). */
  .sf-foil {
    background-image: linear-gradient(
      92deg,
      var(--sf-sunrise) 0%,
      var(--sf-ember) 48%,
      var(--sf-dusk) 100%
    );
    background-size: 200% 100%;
    background-position: 0% 50%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf-foil {
      animation: sf-foil-slide 8s ease-in-out infinite;
    }
  }
  @keyframes sf-foil-slide {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  /* Daylight wordmark gradient: deepened stops so the sunrise gradient stays
     legible clipped to text on cream/white (raw gold/coral wash out). Shares
     the slow slide animation with .sf-foil. */
  .sf-foil-light {
    background-image: linear-gradient(
      92deg,
      #d47500 0%,
      #e8452a 50%,
      #c81e63 100%
    );
    background-size: 200% 100%;
    background-position: 0% 50%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf-foil-light {
      animation: sf-foil-slide 8s ease-in-out infinite;
    }
  }

  /* Warm hairline rule (the horizon). */
  .sf-rule {
    background-image: linear-gradient(
      90deg,
      transparent 0%,
      var(--sf-sunrise) 25%,
      var(--sf-ember) 50%,
      var(--sf-dusk) 75%,
      transparent 100%
    );
  }

  /* The day-arc gradient track, horizontal and vertical. */
  .sf-track {
    background-image: linear-gradient(
      90deg,
      var(--sf-sunrise),
      var(--sf-ember),
      var(--sf-dusk)
