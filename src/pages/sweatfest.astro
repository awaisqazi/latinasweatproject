                  <span
                    class="sf-stamp -top-4 right-4 z-10 bg-[#fffdf6] px-3 py-1.5 text-[11px]"
                    style={`position: absolute; color: ${deep(sweatFestColors.ember)}; transform: rotate(3deg);`}
                  >
                    Best value
                  </span>
                )}
                <div class="p-6 pb-5 text-center">
                  <p class="text-[10px] font-extrabold uppercase tracking-[0.24em] text-off-black/50">
                    Sweat Fest 2026 · Admit one
                  </p>
                  <h3 class="mt-3 font-slab text-2xl uppercase tracking-wide text-off-black">
                    {tier.name}
                  </h3>
                  <p class="mt-2 flex items-baseline justify-center gap-1">
                    <span class="font-slab text-5xl tracking-tight" style={`color: ${tier.featured ? deep(sweatFestColors.ember) : "#1e1e1e"};`}>
                      ${tier.price}
                    </span>
                    <span class="text-[11px] font-bold uppercase tracking-[0.12em] text-medium-gray">
                      per person
                    </span>
                  </p>
                  <p class="mt-3 text-xs font-extrabold uppercase tracking-[0.12em]" style={`color: ${deep(sweatFestColors.dusk)};`}>
                    {tier.includes}
                  </p>
                </div>
                {/* Perforation with punched side notches. */}
                <div class="sf-stub-perf" aria-hidden="true"></div>
                <div class="flex flex-1 flex-col p-6 pt-5 text-center">
                  <p class="flex-1 text-sm leading-relaxed text-medium-gray">
                    {tier.description}
                  </p>
                  <div class="mt-6">
                    {sweatFestTickets.onSale && sweatFestTickets.url ? (
                      <a
                        href={sweatFestTickets.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="sf-btn group inline-flex w-full items-center justify-center gap-2.5 bg-[var(--sf-sunrise)] px-6 py-3.5 text-sm font-extrabold text-off-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-off-black focus-visible:ring-offset-4"
                        data-conversion-event="sweatfest_ticket_click"
                        data-conversion-context={`sweatfest_page_tickets_${tier.id}`}
                      >
                        {sweatFest.ticketsLabel}
                        <svg
                          class="h-4 w-4 transition-transform group-hover:translate-x-1"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2.5"
                          aria-hidden="true"
                          set:html={arrowRight}
                        />
                      </a>
                    ) : (
                      <span class="inline-flex w-full items-center justify-center rounded-md border-2 border-dashed border-off-black/30 px-6 py-3.5 text-xs font-extrabold uppercase tracking-[0.14em] text-medium-gray">
                        On sale soon
                      </span>
                    )}
                  </div>
                  <div class="sf-barcode mx-auto mt-6" aria-hidden="true"></div>
                  <p class="mt-1.5 text-[10px] font-bold uppercase tracking-[0.3em] text-off-black/40" aria-hidden="true">
                    SF26-000{index + 1}
                  </p>
                </div>
              </div>
            ))
          }
        </div>

        {/* Until sales open, the conversion is the follow. */}
        {
          !sweatFestTickets.onSale && (
            <div class="reveal mx-auto mt-14 max-w-2xl text-center">
              <p class="text-base leading-relaxed text-medium-gray">
                Tickets are not on sale yet. Follow
                <span class="font-extrabold text-off-black"> @latinasweatproject </span>
                on Instagram to hear first when they drop.
              </p>
              <a
                href={instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="sf-btn mt-6 inline-flex items-center justify-center gap-3 bg-off-black px-7 py-3.5 text-sm font-extrabold text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--sf-dusk)] focus-visible:ring-offset-4"
                data-conversion-event="sweatfest_follow_click"
                data-conversion-context="sweatfest_page_tickets"
              >
                <svg class="h-4.5 w-4.5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={instagramGlyph} />
                Follow for the drop
              </a>
            </div>
          )
        }
      </div>
    </section>

    {/* Second ticker, tilted the other way. */}
    <div class="sf-ticker-wrap relative z-10 -my-2" aria-hidden="true">
      <div class="sf-ticker rotate-1 bg-off-black py-3">
        <div class="sf-ticker-track sf-ticker-track-reverse">
          {
            [0, 1].map(() => (
              <div class="flex shrink-0 items-center gap-8 pr-8 sm:gap-10 sm:pr-10">
                {[0, 1, 2].map(() =>
                  mottoLines.map((line, i) => (
                    <>
                      <span class="whitespace-nowrap font-slab text-lg uppercase tracking-wide text-[#fff8ef] sm:text-xl">
                        {line.replace(/\.$/, "")}
                      </span>
                      <span
                        class="text-xl leading-none sm:text-2xl"
                        style={`color: ${accentOf(arcOrder[i % 3])};`}
                      >
                        ✶
                      </span>
                    </>
                  )),
                )}
              </div>
            ))
          }
        </div>
      </div>
    </div>

    {/* ============================ IMPACT ============================ */}
    <section id="impact" class="relative overflow-hidden bg-[#fff6ee] py-16 scroll-mt-28 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p class="reveal">
            <span class="sf-stamp px-3 py-1.5 text-[11px]" style={`color: ${deep(sweatFestColors.ember)};`}>
              {sweatFestImpactIntro.eyebrow}
            </span>
          </p>
          <h2
            class="reveal mt-6 font-slab text-4xl uppercase tracking-tight text-off-black sm:text-5xl"
            style="transition-delay: 90ms;"
          >
            {sweatFestImpactIntro.heading}
          </h2>
          <p
            class="reveal mt-5 text-lg leading-relaxed text-medium-gray"
            style="transition-delay: 180ms;"
          >
            {sweatFestImpactIntro.body}
          </p>
        </div>

        <dl class="mt-14 grid grid-cols-2 gap-x-6 gap-y-12 lg:grid-cols-4">
          {
            sweatFestImpact.map((stat, index) => {
              const accent = accentOf(arcOrder[index % 3]);
              const finalValue = `${stat.prefix}${
                stat.useComma ? stat.to.toLocaleString("en-US") : stat.to
              }${stat.suffix}`;
              return (
                <div
                  class="reveal text-center"
                  style={`transition-delay: ${index * 90}ms;`}
                >
                  <dd
                    class="font-slab text-4xl leading-none tracking-tight sm:text-5xl"
                    style={`color: ${deep(accent)};`}
                    data-sf-countup
                    data-sf-countup-to={stat.to}
                    data-sf-countup-prefix={stat.prefix}
                    data-sf-countup-suffix={stat.suffix}
                    data-sf-countup-comma={String(stat.useComma)}
                  >
                    {finalValue}
                  </dd>
                  <div class="mx-auto mt-3 h-3 w-24" set:html={squiggle(accent)} />
                  <dt class="mt-3 text-sm font-bold leading-snug text-off-black">
                    {stat.label}
                  </dt>
                </div>
              );
            })
          }
        </dl>
      </div>
    </section>

    {/* ========================== SPONSORSHIP ========================== */}
    <section
      id="sponsors"
      class="relative overflow-hidden bg-[#fffaf1] py-16 scroll-mt-28 sm:py-20 lg:py-24"
    >
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
          <div class="reveal text-center lg:text-left">
            <p>
              <span class="sf-stamp px-3 py-1.5 text-[11px]" style={`color: ${deep(sweatFestColors.dusk)};`}>
                Partner with us
              </span>
            </p>
            <h2 class="mt-6 font-slab text-4xl uppercase tracking-tight text-off-black sm:text-5xl">
              Sponsor <span class="whitespace-nowrap">Sweat Fest</span>
            </h2>
            <p class="mt-5 text-base leading-relaxed text-medium-gray sm:text-lg">
              {sweatFestSponsorship.intro}
            </p>
            <p class="mt-6 inline-block text-xs font-extrabold uppercase tracking-[0.16em]" style={`color: ${deep(sweatFestColors.dusk)};`}>
              {sweatFestSponsorship.closesLabel}
            </p>
          </div>

          {/* What sponsorship funds: a pinned-up note. */}
          <div class="sf-note reveal relative p-7 pt-9 sm:p-8" style="transition-delay: 120ms; --sf-note-tilt: 0.9deg; background: #fffdf6;">
            <span class="sf-tape left-1/2 top-0 -translate-x-1/2 -translate-y-1/2 rotate-[2deg]" aria-hidden="true"></span>
            <h3 class="text-center font-slab text-xl uppercase tracking-wide text-off-black lg:text-left">
              {sweatFestSponsorship.fundsHeading}
            </h3>
            <ul class="mt-5 space-y-3.5">
              {
                sweatFestSponsorship.funds.map((item, index) => {
                  const accent = accentOf(arcOrder[index % 3]);
                  return (
                    <li class="flex items-start gap-3 text-left">
                      <span
                        class="mt-1.5 inline-block h-2.5 w-2.5 flex-shrink-0 rotate-45"
                        style={`background: ${accent};`}
                        aria-hidden="true"
                      >
                      </span>
                      <span class="text-sm font-semibold leading-relaxed text-off-black">
                        {item}
                      </span>
                    </li>
                  );
                })
              }
            </ul>
          </div>
        </div>

        {/* Sponsor tiers as paper cards. */}
        <div class="mt-16 grid items-stretch gap-x-5 gap-y-8 md:grid-cols-3">
          {
            sweatFestSponsorship.tiers.map((tier, index) => (
              <div
                class:list={["sf-stub reveal relative flex h-full flex-col", tier.featured && "sf-stub-featured"]}
                style={`transition-delay: ${index * 110}ms;`}
              >
                {tier.featured && (
                  <span
                    class="sf-stamp -top-4 right-4 z-10 bg-[#fffdf6] px-3 py-1.5 text-[11px]"
                    style={`position: absolute; color: ${deep(sweatFestColors.ember)}; transform: rotate(3deg);`}
                  >
                    Top billing
                  </span>
                )}
                <div class="p-7 text-center sm:p-8">
                  <h3 class="font-slab text-xl uppercase tracking-wide text-off-black">
                    {tier.name}
                  </h3>
                  <p
                    class="mt-3 font-slab text-5xl tracking-tight"
                    style={`color: ${deep(sweatFestColors.sunrise)};`}
                  >
                    ${tier.amount.toLocaleString("en-US")}
                  </p>
                  <p class="mt-3 text-xs font-extrabold uppercase tracking-[0.12em]" style={`color: ${deep(sweatFestColors.ember)};`}>
                    {tier.tickets}
                  </p>
                </div>
                <div class="sf-stub-perf" aria-hidden="true"></div>
                <ul class="flex-1 space-y-3 p-7 pb-5 pt-5 sm:p-8 sm:pb-5 sm:pt-5">
                  {tier.benefits.map((benefit, i) => (
                    <li class="flex items-start gap-2.5 text-left">
                      <span
                        class="mt-1.5 inline-block h-2 w-2 flex-shrink-0 rotate-45"
                        style={`background: ${accentOf(arcOrder[i % 3])};`}
                        aria-hidden="true"
                      >
                      </span>
                      <span class="text-sm leading-relaxed text-medium-gray">
                        {benefit}
                      </span>
                    </li>
                  ))}
                </ul>
                <div class="px-7 pb-7 sm:px-8 sm:pb-8">
                  {sweatFestTickets.onSale && sweatFestTickets.url ? (
                    <a
                      href={sweatFestTickets.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="sf-btn group inline-flex w-full items-center justify-center gap-2.5 bg-[var(--sf-sunrise)] px-5 py-3.5 text-sm font-extrabold text-off-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-off-black focus-visible:ring-offset-4"
                      data-conversion-event="sweatfest_sponsor_purchase_click"
                      data-conversion-context={`sweatfest_page_sponsors_${tier.id}`}
                    >
                      Purchase {tier.name}
                      <svg
                        class="h-4 w-4 flex-shrink-0 transition-transform group-hover:translate-x-1"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2.5"
                        aria-hidden="true"
                        set:html={arrowRight}
                      />
                    </a>
                  ) : (
                    <a
                      href={sponsorMailto}
                      class="sf-btn group inline-flex w-full items-center justify-center gap-2.5 bg-[var(--sf-sunrise)] px-5 py-3.5 text-sm font-extrabold text-off-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-off-black focus-visible:ring-offset-4"
                      data-conversion-event="sweatfest_sponsor_lead"
                      data-conversion-context={`sweatfest_page_sponsors_${tier.id}`}
                    >
                      Ask about {tier.name}
                      <svg
                        class="h-4 w-4 flex-shrink-0 transition-transform group-hover:translate-x-1"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2.5"
                        aria-hidden="true"
                        set:html={arrowRight}
                      />
                    </a>
                  )}
                </div>
              </div>
            ))
          }
        </div>

        {/* Benefits caveat: packages are still being confirmed. */}
        <p class="reveal mx-auto mt-9 max-w-2xl text-center text-sm font-semibold italic text-medium-gray">
          {sweatFestSponsorship.finePrint}
        </p>

        {/* Sponsorship CTA as an airmail postcard: striped par-avion edges,
            slab headline, hand-stamped deadline. */}
        <div class="sf-postcard reveal relative mt-14 px-6 py-12 text-center text-off-black sm:px-10 lg:px-16">
          <div class="sf-airmail absolute inset-x-0 top-0 h-2.5" aria-hidden="true"></div>
          <div class="sf-airmail absolute inset-x-0 bottom-0 h-2.5" aria-hidden="true"></div>

          <div class="relative">
            <h3 class="font-slab text-3xl uppercase tracking-tight sm:text-4xl">
              {sweatFestSponsorship.ctaHeading}
            </h3>
            <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-medium-gray sm:text-lg">
              {sweatFestSponsorship.ctaBody}
            </p>
            <div class="mt-9 flex flex-col items-center justify-center gap-5">
              {
                sweatFestTickets.onSale && sweatFestTickets.url && (
                  <a
                    href={sweatFestTickets.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="sf-btn group inline-flex w-full items-center justify-center gap-3 bg-[var(--sf-sunrise)] px-5 py-4 text-sm font-extrabold text-off-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-off-black focus-visible:ring-offset-4 sm:w-auto sm:px-8 sm:text-base"
                    data-conversion-event="sweatfest_sponsor_purchase_click"
                    data-conversion-context="sweatfest_page_sponsors_postcard"
                  >
                    Purchase a sponsorship
                    <svg
                      class="h-4 w-4 transition-transform group-hover:translate-x-1"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                      aria-hidden="true"
                      set:html={arrowRight}
                    />
                  </a>
                )
              }
              <p class="text-sm font-semibold text-medium-gray">
                Need a custom partnership? Email
                <a
                  href={sponsorMailto}
                  class="ml-1 font-extrabold text-off-black underline decoration-[var(--sf-dusk)] decoration-2 underline-offset-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--sf-dusk)]"
                  data-conversion-event="sweatfest_sponsor_lead"
                  data-conversion-context="sweatfest_page_sponsors_custom"
                >
                  {sweatFestSponsorship.contactEmail}
                </a>
              </p>
              <span class="sf-stamp px-3 py-1.5 text-[11px]" style={`color: ${deep(sweatFestColors.dusk)};`}>
                {sweatFestSponsorship.closesLabel}
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ===================== CLOSING BAND: LAST SET ===================== */}
    <section class="relative overflow-hidden bg-off-black pb-16 pt-24 text-white sm:pb-20 sm:pt-28 lg:pb-24">
      {/* Papel picado strung across the top of the night. */}
      <div
        class="sf-picado absolute inset-x-0 top-4 h-[52px]"
        style={`background-image: ${picadoUri};`}
        aria-hidden="true"
      >
      </div>
      {/* Dusk glows: the sun has crossed to magenta. */}
      <div
        class="gala-ambient pointer-events-none absolute -left-20 bottom-0 h-80 w-2/3 rounded-full bg-gradient-to-r from-[var(--sf-dusk)]/20 to-transparent blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="gala-ambient pointer-events-none absolute -right-20 top-0 h-72 w-1/2 rounded-full bg-gradient-to-l from-[var(--sf-ember)]/15 to-transparent blur-3xl"
        style="animation-delay: 3s;"
        aria-hidden="true"
      >
      </div>
      {/* Ember motes floating up into the night. */}
      <div
        class="pointer-events-none absolute inset-0 hidden overflow-hidden lg:block"
        aria-hidden="true"
      >
        {
          closingMotes.map((m) => (
            <span
              class="sf-mote absolute bottom-0 rounded-full"
              style={`left: ${m.left}%; width: ${m.size}px; height: ${m.size}px; background: ${m.color}; --sf-drift: ${m.drift}px; --sf-peak: ${m.opacity}; box-shadow: 0 0 8px ${m.color}; animation-duration: ${m.duration}s; animation-delay: ${m.delay}s;`}
            />
          ))
        }
      </div>

      <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
        <p class="reveal text-xs font-extrabold uppercase tracking-[0.3em] text-white/55">
          {sweatFest.title} · {sweatFest.shortDateLabel}
        </p>
        <h2 class="mt-6 font-slab text-4xl uppercase leading-[1.06] tracking-tight sm:text-5xl">
          {
            mottoLines.map((line, i) => (
              <span
                class="reveal block"
                style={`color: ${accentOf(arcOrder[i % 3])}; transition-delay: ${90 + i * 120}ms; transform: rotate(${[-0.7, 0.5, -0.4][i % 3]}deg);`}
              >
                {line}
              </span>
            ))
          }
        </h2>
        <p
          class="reveal mx-auto mt-7 inline-flex flex-wrap items-center justify-center gap-x-3 gap-y-1 border-2 border-white/25 px-5 py-2 text-xs font-bold uppercase tracking-[0.14em] text-white/85"
          style="transition-delay: 420ms;"
        >
          <span>{sweatFest.dateTimeLabel}</span>
          <span class="text-white/40" aria-hidden="true">·</span>
          <span>{sweatFest.venueLine}</span>
        </p>

        <div
          class="reveal mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
          style="transition-delay: 500ms;"
        >
          <a
            href="#tickets"
            class="sf-btn sf-btn-night inline-flex items-center justify-center gap-3 bg-[var(--sf-sunrise)] px-7 py-3.5 text-sm font-extrabold text-off-black focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-off-black"
          >
            Explore passes
          </a>
          <a
            href="#sponsors"
            class="inline-flex items-center justify-center gap-3 border-2 border-white/30 px-7 py-3.5 text-sm font-extrabold text-white transition-colors duration-300 hover:border-[var(--sf-ember)] hover:bg-[var(--sf-ember)]/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-off-black"
          >
            Become a sponsor
          </a>
          <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2.5 border-2 border-white/30 px-7 py-3.5 text-sm font-extrabold text-white transition-colors duration-300 hover:border-[var(--sf-dusk)] hover:bg-[var(--sf-dusk)]/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-off-black"
            data-conversion-event="sweatfest_follow_click"
            data-conversion-context="sweatfest_page_closing"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={instagramGlyph} />
            Follow along
          </a>
        </div>

        <p
          class="reveal mt-9 text-[11px] font-bold uppercase tracking-[0.22em] text-white/65"
          style="transition-delay: 560ms;"
        >
          {sweatFest.statusLabel}
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ============================================================
     Sweat Fest "printed flyer" utilities. Scoped to this page.
     The three arc colors ride on --sf-sunrise / --sf-ember / --sf-dusk,
     set from sweatFestColors on <main> so CSS and data never drift.
     ============================================================ */

  /* Paper grain over everything: printed stock, not backlit glass. */
  .sf-grain {
    background-repeat: repeat;
    background-size: 180px 180px;
    opacity: 0.05;
    mix-blend-mode: multiply;
  }

  /* The print kit itself (.sf-print, .sf-stamp, .sf-tag, .sf-btn,
     .sf-picado, .sf-tape, .sf-taped) lives in global.css, shared with the
     homepage and links callouts. Below are the page-only pieces. */

  /* Bulletin-board note: tilted paper that straightens when grabbed. */
  .sf-note {
    border: 2px solid rgba(30, 30, 30, 0.85);
    border-radius: 4px;
    box-shadow: 4px 5px 0 rgba(30, 30, 30, 0.12);
    transform: rotate(var(--sf-note-tilt, 0deg));
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .sf-note:hover {
    transform: rotate(0deg) translateY(-2px);
    box-shadow: 6px 8px 0 rgba(30, 30, 30, 0.14);
  }

  /* Volunteer application: the Google-backed form wears the same paper,
     border, and ink language as the rest of the festival page. */
  .sf-volunteer-details > summary {
    list-style: none;
  }
  .sf-volunteer-details > summary::-webkit-details-marker {
    display: none;
  }
  .sf-volunteer-details[open] .sf-volunteer-chevron {
    transform: rotate(180deg);
  }
  .sf-volunteer-sheet {
    box-shadow: 8px 9px 0 rgba(30, 30, 30, 0.14);
  }
  .sf-volunteer-input {
    display: block;
    width: 100%;
    border: 2px solid rgba(30, 30, 30, 0.72);
    border-radius: 5px;
    background: #fffaf1;
    padding: 0.8rem 0.9rem;
    color: #1e1e1e;
    font: inherit;
    transition: border-color 0.16s ease, box-shadow 0.16s ease,
      background-color 0.16s ease;
  }
  .sf-volunteer-input:focus {
    outline: none;
    border-color: var(--sf-dusk);
    background: #fffdf6;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--sf-dusk) 22%, transparent);
  }
  .sf-volunteer-choice {
    display: flex;
    cursor: pointer;
    align-items: flex-start;
    gap: 0.75rem;
    border: 1.5px solid rgba(30, 30, 30, 0.3);
    border-radius: 5px;
    background: #fffaf1;
    padding: 0.85rem 0.9rem;
    transition: border-color 0.16s ease, background-color 0.16s ease,
      transform 0.16s ease;
  }
  .sf-volunteer-choice:hover {
    border-color: rgba(30, 30, 30, 0.72);
    background: #fffdf6;
    transform: translateY(-1px);
  }
  .sf-volunteer-choice:has(input:focus-visible) {
    outline: 3px solid color-mix(in srgb, var(--sf-dusk) 28%, transparent);
    outline-offset: 2px;
  }
  .sf-volunteer-choice:has(input:checked) {
    border-color: var(--sf-ember);
    background: color-mix(in srgb, var(--sf-sunrise) 13%, #fffdf6);
  }

  /* Lotería card: heavy outer border, hairline inner frame, hard shadow. */
  .sf-loteria {
    background: #fffdf6;
    border: 3px solid #1e1e1e;
    border-radius: 10px;
    padding: 8px;
    box-shadow: 7px 8px 0 rgba(30, 30, 30, 0.85);
    transform: rotate(var(--sf-note-tilt, 0deg));
    transition: transform 0.25s ease;
  }
  .sf-loteria:hover {
    transform: rotate(0deg) translateY(-3px);
  }
  .sf-loteria-inner {
    border: 1.5px solid rgba(30, 30, 30, 0.5);
    border-radius: 5px;
  }

  /* Ticket stub: bordered paper with a perforation and punched notches. */
  .sf-stub {
    background: #fffdf6;
    border: 2.5px solid #1e1e1e;
    border-radius: 12px;
    box-shadow: 6px 7px 0 rgba(30, 30, 30, 0.16);
  }
  .sf-stub-featured {
    box-shadow: 7px 8px 0 var(--sf-ember);
  }
  .sf-stub-perf {
    position: relative;
    border-top: 2.5px dashed rgba(30, 30, 30, 0.45);
    margin: 0 14px;
  }
  .sf-stub-perf::before,
  .sf-stub-perf::after {
    content: "";
    position: absolute;
    top: -11px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #fffaf1;
    border: 2.5px solid #1e1e1e;
  }
  .sf-stub-perf::before {
    left: -26.5px;
  }
  .sf-stub-perf::after {
    right: -26.5px;
  }

  /* Fake barcode at the bottom of each stub. */
  .sf-barcode {
    width: 120px;
    height: 30px;
    opacity: 0.75;
    background: repeating-linear-gradient(
      90deg,
      #1e1e1e 0 2px,
      transparent 2px 5px,
      #1e1e1e 5px 6px,
      transparent 6px 11px,
      #1e1e1e 11px 14px,
      transparent 14px 17px
    );
  }

  /* Airmail postcard: cream card with striped par-avion edges. */
  .sf-postcard {
    background: #fffdf6;
    border: 2.5px solid #1e1e1e;
    border-radius: 12px;
    box-shadow: 8px 9px 0 rgba(30, 30, 30, 0.14);
    overflow: hidden;
  }
  .sf-airmail {
    background: repeating-linear-gradient(
      -45deg,
      var(--sf-ember) 0 14px,
      #fffdf6 14px 28px,
      var(--sf-dusk) 28px 42px,
      #fffdf6 42px 56px
    );
  }

  /* Countdown reframed as print cards (overrides the shared component's
     rounded sand-bordered look on this page only). */
  .sf-countdown-frame :global([data-sf-countdown] > div) {
    border: 2px solid #1e1e1e;
    border-radius: 8px;
    box-shadow: 4px 4px 0 rgba(30, 30, 30, 0.14);
  }

  /* Ticker strip: one long screen-printed tape, scrolling when motion is
     allowed and standing still otherwise. */
  .sf-ticker-wrap {
    overflow: hidden;
    margin-left: -0.75rem;
    margin-right: -0.75rem;
  }
  .sf-ticker {
    border-top: 2px solid #1e1e1e;
    border-bottom: 2px solid #1e1e1e;
    transform-origin: center;
    scale: 1.02 1;
  }
  .sf-ticker-track {
    display: flex;
    width: max-content;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf-ticker-track {
      animation: sf-ticker-scroll 36s linear infinite;
    }
    .sf-ticker-track-reverse {
      animation-direction: reverse;
    }
  }
  @keyframes sf-ticker-scroll {
    to {
      transform: translateX(-50%);
    }
  }

  /* The rising sun disc, centered behind the wordmark (positioned via Tailwind
     -translate-x/y-1/2). A bright core, a warm glow halo, and crisp printed
     rays fanning out. All motion is motion-safe only. */
  .sf-sun {
    background: radial-gradient(
      circle at 50% 50%,
      rgba(255, 189, 89, 0.55) 0%,
      rgba(255, 189, 89, 0.3) 24%,
      rgba(255, 107, 82, 0.18) 46%,
      rgba(233, 79, 138, 0.07) 62%,
      transparent 74%
    );
  }
  .sf-sun-core {
    background: radial-gradient(
      circle at 50% 44%,
      rgba(255, 250, 238, 0.98) 0%,
      rgba(255, 212, 130, 0.9) 34%,
      rgba(255, 148, 92, 0.55) 62%,
      rgba(233, 79, 138, 0.18) 84%,
      transparent 100%
    );
    filter: blur(2px);
  }
  /* Printed sol rays: a crisp conic fan clipped to a ring, slowly rotating. */
  .sf-rays {
    background: repeating-conic-gradient(
      from 0deg at 50% 50%,
      rgba(255, 149, 77, 0.22) 0deg 7deg,
      transparent 7deg 22.5deg
    );
    -webkit-mask-image: radial-gradient(
      circle at 50% 50%,
      transparent 27%,
      black 34%,
      black 52%,
      transparent 66%
    );
    mask-image: radial-gradient(
      circle at 50% 50%,
      transparent 27%,
      black 34%,
      black 52%,
      transparent 66%
    );
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf-sun {
      animation: sf-sun-breathe 10s ease-in-out infinite;
    }
    .sf-sun-core {
      animation: sf-sun-breathe 10s ease-in-out infinite reverse;
    }
    .sf-rays {
      animation: sf-rays-spin 120s linear infinite;
    }
  }
  @keyframes sf-sun-breathe {
    0%,
    100% {
      opacity: 0.9;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.05);
    }
  }
  @keyframes sf-rays-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @media (forced-colors: active) {
    .sf-grain,
    .sf-barcode,
    .sf-airmail {
      display: none;
    }
  }

  /* Hero load-in rise (mirrors gala's hero-rise, scoped here). */
  @media (prefers-reduced-motion: no-preference) {
    .sf-rise {
      opacity: 0;
      animation: sf-rise 0.85s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
    }
  }
  @keyframes sf-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* Ember motes drifting up through the closing band. Invisible unless
     motion is allowed (they are pure garnish). */
  .sf-mote {
    opacity: 0;
  }
  @media (prefers-reduced-motion: no-preference) {
    .sf-mote {
      animation-name: sf-mote-float;
      animation-timing-function: linear;
      animation-iteration-count: infinite;
    }
  }
  @keyframes sf-mote-float {
    0% {
      transform: translate(0, 0);
      opacity: 0;
    }
    12% {
      opacity: var(--sf-peak, 0.35);
    }
    88% {
      opacity: var(--sf-peak, 0.35);
    }
    100% {
      transform: translate(var(--sf-drift, 0px), -85vh);
      opacity: 0;
    }
  }
</style>

<script>
  // Count-up for the impact stats, modeled on GalaImpactStats: final values
  // are server-rendered so layout is reserved and no-JS / reduced-motion
  // users still see the real figures.
  (() => {
    const nums = Array.from(
      document.querySelectorAll<HTMLElement>("[data-sf-countup]"),
    );
    if (!nums.length) return;

    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (reduceMotion || !("IntersectionObserver" in window)) return;

    const fmt = (n: number, comma: boolean) =>
      comma ? Math.round(n).toLocaleString("en-US") : String(Math.round(n));

    const render = (el: HTMLElement, value: number) => {
      const prefix = el.dataset.sfCountupPrefix || "";
      const suffix = el.dataset.sfCountupSuffix || "";
      const comma = el.dataset.sfCountupComma === "true";
      el.textContent = `${prefix}${fmt(value, comma)}${suffix}`;
    };

    const animate = (el: HTMLElement) => {
      const to = Number(el.dataset.sfCountupTo || "0");
      const duration = 1600;
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      let start: number | null = null;
      const step = (ts: number) => {
        if (start === null) start = ts;
        const progress = Math.min(1, (ts - start) / duration);
        render(el, to * ease(progress));
        if (progress < 1) requestAnimationFrame(step);
        else render(el, to);
      };
      requestAnimationFrame(step);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            render(el, 0);
            animate(el);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.4 },
    );

    nums.forEach((el) => observer.observe(el));
  })();

  // The on-page application posts directly to Google Forms in a hidden
  // response frame. Checkboxes need a small group validator because native
  // HTML `required` would otherwise require one specific shift, not any shift.
  (() => {
    const form = document.querySelector<HTMLFormElement>(
      "[data-sf-volunteer-form]",
    );
    const frame = document.querySelector<HTMLIFrameElement>(
      "[data-sf-volunteer-frame]",
    );
    const success = document.querySelector<HTMLElement>(
      "[data-sf-volunteer-success]",
    );
    const shiftError = document.querySelector<HTMLElement>(
      "[data-sf-shift-error]",
    );
    const submitButton = document.querySelector<HTMLButtonElement>(
      "[data-sf-volunteer-submit]",
    );
    const shifts = Array.from(
      document.querySelectorAll<HTMLInputElement>("[data-sf-shift]"),
    );

    if (!form || !frame || !success || !shiftError || !submitButton) return;

    let submitted = false;
    const hasShift = () => shifts.some((input) => input.checked);
    const clearShiftError = () => {
      if (!hasShift()) return;
      shiftError.classList.add("hidden");
      shifts.forEach((input) => input.removeAttribute("aria-invalid"));
    };

    shifts.forEach((input) => input.addEventListener("change", clearShiftError));

    form.addEventListener("submit", (event) => {
      if (!hasShift()) {
        event.preventDefault();
        shiftError.classList.remove("hidden");
        shifts.forEach((input) => input.setAttribute("aria-invalid", "true"));
        shifts[0]?.focus();
        return;
      }

      submitted = true;
      submitButton.disabled = true;
      submitButton.setAttribute("aria-busy", "true");
      submitButton.textContent = "Sending application...";
    });

    frame.addEventListener("load", () => {
      if (!submitted) return;
      form.classList.add("hidden");
      success.classList.remove("hidden");
      success.focus({ preventScroll: true });
    });
  })();
</script>
