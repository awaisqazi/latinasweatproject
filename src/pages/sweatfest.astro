---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import SweatFestCountdown from "@/components/SweatFestCountdown.astro";
import SweatFestArtwork from "@/components/SweatFestArtwork.astro";
import {
  sweatFest,
  sweatFestExpect,
  sweatFestDay,
  sweatFestTickets,
  sweatFestSponsorship,
  sweatFestImpactIntro,
  sweatFestImpact,
  sweatFestColors,
} from "@/data/sweatFest";

// Sweat Fest: the "Daylight Festival". The page follows the arc of the day
// because the event does: sunrise 5K (gold) → all-day classes (ember) →
// night Pachanga (magenta). It reads BRIGHT: warm cream and white throughout,
// with the full sunrise gradient reserved for thin accents, and the single
// dark payoff held back for the closing "Pachanga at dusk" band. Every fact
// renders from src/data/sweatFest.js so TBDs (venue, Zeffy URL) flip
// automatically when the data updates.

const instagramUrl = "https://www.instagram.com/latinasweatproject/";
const base = import.meta.env.BASE_URL;
const withBase = (path) => `${base}${path.replace(/^\//, "")}`;
const calendarHref = withBase(sweatFest.calendarPath);
const calendarDescription = [
  "Movement Is Ours — Latina Sweat Project's first-ever all-day movement festival in Chicago.",
  "",
  "RUN OF SHOW",
  ...sweatFestDay.map(
    (phase) => `${phase.time} — ${phase.title}: ${phase.detail}`,
  ),
  "",
  "Plus wellbeing experiences, local vendors, food, and community connection throughout the day.",
  "",
  `${sweatFest.statusLabel}. Get updates and plan your day at https://latinasweatproject.com/sweatfest`,
  `Partnership inquiries: ${sweatFest.contactEmail}`,
].join("\n");
const googleCalendarHref = `https://calendar.google.com/calendar/render?${new URLSearchParams(
  {
    action: "TEMPLATE",
    text: "Sweat Fest 2026 — Movement Is Ours",
    dates: "20260822T070000/20260822T210000",
    ctz: "America/Chicago",
    location: "Chicago, IL · Location announced soon",
    details: calendarDescription,
  },
).toString()}`;
const sponsorMailto = `mailto:${sweatFestSponsorship.contactEmail}?subject=${encodeURIComponent(
  "Sweat Fest 2026 Sponsorship",
)}`;

// Day-arc accent lookup. sweatFestDay entries carry accent: sunrise|ember|dusk
// which map 1:1 onto sweatFestColors.
const accentOf = (key) => sweatFestColors[key] ?? sweatFestColors.sunrise;

// Deepened accent for text on light backgrounds. The stronger off-black mix
// keeps even small gold labels readable on white and warm cream.
const deep = (hex) => `color-mix(in oklab, ${hex} 48%, #1e1e1e)`;

// The motto splits into its three arc-colored lines.
// "Move Together. Celebrate Culture. Build Community."
const mottoLines = sweatFest.motto
  .split(".")
  .map((line) => line.trim())
  .filter(Boolean)
  .map((line) => `${line}.`);
const arcOrder = ["sunrise", "ember", "dusk"];

// Inline SVG icon paths (24x24 stroke), index-aligned with sweatFestExpect.
const expectIcons = [
  // Sweat sessions: flame
  '<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" /><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" />',
  // Sunrise 5K: rising sun over the horizon
  '<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.5M5.3 5.9l1.7 1.7M18.7 5.9L17 7.6M3 18h18M6.5 14.5a5.5 5.5 0 0111 0" />',
  // Wellbeing practices: heart
  '<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />',
  // Vendor market: shopping bag
  '<path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />',
  // Food + drink: cup
  '<path stroke-linecap="round" stroke-linejoin="round" d="M17 9h1a3 3 0 010 6h-1M4 9h13v3.5a5.5 5.5 0 01-5.5 5.5h-2A5.5 5.5 0 014 12.5V9zM8 3v2m4-2v2" />',
  // The Pachanga: music note
  '<path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19a3 3 0 11-6 0 3 3 0 016 0zm12-3a3 3 0 11-6 0 3 3 0 016 0z" />',
];
// Accent key per expect card, spread evenly across the arc so no color
// dominates: sweat=ember, 5K=sunrise, wellbeing=dusk, market=sunrise,
// food=ember, Pachanga=dusk.
const expectAccents = ["ember", "sunrise", "dusk", "sunrise", "ember", "dusk"];

// Sun/moon marker icons for the day-arc phases, keyed by phase id.
const dayIcons = {
  run: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.5M5.3 5.9l1.7 1.7M18.7 5.9L17 7.6M3 18h18M6.5 14.5a5.5 5.5 0 0111 0" />',
  sweat:
    '<circle cx="12" cy="12" r="4" /><path stroke-linecap="round" d="M12 2.5V5m0 14v2.5M5.3 5.3L7 7m10 10l1.7 1.7M2.5 12H5m14 0h2.5M5.3 18.7L7 17M17 7l1.7-1.7" />',
  party:
    '<path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />',
};

const checkPath =
  '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />';
const arrowRight =
  '<path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />';
const arrowDown =
  '<path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />';
const calendarGlyph =
  '<path stroke-linecap="round" stroke-linejoin="round" d="M8 3v3m8-3v3M4.5 9.5h15M6 5h12a2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V7a2 2 0 012-2z" />';
const instagramGlyph =
  '<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zm0 10.162a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />';

// Ember motes floating up through the closing band, warm counterpart to the
// gala's gold particles. Colors cycle across the day arc.
const closingMotes = Array.from({ length: 14 }, (_, i) => ({
  left: (i * 71 + 9) % 100,
  size: i % 4 === 0 ? 5 + (i % 3) : 3 + (i % 3),
  duration: 12 + (i % 5) * 2.4,
  delay: (i % 7) * 1.8,
  drift: (i % 2 === 0 ? 1 : -1) * (10 + (i % 3) * 9),
  opacity: 0.2 + (i % 3) * 0.12,
  color: [sweatFestColors.ember, sweatFestColors.dusk, sweatFestColors.sunrise][
    i % 3
  ],
}));

const metaDescription =
  "Join Latina Sweat Project's first Sweat Fest in Chicago on August 22, 2026: a sunrise 5K, all-day classes, local vendors, food, and a sunset Pachanga.";
---

<Layout title="Sweat Fest | The Latina Sweat Project" description={metaDescription}>
  <Header />
  <main
    class="bg-white text-off-black"
    style={`--sf-sunrise: ${sweatFestColors.sunrise}; --sf-ember: ${sweatFestColors.ember}; --sf-dusk: ${sweatFestColors.dusk};`}
  >
    {/* ======================= HERO: DAYBREAK ======================= */}
    <section
      id="save-the-date"
      class="relative isolate overflow-hidden py-20 text-off-black scroll-mt-28 sm:py-24 lg:py-28"
      style="background: linear-gradient(to bottom, #fff8ef 0%, #ffffff 38%, #ffefe2 100%);"
    >
      {/* The rising sun: a big luminous disc climbing behind the wordmark, with
          soft rays fanning out. Bright gold core, ember halo, magenta edge, all
          on cream so the sunrise READS. Clipped by the section. */}
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        {/* One shared positioning wrapper keeps every celestial layer on the
            same center while the children rotate or breathe independently. */}
        <div
          class="absolute left-1/2 top-[38%] h-[46rem] w-[46rem] -translate-x-1/2 -translate-y-1/2 sm:h-[58rem] sm:w-[58rem] lg:h-[70rem] lg:w-[70rem]"
        >
          <div class="sf-rays absolute inset-0"></div>
          <div class="absolute inset-0 grid place-items-center">
            <div class="sf-sun h-[30rem] w-[30rem] rounded-full sm:h-[40rem] sm:w-[40rem] lg:h-[48rem] lg:w-[48rem]"></div>
          </div>
          <div class="absolute inset-0 grid place-items-center">
            <div class="sf-sun-core h-52 w-52 rounded-full sm:h-64 sm:w-64 lg:h-72 lg:w-72"></div>
          </div>
        </div>
      </div>

      <div class="relative mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
        <p
          class="sf-rise inline-flex items-center gap-3 text-xs font-bold uppercase tracking-[0.3em] text-medium-gray"
        >
          <span class="h-px w-8 bg-[var(--sf-sunrise)]" aria-hidden="true"></span>
          {sweatFest.presentedBy}
          <span class="h-px w-8 bg-[var(--sf-dusk)]" aria-hidden="true"></span>
        </p>

        <h1
          class="sf-rise mt-6 font-sans text-6xl font-extrabold uppercase leading-[0.95] tracking-tight sm:text-7xl lg:text-[7rem]"
          style="animation-delay: 0.06s;"
        >
          <span class="sf-foil-light">Sweat Fest</span>
        </h1>

        <p
          class="sf-rise mt-6 text-xl font-extrabold uppercase tracking-[0.14em] text-off-black sm:text-2xl"
          style="animation-delay: 0.14s;"
        >
          {sweatFest.tagline}
        </p>
        <p
          class="sf-rise mt-2 text-lg font-semibold text-medium-gray sm:text-xl"
          style="animation-delay: 0.2s;"
        >
          {sweatFest.taglineSub}
        </p>

        {/* Sticker-style fact chips: date, hours, location, access. */}
        <ul
          class="sf-rise mt-8 flex flex-wrap items-center justify-center gap-2.5"
          style="animation-delay: 0.26s;"
        >
          {
            [
              sweatFest.dateLabel,
              sweatFest.timeLabel,
              sweatFest.venueLine,
              "All levels welcome",
            ].map((chip) => (
              <li class="inline-flex items-center gap-2 rounded-full border border-off-black/10 bg-white/90 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.14em] text-off-black shadow-sm backdrop-blur-sm">
                {chip}
              </li>
            ))
          }
        </ul>

        {/* Status pill: on sale soon, with a pulsing ember dot. */}
        <div class="sf-rise mt-6 flex justify-center" style="animation-delay: 0.3s;">
          <span
            class="inline-flex items-center gap-2.5 rounded-full border px-5 py-2 text-xs font-extrabold uppercase tracking-[0.18em]"
            style={`border-color: ${sweatFestColors.ember}66; background: ${sweatFestColors.ember}12; color: ${deep(sweatFestColors.ember)};`}
          >
            <span class="relative flex h-2 w-2" aria-hidden="true">
              <span class="sf-ping absolute inline-flex h-full w-full rounded-full bg-[var(--sf-ember)] opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--sf-ember)]"></span>
            </span>
            {sweatFest.statusLabel}
          </span>
        </div>

        {/* Give attendees useful, platform-specific calendar actions before
            tickets go live. */}
        <div
          class="sf-rise mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
          style="animation-delay: 0.36s;"
        >
          <a
            href={calendarHref}
            download
            class="group inline-flex items-center justify-center gap-3 rounded-full bg-[var(--sf-sunrise)] px-8 py-4 text-base font-extrabold text-off-black shadow-lg shadow-[#ffbd59]/25 transition-all duration-300 hover:scale-[1.02] hover:shadow-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-off-black focus-visible:ring-offset-4"
            data-conversion-event="sweatfest_save_date_click"
            data-conversion-context="sweatfest_page_hero_apple"
          >
            Apple Calendar
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
              set:html={calendarGlyph}
            />
          </a>
          <a
            href={googleCalendarHref}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-3 rounded-full border border-off-black/15 bg-white px-8 py-4 text-base font-extrabold text-off-black shadow-sm transition-all duration-300 hover:border-[var(--sf-dusk)] hover:bg-[var(--sf-dusk)]/[0.06] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--sf-dusk)] focus-visible:ring-offset-4"
            data-conversion-event="sweatfest_save_date_click"
            data-conversion-context="sweatfest_page_hero_google"
          >
            Google Calendar
            <svg
              class="h-4 w-4"
              style={`color: ${deep(sweatFestColors.dusk)};`}
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
              set:html={calendarGlyph}
            />
          </a>
        </div>

        <a
          href="#the-day"
          class="sf-rise mt-5 inline-flex items-center gap-2 text-sm font-extrabold text-off-black underline decoration-[var(--sf-ember)] decoration-2 underline-offset-4 transition-colors hover:text-[var(--sf-dusk)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--sf-dusk)]"
          style="animation-delay: 0.4s;"
        >
          Explore the full run of show
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true" set:html={arrowDown} />
        </a>

        {/* Countdown to the kickoff 5K. */}
        <div class="sf-rise mx-auto mt-9 max-w-2xl" style="animation-delay: 0.44s;">
          <p class="mb-3 text-[11px] font-bold uppercase tracking-[0.26em] text-medium-gray">
            Countdown to the kickoff 5K
          </p>
          <SweatFestCountdown target={sweatFest.startsAtISO} variant="hero" />
        </div>

        <p class="sf-rise mt-6 text-sm font-semibold text-medium-gray" style="animation-delay: 0.5s;">
          Interested in partnering? <a href="#sponsors" class="font-extrabold text-off-black underline decoration-[var(--sf-dusk)] decoration-2 underline-offset-4 transition-colors hover:text-[var(--sf-dusk)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--sf-dusk)]">Explore sponsorships</a>.
        </p>
      </div>

      {/* Warm horizon hairline into the daylight below. */}
      <div class="sf-rule absolute inset-x-0 bottom-0 h-px" aria-hidden="true"></div>
    </section>

    {/* ====================== MANIFESTO: FIRST LIGHT ====================== */}
    <section class="relative overflow-hidden py-16 sm:py-20" style="background: linear-gradient(to bottom, #ffefe2, #fff8ef 60%, #ffffff);">
      {/* A faint sun disc rising at the edge, purely decorative. */}
      <div
        class="pointer-events-none absolute -right-24 -top-16 h-72 w-72 rounded-full opacity-70 blur-2xl sm:h-96 sm:w-96"
        style="background: radial-gradient(circle at 50% 50%, rgba(255,189,89,0.5) 0%, rgba(255,107,82,0.18) 45%, transparent 70%);"
        aria-hidden="true"
      >
      </div>

      <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-9 lg:grid-cols-[1.15fr_0.85fr] lg:items-center lg:gap-14">
          <SweatFestArtwork
            variant="landscape"
            className="reveal rounded-[2rem] shadow-2xl shadow-[#ff6b52]/20 ring-1 ring-off-black/10"
          />
          <div class="text-center lg:text-left">
            <p class="reveal text-xs font-extrabold uppercase tracking-[0.3em]" style={`color: ${deep(sweatFestColors.sunrise)};`}>
              First light · First festival
            </p>
            <h2 class="mt-5 font-sans text-4xl font-extrabold uppercase leading-[1.05] tracking-tight sm:text-5xl">
              {
                mottoLines.map((line, i) => (
                  <span
                    class="reveal block"
                    style={`color: ${deep(accentOf(arcOrder[i % 3]))}; transition-delay: ${i * 120}ms;`}
                  >
                    {line}
                  </span>
                ))
              }
            </h2>
            <div class="reveal mt-6 flex justify-center lg:justify-start" style="transition-delay: 300ms;">
              <span class="sf-track h-1 w-24 rounded-full" aria-hidden="true"></span>
            </div>
            <p
              class="reveal mt-7 text-lg leading-relaxed text-medium-gray"
              style="transition-delay: 360ms;"
            >
              {sweatFest.pageDescription}
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ======================= WHAT TO EXPECT: DAYLIGHT ======================= */}
    <section class="relative overflow-hidden bg-white py-16 sm:py-20 lg:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p class="reveal text-xs font-extrabold uppercase tracking-[0.3em]" style={`color: ${deep(sweatFestColors.ember)};`}>
            On the ground
          </p>
          <h2
            class="reveal mt-4 font-sans text-4xl font-extrabold uppercase tracking-tight text-off-black sm:text-5xl"
            style="transition-delay: 90ms;"
          >
            What to expect
          </h2>
          <div class="reveal mt-5 flex justify-center" style="transition-delay: 150ms;">
            <span class="sf-track h-1 w-24 rounded-full" aria-hidden="true"></span>
          </div>
        </div>

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            sweatFestExpect.map((item, index) => {
              const accent = accentOf(expectAccents[index]);
              return (
                <div
                  class="reveal group relative overflow-hidden rounded-2xl border border-off-black/10 bg-white p-6 text-center shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg lg:text-left"
                  style={`transition-delay: ${index * 80}ms;`}
                >
                  <div
                    class="pointer-events-none absolute inset-x-0 top-0 h-1 opacity-70 transition-opacity duration-300 group-hover:opacity-100"
                    style={`background: ${accent};`}
                    aria-hidden="true"
                  />
                  <span
                    class="inline-flex h-11 w-11 items-center justify-center rounded-xl transition-transform duration-300 group-hover:scale-110"
                    style={`background: ${accent}1f; color: ${deep(accent)};`}
                  >
                    <svg
                      class="h-5 w-5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.8"
                      aria-hidden="true"
                      set:html={expectIcons[index]}
                    />
                  </span>
                  <h3 class="mt-4 text-lg font-extrabold tracking-tight text-off-black">
                    {item.title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-medium-gray">
                    {item.detail}
                  </p>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    {/* ==================== THE DAY: SUNRISE TO LAST SET ==================== */}
    <section
      id="the-day"
      class="relative overflow-hidden py-16 scroll-mt-28 sm:py-20 lg:py-24"
      style="background: linear-gradient(to bottom, #ffffff, #fff6ee 45%, #ffffff);"
    >
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p class="reveal text-xs font-extrabold uppercase tracking-[0.3em]" style={`color: ${deep(sweatFestColors.sunrise)};`}>
            The itinerary
          </p>
          <h2
            class="reveal mt-4 font-sans text-4xl font-extrabold uppercase tracking-tight text-off-black sm:text-5xl"
            style="transition-delay: 90ms;"
          >
            Sunrise to last set
          </h2>
          <p
            class="reveal mt-4 text-lg leading-relaxed text-medium-gray"
            style="transition-delay: 180ms;"
          >
            {sweatFest.dateLabel} · {sweatFest.timeLabel}
          </p>
        </div>

        {/* Desktop sun track: one gradient line from gold through ember to
            magenta, with a sun or moon marker over each phase. */}
        <div class="reveal relative mx-auto mt-14 hidden max-w-6xl lg:block">
          <div class="relative h-14" aria-hidden="true">
            {/* Dotted 5K route weaving under the solid day arc. */}
            <div class="sf-route absolute inset-x-10 top-[calc(50%-7px)] h-2"></div>
            <div class="sf-track absolute inset-x-10 top-1/2 h-1 -translate-y-1/2 rounded-full"></div>
            <div class="relative grid h-full grid-cols-3">
              {
                sweatFestDay.map((phase) => (
                  <div class="flex items-center justify-center">
                    <span
                      class="relative z-10 inline-flex h-12 w-12 items-center justify-center rounded-full text-off-black shadow-lg"
                      style={`background: ${accentOf(phase.accent)}; box-shadow: 0 0 24px -4px ${accentOf(phase.accent)};`}
                    >
                      <svg
                        class="h-6 w-6"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.8"
                        set:html={dayIcons[phase.id]}
                      />
                    </span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        {/* Phase cards. On mobile a vertical gradient rail carries the arc. */}
        <div class="relative mx-auto mt-6 max-w-6xl lg:mt-8">
          <div
