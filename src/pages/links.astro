    box-shadow: 0 2px 10px rgba(255, 189, 89, 0.3);
  }
  
  .lang-active-es .switcher-slider {
    transform: translateX(100%);
  }

  /* Bilingual dynamic toggle styles */
  .lang-active-en .lang-en { display: inline-block; }
  .lang-active-en .lang-es { display: none !important; }
  .lang-active-es .lang-en { display: none !important; }
  .lang-active-es .lang-es { display: inline-block; }

  .lang-active-en div.lang-en,
  .lang-active-en p.lang-en,
