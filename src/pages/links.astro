---
import Layout from "@/layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
const kidsDayRegistrationUrl = "https://www.zeffy.com/en-US/ticketing/lsp-dia-del-nino-kids-day";

// Define links data with English and Spanish translations
const links = [
  {
    title: {
      en: "🎨 Kids Day at LSP",
      es: "🎨 DÍA DEL NIÑO EN LSP"
    },
    description: {
      en: "Four age-group yoga classes full of movement, play, and wellness. Bring the kids for a free class and goody bag with peers their age.",
      es: "Cuatro clases de yoga por edad llenas de movimiento, juego y bienestar. Trae a los niños a una clase gratis con bolsita de regalo."
    },
    url: kidsDayRegistrationUrl,
    color: "amber",
    icon: "calendar",
    badge: {
      en: "Free · Jun 14",
      es: "Gratis · 14 Jun"
    },
    featured: true,
  },
  {
    title: {
      en: "📺 WGN9 Around Town visits LSP",
      es: "📺 WGN9 Around Town visita LSP"
    },
    description: {
      en: "Watch all four Around Town segments: Ana tries the workout, meets founder Margarita, joins our Spanish yoga flow, and tours the community art gallery.",
      es: "Mira los cuatro segmentos de Around Town: Ana prueba el entrenamiento, conoce a la fundadora Margarita, se une a nuestra clase en español y recorre la galería de arte."
    },
    url: "https://latinasweatproject.com/wgn9-around-town/",
    color: "wish",
    icon: "tv",
    badge: {
      en: "On TV",
      es: "En TV"
    },
    featured: true,
  },
  {
    title: {
      en: "🧘🏽‍♀️ Check out our 2025 YTT Cohort",
      es: "🧘🏽‍♀️ Conoce nuestra cohorte YTT 2025"
    },
    description: {
      en: "Meet our graduating teachers. Roughly one-minute clips of each instructor, tap any pose to learn from a new voice in our movement.",
      es: "Conoce a nuestras maestras graduadas. Videos de aproximadamente un minuto de cada instructora, toca cualquier pose para aprender de una nueva voz en nuestro movimiento."
    },
    url: "https://latinasweatproject.com/2025ytt/",
    color: "amber",
    icon: "yoga",
    badge: {
      en: "New",
      es: "Nuevo"
    },
    featured: true,
  },
  {
    title: {
      en: "🧠 Free Men's Therapy Group",
      es: "🧠 Grupo de Terapia Gratuito para Hombres"
    },
    description: {
      en: "A bilingual, confidential, cost-free weekly therapy group for men, on Tuesdays starting on April 7th. Led by Roberto Lopez-Tamayo, Ph.D. Open to all adult men.",
      es: "Un grupo de terapia semanal bilingüe, confidencial y gratuito para hombres, los martes a partir del 7 de abril. Dirigido por el Dr. Roberto López-Tamayo. Abierto a todos los hombres adultos."
    },
    url: "https://www.redcap.ihrp.uic.edu/surveys/?s=MDMA4L9CD398798Y&utm_source=ig&utm_medium=social&utm_content=link_in_bio",
    color: "blue",
    icon: "mind",
    badge: {
      en: "New",
      es: "Nuevo"
    },
    featured: true,
  },
  {
    title: {
      en: "📅 Class Schedule",
      es: "📅 Horario de Clases"
    },
    description: {
      en: "Book a yoga, fitness, or wellness class in Pilsen.",
      es: "Reserva una clase de yoga, fitness o bienestar en Pilsen."
    },
    url: "https://latinasweatproject.com/schedule/",
    color: "vibrant-pink",
    icon: "calendar",
    featured: true,
  },
  {
    title: {
      en: "🌐 Visit Our Website",
      es: "🌐 Visita Nuestro Sitio Web"
    },
    description: {
      en: "Explore everything The Latina Sweat Project has to offer.",
      es: "Explora todo lo que The Latina Sweat Project tiene para ofrecer."
    },
    url: "https://latinasweatproject.com/",
    color: "gold",
    icon: "globe",
  },
];

// Highlight Stories Bar configuration
const highlights = [
  {
    title: {
      en: "✨ Free Classes",
      es: "✨ Clases Gratis"
    },
    target: "#free-classes",
    image: `${base}images/highlights/hl_free_classes.png`,
    scale: "scale-[1.48]",
    hoverScale: "group-hover:scale-[1.65]",
    color: "amber"
  },
  {
    title: {
      en: "📺 WGN Feature",
      es: "📺 Canal WGN"
    },
    url: `${base}wgn9-around-town/`,
    image: `${base}images/highlights/hl_wgn.png`,
    scale: "scale-[1.38]",
    hoverScale: "group-hover:scale-[1.55]",
    color: "wish"
  },
  {
    title: {
      en: "🧘🏽‍♀️ YTT 2025",
      es: "🧘🏽‍♀️ YTT 2025"
    },
    url: "https://latinasweatproject.com/2025ytt/",
    image: `${base}images/highlights/hl_ytt.png`,
    scale: "scale-[1.35] -translate-y-[2px]",
    hoverScale: "group-hover:scale-[1.5] group-hover:-translate-y-[2px]",
    color: "wish"
  },
  {
    title: {
      en: "🧠 Therapy",
      es: "🧠 Terapia"
    },
    url: "https://www.redcap.ihrp.uic.edu/surveys/?s=MDMA4L9CD398798Y&utm_source=ig&utm_medium=social&utm_content=link_in_bio",
    image: `${base}images/highlights/hl_therapy.png`,
    scale: "scale-[1.38]",
    hoverScale: "group-hover:scale-[1.55]",
    color: "blue"
  },
  {
    title: {
      en: "📱 Download App",
      es: "📱 Descarga App"
    },
    target: "#app-download",
    image: `${base}images/highlights/hl_app.png`,
    scale: "scale-[1.3]",
    hoverScale: "group-hover:scale-[1.45]",
    color: "vibrant-pink"
  }
];

const socials = [
  {
    name: "Instagram",
    url: "https://www.instagram.com/latinasweatproject/",
    icon: "instagram",
  },
  {
    name: "TikTok",
    url: "https://www.tiktok.com/@latinasweatproject",
    icon: "tiktok",
  },
];

const getLinkConversionEvent = (url = "") => {
  if (url.includes("lsp-dia-del-nino-kids-day")) return "class_booking_start";
  if (url.includes("/schedule")) return "class_booking_start";
  if (url.includes("support-the-latina-sweat-project")) return "donation_click";
  return undefined;
};

const getLinkBookingPath = (url = "") => {
  if (url.includes("lsp-dia-del-nino-kids-day")) return "kids_day_ticketing";
  if (url.includes("/schedule")) return "schedule_page";
  return undefined;
};

const getLinkConversionProvider = (url = "") => {
  if (url.includes("zeffy.com")) return "zeffy";
  if (url.includes("/schedule")) return "lsp_website";
  return undefined;
};
---

<Layout
  title="Latina Sweat Project | Links"
  description="Quick links from The Latina Sweat Project: classes, events, therapy, and more."
  hideFooter={true}
>
  <main class="links-page lang-active-en min-h-screen relative overflow-hidden">
    {/* Animated gradient background */}
    <div class="links-bg absolute inset-0"></div>

    {/* Floating decorative shapes */}
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="links-blob links-blob-1"></div>
      <div class="links-blob links-blob-2"></div>
      <div class="links-blob links-blob-3"></div>
    </div>

    {/* Content Container */}
    <div class="relative z-10 mx-auto max-w-lg px-4 py-8 sm:py-12">
      {/* Profile Header */}
      <div class="text-center mb-6">
        <div class="relative inline-block mb-4">
          {/* Glow ring */}
          <div
            class="absolute -inset-1.5 rounded-full bg-gradient-to-br from-[#b5a18d] via-[#ffbd59] to-[#b5a18d] opacity-70 blur-sm animate-pulse"
          >
          </div>
          <img
            src={`${base}logo2.png`}
            alt="The Latina Sweat Project"
            class="relative w-24 h-24 rounded-full object-cover border-3 border-white shadow-xl"
          />
        </div>
        <h1
          class="font-rubik text-2xl font-extrabold text-white tracking-tight drop-shadow-md"
        >
          The Latina Sweat Project
        </h1>
        
        {/* Profile bio (Bilingual) */}
        <p class="mt-2 text-white/75 text-sm font-medium max-w-xs mx-auto leading-relaxed">
          <span class="lang-en">Accessible yoga, fitness & wellness in Pilsen, Chicago&nbsp;🧘🏽‍♀️✨</span>
          <span class="lang-es hidden">Yoga, fitness y bienestar accesible en Pilsen, Chicago&nbsp;🧘🏽‍♀️✨</span>
        </p>

        {/* Social icons row */}
        <div class="mt-4 flex items-center justify-center gap-3">
          {
            socials.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-white/80 hover:bg-white/25 hover:text-white hover:scale-110 transition-all duration-300"
                aria-label={social.name}
              >
                {social.icon === "instagram" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                  </svg>
                )}
                {social.icon === "tiktok" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      {/* Global Bilingual Language Switcher Slider */}
      <div class="lang-switcher-wrap mb-8 text-center" style="animation: links-slide-up 0.5s ease backwards; animation-delay: 40ms;">
        <div class="inline-flex items-center justify-center p-[2px] rounded-full bg-white/[0.05] border border-white/10 backdrop-blur-md relative select-none w-[170px] h-[34px] overflow-hidden shadow-inner cursor-pointer" id="global-lang-switcher">
          <div class="switcher-slider"></div>
          <button class="switcher-btn w-1/2 text-[11px] font-extrabold uppercase tracking-wider relative z-10 text-white transition-colors duration-300" data-lang="en">
            EN
          </button>
          <button class="switcher-btn w-1/2 text-[11px] font-extrabold uppercase tracking-wider relative z-10 text-white/50 transition-colors duration-300" data-lang="es">
            ES
          </button>
        </div>
      </div>

      {/* Horizontal scrolling Highlight Stories bar */}
      <div class="highlights-container-wrap mb-8 relative" style="animation: links-slide-up 0.5s ease backwards; animation-delay: 70ms;">
        <div class="flex items-start gap-4 overflow-x-auto pb-4 pt-1 scrollbar-none px-2 snap-x select-none" id="highlights-bar">
          {
            highlights.map((story) => (
              <a
                href={story.target ? story.target : story.url}
                target={story.url ? "_blank" : undefined}
                rel={story.url ? "noopener noreferrer" : undefined}
                class="story-highlight flex flex-col items-center flex-shrink-0 snap-center select-none group"
                data-target={story.target}
              >
                {/* Glow story ring */}
                <div class="relative w-[66px] h-[66px] flex items-center justify-center flex-shrink-0 rounded-full bg-gradient-to-tr from-[#b5a18d] via-[#ffbd59] to-[#b5a18d] transition-all duration-300 group-hover:scale-105 active:scale-95 group-hover:shadow-[0_0_15px_rgba(255,189,89,0.4)] shadow-md">
                  <div class="w-[62px] h-[62px] rounded-full bg-[#1e1e1e]/85 overflow-hidden flex items-center justify-center border border-white/10 flex-shrink-0">
                    <img
                      src={story.image}
                      alt=""
                      class:list={[
                        "w-full h-full object-cover transition-transform duration-300",
                        story.scale,
                        story.hoverScale
                      ]}
                    />
                  </div>
                </div>
                {/* Labels */}
                <span class="text-[9px] font-extrabold text-white/55 mt-2 uppercase tracking-widest text-center max-w-[80px] leading-tight transition-colors duration-300 group-hover:text-white">
                  <span class="lang-en">{story.title.en}</span>
                  <span class="lang-es hidden">{story.title.es}</span>
                </span>
              </a>
            ))
          }
        </div>
      </div>

      {/* Free Classes · Two Locations Promo · MAIN CTA */}
      <div class="free-hero relative mb-8 scroll-mt-24" id="free-classes" style="animation: links-slide-up 0.5s ease backwards; animation-delay: 100ms;">
        {/* Outer glow ring */}
        <div class="free-hero-glow absolute -inset-2 rounded-3xl opacity-70 blur-xl pointer-events-none"></div>

        <div class="relative rounded-2xl p-[1.5px] bg-gradient-to-br from-[#ffbd59]/70 via-emerald-400/40 to-[#ffbd59]/70">
          <div class="rounded-2xl bg-[#1a1a1a]/85 backdrop-blur-xl px-5 py-5 border border-white/5">
            {/* Header */}
            <div class="text-center">
              <div class="inline-flex items-center gap-1.5 rounded-full bg-[#ffbd59]/20 border border-[#ffbd59]/30 px-3 py-1 mb-3">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#ffbd59] opacity-75"></span>
                  <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-[#ffbd59]"></span>
                </span>
                <span class="text-[9px] font-extrabold uppercase tracking-widest text-[#ffbd59]">
                  <span class="lang-en">Free · May & June 2026</span>
                  <span class="lang-es hidden">Gratis · Mayo y Junio 2026</span>
                </span>
              </div>

              <h3 class="text-xl sm:text-2xl font-extrabold text-white tracking-tight leading-tight font-rubik">
                <span class="lang-en">Free Classes, <span class="bg-gradient-to-r from-[#ffbd59] to-emerald-400 bg-clip-text text-transparent">Two Locations</span></span>
                <span class="lang-es hidden">Clases Gratis, <span class="bg-gradient-to-r from-[#ffbd59] to-emerald-400 bg-clip-text text-transparent">Dos Ubicaciones</span></span>
              </h3>
              <p class="mt-1.5 text-[10px] text-white/55 font-semibold tracking-wide uppercase">
                <span class="lang-en">Free classes · No membership · Two ways to register</span>
                <span class="lang-es hidden">Clases gratis · Sin membresía · Dos formas de registrarse</span>
              </p>
            </div>

            {/* Location cards · each links to its own registration path */}
            <div class="mt-5 space-y-3 text-left">
              {/* PILSEN → Schedule / LSP app */}
              <a
                href={`${base}schedule`}
                class="free-promo group block rounded-xl bg-[#ffbd59]/[0.06] border border-[#ffbd59]/25 px-3.5 py-3 transition-all duration-300 hover:bg-[#ffbd59]/[0.12] hover:border-[#ffbd59]/45 hover:-translate-y-0.5"
                data-conversion-event="class_booking_start"
                data-conversion-context="links_free_classes_pilsen"
                data-conversion-provider="lsp_website"
                data-conversion-booking-path="schedule_page"
              >
                <div class="flex items-center gap-2.5 mb-3">
                  <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#1E1E1E] text-[#ffbd59] font-extrabold text-base flex-shrink-0">X</span>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-baseline gap-1.5">
                      <p class="text-[12px] font-extrabold uppercase tracking-wider text-[#ffbd59] leading-none">Pilsen</p>
                      <span class="text-[8px] font-bold uppercase tracking-wider text-white/40 leading-none">8 days</span>
                    </div>
                    <p class="text-[10px] font-medium text-white/60 leading-tight mt-0.5 truncate">LSP Studio · 949 W 16th St</p>
                  </div>
                  <svg class="h-3.5 w-3.5 text-[#ffbd59] flex-shrink-0 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </div>

                <div class="space-y-1.5">
                  <div class="flex items-center gap-2">
                    <span class="text-[9px] font-extrabold uppercase tracking-widest text-[#ffbd59]/70 w-6 flex-shrink-0">
                      <span class="lang-en">May</span>
                      <span class="lang-es hidden">Mayo</span>
                    </span>
                    <div class="grid grid-cols-8 gap-1 flex-1">
                      <span class="free-pill free-pill--wide col-span-2" data-free-date="2026-05-01" data-free-loc="pilsen"><em>Fri</em>1</span>
                      <span class="free-pill free-pill--wide col-span-2" data-free-date="2026-05-09" data-free-loc="pilsen"><em>Sat</em>9</span>
                      <span class="free-pill free-pill--wide col-span-2" data-free-date="2026-05-17" data-free-loc="pilsen"><em>Sun</em>17</span>
                      <span class="free-pill free-pill--wide col-span-2" data-free-date="2026-05-25" data-free-loc="pilsen"><em>Mon</em>25</span>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class="text-[9px] font-extrabold uppercase tracking-widest text-[#ffbd59]/70 w-6 flex-shrink-0">
                      <span class="lang-en">Jun</span>
                      <span class="lang-es hidden">Jun</span>
                    </span>
                    <div class="grid grid-cols-8 gap-1 flex-1">
                      <span class="free-pill free-pill--wide col-span-2" data-free-date="2026-06-02" data-free-loc="pilsen"><em>Tue</em>2</span>
                      <span class="free-pill free-pill--wide col-span-2" data-free-date="2026-06-10" data-free-loc="pilsen"><em>Wed</em>10</span>
                      <span class="free-pill free-pill--wide col-span-2" data-free-date="2026-06-18" data-free-loc="pilsen"><em>Thu</em>18</span>
                      <span class="free-pill free-pill--wide col-span-2" data-free-date="2026-06-26" data-free-loc="pilsen"><em>Fri</em>26</span>
                    </div>
                  </div>
                </div>

                <p class="mt-2.5 text-[9px] font-bold uppercase tracking-widest text-[#ffbd59]/80 text-center">
                  <span class="lang-en">Book in LSP app or schedule page →</span>
                  <span class="lang-es hidden">Reserva en la app de LSP o en la web →</span>
                </p>
              </a>

              {/* SOUTHSIDE SOCIAL → Zeffy */}
              <a
                href="https://www.zeffy.com/en-US/ticketing/latina-sweat-project-southside-social-free-classes"
                target="_blank"
                rel="noopener noreferrer"
                class="free-promo group block rounded-xl bg-emerald-500/[0.06] border border-emerald-400/25 px-3.5 py-3 transition-all duration-300 hover:bg-emerald-500/[0.12] hover:border-emerald-400/50 hover:-translate-y-0.5"
                data-conversion-event="class_booking_start"
                data-conversion-context="links_free_classes_southside"
                data-conversion-provider="zeffy"
                data-conversion-booking-path="southside_ticketing"
                data-conversion-location="southside_social"
              >
                <div class="flex items-center gap-2.5 mb-2.5">
                  <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-600 text-white font-extrabold text-base flex-shrink-0">X</span>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-baseline gap-1.5">
                      <p class="text-[12px] font-extrabold uppercase tracking-wider text-emerald-300 leading-none">Southside Social</p>
                      <span class="text-[8px] font-bold uppercase tracking-wider text-white/40 leading-none">16 days</span>
                    </div>
                    <p class="text-[10px] font-medium text-white/60 leading-tight mt-0.5 truncate">4432 S Ashland · Every Sat &amp; Sun</p>
                  </div>
                  <svg class="h-3.5 w-3.5 text-emerald-300 flex-shrink-0 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                </div>

                {/* Compact lineup */}
                <div class="rounded-lg bg-emerald-500/[0.08] border border-emerald-400/15 px-3 py-2.5 mb-3">
                  <div class="grid grid-cols-2 gap-4">
                    <div>
                      <p class="text-[9px] font-extrabold uppercase tracking-widest text-emerald-300/80 mb-1.5">
                        <span class="lang-en">Saturday</span>
                        <span class="lang-es hidden">Sábado</span>
                      </p>
                      <div class="space-y-1.5">
                        <div>
