  /* Highlights Bar customization */
  #highlights-bar::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Liquid Glass sliding switcher */
  .switcher-slider {
    position: absolute;
    top: 2px;
    left: 2px;
    width: calc(50% - 2px);
    height: calc(100% - 4px);
    background: linear-gradient(135deg, var(--color-vibrant-pink) 0%, var(--color-accent-gold) 100%);
    border-radius: 9999px;
    transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
