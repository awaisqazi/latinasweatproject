---
import Layout from "@/layouts/Layout.astro";
const base = import.meta.env.BASE_URL;

// Define links data (chronological — upcoming events first, recurring/undated next, past events last)
const links = [
  {
    title: "⭐ Yoga For Wishes × Make‑A‑Wish",
    description:
      "Join our 3:30 PM donation‑based class supporting Make‑A‑Wish Illinois, or stop by anytime to write a birthday card for a wish child. Move. Breathe. Give back.",
    url: "https://www.zeffy.com/en-US/ticketing/makeawish-together-we-grant-wishes-for-children-with-critical-illnesses",
    color: "wish",
    icon: "star",
    badge: "April 18",
    featured: true,
  },
  {
    title: "🌿 Spring Clean Up",
    description:
      "Roll up your sleeves and help clean up our neighborhood! A collaboration with Alderman Byron Sigcho-Lopez's office. Light refreshments provided. 10 AM – 12 PM.",
    url: "https://www.zeffy.com/en-US/ticketing/spring-clean-up",
    color: "green",
    icon: "leaf",
    badge: "April 25",
    featured: true,
  },
  {
    title: "🧠 ALPFA × LSP: Mental Health & Business Panel",
    description:
      "A powerful panel on the intersection of mental health and business. Balance career growth with well-being. Doors 3:30 PM · Panel 4–5 PM · Networking until 6 PM.",
    url: "https://www.zeffy.com/en-US/ticketing/alpfa-x-lsp-mental-health-and-business-panel",
    color: "indigo",
    icon: "panel",
    badge: "May 2",
    featured: true,
  },
  {
    title: "🩺 Equal Hope × LSP",
    description:
      "Body literacy workshop, salsa class with Maria Luisa, and a community health discussion with Dr. Elizabeth Yepez (Rush OBGYN). Grounding practices, vendors, and healing, all in one space.",
    url: "https://www.zeffy.com/en-US/ticketing/equal-hope-x-latina-sweat-project?utm_source=ig&utm_medium=social&utm_content=link_in_bio",
    color: "teal",
    icon: "heart",
    badge: "Event",
    featured: true,
  },
  {
    title: "🧠 Free Men's Therapy Group",
    description:
      "A bilingual, confidential, cost-free weekly therapy group for men, on Tuesdays starting on April 7th. Led by Roberto Lopez-Tamayo, Ph.D. Open to all adult men.",
    url: "https://www.redcap.ihrp.uic.edu/surveys/?s=MDMA4L9CD398798Y&utm_source=ig&utm_medium=social&utm_content=link_in_bio",
    color: "blue",
    icon: "mind",
    badge: "New",
    featured: true,
  },
  {
    title: "📅 Class Schedule",
    description: "Book a yoga, fitness, or wellness class in Pilsen.",
    url: "https://latinasweatproject.com/schedule/",
    color: "vibrant-pink",
    icon: "calendar",
    featured: true,
  },
  {
    title: "🏥 World Health Day",
    description:
      "Health is a right, not a privilege. LSP highlights Chicago organizations providing affordable, bilingual healthcare to our communities.",
    url: "https://latinasweatproject.com/healthday/",
    color: "sky",
    icon: "health",
    badge: "April 7",
    featured: true,
  },
  {
    title: "🌐 Visit Our Website",
    description: "Explore everything The Latina Sweat Project has to offer.",
    url: "https://latinasweatproject.com/",
    color: "gold",
    icon: "globe",
  },
];

const socials = [
  {
    name: "Instagram",
    url: "https://www.instagram.com/latinasweatproject/",
    icon: "instagram",
  },
  {
    name: "TikTok",
    url: "https://www.tiktok.com/@latinasweatproject",
    icon: "tiktok",
  },
];
---

<Layout
  title="Latina Sweat Project | Links"
  description="Quick links from The Latina Sweat Project: classes, events, therapy, and more."
  hideFooter={true}
>
  <main class="links-page min-h-screen relative overflow-hidden">
    {/* Animated gradient background */}
    <div class="links-bg absolute inset-0"></div>

    {/* Floating decorative shapes */}
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="links-blob links-blob-1"></div>
      <div class="links-blob links-blob-2"></div>
      <div class="links-blob links-blob-3"></div>
    </div>

    {/* Content */}
    <div class="relative z-10 mx-auto max-w-lg px-4 py-10 sm:py-14">
      {/* Profile Header */}
      <div class="text-center mb-10">
        <div class="relative inline-block mb-5">
          {/* Glow ring */}
          <div
            class="absolute -inset-1.5 rounded-full bg-gradient-to-br from-[#b5a18d] via-[#ffbd59] to-[#b5a18d] opacity-70 blur-sm animate-pulse"
          >
          </div>
          <img
            src={`${base}logo2.png`}
            alt="The Latina Sweat Project"
            class="relative w-24 h-24 rounded-full object-cover border-3 border-white shadow-xl"
          />
        </div>
        <h1
          class="font-rubik text-2xl font-extrabold text-white tracking-tight drop-shadow-md"
        >
          The Latina Sweat Project
        </h1>
        <p
          class="mt-2 text-white/70 text-sm font-medium max-w-xs mx-auto leading-relaxed"
        >
          Accessible yoga, fitness & wellness in Pilsen, Chicago&nbsp;🧘🏽‍♀️✨
        </p>

        {/* Social icons row */}
        <div class="mt-4 flex items-center justify-center gap-3">
          {
            socials.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center w-10 h-10 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-white/80 hover:bg-white/25 hover:text-white hover:scale-110 transition-all duration-300"
                aria-label={social.name}
              >
                {social.icon === "instagram" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                  </svg>
                )}
                {social.icon === "tiktok" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      {/* Links */}
      <div class="flex flex-col gap-4">
        {
          links.map((link, index) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "link-card group relative block rounded-2xl p-[1px] transition-all duration-300 hover:scale-[1.02] hover:-translate-y-0.5",
                link.featured ? "link-card-featured" : "link-card-default",
              ]}
              style={`animation-delay: ${index * 80}ms`}
              id={`link-${index}`}
            >
              {/* Gradient border via background on the outer, inner has the solid bg */}
              <div
                class:list={[
                  "relative rounded-2xl px-5 py-4 backdrop-blur-xl transition-all duration-300",
                  link.featured
                    ? "bg-white/[0.12] group-hover:bg-white/[0.18]"
                    : "bg-white/[0.08] group-hover:bg-white/[0.14]",
                ]}
              >
                {/* Badge */}
                {link.badge && (
                  <span
                    class:list={[
                      "absolute -top-2.5 right-4 inline-flex items-center gap-1 rounded-full px-3 py-0.5 text-[10px] font-bold uppercase tracking-wider shadow-lg",
                      link.color === "teal" && "bg-teal-400 text-teal-950",
                      link.color === "blue" && "bg-blue-400 text-blue-950",
                      link.color === "sky" && "bg-sky-400 text-sky-950",
                      link.color === "wish" && "bg-rose-400 text-rose-950",
                      link.color === "green" && "bg-emerald-400 text-emerald-950",
                      link.color === "indigo" && "bg-indigo-400 text-indigo-950",
                      link.color === "vibrant-pink" &&
                        "bg-[#b5a18d] text-white",
                    ]}
                  >
                    <span class="relative flex h-1.5 w-1.5">
                      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-current opacity-60" />
                      <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-current" />
                    </span>
                    {link.badge}
                  </span>
                )}

                <div class="flex items-start gap-4">
                  {/* Icon */}
                  <div
                    class:list={[
                      "flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-xl transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg",
                      link.color === "vibrant-pink" &&
                        "bg-[#b5a18d]/30 text-[#d4b896] group-hover:bg-[#b5a18d]/50",
                      link.color === "teal" &&
                        "bg-teal-500/30 text-teal-300 group-hover:bg-teal-500/50",
                      link.color === "blue" &&
                        "bg-blue-500/30 text-blue-300 group-hover:bg-blue-500/50",
                      link.color === "gold" &&
                        "bg-[#ffbd59]/30 text-[#ffbd59] group-hover:bg-[#ffbd59]/50",
                      link.color === "sky" &&
                        "bg-sky-500/30 text-sky-300 group-hover:bg-sky-500/50",
                      link.color === "wish" &&
                        "bg-rose-500/30 text-rose-300 group-hover:bg-rose-500/50",
                      link.color === "green" &&
                        "bg-emerald-500/30 text-emerald-300 group-hover:bg-emerald-500/50",
                      link.color === "indigo" &&
                        "bg-indigo-500/30 text-indigo-300 group-hover:bg-indigo-500/50",
                    ]}
                  >
                    {link.icon === "calendar" && (
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <rect
                          x="3"
                          y="4"
                          width="18"
                          height="18"
                          rx="2"
                          ry="2"
                        />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </svg>
                    )}
                    {link.icon === "heart" && (
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                      </svg>
                    )}
                    {link.icon === "mind" && (
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M12 2a7 7 0 0 1 7 7c0 2.38-1.19 4.47-3 5.74V17a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 0 1 7-7z" />
                        <line x1="9" y1="21" x2="15" y2="21" />
                        <line x1="10" y1="24" x2="14" y2="24" />
                      </svg>
                    )}
                    {link.icon === "globe" && (
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <line x1="2" y1="12" x2="22" y2="12" />
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                      </svg>
                    )}
                    {link.icon === "star" && (
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                      </svg>
                    )}
                    {link.icon === "health" && (
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                      </svg>
                    )}
                    {link.icon === "leaf" && (
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c4.97 0 9 4.03 9 9-4.97 0-9-4.03-9-9zM3 21c0-4.97 4.03-9 9-9" />
                      </svg>
                    )}
                    {link.icon === "panel" && (
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
                      </svg>
                    )}
                  </div>

                  {/* Text */}
                  <div class="flex-1 min-w-0">
                    <h2 class="text-base font-bold text-white group-hover:text-[#ffbd59] transition-colors duration-300 leading-snug">
                      {link.title}
                    </h2>
                    <p class="mt-1 text-[13px] text-white/55 leading-relaxed group-hover:text-white/70 transition-colors duration-300 line-clamp-3">
                      {link.description}
                    </p>
                  </div>

                  {/* Arrow */}
                  <div class="flex-shrink-0 mt-1 text-white/30 group-hover:text-[#ffbd59] transition-all duration-300 group-hover:translate-x-1">
                    <svg
                      class="w-5 h-5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      {/* One Free Day Every Week — Promo */}
      <div class="mt-8" style="animation: links-slide-up 0.5s ease backwards; animation-delay: 350ms;">
        <a
          href={`${base}schedule`}
          class="group block rounded-2xl p-[1px] bg-gradient-to-br from-[#ffbd59]/50 via-[#b5a18d]/30 to-[#ffbd59]/50 transition-all duration-300 hover:scale-[1.02] hover:-translate-y-0.5"
        >
          <div class="rounded-2xl bg-white/[0.08] backdrop-blur-xl px-5 py-5 text-center transition-all duration-300 group-hover:bg-white/[0.14]">
            {/* Header */}
            <div class="inline-flex items-center gap-1.5 rounded-full bg-[#ffbd59]/20 border border-[#ffbd59]/30 px-3 py-1 mb-3">
              <span class="relative flex h-1.5 w-1.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#ffbd59] opacity-75"></span>
                <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-[#ffbd59]"></span>
              </span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-[#ffbd59]">New at LSP</span>
            </div>

            <h3 class="text-lg font-extrabold text-white tracking-tight leading-tight">
              One Free Day <span class="text-[#ffbd59]">Every Week</span>&nbsp;🎉
            </h3>
            <p class="mt-1 text-[11px] text-white/50 font-medium">
              Un dia gratis cada semana · All classes, all day
            </p>

            {/* Days row */}
            <div class="mt-3 flex items-center justify-center gap-2 overflow-x-auto pb-1">
              <div class="flex-shrink-0 rounded-lg bg-white/[0.07] border border-white/10 px-3 py-1.5 text-center min-w-[68px]">
                <p class="text-[8px] font-bold uppercase tracking-wider text-[#ffbd59] leading-none">Mar 30</p>
                <p class="text-xs font-bold text-white leading-tight mt-0.5">Mon</p>
              </div>
              <div class="flex-shrink-0 rounded-lg bg-white/[0.07] border border-white/10 px-3 py-1.5 text-center min-w-[68px]">
                <p class="text-[8px] font-bold uppercase tracking-wider text-[#ffbd59] leading-none">Apr 7</p>
                <p class="text-xs font-bold text-white leading-tight mt-0.5">Tue</p>
              </div>
              <div class="flex-shrink-0 rounded-lg bg-white/[0.07] border border-white/10 px-3 py-1.5 text-center min-w-[68px]">
                <p class="text-[8px] font-bold uppercase tracking-wider text-[#ffbd59] leading-none">Apr 15</p>
                <p class="text-xs font-bold text-white leading-tight mt-0.5">Wed</p>
              </div>
              <div class="flex-shrink-0 rounded-lg bg-white/[0.07] border border-white/10 px-3 py-1.5 text-center min-w-[68px]">
                <p class="text-[8px] font-bold uppercase tracking-wider text-[#ffbd59] leading-none">Apr 23</p>
                <p class="text-xs font-bold text-white leading-tight mt-0.5">Thu</p>
              </div>
              <div class="flex-shrink-0 rounded-lg bg-white/[0.07] border border-white/10 px-3 py-1.5 text-center min-w-[68px]">
                <p class="text-[8px] font-bold uppercase tracking-wider text-[#ffbd59] leading-none">May 1</p>
                <p class="text-xs font-bold text-white leading-tight mt-0.5">Fri</p>
              </div>
            </div>

            {/* CTA */}
            <div class="mt-3 inline-flex items-center gap-1.5 text-xs font-bold text-[#ffbd59] group-hover:gap-2.5 transition-all duration-300">
              View Schedule
              <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </div>
          </div>
        </a>
      </div>

      {/* App Download Section */}
      <div class="app-section mt-10 text-center" style="animation: links-slide-up 0.5s ease backwards; animation-delay: 400ms;">
        {/* Gradient divider */}
        <div class="mx-auto mb-6 h-px w-2/3 bg-gradient-to-r from-transparent via-[#b5a18d]/40 to-transparent"></div>

        <p class="app-section-label text-xs font-semibold uppercase tracking-[0.2em] mb-5">
          Download the LSP Studio App
        </p>

        <div class="flex items-center justify-center gap-3">
          {/* Apple App Store */}
          <a
            href="https://apps.apple.com/us/app/lsp-studio/id6755971141"
            target="_blank"
            rel="noopener noreferrer"
            class="app-badge group relative flex items-center gap-3 rounded-2xl px-5 py-3 overflow-hidden transition-all duration-300 hover:scale-[1.04] hover:-translate-y-1"
            id="link-app-ios"
          >
            <svg class="w-7 h-7 text-white/80 flex-shrink-0 group-hover:text-white transition-colors duration-300" viewBox="0 0 24 24" fill="currentColor">
