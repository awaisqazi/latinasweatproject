      border-color: rgba(181, 161, 141, 0.6);
    }
    100% {
      transform: scale(1);
      box-shadow: none;
    }
  }

  /* Custom themed borders and glows on hover */
  .link-card-featured {
    background: linear-gradient(
      135deg,
      rgba(181, 161, 141, 0.3),
      rgba(255, 189, 89, 0.15),
      rgba(181, 161, 141, 0.3)
    );
  }
  
  .link-card-default {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.08),
      rgba(255, 255, 255, 0.02)
    );
  }

  .link-card:hover {
    border-color: rgba(255, 255, 255, 0.25);
  }

  /* Color Specific Glow styles */
  .link-card--amber:hover {
    box-shadow: 0 10px 30px -8px rgba(255, 189, 89, 0.4);
    border-color: rgba(255, 189, 89, 0.4);
  }
  .link-card--gold:hover {
    box-shadow: 0 10px 30px -8px rgba(255, 189, 89, 0.4);
    border-color: rgba(255, 189, 89, 0.4);
  }
  .link-card--teal:hover {
    box-shadow: 0 10px 30px -8px rgba(20, 184, 166, 0.4);
    border-color: rgba(20, 184, 166, 0.4);
  }
  .link-card--blue:hover {
    box-shadow: 0 10px 30px -8px rgba(59, 130, 246, 0.4);
    border-color: rgba(59, 130, 246, 0.4);
  }
  .link-card--sky:hover {
    box-shadow: 0 10px 30px -8px rgba(56, 189, 248, 0.4);
    border-color: rgba(56, 189, 248, 0.4);
  }
  .link-card--wish:hover {
    box-shadow: 0 10px 30px -8px rgba(244, 63, 94, 0.4);
    border-color: rgba(244, 63, 94, 0.4);
  }
  .link-card--green:hover {
    box-shadow: 0 10px 30px -8px rgba(16, 185, 129, 0.4);
    border-color: rgba(16, 185, 129, 0.4);
  }
  .link-card--vibrant-pink:hover {
    box-shadow: 0 10px 30px -8px rgba(181, 161, 141, 0.4);
    border-color: rgba(181, 161, 141, 0.4);
  }

  /* Shimmer text effect on App download label */
  .app-section-label {
    background: linear-gradient(135deg, #b5a18d 0%, #ffbd59 50%, #b5a18d 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: app-label-shimmer 4s ease-in-out infinite;
  }

  @keyframes app-label-shimmer {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 200% center; }
  }

  /* Apple App & Android Store cards styling */
  .app-badge {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 15px -4px rgba(0, 0, 0, 0.3);
  }

  .app-badge::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(181, 161, 141, 0) 0%,
      rgba(181, 161, 141, 0.25) 40%,
      rgba(255, 189, 89, 0.3) 60%,
      rgba(181, 161, 141, 0) 100%
    );
    background-size: 300% 300%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease;
    animation: app-border-sweep 3s ease-in-out infinite;
  }

  .app-badge:hover::before {
    opacity: 1;
  }

  .app-badge:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow:
      0 8px 24px -6px rgba(181, 161, 141, 0.2),
      0 0 20px -8px rgba(255, 189, 89, 0.15);
  }

  @keyframes app-border-sweep {
    0%, 100% { background-position: 0% 0%; }
    50% { background-position: 100% 100%; }
  }

  /* Free Classes banner glow pulse */
  .free-hero-glow {
    background: radial-gradient(
      ellipse at center,
      rgba(255, 189, 89, 0.32) 0%,
      rgba(52, 211, 153, 0.15) 45%,
      transparent 75%
    );
    animation: free-hero-pulse 4s ease-in-out infinite;
  }

  @keyframes free-hero-pulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.02); }
  }

  /* Booking pills styling */
  .free-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 30px;
    padding: 0 6px;
    border-radius: 7px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 189, 89, 0.25);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.02em;
    transition: all 0.25s ease;
  }
  
  .free-pill--emerald {
    border-color: rgba(52, 211, 153, 0.25);
  }
  
  .free-pill--wide {
    gap: 5px;
    padding: 0 8px;
  }
  
  .free-pill--wide em {
    font-size: 10px;
    font-style: normal;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 189, 89, 0.85);
    line-height: 1;
  }
  
  .free-pill--wide[data-free-next="true"] em {
    color: rgba(30, 30, 30, 0.75);
  }
  
  .free-pill--wide.free-pill--emerald em {
    color: rgba(110, 231, 183, 0.85);
  }
  
  .free-pill--wide.free-pill--emerald[data-free-next="true"] em {
    color: rgba(6, 78, 59, 0.75);
  }
  
  .free-pill[data-free-next="true"] {
    background: linear-gradient(135deg, #ffbd59, #ffd28a);
    border-color: #ffbd59;
    color: #1E1E1E;
    box-shadow: 0 0 0 0 rgba(255, 189, 89, 0.6);
    animation: free-pulse-gold 2s ease-in-out infinite;
    transform: none;
    position: relative;
  }
  
  .free-pill--emerald[data-free-next="true"] {
    background: linear-gradient(135deg, #34d399, #6ee7b7);
    border-color: #34d399;
    color: #064e3b;
    animation: free-pulse-emerald 2s ease-in-out infinite;
  }
  
  .free-pill[data-free-next="true"]::after {
    content: 'NEXT';
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 7px;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 1px 4px;
    border-radius: 3px;
    background: #b5a18d;
    color: #fff;
    white-space: nowrap;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
  }

  @keyframes free-pulse-gold {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 189, 89, 0.5); }
    50% { box-shadow: 0 0 0 6px rgba(255, 189, 89, 0); }
  }
  
  @keyframes free-pulse-emerald {
    0%, 100% { box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.5); }
    50% { box-shadow: 0 0 0 6px rgba(52, 211, 153, 0); }
  }

  /* Newsletter embed container */
  .newsletter-frame {
    height: 195px;
  }
  
  @media (min-width: 640px) {
    .newsletter-frame {
      height: 195px;
    }
  }

  /* Profile logo border custom width helper */
  .border-3 {
    border-width: 3px;
  }

  /* Line clamp fallback */
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // 1. DYNAMIC NEXT FREE CLASS SCRIPT
  (function () {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const todayStr =
      today.getFullYear() +
      '-' +
      String(today.getMonth() + 1).padStart(2, '0') +
      '-' +
      String(today.getDate()).padStart(2, '0');

    const groups = new Map<string, HTMLElement[]>();
    document.querySelectorAll<HTMLElement>('[data-free-date][data-free-loc]').forEach((el) => {
      const loc = el.dataset.freeLoc || 'default';
      if (!groups.has(loc)) groups.set(loc, []);
      groups.get(loc)!.push(el);
    });

    groups.forEach((pills) => {
      pills.sort((a, b) => (a.dataset.freeDate || '').localeCompare(b.dataset.freeDate || ''));
      const next = pills.find((p) => (p.dataset.freeDate || '') >= todayStr);
      if (next) next.dataset.freeNext = 'true';
    });
  })();

  // 2. INTERACTIVE GLOBAL BILINGUAL LANGUAGE SWITCHER
  (function () {
    const switcher = document.getElementById("global-lang-switcher");
    const mainPage = document.querySelector(".links-page");
    if (!switcher || !mainPage) return;

    const btns = switcher.querySelectorAll<HTMLButtonElement>(".switcher-btn");

    function setLanguage(lang: "en" | "es") {
      if (lang === "en") {
        mainPage!.classList.remove("lang-active-es");
        mainPage!.classList.add("lang-active-en");
        btns[0].classList.remove("text-white/50");
        btns[0].classList.add("text-white");
        btns[1].classList.remove("text-white");
        btns[1].classList.add("text-white/50");
      } else {
        mainPage!.classList.remove("lang-active-en");
        mainPage!.classList.add("lang-active-es");
        btns[0].classList.remove("text-white");
        btns[0].classList.add("text-white/50");
        btns[1].classList.remove("text-white/50");
        btns[1].classList.add("text-white");
      }
      localStorage.setItem("lsp-links-language", lang);
    }

    // Tapping track triggers swap
    switcher.addEventListener("click", () => {
      const current = mainPage.classList.contains("lang-active-es") ? "es" : "en";
      setLanguage(current === "en" ? "es" : "en");
    });

    // Individual button click prevention override
    btns.forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation(); // Prevent duplicate toggle on switcher wrapper
        const targetLang = btn.dataset.lang as "en" | "es";
        if (targetLang) setLanguage(targetLang);
      });
    });

    // Read stored language or default
    const saved = localStorage.getItem("lsp-links-language");
    if (saved === "es" || saved === "en") {
      setLanguage(saved);
    } else {
      setLanguage("en"); // Default
    }
  })();

  // 3. STORY HIGHLIGHT SMOOTH SCROLLING & ACTIVE CARD FLASH PULSE
  (function () {
    const highlights = document.querySelectorAll(".story-highlight");
    highlights.forEach((story) => {
      story.addEventListener("click", function (this: HTMLAnchorElement, e) {
        const targetSelector = this.getAttribute("data-target");
        if (!targetSelector || !targetSelector.startsWith("#")) return;

        // If target is valid, intercept scroll
        e.preventDefault();
        const targetElement = document.querySelector(targetSelector) as HTMLElement;
        if (targetElement) {
          targetElement.scrollIntoView({
            behavior: "smooth",
            block: "center",
          });

          // Add flash animation glow
          targetElement.classList.add("targeted-glow");
          setTimeout(() => {
            targetElement.classList.remove("targeted-glow");
          }, 2200);
        }
      });
    });
  })();
</script>
