      #271c15 25%,
      #1e1e1e 50%,
      #121d25 75%,
      #1e1e1e 100%
    );
    background-size: 400% 400%;
    animation: links-gradient-shift 15s ease infinite;
  }

  @keyframes links-gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Floating background blobs */
  .links-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
  }

  .links-blob-1 {
    width: 300px;
    height: 300px;
    background: #b5a18d;
    top: -50px;
    right: -80px;
    animation: links-float-1 8s ease-in-out infinite;
  }

  .links-blob-2 {
    width: 250px;
    height: 250px;
    background: #ffbd59;
    bottom: 15%;
    left: -60px;
    animation: links-float-2 10s ease-in-out infinite;
  }

  .links-blob-3 {
    width: 200px;
    height: 200px;
    background: #34d399;
    top: 45%;
    right: -40px;
    animation: links-float-3 7s ease-in-out infinite;
  }

  @keyframes links-float-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-30px, 45px) scale(1.1); }
  }
  @keyframes links-float-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, -30px) scale(1.15); }
  }
  @keyframes links-float-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
