---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";

// Published Google Form (LSP collab account). The form requires Google sign-in
// (file-upload questions plus verified email collection), and Google blocks that
// sign-in flow inside a cross-origin iframe when third-party cookies are
// restricted. So we link out to the live form in a new tab instead of embedding
// it, which keeps receipt uploads working for every responder.
const formId =
  "1FAIpQLScaDNlKHL4yQWRl5KvZZW-2JtQwb6Sm98cGAyJv4oVDzL4r6w";
const formViewUrl = `https://docs.google.com/forms/d/e/${formId}/viewform`;
---

<Layout
  title="Reimbursement Requests | The Latina Sweat Project"
  description="Submit receipts and details for tax-compliant reimbursement of expenses you covered for The Latina Sweat Project. Instructors, staff, and volunteers can request to be paid back for approved purchases."
>
  <Header />

  <main class="min-h-screen bg-[#f5ede3]">
    <section class="bg-off-black px-4 py-12 text-white sm:px-6 sm:py-16 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent-gold">
            Reimbursement Requests
          </p>
          <h1 class="mt-4 font-sans text-4xl font-extrabold leading-tight text-white sm:text-5xl">
            Spent your own money for LSP? Let us pay you back.
          </h1>
        </div>

        <p class="font-body text-lg leading-8 text-white/75">
          Gracias for taking care of our community. If you bought supplies,
          covered an event cost, or paid for something on behalf of The Latina
          Sweat Project, submit your receipt here so our team can review and
          reimburse you. We collect a little detail up front to keep our
          nonprofit records clean and audit-ready.
        </p>
      </div>
    </section>

    <section class="px-4 py-10 sm:px-6 sm:py-14 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="rounded-lg border border-[#d9c8b3] bg-white p-6 shadow-sm sm:p-8">
          <h2 class="font-sans text-2xl font-bold text-off-black sm:text-3xl">
            Submit a reimbursement request
          </h2>
          <p class="mt-3 font-body text-base leading-7 text-medium-gray">
            The request lives in our secure Latina Sweat Project Google form, so
            your receipts upload straight into LSP's private Drive. Because we
            collect receipts, Google will ask you to sign in before you upload,
            which is why we open the form in its own tab.
          </p>

          <div
            class="mt-5 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm font-bold text-amber-800"
          >
            Heads up: you will be asked to sign in to a Google account to attach
            your receipts. Any Google account works, your files stay private to LSP.
          </div>

          <a
            href={formViewUrl}
            target="_blank"
            rel="noopener"
            class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-full bg-off-black px-6 py-4 font-sans text-base font-bold text-white shadow-md transition hover:bg-vibrant-pink focus:outline-none focus:ring-2 focus:ring-vibrant-pink focus:ring-offset-2 sm:w-auto"
          >
            Start your reimbursement request
            <span aria-hidden="true">&rarr;</span>
          </a>
          <p class="mt-3 font-body text-xs leading-5 text-medium-gray">
            Opens the form in a new tab. Takes about five minutes if your receipts
            are handy.
          </p>

          <hr class="my-7 border-[#e4d7c4]" />

          <h3 class="font-sans text-sm font-bold uppercase tracking-[0.14em] text-off-black">
            How it works
          </h3>
          <ol class="mt-4 space-y-4 font-body text-sm leading-6 text-medium-gray">
            <li class="flex gap-3">
              <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-off-black text-xs font-bold text-white">1</span>
              <span>Open the form, sign in to Google, and tell us about the expense (date, vendor, amount, and purpose).</span>
            </li>
            <li class="flex gap-3">
              <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-off-black text-xs font-bold text-white">2</span>
              <span>Attach an itemized receipt for each purchase and choose how you would like to be paid back.</span>
            </li>
            <li class="flex gap-3">
              <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-off-black text-xs font-bold text-white">3</span>
              <span>Our team reviews your request and reimburses you. We will reach out if we need anything else.</span>
            </li>
          </ol>
        </div>

        <aside class="rounded-lg bg-off-black p-6 text-white lg:sticky lg:top-8 lg:self-start">
          <h2 class="font-sans text-2xl font-bold">Before you submit</h2>
          <ul class="mt-5 space-y-4 font-body text-sm leading-6 text-white/75">
            <li class="border-l-2 border-accent-gold pl-4">
              Attach an <span class="font-bold text-white">itemized receipt</span>
              for every expense. A photo or PDF that shows the date, vendor,
              items, and total works best.
            </li>
            <li class="border-l-2 border-accent-gold pl-4">
              Tell us the <span class="font-bold text-white">business purpose</span>:
              what you bought and how it supports our classes, events, or programs.
            </li>
            <li class="border-l-2 border-accent-gold pl-4">
              Only request reimbursement for <span class="font-bold text-white">LSP
              expenses</span> you have not been paid back for anywhere else.
            </li>
            <li class="border-l-2 border-accent-gold pl-4">
              Add how you would like to be paid (Zelle, check, etc.) so we can
              process it quickly.
            </li>
          </ul>

          <p class="mt-6 font-body text-xs leading-5 text-white/55">
            Questions about a reimbursement? Email
            <a
              class="font-bold text-accent-gold underline decoration-2 underline-offset-2"
              href="mailto:fez@latinasweatproject.com"
            >
              fez@latinasweatproject.com
            </a>.
          </p>
        </aside>
      </div>
    </section>
  </main>
</Layout>
