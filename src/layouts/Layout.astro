---
import "@/styles/global.css";
import Footer from "@/components/Footer.astro"; // Import the new Footer
// (The studio status banner renders inside Header.astro's fixed
// #header-wrapper so it can never overlap the header.)
const base = import.meta.env.BASE_URL;

interface Props {
  title: string;
  description?: string;
  hideFooter?: boolean;
  robots?: string;
  socialImage?: string;
  socialImageAlt?: string;
  socialImageWidth?: number;
  socialImageHeight?: number;
  socialImageType?: string;
  twitterCard?: "summary" | "summary_large_image";
}

const {
  title,
  description: pageDescription,
  hideFooter = false,
  robots = "index, follow",
  socialImage: pageSocialImage = "logo2.png",
  socialImageAlt = "The Latina Sweat Project Logo",
  socialImageWidth = 500,
  socialImageHeight = 500,
  socialImageType = "image/png",
  twitterCard = "summary",
} = Astro.props;
const siteName = "The Latina Sweat Project";
const description =
  pageDescription ||
  "Free community yoga, fitness classes, and wellness events in Pilsen, Chicago. The Latina Sweat Project empowers through movement, culture, and community on the Southwest Side.";
const socialImageUrl = new URL(
  `${base}${pageSocialImage.replace(/^\//, "")}`,
  Astro.url,
);
const canonicalURL = new URL(
  Astro.url.pathname,
  "https://latinasweatproject.com",
);

// Google Analytics 4 Measurement ID
const GA_MEASUREMENT_ID = "G-RW22LK0G9J";
// Google Ads Conversion ID
const GOOGLE_ADS_ID = "AW-17990206229";
---

<!doctype html>
<html lang="en" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Marks JS as available so scroll-reveal elements only start hidden when
      // we can actually reveal them. Runs before paint to avoid a flash.
      document.documentElement.classList.add("js");
    </script>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.ico`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Local SEO: Geo & Keywords -->
    <meta name="geo.region" content="US-IL" />
    <meta name="geo.placename" content="Pilsen, Chicago" />
    <meta name="geo.position" content="41.8584;-87.6510" />
    <meta name="ICBM" content="41.8584, -87.6510" />
    <meta
      name="keywords"
      content="yoga Pilsen Chicago, free yoga classes Chicago, Latina wellness, community yoga Southwest Side, nonprofit yoga studio Pilsen, fitness classes Pilsen, yoga teacher training Chicago, BIPOC yoga Chicago, wellness events Pilsen, Latina Sweat Project"
    />
    <meta name="robots" content={robots} />

    <!-- Google Analytics 4 -->
    <script
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>
    <script define:vars={{ GA_MEASUREMENT_ID, GOOGLE_ADS_ID }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag =
        window.gtag ||
        function () {
          window.dataLayer.push(arguments);
        };
      window.gtag("js", new Date());
      window.gtag("config", GA_MEASUREMENT_ID);
      window.gtag("config", GOOGLE_ADS_ID);
    </script>
    <script>
      (function () {
        const DEFAULT_EVENT_PARAMS = {
          event_source: "lsp_website",
        };
        const RESERVED_CONVERSION_KEYS = new Set([
          "conversionEvent",
          "conversionInteractionEvent",
          "conversionSuccessEvent",
        ]);

        const toSnakeCase = (value) =>
          value
            .replace(/([a-z0-9])([A-Z])/g, "$1_$2")
            .replace(/[\s-]+/g, "_")
            .toLowerCase();

        const readConversionParams = (element) => {
          const params = {};
          const dataset = element.dataset || {};

          Object.keys(dataset).forEach((key) => {
            if (!key.startsWith("conversion") || RESERVED_CONVERSION_KEYS.has(key)) {
              return;
            }

            const paramName = toSnakeCase(key.replace(/^conversion/, ""));
            if (paramName) params[paramName] = dataset[key];
          });

          if (element instanceof HTMLAnchorElement && element.href) {
            params.link_url = element.href;
            params.outbound = element.origin !== window.location.origin;
          }

          const ctaId =
            element.id || element.getAttribute("data-conversion-cta-id");
          if (ctaId && !params.cta_id) params.cta_id = ctaId;

          return params;
        };

        window.trackConversion = function (eventName, params = {}) {
          if (!eventName || typeof eventName !== "string") return false;

          const eventParams = {
            ...DEFAULT_EVENT_PARAMS,
            page_location: window.location.href,
            page_path: window.location.pathname,
            ...params,
            transport_type: "beacon",
          };

          // Google Ads conversions should import these GA4 events unless real
          // Ads conversion labels are later added in Google Ads.
          if (typeof window.gtag !== "function") {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({ event: eventName, ...eventParams });
            return false;
          }

          window.gtag("event", eventName, eventParams);
          return true;
        };

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const trigger = target.closest("[data-conversion-event]");
          if (!trigger) return;

          window.trackConversion(
            trigger.getAttribute("data-conversion-event"),
            readConversionParams(trigger),
          );
        });

        const trackedInteractionElements = new WeakSet();
        const trackInteractionStart = (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const trigger = target.closest(
            "[data-conversion-interaction-event]",
          );
          if (!trigger || trackedInteractionElements.has(trigger)) return;

          trackedInteractionElements.add(trigger);
          window.trackConversion(
            trigger.getAttribute("data-conversion-interaction-event"),
            readConversionParams(trigger),
          );
        };

        document.addEventListener("pointerdown", trackInteractionStart, {
          passive: true,
        });
        document.addEventListener("focusin", trackInteractionStart);
      })();
    </script>

    <!-- Open Graph / Facebook -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl.href} />
    <meta property="og:image:secure_url" content={socialImageUrl.href} />
    <meta property="og:image:type" content={socialImageType} />
    <meta property="og:image:width" content={String(socialImageWidth)} />
    <meta property="og:image:height" content={String(socialImageHeight)} />
    <meta property="og:image:alt" content={socialImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl.href} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Rubik:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- XplorGrowth Signup Form Assets -->
    <script
      type="application/javascript"
      src="https://forms.prd.xplorcs.com/assets/embed/xpl-form-api.js"></script>
    <link
      href="https://forms.prd.xplorcs.com/assets/embed/embed.css"
      rel="stylesheet"
      type="text/css"
    />
  </head>
  <body class="bg-white text-off-black overflow-x-hidden">
    <slot />
    <script>
      // Scroll-reveal: reveals any element with the `.reveal` class as it
      // enters the viewport. Opt-in only, so it is safe to run site-wide.
      (() => {
        const reveal = () => {
          const els = Array.from(document.querySelectorAll<HTMLElement>(".reveal"));
          if (!els.length) return;

          const reduceMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;

          if (reduceMotion || !("IntersectionObserver" in window)) {
            els.forEach((el) => el.classList.add("is-visible"));
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  observer.unobserve(entry.target);
                }
              });
            },
            { rootMargin: "0px 0px -10% 0px", threshold: 0.1 },
          );

          els.forEach((el) => observer.observe(el));
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", reveal);
        } else {
          reveal();
        }
      })();
    </script>
    <script>
      (function () {
        // MarianaTek booking widgets are only used on public pages. Skip the
        // loader on the admin dashboard, where there's no booking element and
        // its script throws "Cannot read properties of null (reading 'url')".
        if (window.location.pathname.includes("/admin")) return;

        // Set tenant name here
        var TENANT_NAME = "latinasweatproject";

        var d = document;
        var sA = ["polyfills", "js"];

        for (var i = 0; i < sA.length; i++) {
          var s = d.createElement("script");
          s.src = "https://" + TENANT_NAME + ".marianaiframes.com/" + sA[i];
          s.setAttribute("data-timestamp", +new Date());
          (d.head || d.body).appendChild(s);
        }
      })();
    </script>
    <noscript>
      Please enable JavaScript to view the
      <a href="https://marianatek.com/?ref_noscript" rel="nofollow">
        Web Integrations by Mariana Tek.
      </a>
    </noscript>

