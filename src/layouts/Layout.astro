---
import "@/styles/global.css";
import Footer from "@/components/Footer.astro"; // Import the new Footer
import PrideTheme from "@/components/PrideTheme.astro"; // TEMPORARY: Pride Month 2026, remove with the component file
import { statusBanner } from "@/data/studioStatus.js";
const base = import.meta.env.BASE_URL;
const bannerHref = statusBanner.href.startsWith("/")
  ? base.replace(/\/$/, "") + statusBanner.href
  : statusBanner.href;

interface Props {
  title: string;
  description?: string;
  hideFooter?: boolean;
  robots?: string;
}

const {
  title,
  description: pageDescription,
  hideFooter = false,
  robots = "index, follow",
} = Astro.props;
const siteName = "The Latina Sweat Project";
const description =
  pageDescription ||
  "Free community yoga, fitness classes, and wellness events in Pilsen, Chicago. The Latina Sweat Project empowers through movement, culture, and community on the Southwest Side.";
const socialImage = "logo2.png";
const socialImageAlt = "The Latina Sweat Project Logo";
const socialImageUrl = new URL(base + socialImage, Astro.url);
const canonicalURL = new URL(
  Astro.url.pathname,
  "https://latinasweatproject.com",
);

// Google Analytics 4 Measurement ID
const GA_MEASUREMENT_ID = "G-RW22LK0G9J";
// Google Ads Conversion ID
const GOOGLE_ADS_ID = "AW-17990206229";
---

<!doctype html>
<html lang="en" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Marks JS as available so scroll-reveal elements only start hidden when
      // we can actually reveal them. Runs before paint to avoid a flash.
      document.documentElement.classList.add("js");
    </script>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.ico`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Local SEO: Geo & Keywords -->
    <meta name="geo.region" content="US-IL" />
    <meta name="geo.placename" content="Pilsen, Chicago" />
    <meta name="geo.position" content="41.8584;-87.6510" />
    <meta name="ICBM" content="41.8584, -87.6510" />
    <meta
      name="keywords"
      content="yoga Pilsen Chicago, free yoga classes Chicago, Latina wellness, community yoga Southwest Side, nonprofit yoga studio Pilsen, fitness classes Pilsen, yoga teacher training Chicago, BIPOC yoga Chicago, wellness events Pilsen, Latina Sweat Project"
    />
    <meta name="robots" content={robots} />

    <!-- Google Analytics 4 -->
    <script
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>
    <script define:vars={{ GA_MEASUREMENT_ID, GOOGLE_ADS_ID }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag =
        window.gtag ||
        function () {
          window.dataLayer.push(arguments);
        };
      window.gtag("js", new Date());
      window.gtag("config", GA_MEASUREMENT_ID);
      window.gtag("config", GOOGLE_ADS_ID);
    </script>
    <script>
      (function () {
        const DEFAULT_EVENT_PARAMS = {
          event_source: "lsp_website",
        };
        const RESERVED_CONVERSION_KEYS = new Set([
          "conversionEvent",
          "conversionInteractionEvent",
          "conversionSuccessEvent",
        ]);

        const toSnakeCase = (value) =>
          value
            .replace(/([a-z0-9])([A-Z])/g, "$1_$2")
            .replace(/[\s-]+/g, "_")
            .toLowerCase();

        const readConversionParams = (element) => {
          const params = {};
          const dataset = element.dataset || {};

          Object.keys(dataset).forEach((key) => {
            if (!key.startsWith("conversion") || RESERVED_CONVERSION_KEYS.has(key)) {
              return;
            }

            const paramName = toSnakeCase(key.replace(/^conversion/, ""));
            if (paramName) params[paramName] = dataset[key];
          });

          if (element instanceof HTMLAnchorElement && element.href) {
            params.link_url = element.href;
            params.outbound = element.origin !== window.location.origin;
          }

          const ctaId =
            element.id || element.getAttribute("data-conversion-cta-id");
          if (ctaId && !params.cta_id) params.cta_id = ctaId;

          return params;
        };

        window.trackConversion = function (eventName, params = {}) {
          if (!eventName || typeof eventName !== "string") return false;

          const eventParams = {
            ...DEFAULT_EVENT_PARAMS,
            page_location: window.location.href,
            page_path: window.location.pathname,
            ...params,
            transport_type: "beacon",
          };

          // Google Ads conversions should import these GA4 events unless real
          // Ads conversion labels are later added in Google Ads.
          if (typeof window.gtag !== "function") {
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({ event: eventName, ...eventParams });
            return false;
          }

          window.gtag("event", eventName, eventParams);
          return true;
        };

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const trigger = target.closest("[data-conversion-event]");
          if (!trigger) return;

          window.trackConversion(
            trigger.getAttribute("data-conversion-event"),
            readConversionParams(trigger),
          );
        });

        const trackedInteractionElements = new WeakSet();
        const trackInteractionStart = (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const trigger = target.closest(
            "[data-conversion-interaction-event]",
          );
          if (!trigger || trackedInteractionElements.has(trigger)) return;

          trackedInteractionElements.add(trigger);
          window.trackConversion(
            trigger.getAttribute("data-conversion-interaction-event"),
            readConversionParams(trigger),
          );
        };

        document.addEventListener("pointerdown", trackInteractionStart, {
          passive: true,
        });
        document.addEventListener("focusin", trackInteractionStart);
      })();
    </script>

    <!-- Open Graph / Facebook -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl.href} />
    <meta property="og:image:secure_url" content={socialImageUrl.href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="512" />
    {/* Note: Update with actual width of logo2.png */}
    <meta property="og:image:height" content="512" />
    {/* Note: Update with actual height of logo2.png */}
    <meta property="og:image:alt" content={socialImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl.href} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Rubik:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- XplorGrowth Signup Form Assets -->
    <script
      type="application/javascript"
      src="https://forms.prd.xplorcs.com/assets/embed/xpl-form-api.js"></script>
    <link
      href="https://forms.prd.xplorcs.com/assets/embed/embed.css"
      rel="stylesheet"
      type="text/css"
    />
  </head>
  <body class="bg-white text-off-black overflow-x-hidden">
    {
      statusBanner.active && (
        <div
          id="status-banner"
          role="region"
          aria-label="Studio status announcement"
          class="fixed top-0 left-0 right-0 z-[60] bg-accent-gold text-off-black shadow-sm"
        >
          <div class="mx-auto flex max-w-7xl items-center gap-2.5 px-4 py-2 sm:px-6 lg:px-8">
            <svg
              class="h-4 w-4 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <p class="min-w-0 flex-1 text-xs font-semibold leading-snug sm:text-sm">
              <span>{statusBanner.message}</span>{" "}
              <a
                href={bannerHref}
                class="whitespace-nowrap font-bold underline underline-offset-2 hover:text-off-black/70"
              >
                {statusBanner.linkLabel}
              </a>
            </p>
            <button
              type="button"
              id="status-banner-dismiss"
              aria-label="Dismiss announcement"
              class="hidden flex-shrink-0 rounded-full p-1 text-off-black/70 transition-colors hover:bg-off-black/10 hover:text-off-black"
            >
              <svg
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 18L18 6M6 6l12 12"
                />
              </svg>
            </button>
          </div>
        </div>
        <script is:inline>
          (function () {
            var banner = document.getElementById("status-banner");
            if (!banner) return;

            var KEY = "lsp-status-banner-dismissed";
            var dismissBtn = document.getElementById("status-banner-dismiss");
            // No-JS users never reach here, so the dismiss button starts hidden
            // and is only shown once JS can actually persist the dismissal.
            if (dismissBtn) dismissBtn.classList.remove("hidden");

            // Offsets the fixed header + its spacer by the banner height so the
            // announcement never overlaps the sticky header on any page.
            function applyOffset() {
              var wrapper = document.getElementById("header-wrapper");
              var spacer = document.getElementById("header-spacer");
              var h = banner.offsetHeight || 0;
              if (wrapper) wrapper.style.top = h + "px";
              if (spacer) spacer.style.paddingTop = h + "px";
            }

            function hideBanner() {
              banner.style.display = "none";
              var wrapper = document.getElementById("header-wrapper");
              var spacer = document.getElementById("header-spacer");
              if (wrapper) wrapper.style.top = "";
              if (spacer) spacer.style.paddingTop = "";
            }

            try {
              if (sessionStorage.getItem(KEY) === "1") {
                hideBanner();
                return;
              }
            } catch (e) {}

            applyOffset();
            window.addEventListener("resize", applyOffset, { passive: true });

            if (dismissBtn) {
              dismissBtn.addEventListener("click", function () {
                try {
                  sessionStorage.setItem(KEY, "1");
                } catch (e) {}
                hideBanner();
              });
            }
          })();
        </script>
      )
    }
    <PrideTheme />
    <slot />
    <script>
      // Scroll-reveal: reveals any element with the `.reveal` class as it
      // enters the viewport. Opt-in only, so it is safe to run site-wide.
      (() => {
        const reveal = () => {
          const els = Array.from(document.querySelectorAll<HTMLElement>(".reveal"));
          if (!els.length) return;

          const reduceMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;

          if (reduceMotion || !("IntersectionObserver" in window)) {
            els.forEach((el) => el.classList.add("is-visible"));
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  observer.unobserve(entry.target);
                }
              });
            },
            { rootMargin: "0px 0px -10% 0px", threshold: 0.1 },
          );

          els.forEach((el) => observer.observe(el));
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", reveal);
        } else {
          reveal();
        }
      })();
    </script>
    <script>
      (function () {
        // MarianaTek booking widgets are only used on public pages. Skip the
        // loader on the admin dashboard, where there's no booking element and
        // its script throws "Cannot read properties of null (reading 'url')".
        if (window.location.pathname.includes("/admin")) return;

        // Set tenant name here
        var TENANT_NAME = "latinasweatproject";

        var d = document;
        var sA = ["polyfills", "js"];

        for (var i = 0; i < sA.length; i++) {
          var s = d.createElement("script");
          s.src = "https://" + TENANT_NAME + ".marianaiframes.com/" + sA[i];
          s.setAttribute("data-timestamp", +new Date());
          (d.head || d.body).appendChild(s);
        }
      })();
    </script>
    <noscript>
      Please enable JavaScript to view the
      <a href="https://marianatek.com/?ref_noscript" rel="nofollow">
        Web Integrations by Mariana Tek.
      </a>
    </noscript>

