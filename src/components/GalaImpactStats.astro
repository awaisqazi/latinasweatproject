---
import { galaImpact } from "@/data/galaTeaser";

interface Props {
  variant?: "feature" | "strip";
  class?: string;
}

const { variant = "feature", class: className = "" } = Astro.props;

const display = (stat) =>
  `${stat.prefix}${stat.useComma ? stat.to.toLocaleString("en-US") : stat.to}${stat.suffix}`;
---

{
  variant === "strip" ? (
    <ul
      class:list={[
        "flex flex-wrap items-center justify-center gap-x-3 gap-y-2",
        className,
      ]}
    >
      {galaImpact.map((stat) => (
        <li class="rounded-full border border-accent-gold/25 bg-accent-gold/10 px-3.5 py-1.5 text-xs font-bold tracking-wide text-accent-gold">
          {stat.short}
        </li>
      ))}
    </ul>
  ) : (
    <dl
      class:list={[
        "grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-4 lg:gap-x-2",
        className,
      ]}
    >
      {galaImpact.map((stat, index) => (
        <div
          class:list={[
            "reveal text-center sm:px-4",
            index > 0 ? "sm:border-l sm:border-accent-gold/15" : "",
          ]}
          style={`transition-delay: ${index * 90}ms;`}
        >
          <dd
            class="font-display text-4xl font-bold leading-none tracking-tight text-accent-gold tabular-nums [text-shadow:0_0_28px_rgba(255,189,89,0.28)] sm:text-5xl lg:text-[3.25rem]"
            data-countup
            data-countup-to={stat.to}
            data-countup-prefix={stat.prefix}
            data-countup-suffix={stat.suffix}
            data-countup-comma={String(stat.useComma)}
          >
            {display(stat)}
          </dd>
          <dt class="mt-3 text-sm font-bold leading-snug text-white">
            {stat.label}
          </dt>
          <p class="mt-1.5 text-xs leading-snug text-white/55">
            {stat.sublabel}
          </p>
        </div>
      ))}
    </dl>
  )
}

<script>
  // Count-up for gala impact numbers. The final value is server-rendered so
  // layout is reserved and no-JS / reduced-motion users still see the figure.
  (() => {
    const nums = Array.from(
      document.querySelectorAll<HTMLElement>("[data-countup]"),
    );
    if (!nums.length) return;

    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (reduceMotion || !("IntersectionObserver" in window)) return;

    const fmt = (n: number, comma: boolean) =>
      comma ? Math.round(n).toLocaleString("en-US") : String(Math.round(n));

    const render = (el: HTMLElement, value: number) => {
      const prefix = el.dataset.countupPrefix || "";
      const suffix = el.dataset.countupSuffix || "";
      const comma = el.dataset.countupComma === "true";
      el.textContent = `${prefix}${fmt(value, comma)}${suffix}`;
    };

    const animate = (el: HTMLElement) => {
      const to = Number(el.dataset.countupTo || "0");
      const duration = 1600;
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      let start: number | null = null;
      const step = (ts: number) => {
        if (start === null) start = ts;
        const progress = Math.min(1, (ts - start) / duration);
        render(el, to * ease(progress));
        if (progress < 1) requestAnimationFrame(step);
        else render(el, to);
      };
      requestAnimationFrame(step);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            render(el, 0); // reset, then count up, only as the stat enters view
            animate(el);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.4 },
    );

    // Server-rendered final values stay in place until each stat scrolls into
    // view, so the real figures show at rest (and if the observer never fires).
    nums.forEach((el) => observer.observe(el));
  })();
</script>
