---
// src/components/Footer.astro
const base = import.meta.env.BASE_URL;
---

<footer class="bg-off-black text-white">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-8 xl:col-span-1">
        <a href={base} class="flex items-center gap-3">
          <img
            src={`${base}logo.svg`}
            alt="The Latina Sweat Project Logo"
            class="h-10 w-10"
          />
          <span class="font-sans text-xl font-bold text-white"
            >The Latina Sweat Project</span
          >
        </a>
        <p class="font-body text-base text-slate-400">
          Empowering through movement, community, and culture.
        </p>
        <div class="flex space-x-6">
          <a
            href="https://www.instagram.com/latinasweatproject/"
            class="link-underline text-slate-400"
          >
            <span class="sr-only">Instagram</span>
            <svg
              class="h-6 w-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 012.792 2.792c.247.636.416 1.363.465 2.427.048 1.024.06 1.378.06 3.808s-.012 2.784-.06 3.808c-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-2.792 2.792c-.636.247-1.363.416-2.427.465-1.024.048-1.378.06-3.808.06s-2.784-.012-3.808-.06c-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-2.792-2.792c-.247-.636-.416-1.363-.465-2.427-.048-1.024-.06-1.378-.06-3.808s.012-2.784.06-3.808c.049-1.064.218-1.791.465-2.427a4.902 4.902 0 012.792-2.792c.636.247 1.363.416 2.427.465C9.53 2.013 9.884 2 12.315 2zM12 7a5 5 0 100 10 5 5 0 000-10zm0 8a3 3 0 110-6 3 3 0 010 6zm6.406-11.845a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5z"
                clip-rule="evenodd"></path>
            </svg>
          </a>
          <a
            href="https://www.tiktok.com/@latinasweatproject"
            class="link-underline text-slate-400"
          >
            <span class="sr-only">TikTok</span>
            <svg
              class="h-6 w-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.৩৭-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.04-5.36-.01-4.03-.01-8.05.02-12.07z"
              ></path>
            </svg>
          </a>
          <a
            href="mailto:collab@latinasweatproject.com"
            class="link-underline text-slate-400"
          >
            <span class="sr-only">Email</span>
            <svg
              class="h-6 w-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M2.992 6.992a2 2 0 011.992-1.992h14.032a2 2 0 011.992 1.992l-9.008 6.004a1 1 0 01-1.008 0L2.992 6.992zM2 8.5v8.5a2 2 0 002 2h14a2 2 0 002-2V8.5l-8.01 5.34a3 3 0 01-2.98 0L2 8.5z"
              ></path>
            </svg>
          </a>
        </div>
        <!-- iPhone App Available Banner -->
        <a
          href="https://apps.apple.com/us/app/lsp-studio/id6755971141"
          target="_blank"
          rel="noopener noreferrer"
          class="group mt-5 flex items-center gap-3 rounded-xl border border-accent-gold/30 bg-off-black px-4 py-3 transform transition-all duration-300 hover:-translate-y-2 hover:border-accent-gold/60 hover:shadow-2xl hover:shadow-accent-gold/20"
          data-conversion-event="app_download_click"
          data-conversion-context="footer"
          data-conversion-platform="ios"
        >
          <span
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-white p-1"
          >
            <img
              src={`${base}images/lsp-studio-logo.png`}
              alt="LSP Studio App"
              class="h-full w-full object-contain"
            />
          </span>
          <div class="flex flex-col">
            <span
              class="text-xs font-semibold uppercase tracking-wider text-accent-gold"
            >
              Now on iPhone
            </span>
            <span
              class="text-sm font-bold text-white group-hover:text-accent-gold transition-colors"
              >LSP Studio App</span
            >
          </div>
          <div
            class="ml-auto flex items-center gap-1 text-slate-400 group-hover:text-accent-gold transition-colors"
          >
            <svg
              class="h-4 w-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
              ></path>
            </svg>
            <svg
              class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
        <!-- Android App Available Banner -->
        <a
          href="https://play.google.com/store/apps/details?id=com.marianatek.latinasweatproject&hl=en_US"
          target="_blank"
          rel="noopener noreferrer"
          class="group mt-3 flex items-center gap-3 rounded-xl border border-green-500/30 bg-off-black px-4 py-3 transform transition-all duration-300 hover:-translate-y-2 hover:border-green-500/60 hover:shadow-2xl hover:shadow-green-500/20"
          data-conversion-event="app_download_click"
          data-conversion-context="footer"
          data-conversion-platform="android"
        >
          <span
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-white p-1"
          >
            <img
              src={`${base}images/lsp-studio-logo.png`}
              alt="LSP Studio App"
              class="h-full w-full object-contain"
            />
          </span>
          <div class="flex flex-col">
            <span
              class="text-xs font-semibold uppercase tracking-wider text-green-400"
            >
              Now on Android
            </span>
            <span
              class="text-sm font-bold text-white group-hover:text-green-400 transition-colors"
              >LSP Studio App</span
            >
          </div>
          <div
            class="ml-auto flex items-center gap-1 text-slate-400 group-hover:text-green-400 transition-colors"
          >
            <svg
              class="h-4 w-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"
              ></path>
            </svg>
            <svg
              class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
      </div>
      <div
        class="mt-12 grid grid-cols-1 gap-8 lg:grid-cols-2 xl:col-span-2 xl:mt-0"
      >
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3
              class="font-sans text-sm font-semibold uppercase tracking-wider text-slate-300"
            >
              Navigation
            </h3>
            <ul class="mt-4 space-y-4 font-body" role="list">
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}`}>Home</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}about`}>About Us</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}schedule`}>Classes</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}pricing`}>Pricing</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}impact`}>Impact</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}gallery`}>Gallery</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}gala`}>Gala</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}corporate-collaborations`}>Corporate Collabs</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}community-collaborations`}>Community Collabs</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}shifts`}>Volunteer</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}press`}>Press</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}faq`}>FAQ</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}contact`}>Contact</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}account`}>My Account</a
                >
              </li>
              <!--<li><a class="link-underline text-base text-slate-400" href={`${base}events`}>Events</a></li>-->
            </ul>
          </div>
          <div class="mt-12 md:mt-0">
            <h3
              class="font-sans text-sm font-semibold uppercase tracking-wider text-slate-300"
            >
              Legal
            </h3>
            <ul class="mt-4 space-y-4 font-body" role="list">
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}privacy-policy`}>Privacy Policy</a
                >
              </li>
              <li>
                <a
                  class="link-underline text-base text-slate-400"
                  href={`${base}terms-of-service`}>Terms of Service</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-1 md:gap-8">
          <div>
            <h3
              class="font-sans text-sm font-semibold uppercase tracking-wider text-slate-300"
            >
              Newsletter
            </h3>
            <div
              class="footer-newsletter-frame relative mt-4 w-full overflow-hidden"
              data-conversion-interaction-event="newsletter_signup_start"
              data-conversion-context="footer_newsletter"
              data-conversion-provider="zeffy"
            >
              <iframe
                title="Signup form powered by Zeffy"
                src="https://www.zeffy.com/en-US/embed/newsletter-form/sign-up-for-our-newsletter-1965"
                allowtransparency="true"
                loading="lazy"
                class="absolute inset-0 h-full w-full border-0"
              ></iframe>
            </div>
            <a
              href={`${base}feedback`}
              class="group mt-4 flex flex-col rounded-lg border border-accent-gold/35 bg-white/[0.04] px-4 py-3 text-slate-200 transition-all hover:-translate-y-0.5 hover:border-accent-gold hover:bg-accent-gold/10"
            >
              <span class="text-xs font-bold uppercase tracking-[0.18em] text-accent-gold">
                After class
              </span>
              <span class="mt-1 text-base font-bold">Share Feedback</span>
              <span class="mt-1 text-sm leading-6 text-slate-400 group-hover:text-slate-300">
                Tell us about your experience so we can keep improving.
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-12 border-t border-slate-700 pt-8">
      <p class="font-body text-base text-slate-400 xl:text-center">
        © 2025 The Latina Sweat Project. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-newsletter-frame {
    height: 320px;
  }
  @media (min-width: 640px) {
    .footer-newsletter-frame {
      height: 300px;
    }
  }
</style>
