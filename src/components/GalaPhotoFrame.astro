---
interface PhotoSlot {
  label?: string;
  detail?: string;
  src?: string;
  alt?: string;
  objectPosition?: string;
}

interface Props {
  slot: PhotoSlot;
  variant?:
    | "hero"
    | "venue"
    | "panorama"
    | "promo"
    | "event"
    | "carousel"
    | "links";
  label?: boolean;
  loading?: "lazy" | "eager";
  corners?: boolean;
  class?: string;
}

const {
  slot,
  variant = "venue",
  label = true,
  loading = "lazy",
  corners = false,
  class: className = "",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const src = slot?.src ? `${base}${slot.src.replace(/^\//, "")}` : "";
const alt = slot?.alt || `${slot?.detail || "MCA Chicago"} venue photo`;
const objectPosition = slot?.objectPosition || "50% 50%";

const frameClass = {
  hero:
    "aspect-[3/2] rounded-[1.75rem] border border-accent-gold/35 bg-off-black p-2 shadow-2xl shadow-black/40",
  venue:
    "aspect-[3/2] rounded-2xl border border-accent-gold/28 bg-white/[0.05] p-2 shadow-lg shadow-black/20",
  panorama:
    "aspect-[21/10] rounded-2xl border border-accent-gold/28 bg-white/[0.05] p-2 shadow-xl shadow-black/25",
  promo:
    "aspect-[21/10] rounded-2xl border border-accent-gold/30 bg-off-black p-2 shadow-xl shadow-black/25",
  event:
    "aspect-[3/2] rounded-2xl border border-accent-gold/35 bg-white/[0.04] p-2 shadow-2xl shadow-black/25",
  carousel: "h-52 rounded-none bg-off-black",
  links:
    "aspect-[21/10] rounded-xl border border-[#ffbd59]/30 bg-black/25 p-1.5 shadow-lg shadow-black/25",
}[variant];

const innerClass = {
  hero: "rounded-[1.25rem]",
  venue: "rounded-xl",
  panorama: "rounded-xl",
  promo: "rounded-xl",
  event: "rounded-xl",
  carousel: "rounded-none",
  links: "rounded-lg",
}[variant];

const overlayClass = {
  hero: "bg-gradient-to-t from-off-black/88 via-off-black/12 to-black/5",
  venue: "bg-gradient-to-t from-off-black/78 via-transparent to-transparent",
  panorama: "bg-gradient-to-t from-off-black/76 via-transparent to-black/5",
  promo: "bg-gradient-to-br from-off-black/78 via-off-black/18 to-transparent",
  event: "bg-gradient-to-t from-off-black/84 via-off-black/10 to-black/5",
  carousel: "bg-gradient-to-t from-off-black/92 via-off-black/18 to-transparent",
  links: "bg-gradient-to-t from-[#101010]/92 via-[#101010]/10 to-transparent",
}[variant];

const captionClass = {
  hero: "bottom-5 left-5 right-5",
  venue: "bottom-4 left-4 right-4",
  panorama: "bottom-4 left-4 right-4",
  promo: "bottom-4 left-4 right-4",
  event: "bottom-4 left-4 right-4",
  carousel: "bottom-4 left-4 right-4",
  links: "bottom-3 left-3 right-3",
}[variant];
---

<div class:list={["relative overflow-hidden", frameClass, className]}>
  {
    src ? (
      <div class:list={["relative h-full w-full overflow-hidden ring-1 ring-inset ring-white/10 [transform:translateZ(0)]", innerClass]}>
        <img
          src={src}
          alt={alt}
          loading={loading}
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.035]"
          style={`object-position: ${objectPosition};`}
        />
        <div class:list={["pointer-events-none absolute inset-0", overlayClass]}></div>
        <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-gold/80 to-transparent"></div>
        {label && (
          <div class:list={["absolute", captionClass]}>
            <p class="text-[10px] font-extrabold uppercase tracking-[0.22em] text-accent-gold drop-shadow">
              {slot.label || "Official MCA photo"}
            </p>
            <p class="mt-1 text-sm font-bold text-white drop-shadow-sm">
              {slot.detail}
            </p>
          </div>
        )}
      </div>
    ) : (
      <div class:list={["flex h-full w-full flex-col items-center justify-center border border-dashed border-accent-gold/45 bg-black/30 p-6 text-center", innerClass]}>
        <svg
          class="h-12 w-12 text-accent-gold/65"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m3 16 5-5 4 4 2-2 7 7M5 5h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"
          />
        </svg>
        <p class="mt-4 text-sm font-extrabold text-white">
          {slot?.label || "Official MCA photo"}
        </p>
        <p class="mt-1 text-xs font-semibold text-white/50">{slot?.detail}</p>
      </div>
    )
  }
  {corners && (
    <>
      <span class="pointer-events-none absolute left-3 top-3 z-10 h-6 w-6 rounded-tl-md border-l-2 border-t-2 border-accent-gold/75"></span>
      <span class="pointer-events-none absolute right-3 top-3 z-10 h-6 w-6 rounded-tr-md border-r-2 border-t-2 border-accent-gold/75"></span>
      <span class="pointer-events-none absolute bottom-3 left-3 z-10 h-6 w-6 rounded-bl-md border-b-2 border-l-2 border-accent-gold/75"></span>
      <span class="pointer-events-none absolute bottom-3 right-3 z-10 h-6 w-6 rounded-br-md border-b-2 border-r-2 border-accent-gold/75"></span>
    </>
  )}
</div>
