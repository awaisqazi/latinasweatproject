---
// TEMPORARY Pride Month 2026 theme. To remove: delete this file and the two
// PrideTheme lines in src/layouts/Layout.astro. Everything is gated behind a
// client-side date check, so after June 30, 2026 the site renders vanilla
// even if this component is still installed.
const base = import.meta.env.BASE_URL;
---

{/* Banner is hidden until the script confirms the date gate and a fixed
    header wrapper exists on the page (links/admin pages have neither). */}
<a
  id="pride-banner"
  hidden
  href={`${base}events#pride-in-the-park`}
  data-conversion-event="event_registration_start"
  data-conversion-context="site_pride_banner"
  data-conversion-booking-path="pride_in_the_park_ticketing"
>
  <span class="pride-banner-msg">Celebrating Pride Month 🏳️‍🌈 Everyone belongs here</span>
  <span class="pride-banner-cta">Pride in the Park · June 14 →</span>
</a>

<script>
  const PRIDE_END = new Date("2026-07-01T05:00:00Z"); // end of June 30, Chicago

  if (Date.now() < PRIDE_END.getTime() && !location.pathname.includes("/admin")) {
    document.documentElement.classList.add("pride-2026");

    const PRIDE_COLORS = ["#e40303", "#ff8c00", "#ffed00", "#008026", "#24408e", "#732982"];

    const fireBurst = async (origin: { x: number; y: number }) => {
      const confetti = (await import("canvas-confetti")).default;
      confetti({
        colors: PRIDE_COLORS,
        particleCount: 120,
        spread: 80,
        startVelocity: 35,
        origin,
      });
    };

    let raining = false;
    const prideRain = async () => {
      if (raining) return;
      raining = true;
      const confetti = (await import("canvas-confetti")).default;
      const end = Date.now() + 3000;
      const tick = () => {
        confetti({
          colors: PRIDE_COLORS,
          particleCount: 24,
          angle: 90,
          spread: 70,
          startVelocity: 25,
          gravity: 0.9,
          ticks: 300,
          origin: { x: Math.random(), y: -0.1 },
        });
        if (Date.now() < end) {
          setTimeout(tick, 180);
        } else {
          raining = false;
        }
      };
      tick();
      showToast();
    };

    const showToast = () => {
      if (document.querySelector(".pride-toast")) return;
      const toast = document.createElement("div");
      toast.className = "pride-toast";
      toast.textContent = "Happy Pride! 🏳️‍🌈";
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 4000);
    };

    // Banner: move into the fixed header wrapper when one exists.
    const banner = document.getElementById("pride-banner");
    const wrapper = document.getElementById("header-wrapper");
    if (banner && wrapper) {
      wrapper.insertBefore(banner, wrapper.firstChild);
      banner.hidden = false;

      // The static spacer (h-28) and mobile overlay (pt-32) already leave
      // room for banner + header; only bump them if real heights disagree.
      const spacer = document.getElementById("header-spacer");
      const overlay = document.getElementById("mobile-menu-overlay");
      const syncOffsets = () => {
        const h = wrapper.offsetHeight;
        if (spacer && h > 112) spacer.style.height = `${h}px`;
        if (overlay && h + 16 > 128) overlay.style.paddingTop = `${h + 16}px`;
      };
      syncOffsets();
      window.addEventListener("resize", syncOffsets);
    }

    // Logo easter egg: confetti burst on click; five quick taps make it rain.
    const logo = document.querySelector("#main-header .flex-shrink-0 a") as HTMLAnchorElement | null;
    if (logo) {
      let taps = 0;
      let tapTimer: ReturnType<typeof setTimeout> | undefined;
      const homePath = new URL(logo.href).pathname.replace(/\/$/, "");
      logo.addEventListener("click", (e) => {
        const onHome = location.pathname.replace(/\/$/, "") === homePath;
        const rect = logo.getBoundingClientRect();
        fireBurst({
          x: (rect.left + rect.width / 2) / window.innerWidth,
          y: (rect.top + rect.height / 2) / window.innerHeight,
        });
        e.preventDefault();
        if (onHome) {
          taps += 1;
          clearTimeout(tapTimer);
          tapTimer = setTimeout(() => (taps = 0), 3000);
          if (taps >= 5) {
            taps = 0;
            prideRain();
          }
        } else {
          setTimeout(() => {
            location.href = logo.href;
          }, 400);
        }
      });
    }

    // Konami code: rainbow confetti rain + Happy Pride toast.
    const KONAMI = ["arrowup", "arrowup", "arrowdown", "arrowdown", "arrowleft", "arrowright", "arrowleft", "arrowright", "b", "a"];
    let pos = 0;
    window.addEventListener("keydown", (e) => {
      const key = e.key.toLowerCase();
      pos = key === KONAMI[pos] ? pos + 1 : key === KONAMI[0] ? 1 : 0;
      if (pos === KONAMI.length) {
        pos = 0;
        prideRain();
      }
    });
  }
</script>

<style is:global>
  /* ---- Pride banner (only shown once the script unhides it) ---- */
  #pride-banner[hidden] {
    display: none;
  }
  #pride-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    height: 36px;
    padding: 0 12px;
    background: linear-gradient(
      90deg,
      #e40303,
      #ff8c00,
      #e3b505,
      #008026,
      #24408e,
      #732982,
      #e40303
    );
    background-size: 300% 100%;
    animation: pride-shift 14s linear infinite;
    color: #fff;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.02em;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
  }
  #pride-banner .pride-banner-msg {
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #pride-banner .pride-banner-cta {
    flex-shrink: 0;
    padding: 2px 10px;
    border-radius: 9999px;
    background: rgba(30, 30, 30, 0.45);
    transition: background 0.3s ease;
  }
  #pride-banner:hover .pride-banner-cta {
    background: rgba(30, 30, 30, 0.7);
  }
  @media (max-width: 480px) {
    #pride-banner .pride-banner-cta {
      display: none;
    }
  }

  @keyframes pride-shift {
    0% {
      background-position: 0% 50%;
    }
    100% {
      background-position: 300% 50%;
    }
  }

  /* ---- Happy Pride toast ---- */
  .pride-toast {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 100;
    padding: 16px 32px;
    border-radius: 9999px;
    background: #1e1e1e;
    color: #fff;
    font-weight: 800;
    font-size: 22px;
    white-space: nowrap;
    box-shadow:
      0 0 0 3px #fff,
      0 0 0 6px #e40303,
      0 0 0 9px #ff8c00,
      0 0 0 12px #008026,
      0 0 0 15px #24408e,
      0 20px 60px rgba(0, 0, 0, 0.35);
    animation: pride-toast-pop 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  @keyframes pride-toast-pop {
    from {
      transform: translate(-50%, -50%) scale(0.6);
      opacity: 0;
    }
    to {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }
  }

  /* ---- Subtle rainbow accents (active only while html.pride-2026) ---- */
  html.pride-2026 #main-header .link-underline::after {
    background: linear-gradient(
      90deg,
      #e40303,
      #ff8c00,
      #e3b505,
      #008026,
      #24408e,
      #732982
    );
  }

  html.pride-2026 footer span.text-xl::after {
    content: " 🏳️‍🌈";
    font-size: 0.85em;
  }

  /* ---- Links page: rainbow profile ring + animated Pride card border ---- */
  html.pride-2026 .links-page .-inset-1\.5 {
    background: conic-gradient(
      from 0deg,
      #e40303,
      #ff8c00,
      #ffed00,
      #008026,
      #24408e,
      #732982,
      #e40303
    );
    animation: pride-spin 6s linear infinite;
    opacity: 0.8;
  }

  @keyframes pride-spin {
    to {
      transform: rotate(360deg);
    }
  }

  html.pride-2026 .link-card--pride {
    background: linear-gradient(
      135deg,
      rgba(228, 3, 3, 0.55),
      rgba(255, 140, 0, 0.5),
      rgba(255, 237, 0, 0.45),
      rgba(0, 128, 38, 0.5),
      rgba(36, 64, 142, 0.55),
      rgba(115, 41, 130, 0.55)
    );
    background-size: 300% 300%;
    animation: pride-card-shift 6s ease infinite;
  }

  @keyframes pride-card-shift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #pride-banner,
    html.pride-2026 .links-page .-inset-1\.5,
    html.pride-2026 .link-card--pride {
      animation: none;
    }
  }
</style>
